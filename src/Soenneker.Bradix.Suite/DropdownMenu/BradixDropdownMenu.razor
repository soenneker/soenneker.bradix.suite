@namespace Soenneker.Bradix

@inherits BradixComponent

@using Soenneker.Blazor.Utils.Ids
@implements IBradixDropdownMenu

<BradixMenu Open="@CurrentOpen"
            OpenChanged="HandleMenuOpenChanged"
            Dir="@Dir"
            Modal="@Modal">
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</BradixMenu>

@code {
    private bool _initialized;
    private bool _uncontrolledOpen;

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public bool Modal { get; set; } = true;

    [Parameter]
    public string? ContentIdOverride { get; set; }

    public string? BaseId { get; private set; }

    public bool CurrentOpen => Open ?? _uncontrolledOpen;

    public string TriggerId => BlazorIdGenerator.Child(BaseId!, "trigger");

    public string ContentId => string.IsNullOrWhiteSpace(ContentIdOverride)
        ? BlazorIdGenerator.Child(BaseId!, "content")
        : ContentIdOverride;

    internal ElementReference TriggerElement { get; private set; }

    internal bool HasTrigger { get; private set; }

    protected override void OnInitialized()
    {
        BaseId ??= BlazorIdGenerator.New("bradix-dropdown-menu");
    }

    protected override void OnParametersSet()
    {
        if (_initialized)
            return;

        _uncontrolledOpen = DefaultOpen;
        _initialized = true;
    }

    public Task ToggleOpen()
    {
        return SetOpen(!CurrentOpen);
    }

    internal void RegisterTrigger(ElementReference element)
    {
        TriggerElement = element;
        HasTrigger = true;
        _ = InvokeAsync(StateHasChanged);
    }

    public async Task SetOpen(bool open)
    {
        if (CurrentOpen == open)
            return;

        if (Open is null)
            _uncontrolledOpen = open;

        if (OpenChanged.HasDelegate)
            await OpenChanged.InvokeAsync(open);

        if (OnOpenChange.HasDelegate)
            await OnOpenChange.InvokeAsync(open);

        await InvokeAsync(StateHasChanged);
    }

    private Task HandleMenuOpenChanged(bool open)
    {
        return SetOpen(open);
    }
}
