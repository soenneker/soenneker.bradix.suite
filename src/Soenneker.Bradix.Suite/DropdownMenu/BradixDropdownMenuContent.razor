@namespace Soenneker.Bradix

<BradixMenuContent Id="@ResolvedContentId"
                   ForceMount="@ForceMount"
                   Loop="@Loop"
                   Side="@Side"
                   SideOffset="@SideOffset"
                   Align="@Align"
                   AlignOffset="@AlignOffset"
                   ArrowPadding="@ArrowPadding"
                   AvoidCollisions="@AvoidCollisions"
                   CollisionPadding="@CollisionPadding"
                   HideWhenDetached="@HideWhenDetached"
                   Class="@Class"
                   Style="@MergedStyle"
                   AdditionalAttributes="@ContentAttributes"
                   OnOpenAutoFocus="@OnOpenAutoFocus"
                   OnOpenAutoFocusDetailed="@OnOpenAutoFocusDetailed"
                   OnCloseAutoFocusDetailed="@HandleCloseAutoFocus"
                   OnEscapeKeyDown="@OnEscapeKeyDown"
                   OnEscapeKeyDownDetailed="@OnEscapeKeyDownDetailed"
                   OnPointerDownOutside="@OnPointerDownOutside"
                   OnPointerDownOutsideDetailed="@OnPointerDownOutsideDetailed"
                   OnFocusOutside="@OnFocusOutside"
                   OnFocusOutsideDetailed="@OnFocusOutsideDetailed"
                   OnInteractOutsideDetailed="@HandleInteractOutside"
                   OnPlaced="@OnPlaced">
    @ChildContent
</BradixMenuContent>

@code {
    [CascadingParameter]
    private BradixDropdownMenu? DropdownMenu { get; set; }

    [CascadingParameter]
    private BradixMenu? Menu { get; set; }

    private bool _hasInteractedOutside;

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public bool Loop { get; set; }

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public string Align { get; set; } = "start";

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnOpenAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnCloseAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnCloseAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback<BradixPointerDownOutsideEventArgs> OnPointerDownOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback<BradixFocusOutsideEventArgs> OnFocusOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnInteractOutside { get; set; }

    [Parameter]
    public EventCallback<BradixInteractOutsideEventArgs> OnInteractOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnPlaced { get; set; }

    private string? ResolvedContentId => string.IsNullOrWhiteSpace(Id) ? DropdownMenu?.ContentId : Id;

    private string MergedStyle
    {
        get
        {
            const string dropdownVariables =
                "--radix-dropdown-menu-content-transform-origin: var(--radix-popper-transform-origin); --radix-dropdown-menu-content-available-width: var(--radix-popper-available-width); --radix-dropdown-menu-content-available-height: var(--radix-popper-available-height); --radix-dropdown-menu-trigger-width: var(--radix-popper-anchor-width); --radix-dropdown-menu-trigger-height: var(--radix-popper-anchor-height);";

            return string.IsNullOrWhiteSpace(Style) ? dropdownVariables : $"{dropdownVariables} {Style}";
        }
    }

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            if (!string.IsNullOrWhiteSpace(DropdownMenu?.TriggerId))
                attributes["aria-labelledby"] = DropdownMenu.TriggerId;

            return attributes;
        }
    }

    private async Task HandleCloseAutoFocus(BradixAutoFocusEventArgs args)
    {
        if (OnCloseAutoFocus.HasDelegate)
            await OnCloseAutoFocus.InvokeAsync();

        if (OnCloseAutoFocusDetailed.HasDelegate)
            await OnCloseAutoFocusDetailed.InvokeAsync(args);

        if (!args.DefaultPrevented && !_hasInteractedOutside && Menu is not null)
            await Menu.FocusTrigger();

        _hasInteractedOutside = false;
        args.PreventDefault();
    }

    private async Task HandleInteractOutside(BradixInteractOutsideEventArgs args)
    {
        if (OnInteractOutside.HasDelegate)
            await OnInteractOutside.InvokeAsync();

        if (OnInteractOutsideDetailed.HasDelegate)
            await OnInteractOutsideDetailed.InvokeAsync(args);

        if (!args.DefaultPrevented && (DropdownMenu?.Modal == false || IsRightClick(args.PointerDownOutsideEvent)))
            _hasInteractedOutside = true;
    }

    private static bool IsRightClick(BradixDelegatedMouseEvent? args)
    {
        return args is not null && (args.Button == 2 || (args.Button == 0 && args.CtrlKey));
    }
}
