@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixDropdownMenuTrigger

@inject IBradixSuiteInterop Interop
<BradixDismissableLayerBranch>
    <BradixMenuAnchor>
        <button @ref="_button"
                @onpointerdown="HandlePointerDown"
                @onpointerdown:preventDefault="PreventTriggerFocusOnOpen"
                @onkeydown="HandleKeyDown"
                @attributes="ButtonAttributes">
            @ChildContent
        </button>
    </BradixMenuAnchor>
</BradixDismissableLayerBranch>

@code {
    private ElementReference _button;
    private bool _delegatedInteractionRegistered;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixDropdownMenu? DropdownMenu { get; set; }

    [CascadingParameter]
    private BradixMenu? Menu { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    // Match Radix trigger semantics: when opening from pointerdown, keep focus
    // off the trigger so the menu content can claim it without competition.
    private bool PreventTriggerFocusOnOpen => !Disabled && DropdownMenu?.CurrentOpen != true;

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("type", "button"),
        ("id", DropdownMenu?.TriggerId),
        ("aria-haspopup", "menu"),
        ("aria-expanded", DropdownMenu?.CurrentOpen == true ? "true" : "false"),
        ("aria-controls", DropdownMenu?.ContentId),
        ("data-state", DropdownMenu?.CurrentOpen == true ? "open" : "closed"),
        ("data-disabled", Disabled ? string.Empty : null),
        ("disabled", Disabled ? true : null));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Menu?.RegisterTrigger(_button);
            _dotNetReference ??= DotNetObjectReference.Create<object>(this);
            await Interop.RegisterDelegatedInteraction(_button, _dotNetReference, new
            {
                keydown = new
                {
                    currentTargetOnly = true,
                    preventDefaultKeys = new[] { "Enter", " ", "Spacebar", "ArrowDown" }
                }
            });
            _delegatedInteractionRegistered = true;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_button);

        _dotNetReference?.Dispose();
    }

    private Task HandlePointerDown(PointerEventArgs args)
    {
        Menu?.SetFocusFirstItemOnOpen(false);
        return Disabled || DropdownMenu is null || args.Button != 0 || args.CtrlKey
            ? Task.CompletedTask
            : DropdownMenu.ToggleOpen();
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Disabled || DropdownMenu is null)
            return Task.CompletedTask;

        if (args.Key is "Enter" or " " or "Spacebar" or "ArrowDown")
            Menu?.SetFocusFirstItemOnOpen(true);

        return args.Key switch
        {
            "Enter" => DropdownMenu.ToggleOpen(),
            " " => DropdownMenu.ToggleOpen(),
            "Spacebar" => DropdownMenu.ToggleOpen(),
            "ArrowDown" => DropdownMenu.SetOpen(true),
            _ => Task.CompletedTask
        };
    }

}
