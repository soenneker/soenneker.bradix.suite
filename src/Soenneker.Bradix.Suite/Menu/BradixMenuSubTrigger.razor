@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@using System.Threading

@inherits BradixComponentBase

@implements IBradixMenuRovingItem
@implements IBradixMenuSubTrigger

@inject IBradixIdGenerator IdGenerator
@inject IBradixSuiteInterop Interop
<div @ref="_element"
     @onclick="HandleClick"
     @onfocus="HandleFocus"
     @onblur="HandleBlur"
     @onkeydown="HandleKeyDown"
     @onpointermove="HandlePointerMove"
     @onpointerleave="HandlePointerLeave"
     @attributes="ItemAttributes">
    @ChildContent
</div>

@code {
    private ElementReference _element;
    private bool _registered;
    private bool _isFocused;
    private bool _pointerGraceActive;
    private string? _resolvedTextValue;
    private CancellationTokenSource? _openPointerMoveCts;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _delegatedInteractionRegistered;

    [CascadingParameter]
    internal BradixMenu SubMenu { get; set; } = null!;

    [CascadingParameter]
    internal IBradixMenuContentController ParentContent { get; set; } = null!;

    [CascadingParameter]
    internal BradixMenuSub Sub { get; set; } = null!;

    [CascadingParameter(Name = "BradixParentMenu")]
    internal BradixMenu ParentMenu { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? TextValue { get; set; }

    public string? TabStopId { get; private set; }

    bool IBradixMenuRovingItem.IsDisabled => Disabled;

    string IBradixMenuRovingItem.TabStopId => TabStopId!;

    string IBradixMenuRovingItem.TextValue => string.IsNullOrWhiteSpace(TextValue)
        ? _resolvedTextValue ?? string.Empty
        : TextValue;

    private Dictionary<string, object> ItemAttributes => BuildAttributes(
        ("id", Sub.TriggerId),
        ("role", "menuitem"),
        ("tabindex", ParentMenu.IsCurrentTabStop(this) ? 0 : -1),
        ("aria-haspopup", "menu"),
        ("aria-expanded", SubMenu.CurrentOpen ? "true" : "false"),
        ("aria-controls", Sub.ContentId),
        ("aria-disabled", Disabled ? "true" : null),
        ("data-disabled", Disabled ? string.Empty : null),
        ("data-state", SubMenu.CurrentOpen ? "open" : "closed"),
        ("data-highlighted", _isFocused ? string.Empty : null));

    protected override void OnInitialized()
    {
        TabStopId ??= IdGenerator.New("bradix-menu-sub-trigger");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ParentMenu.RegisterItem(this);
            SubMenu.RegisterTrigger(_element);
            SubMenu.RegisterAnchor(_element);
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterDelegatedInteraction(_element, _dotNetReference, new
            {
                keydown = new
                {
                    currentTargetOnly = true,
                    preventDefaultKeys = new[] { "ArrowLeft", "ArrowRight", "Enter", " ", "Spacebar" }
                }
            });
            _delegatedInteractionRegistered = true;
            _registered = true;
        }

        if (string.IsNullOrWhiteSpace(TextValue))
        {
            string textContent = await Interop.GetTextContent(_element);

            if (!string.Equals(_resolvedTextValue, textContent, StringComparison.Ordinal))
                _resolvedTextValue = textContent;
        }
    }

    public async ValueTask DisposeAsync()
    {
        CancelOpenPointerMove();
        ClearPointerGraceState();

        if (_registered)
            ParentMenu.UnregisterItem(this);

        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_element);

        await Interop.CancelMenuSubmenuPointerGrace(_element);
        _dotNetReference?.Dispose();
    }

    public ValueTask Focus() => Interop.FocusElementPreventScroll(_element);

    private async Task HandleClick()
    {
        if (Disabled)
            return;

        CancelOpenPointerMove();
        await CancelPointerGrace();
        SubMenu.SetFocusContentOnOpen(false);
        SubMenu.SetFocusFirstItemOnOpen(false);
        await Interop.FocusElementPreventScroll(_element);
        await SubMenu.SetOpen(true);
    }

    private Task HandleBlur(FocusEventArgs _)
    {
        _isFocused = false;
        return InvokeAsync(StateHasChanged);
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (Disabled)
            return Task.CompletedTask;

        _isFocused = true;
        ParentMenu.SetCurrentTabStop(TabStopId);
        return InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Disabled || args.CtrlKey || args.AltKey || args.MetaKey)
            return;

        if (ParentMenu.IsTypeaheadActive && args.Key is " " or "Spacebar")
            return;

        bool isOpenKey = ParentMenu.ResolvedDirection == "rtl"
            ? args.Key is "ArrowLeft" or "Enter" or " " or "Spacebar"
            : args.Key is "ArrowRight" or "Enter" or " " or "Spacebar";

        if (isOpenKey)
        {
            CancelOpenPointerMove();
            await CancelPointerGrace();
            SubMenu.SetFocusContentOnOpen(true);
            SubMenu.SetFocusFirstItemOnOpen(true);
            await SubMenu.SetOpen(true);
            return;
        }

        if (args.Key.Length == 1)
        {
            await ParentContent.HandleTypeaheadKey(this, args.Key);
            return;
        }

        await ParentContent.HandleItemKeyDown(this, args);
    }

    private async Task HandlePointerMove(PointerEventArgs args)
    {
        if (Disabled)
        {
            if (!_pointerGraceActive)
                await ParentContent.HandleItemLeave();
            return;
        }

        await CancelPointerGrace();
        await ParentContent.HandlePointerMove(this, args.PointerType);

        if (!SubMenu.CurrentOpen)
        {
            CancelOpenPointerMove();
            _openPointerMoveCts = new CancellationTokenSource();
            _ = OpenFromPointerMove(_openPointerMoveCts.Token);
        }
    }

    private async Task HandlePointerLeave(PointerEventArgs args)
    {
        CancelOpenPointerMove();

        if (string.Equals(args.PointerType, "mouse", StringComparison.Ordinal) && await TryBeginPointerGrace(args))
            return;

        await ParentContent.HandleItemLeave();
    }

    private async Task OpenFromPointerMove(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(100, cancellationToken);

            if (cancellationToken.IsCancellationRequested || SubMenu.CurrentOpen)
                return;

            SubMenu.SetFocusContentOnOpen(false);
            SubMenu.SetFocusFirstItemOnOpen(false);
            await SubMenu.SetOpen(true);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void CancelOpenPointerMove()
    {
        _openPointerMoveCts?.Cancel();
        _openPointerMoveCts?.Dispose();
        _openPointerMoveCts = null;
    }

    [JSInvokable]
    public Task HandlePointerGraceChanged(bool active)
    {
        _pointerGraceActive = active;
        ParentContent.SetSubmenuPointerGrace(TabStopId, active);
        return Task.CompletedTask;
    }

    private async Task<bool> TryBeginPointerGrace(PointerEventArgs args)
    {
        if (!SubMenu.CurrentOpen || !SubMenu.HasContentElement || _dotNetReference is null)
            return false;

        _pointerGraceActive = true;
        ParentContent.SetSubmenuPointerGrace(TabStopId, true);

        bool started;

        try
        {
            started = await Interop.BeginMenuSubmenuPointerGrace(_element, SubMenu.ContentElement, args.ClientX, args.ClientY, _dotNetReference);
        }
        catch
        {
            ClearPointerGraceState();
            throw;
        }

        if (!started)
            ClearPointerGraceState();

        return started;
    }

    private async Task CancelPointerGrace()
    {
        if (!_pointerGraceActive)
            return;

        await Interop.CancelMenuSubmenuPointerGrace(_element);
        ClearPointerGraceState();
    }

    private void ClearPointerGraceState()
    {
        _pointerGraceActive = false;
        ParentContent.SetSubmenuPointerGrace(TabStopId, false);
    }
}
