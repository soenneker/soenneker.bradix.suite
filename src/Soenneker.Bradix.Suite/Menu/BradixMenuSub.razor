@namespace Soenneker.Bradix

@inherits BradixComponent

@using Soenneker.Blazor.Utils.Ids
@implements IBradixMenuSub

<BradixMenu Open="@Open"
            DefaultOpen="DefaultOpen"
            OpenChanged="HandleOpenChanged"
            OnOpenChange="HandleOpenChange"
            Dir="@ParentMenu?.ResolvedDirection"
            Modal="false">
    <CascadingValue Value="this">
        <CascadingValue Name="BradixParentMenu" Value="ParentMenu">
            @ChildContent
        </CascadingValue>
    </CascadingValue>
</BradixMenu>

@code {
    [CascadingParameter]
    private BradixMenu? ParentMenu { get; set; }

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    public string? BaseId { get; private set; }

    internal string TriggerId => BlazorIdGenerator.Child(BaseId!, "trigger");

    internal string ContentId => BlazorIdGenerator.Child(BaseId!, "content");

    protected override void OnInitialized()
    {
        BaseId ??= BlazorIdGenerator.New("bradix-menu-sub");
    }

    private Task HandleOpenChanged(bool open)
    {
        return OpenChanged.HasDelegate ? OpenChanged.InvokeAsync(open) : Task.CompletedTask;
    }

    private Task HandleOpenChange(bool open)
    {
        return OnOpenChange.HasDelegate ? OnOpenChange.InvokeAsync(open) : Task.CompletedTask;
    }
}
