@namespace Soenneker.Bradix

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

@if (ShouldRenderContainer)
{
    @if (Menu?.Modal == true)
    {
        <BradixRemoveScroll AllowPinchZoom>
            @RenderContentTree()
        </BradixRemoveScroll>
    }
    else
    {
        @RenderContentTree()
    }
}

@code {
    private bool _wasPresent;
    private bool _isExiting;
    private bool _hasInteractedOutside;
    private bool _hideOthersRegistered;
    private ElementReference _contentElement;
    private ElementReference _layerElement;

    [CascadingParameter]
    private BradixMenu? Menu { get; set; }

    [CascadingParameter(Name = "BradixMenuPortalForceMount")]
    private bool PortalForceMount { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public bool Loop { get; set; }

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public string Align { get; set; } = "start";

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback OnCloseAutoFocus { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback OnInteractOutside { get; set; }

    [Parameter]
    public EventCallback OnPlaced { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnContentKeyDown { get; set; }

    private bool IsPresent => ForceMount || PortalForceMount || Menu?.CurrentOpen == true;

    private bool ShouldRenderContainer => IsPresent || _isExiting;

    private bool ShouldTrapFocus => Menu?.Modal == true && Menu.CurrentOpen;

    private bool ShouldDisableOutsidePointerEvents => Menu?.Modal == true && Menu.CurrentOpen;

    private string? ResolvedContentId => string.IsNullOrWhiteSpace(Id) ? Menu?.ContentId : Id;

    private string PositionerStyle =>
        "--radix-menu-content-transform-origin: var(--radix-popper-transform-origin); --radix-menu-content-available-width: var(--radix-popper-available-width); --radix-menu-content-available-height: var(--radix-popper-available-height); --radix-menu-trigger-width: var(--radix-popper-anchor-width); --radix-menu-trigger-height: var(--radix-popper-anchor-height);";

    private string MergedContentStyle => string.IsNullOrWhiteSpace(Style) ? "outline:none;" : $"outline:none; {Style}";

    private IReadOnlyDictionary<string, object> PresenceAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["role"] = "menu";
            attributes["tabindex"] = -1;
            attributes["dir"] = Menu?.ResolvedDirection ?? "ltr";
            attributes["aria-orientation"] = "vertical";
            attributes["data-state"] = Menu?.CurrentOpen == true ? "open" : "closed";

            if (OnContentKeyDown.HasDelegate)
                attributes["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleContentKeyDownAsync);

            if (Menu?.Modal == true)
                attributes["aria-modal"] = "true";

            return attributes;
        }
    }

    protected override void OnParametersSet()
    {
        bool present = IsPresent;

        if (_wasPresent && !present)
            _isExiting = true;
        else if (present)
            _isExiting = false;

        _wasPresent = present;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hideOthersRegistered)
        {
            await Interop.UnregisterHideOthers(_layerElement);
            _hideOthersRegistered = false;
        }
    }

    internal Task HandleItemKeyDownAsync(IBradixMenuItem item, KeyboardEventArgs args)
    {
        return Menu is null
            ? Task.CompletedTask
            : Menu.HandleItemNavigationAsync(item, args.Key, Loop);
    }

    internal Task HandleTypeaheadKeyAsync(IBradixMenuItem item, string key)
    {
        return Menu is null ? Task.CompletedTask : Menu.HandleTypeaheadAsync(item, key);
    }

    internal Task HandlePointerMoveAsync(IBradixMenuItem item)
    {
        if (Menu is null)
            return Task.CompletedTask;

        Menu.SetCurrentTabStop(item.TabStopId);
        return item.FocusAsync().AsTask();
    }

    private async Task HandleOpenAutoFocusAsync()
    {
        if (OnOpenAutoFocus.HasDelegate)
            await OnOpenAutoFocus.InvokeAsync();

        if (Menu is null)
            return;

        if (Menu.ConsumeFocusFirstItemOnOpen())
            await Menu.FocusFirstItemAsync();
        else
            await _contentElement.FocusAsync();
    }

    private async Task HandleCloseAutoFocusAsync()
    {
        if (OnCloseAutoFocus.HasDelegate)
            await OnCloseAutoFocus.InvokeAsync();

        if (Menu is not null && (Menu.Modal || !_hasInteractedOutside))
            await Menu.FocusTriggerAsync();

        _hasInteractedOutside = false;
    }

    private async Task HandleEscapeKeyDownAsync()
    {
        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        if (Menu is not null)
            await Menu.SetOpenAsync(false);
    }

    private Task HandleContentKeyDownAsync(KeyboardEventArgs args)
    {
        return OnContentKeyDown.HasDelegate ? OnContentKeyDown.InvokeAsync(args) : Task.CompletedTask;
    }

    private async Task HandlePointerDownOutsideAsync()
    {
        if (OnPointerDownOutside.HasDelegate)
            await OnPointerDownOutside.InvokeAsync();

        if (OnInteractOutside.HasDelegate)
            await OnInteractOutside.InvokeAsync();

        if (Menu is not null && !Menu.Modal)
            _hasInteractedOutside = true;

        if (Menu is not null)
            await Menu.SetOpenAsync(false);
    }

    private async Task HandleFocusOutsideAsync()
    {
        if (OnFocusOutside.HasDelegate)
            await OnFocusOutside.InvokeAsync();

        if (Menu?.Modal == true)
            return;

        if (OnInteractOutside.HasDelegate)
            await OnInteractOutside.InvokeAsync();

        _hasInteractedOutside = true;

        if (Menu is not null)
            await Menu.SetOpenAsync(false);
    }

    private Task HandleExitCompleteAsync()
    {
        _isExiting = false;
        return CleanupAfterExitAsync();
    }

    private RenderFragment RenderContentTree() => @<CascadingValue Value="this">
        <BradixFocusGuards>
            <BradixFocusScope Loop="@Loop"
                              Trapped="ShouldTrapFocus"
                              PreventMountAutoFocus="true"
                              PreventUnmountAutoFocus="true"
                              OnMountAutoFocus="HandleOpenAutoFocusAsync"
                              OnUnmountAutoFocus="HandleCloseAutoFocusAsync">
                <BradixDismissableLayer DisableOutsidePointerEvents="ShouldDisableOutsidePointerEvents"
                                        DismissOnEscapeKeyDown="false"
                                        DismissOnPointerDownOutside="false"
                                        DismissOnFocusOutside="false"
                                        OnEscapeKeyDown="@HandleEscapeKeyDownAsync"
                                        OnPointerDownOutside="@HandlePointerDownOutsideAsync"
                                        OnFocusOutside="@HandleFocusOutsideAsync"
                                        OnElementReferenceCaptured="@HandleElementReferenceCapturedAsync">
                    <BradixPopperContent Side="@Side"
                                         SideOffset="SideOffset"
                                         Align="@Align"
                                         AlignOffset="AlignOffset"
                                         ArrowPadding="ArrowPadding"
                                         AvoidCollisions="AvoidCollisions"
                                         CollisionPadding="CollisionPadding"
                                         HideWhenDetached="HideWhenDetached"
                                         Style="@PositionerStyle"
                                         OnPlaced="@OnPlaced">
                        <BradixPresence Present="IsPresent"
                                        Tag="div"
                                        Id="@ResolvedContentId"
                                        Class="@Class"
                                        Style="@MergedContentStyle"
                                        AdditionalAttributes="@PresenceAttributes"
                                        OnElementReferenceCaptured="@HandleContentElementCapturedAsync"
                                        OnExitComplete="@HandleExitCompleteAsync">
                            @ChildContent
                        </BradixPresence>
                    </BradixPopperContent>
                </BradixDismissableLayer>
            </BradixFocusScope>
        </BradixFocusGuards>
    </CascadingValue>;

    private async Task HandleElementReferenceCapturedAsync(ElementReference element)
    {
        _layerElement = element;

        if (Menu?.Modal == true && !_hideOthersRegistered)
        {
            await Interop.RegisterHideOthers(_layerElement);
            _hideOthersRegistered = true;
        }
    }

    private Task HandleContentElementCapturedAsync(ElementReference element)
    {
        _contentElement = element;
        return Task.CompletedTask;
    }

    private async Task CleanupAfterExitAsync()
    {
        _isExiting = false;

        if (_hideOthersRegistered)
        {
            await Interop.UnregisterHideOthers(_layerElement);
            _hideOthersRegistered = false;
        }
    }
}
