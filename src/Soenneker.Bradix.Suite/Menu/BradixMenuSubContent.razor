@namespace Soenneker.Bradix

@implements IBradixMenuSubContent

<BradixDismissableLayerBranch>
    <BradixMenuContent Id="@Sub.ContentId"
                       ForceMount="ForceMount"
                       Loop="Loop"
                       Side="@ResolvedSide"
                       Align="@BradixAlignment.Start"
                       SideOffset="SideOffset"
                       AlignOffset="AlignOffset"
                       ArrowPadding="ArrowPadding"
                       AvoidCollisions="AvoidCollisions"
                       CollisionPadding="CollisionPadding"
                       HideWhenDetached="HideWhenDetached"
                       Class="@Class"
                       Style="@Style"
                       AdditionalAttributes="@ContentAttributes"
                       OnOpenAutoFocus="@OnOpenAutoFocus"
                       OnOpenAutoFocusDetailed="@OnOpenAutoFocusDetailed"
                       OnEscapeKeyDownDetailed="HandleEscapeKeyDown"
                       OnContentKeyDown="HandleContentKeyDown"
                       OnCloseAutoFocusDetailed="HandleCloseAutoFocus"
                       OnPointerDownOutside="OnPointerDownOutside"
                       OnPointerDownOutsideDetailed="OnPointerDownOutsideDetailed"
                       OnFocusOutsideDetailed="HandleFocusOutside"
                       OnInteractOutside="OnInteractOutside"
                       OnInteractOutsideDetailed="OnInteractOutsideDetailed"
                       OnPlaced="OnPlaced">
        @ChildContent
    </BradixMenuContent>
</BradixDismissableLayerBranch>

@code {
    [CascadingParameter]
    private BradixMenu SubMenu { get; set; } = null!;

    [CascadingParameter]
    private BradixMenuSub Sub { get; set; } = null!;

    [CascadingParameter(Name = "BradixParentMenu")]
    private BradixMenu ParentMenu { get; set; } = null!;

    [CascadingParameter(Name = "BradixMenuRoot")]
    private BradixMenu RootMenu { get; set; } = null!;

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public bool Loop { get; set; }

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnOpenAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback<BradixPointerDownOutsideEventArgs> OnPointerDownOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback<BradixFocusOutsideEventArgs> OnFocusOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnInteractOutside { get; set; }

    [Parameter]
    public EventCallback<BradixInteractOutsideEventArgs> OnInteractOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnContentKeyDown { get; set; }

    [Parameter]
    public EventCallback OnPlaced { get; set; }

    private BradixSide ResolvedSide => ParentMenu.ResolvedDirection == "rtl" ? BradixSide.Left : BradixSide.Right;

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["aria-labelledby"] = Sub.TriggerId;
            return attributes;
        }
    }

    private Task HandleCloseAutoFocus(BradixAutoFocusEventArgs args)
    {
        args.PreventDefault();
        return Task.CompletedTask;
    }

    private async Task HandleFocusOutside(BradixFocusOutsideEventArgs args)
    {
        if (OnFocusOutside.HasDelegate)
            await OnFocusOutside.InvokeAsync();

        if (OnFocusOutsideDetailed.HasDelegate)
            await OnFocusOutsideDetailed.InvokeAsync(args);

        if (args.DefaultPrevented)
            return;

        if (!string.Equals(args.OriginalEvent.TargetId, Sub.TriggerId, StringComparison.Ordinal))
        {
            await SubMenu.SetOpen(false);
            return;
        }

        args.PreventDefault();
    }

    private async Task HandleEscapeKeyDown(BradixEscapeKeyDownEventArgs args)
    {
        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        if (OnEscapeKeyDownDetailed.HasDelegate)
            await OnEscapeKeyDownDetailed.InvokeAsync(args);

        if (args.DefaultPrevented)
            return;

        args.PreventDefault();
        await RootMenu.SetOpen(false);
    }

    private async Task HandleContentKeyDown(KeyboardEventArgs args)
    {
        if (OnContentKeyDown.HasDelegate)
            await OnContentKeyDown.InvokeAsync(args);

        bool isCloseKey = ParentMenu.ResolvedDirection == "rtl"
            ? args.Key == "ArrowRight"
            : args.Key == "ArrowLeft";

        if (!isCloseKey)
            return;

        await SubMenu.SetOpen(false);
        await SubMenu.FocusTrigger();
    }
}
