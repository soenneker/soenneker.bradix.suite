@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixMenuRadioItem
<CascadingValue Value="IndicatorContext">
    <BradixMenuItem Id="@Id"
                    Class="@Class"
                    Style="@Style"
                    TextValue="@TextValue"
                    Role="menuitemradio"
                    AriaChecked="@(IsChecked ? "true" : "false")"
                    DataState="@(IsChecked ? "checked" : "unchecked")"
                    Disabled="IsDisabled"
                    CloseOnSelect="CloseOnSelect"
                    OnSelect="HandleSelect"
                    OnSelectDetailed="@HandleSelectDetailed"
                    AdditionalAttributes="@AdditionalAttributes">
        @ChildContent
    </BradixMenuItem>
</CascadingValue>

@code {
    [CascadingParameter]
    internal BradixMenuRadioGroupContext Group { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? TextValue { get; set; }

    [Parameter]
    public bool CloseOnSelect { get; set; } = true;

    [Parameter]
    public EventCallback OnSelect { get; set; }

    [Parameter]
    public EventCallback<BradixMenuItemSelectEventArgs> OnSelectDetailed { get; set; }

    private bool IsDisabled => Group.Disabled || Disabled;

    private bool IsChecked => string.Equals(Group.CurrentValue, Value, StringComparison.Ordinal);

    private BradixMenuItemIndicatorContext IndicatorContext => new()
    {
        CheckedState = IsChecked ? BradixCheckboxCheckedState.Checked : BradixCheckboxCheckedState.Unchecked,
        Disabled = IsDisabled
    };

    private async Task HandleSelect()
    {
        if (OnSelect.HasDelegate)
            await OnSelect.InvokeAsync();

        await Group.SetValue(Value);
    }

    private Task HandleSelectDetailed(BradixMenuItemSelectEventArgs args)
    {
        return OnSelectDetailed.HasDelegate
            ? OnSelectDetailed.InvokeAsync(args)
            : Task.CompletedTask;
    }
}
