@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@using Soenneker.Blazor.Utils.Ids

@inherits BradixComponent

@implements IBradixMenuRovingItem
@implements IBradixMenuItem

@inject IBradixSuiteInterop Interop
@if (RenderAsLink)
{
    <a @ref="_element"
       @onclick="HandleClick"
       @onfocus="HandleFocus"
       @onblur="HandleBlur"
       @onkeydown="HandleKeyDown"
       @onpointerdown="HandlePointerDown"
       @onpointerup="HandlePointerUp"
       @onpointermove="HandlePointerMove"
       @onpointerleave="HandlePointerLeave"
       @attributes="ItemAttributes">
        @ChildContent
    </a>
}
else
{
    <div @ref="_element"
         @onclick="HandleClick"
         @onfocus="HandleFocus"
         @onblur="HandleBlur"
         @onkeydown="HandleKeyDown"
         @onpointerdown="HandlePointerDown"
         @onpointerup="HandlePointerUp"
         @onpointermove="HandlePointerMove"
         @onpointerleave="HandlePointerLeave"
         @attributes="ItemAttributes">
        @ChildContent
    </div>
}

@code {
    private ElementReference _element;
    private bool _registered;
    private bool _isFocused;
    private bool _isPointerDown;
    private string? _resolvedTextValue;
    private bool _delegatedInteractionRegistered;
    private bool _rovingFocusBridgeReady;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    internal BradixMenu Menu { get; set; } = null!;

    [CascadingParameter]
    internal IBradixMenuContentController Content { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? TextValue { get; set; }

    [Parameter]
    public string Role { get; set; } = "menuitem";

    [Parameter]
    public string? AriaChecked { get; set; }

    [Parameter]
    public string? DataState { get; set; }

    [Parameter]
    public bool CloseOnSelect { get; set; } = true;

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string? Target { get; set; }

    [Parameter]
    public EventCallback OnSelect { get; set; }

    [Parameter]
    public EventCallback<BradixMenuItemSelectEventArgs> OnSelectDetailed { get; set; }

    public string? TabStopId { get; private set; }

    bool IBradixMenuRovingItem.IsDisabled => Disabled;

    string IBradixMenuRovingItem.TabStopId => TabStopId!;

    string IBradixMenuRovingItem.TextValue => string.IsNullOrWhiteSpace(TextValue)
        ? _resolvedTextValue ?? string.Empty
        : TextValue;

    private bool RenderAsLink => !string.IsNullOrWhiteSpace(Href);

    private Dictionary<string, object> ItemAttributes => BuildAttributes(
        ("role", Role),
        ("aria-checked", AriaChecked),
        ("tabindex", Menu.IsCurrentTabStop(this) ? 0 : -1),
        ("data-bradix-roving-group", Menu.BaseId),
        ("data-bradix-roving-item", string.Empty),
        ("data-bradix-roving-item-id", TabStopId),
        ("data-bradix-roving-orientation", "vertical"),
        ("data-bradix-roving-dir", Menu.ResolvedDirection),
        ("data-bradix-roving-loop", "true"),
        ("href", RenderAsLink ? Href : null),
        ("target", RenderAsLink ? Target : null),
        ("aria-disabled", Disabled ? "true" : null),
        ("data-disabled", Disabled ? string.Empty : null),
        ("data-state", DataState),
        ("data-highlighted", _isFocused ? string.Empty : null));

    protected override void OnInitialized()
    {
        TabStopId ??= BlazorIdGenerator.New("bradix-menu-item");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Menu.RegisterItem(this);
            _registered = true;
            _dotNetReference ??= DotNetObjectReference.Create<object>(this);
            await Interop.RegisterRovingFocusNavigationKeys(_element, _dotNetReference);
            await Interop.RegisterDelegatedInteraction(_element, _dotNetReference, new
            {
                keydown = new
                {
                    currentTargetOnly = true,
                    preventDefaultKeys = new[] { " ", "Spacebar", "Enter" }
                }
            });
            _delegatedInteractionRegistered = true;
        }

        if (string.IsNullOrWhiteSpace(TextValue))
        {
            string textContent = await Interop.GetTextContent(_element);

            if (!string.Equals(_resolvedTextValue, textContent, StringComparison.Ordinal))
                _resolvedTextValue = textContent;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_element);

        await Interop.UnregisterRovingFocusNavigationKeys(_element);

        if (_registered)
            Menu.UnregisterItem(this);

        _dotNetReference?.Dispose();
    }

    public ValueTask Focus() => Interop.FocusElementPreventScroll(_element);

    private async Task HandleClick()
    {
        if (Disabled)
            return;

        var args = new BradixMenuItemSelectEventArgs();

        if (OnSelect.HasDelegate)
            await OnSelect.InvokeAsync();

        if (OnSelectDetailed.HasDelegate)
            await OnSelectDetailed.InvokeAsync(args);

        Menu.ResetTypeahead();

        if (CloseOnSelect && !args.DefaultPrevented)
            await Menu.RootMenu.SetOpen(false);
    }

    private void HandlePointerDown(PointerEventArgs args)
    {
        if (Disabled || args.Button != 0)
            return;

        _isPointerDown = true;
    }

    private async Task HandlePointerUp(PointerEventArgs args)
    {
        if (Disabled || args.Button != 0)
            return;

        bool shouldSelectOnPointerUp = !_isPointerDown;
        _isPointerDown = false;

        if (shouldSelectOnPointerUp)
            await HandleClick();
    }

    private Task HandleBlur(FocusEventArgs _)
    {
        _isFocused = false;
        return InvokeAsync(StateHasChanged);
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (Disabled)
            return Task.CompletedTask;

        _isFocused = true;
        Menu.SetCurrentTabStop(TabStopId);
        return InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Disabled || args.CtrlKey || args.AltKey || args.MetaKey)
            return;

        if (_rovingFocusBridgeReady && args.Key is "Home" or "End" or "PageUp" or "PageDown")
            return;

        if (args.Key is " " or "Spacebar")
        {
            if (Menu.IsTypeaheadActive)
                return;

            await HandleClick();
            return;
        }

        if (args.Key == "Enter")
        {
            await HandleClick();
            return;
        }

        if (args.Key.Length == 1)
        {
            await Content.HandleTypeaheadKey(this, args.Key);
            return;
        }

        await Content.HandleItemKeyDown(this, args);
    }

    private Task HandlePointerMove(PointerEventArgs args)
    {
        return Disabled
            ? Content.HandleItemLeave()
            : Content.HandlePointerMove(this, args.PointerType);
    }

    private Task HandlePointerLeave(PointerEventArgs args)
    {
        return string.Equals(args.PointerType, "mouse", StringComparison.Ordinal)
            ? Content.HandleItemLeave()
            : Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReady()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }
}
