@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@using Soenneker.Blazor.Utils.Ids

@inherits BradixComponent

@implements IBradixRadioGroupItem

@inject IBradixSuiteInterop Interop
<CascadingValue Value="this">
    <button @ref="_element"
            @onclick="HandleClick"
            @onclick:stopPropagation="ShouldRenderBubbleInput"
            @onfocus="HandleFocus"
            @onkeydown="HandleKeyDown"
            @attributes="ItemAttributes">
        @ChildContent
    </button>
</CascadingValue>

@if (ShouldRenderBubbleInput)
{
    <input @ref="_bubbleInputElement"
           @attributes="BubbleInputAttributes" />
}

@code {
    private ElementReference _element;
    private ElementReference _bubbleInputElement;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _hasSyncedBubbleInput;
    private bool _isFormControl = true;
    private bool _formControlStateResolved;
    private bool _lastRenderedChecked;
    private string? _lastResolvedForm;
    private bool _registered;
    private bool _rovingFocusBridgeReady;

    [CascadingParameter]
    internal BradixRadioGroup Group { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string InputValue { get; set; } = "on";

    [Parameter]
    public string? Form { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public EventCallback<FocusEventArgs> OnFocus { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    internal string? TabStopId { get; private set; }

    internal bool IsDisabled => Group.Disabled || Disabled;

    internal bool IsChecked => Group.IsChecked(Value);

    private bool ShouldRenderBubbleInput => _isFormControl || !string.IsNullOrWhiteSpace(Form);

    private Dictionary<string, object> ItemAttributes => BuildAttributes(
        ("type", "button"),
        ("role", "radio"),
        ("aria-checked", IsChecked ? "true" : "false"),
        ("data-state", IsChecked ? "checked" : "unchecked"),
        ("data-disabled", IsDisabled ? string.Empty : null),
        ("data-orientation", Group.Orientation?.Value),
        ("data-bradix-roving-group", Group.GroupId),
        ("data-bradix-roving-item", string.Empty),
        ("data-bradix-roving-item-id", TabStopId),
        ("data-bradix-roving-orientation", Group.Orientation?.Value),
        ("data-bradix-roving-dir", Group.ResolvedDirection),
        ("data-bradix-roving-loop", Group.Loop ? "true" : "false"),
        ("disabled", IsDisabled ? true : null),
        ("value", InputValue),
        ("tabindex", Group.IsCurrentTabStop(this) ? 0 : -1));

    private Dictionary<string, object> BubbleInputAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new()
            {
                ["type"] = "radio",
                ["name"] = Group.Name!,
                ["value"] = InputValue,
                ["checked"] = IsChecked,
                ["required"] = Group.Required,
                ["disabled"] = IsDisabled,
                ["tabindex"] = -1,
                ["aria-hidden"] = "true",
                ["style"] = "position:absolute;pointer-events:none;opacity:0;margin:0;transform:translateX(-100%);"
            };

            if (!string.IsNullOrWhiteSpace(Form))
                attributes["form"] = Form;

            return attributes;
        }
    }

    protected override void OnInitialized()
    {
        TabStopId ??= BlazorIdGenerator.New("bradix-radio-group-item");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Group.RegisterItem(this);
            _registered = true;
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterRovingFocusNavigationKeys(_element, _dotNetReference);
            await Interop.RegisterRadioGroupItemKeys(_element);
            _lastRenderedChecked = IsChecked;
        }

        if (!_formControlStateResolved || !string.Equals(_lastResolvedForm, Form, StringComparison.Ordinal))
        {
            var isFormControl = await Interop.IsFormControl(_element, Form);
            _formControlStateResolved = true;
            _lastResolvedForm = Form;

            if (_isFormControl != isFormControl)
            {
                _isFormControl = isFormControl;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        if (ShouldRenderBubbleInput)
        {
            var dispatchEvent = _hasSyncedBubbleInput && _lastRenderedChecked != IsChecked;
            await Interop.SyncCheckboxBubbleInputState(_bubbleInputElement, IsChecked, false, dispatchEvent);
            _hasSyncedBubbleInput = true;
        }

        _lastRenderedChecked = IsChecked;
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterRovingFocusNavigationKeys(_element);
        await Interop.UnregisterRadioGroupItemKeys(_element);
        _dotNetReference?.Dispose();

        if (_registered)
            Group.UnregisterItem(this);
    }

    internal ValueTask Focus()
    {
        return _element.FocusAsync();
    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);

        if (IsDisabled)
            return;

        await Group.SelectValue(Value);
    }

    private async Task HandleFocus(FocusEventArgs args)
    {
        if (OnFocus.HasDelegate)
            await OnFocus.InvokeAsync(args);

        if (IsDisabled)
            return;

        Group.SetCurrentTabStop(TabStopId);

        if (!IsChecked && Group.TryConsumeSelectOnFocus())
            await Group.SelectValue(Value);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (OnKeyDown.HasDelegate)
            await OnKeyDown.InvokeAsync(args);

        if (_rovingFocusBridgeReady && BradixRovingFocusNavigator.IsNavigationKey(args.Key))
            return;

        if (IsDisabled)
            return;

        await Group.HandleItemKeyDown(this, args);
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReady()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }
}
