@using Soenneker.Bradix.Suite.Base
@implements IAsyncDisposable
@inherits BradixComponentBase
@inject Soenneker.Bradix.Suite.Id.IBradixIdGenerator IdGenerator
@inject Soenneker.Bradix.Suite.Interop.BradixSuiteInterop Interop

<CascadingValue Value="this">
    <button @ref="_element"
            @onclick="HandleClick"
            @onfocus="HandleFocus"
            @onkeydown="HandleKeyDown"
            @attributes="ItemAttributes">
        @ChildContent
    </button>
</CascadingValue>

@if (ShouldRenderBubbleInput)
{
    <input @attributes="BubbleInputAttributes" />
}

@code {
    private ElementReference _element;
    private bool _registered;

    [CascadingParameter]
    internal BradixRadioGroup Group { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string InputValue { get; set; } = "on";

    internal string? TabStopId { get; private set; }

    internal bool IsDisabled => Group.Disabled || Disabled;

    internal bool IsChecked => Group.IsChecked(Value);

    private bool ShouldRenderBubbleInput => !string.IsNullOrWhiteSpace(Group.Name);

    private Dictionary<string, object> ItemAttributes => BuildAttributes(
        ("type", "button"),
        ("role", "radio"),
        ("aria-checked", IsChecked ? "true" : "false"),
        ("data-state", IsChecked ? "checked" : "unchecked"),
        ("data-disabled", IsDisabled ? string.Empty : null),
        ("data-orientation", Group.Orientation),
        ("disabled", IsDisabled ? true : null),
        ("value", InputValue),
        ("tabindex", Group.IsCurrentTabStop(this) ? 0 : -1));

    private Dictionary<string, object> BubbleInputAttributes => new()
    {
        ["type"] = "radio",
        ["name"] = Group.Name!,
        ["value"] = InputValue,
        ["checked"] = IsChecked,
        ["required"] = Group.Required,
        ["disabled"] = IsDisabled,
        ["tabindex"] = -1,
        ["aria-hidden"] = "true",
        ["style"] = "position:absolute;pointer-events:none;opacity:0;margin:0;"
    };

    protected override void OnInitialized()
    {
        TabStopId ??= IdGenerator.New("bradix-radio-group-item");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        Group.RegisterItem(this);
        _registered = true;
        await Interop.RegisterRovingFocusNavigationKeys(_element);
        await Interop.RegisterRadioGroupItemKeys(_element);
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterRovingFocusNavigationKeys(_element);
        await Interop.UnregisterRadioGroupItemKeys(_element);

        if (_registered)
            Group.UnregisterItem(this);
    }

    internal ValueTask FocusAsync()
    {
        return _element.FocusAsync();
    }

    private Task HandleClick()
    {
        return IsDisabled ? Task.CompletedTask : Group.SelectValueAsync(Value);
    }

    private async Task HandleFocus(FocusEventArgs _)
    {
        if (IsDisabled)
            return;

        Group.SetCurrentTabStop(TabStopId);

        if (!IsChecked && Group.TryConsumeSelectOnFocus())
            await Group.SelectValueAsync(Value);
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        return IsDisabled
            ? Task.CompletedTask
            : Group.HandleItemKeyDownAsync(this, args);
    }
}
