@namespace Soenneker.Bradix

@using System.Threading

@inherits BradixComponent

@implements IBradixHoverCard

@inject IBradixIdGenerator IdGenerator
<BradixPopper>
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</BradixPopper>

@code {
    private bool _initialized;
    private bool _uncontrolledOpen;
    private CancellationTokenSource? _openDelayTokenSource;
    private CancellationTokenSource? _closeDelayTokenSource;
    private bool _isPointerDownOnContent;
    private bool _hasSelection;

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    [Parameter]
    public int OpenDelay { get; set; } = 700;

    [Parameter]
    public int CloseDelay { get; set; } = 300;

    public string? BaseId { get; private set; }

    public bool CurrentOpen => Open ?? _uncontrolledOpen;

    public string ContentId => $"{BaseId}-content";

    protected override void OnInitialized()
    {
        BaseId ??= IdGenerator.New("bradix-hover-card");
    }

    protected override void OnParametersSet()
    {
        if (_initialized)
            return;

        _uncontrolledOpen = DefaultOpen;
        _initialized = true;
    }

    public ValueTask DisposeAsync()
    {
        CancelOpenDelay();
        CancelCloseDelay();
        return ValueTask.CompletedTask;
    }

    public Task HandleTriggerEnter()
    {
        CancelCloseDelay();
        StartOpenDelay();
        return Task.CompletedTask;
    }

    public Task HandleTriggerLeave()
    {
        StartCloseDelay();
        return Task.CompletedTask;
    }

    public async Task HandleTriggerFocus()
    {
        CancelOpenDelay();
        CancelCloseDelay();
        await SetOpen(true);
    }

    public Task HandleTriggerBlur()
    {
        StartCloseDelay();
        return Task.CompletedTask;
    }

    public Task HandleContentEnter()
    {
        CancelCloseDelay();
        return Task.CompletedTask;
    }

    public Task HandleContentLeave()
    {
        StartCloseDelay();
        return Task.CompletedTask;
    }

    public void NotifyContentPointerDown()
    {
        _hasSelection = false;
        _isPointerDownOnContent = true;
        CancelCloseDelay();
    }

    public void NotifyContentPointerUp(bool hasSelection)
    {
        _isPointerDownOnContent = false;
        _hasSelection = hasSelection;
    }

    public async Task Dismiss()
    {
        CancelOpenDelay();
        CancelCloseDelay();
        _isPointerDownOnContent = false;
        _hasSelection = false;
        await SetOpen(false);
    }

    private void StartOpenDelay()
    {
        CancelOpenDelay();
        _openDelayTokenSource = new CancellationTokenSource();
        _ = OpenAfterDelay(_openDelayTokenSource.Token);
    }

    private async Task OpenAfterDelay(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(OpenDelay, cancellationToken);
            await SetOpen(true);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void StartCloseDelay()
    {
        CancelOpenDelay();

        if (_hasSelection || _isPointerDownOnContent)
            return;

        CancelCloseDelay();
        _closeDelayTokenSource = new CancellationTokenSource();
        _ = CloseAfterDelay(_closeDelayTokenSource.Token);
    }

    private async Task CloseAfterDelay(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(CloseDelay, cancellationToken);
            await SetOpen(false);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task SetOpen(bool open)
    {
        if (CurrentOpen == open)
            return;

        if (Open is null)
            _uncontrolledOpen = open;

        if (!open)
        {
            _isPointerDownOnContent = false;
            _hasSelection = false;
        }

        if (OpenChanged.HasDelegate)
            await OpenChanged.InvokeAsync(open);

        if (OnOpenChange.HasDelegate)
            await OnOpenChange.InvokeAsync(open);

        await InvokeAsync(StateHasChanged);
    }

    private void CancelOpenDelay()
    {
        _openDelayTokenSource?.Cancel();
        _openDelayTokenSource?.Dispose();
        _openDelayTokenSource = null;
    }

    private void CancelCloseDelay()
    {
        _closeDelayTokenSource?.Cancel();
        _closeDelayTokenSource?.Dispose();
        _closeDelayTokenSource = null;
    }
}
