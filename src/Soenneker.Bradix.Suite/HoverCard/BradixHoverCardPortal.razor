@namespace Soenneker.Bradix

@implements IBradixHoverCardPortal
<CascadingValue Name="BradixHoverCardPortalForceMount" Value="ForceMount">
    <BradixPortal ContainerSelector="@ContainerSelector"
                  Container="@Container">
        @ChildContent
    </BradixPortal>
</CascadingValue>

@code {
    [Parameter]
    public string? ContainerSelector { get; set; }

    [Parameter]
    public ElementReference Container { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
