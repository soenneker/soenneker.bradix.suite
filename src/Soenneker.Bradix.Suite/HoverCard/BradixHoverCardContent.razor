@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixHoverCardContent

@inject IBradixSuiteInterop Interop

@if (IsPresent)
{
    <BradixDismissableLayer DisableOutsidePointerEvents="false"
                            DismissOnEscapeKeyDown="false"
                            DismissOnPointerDownOutside="false"
                            DismissOnFocusOutside="false"
                            OnEscapeKeyDownDetailed="@HandleEscapeKeyDown"
                            OnPointerDownOutsideDetailed="@HandlePointerDownOutside"
                            OnFocusOutsideDetailed="@HandleFocusOutside"
                            OnInteractOutsideDetailed="@HandleInteractOutside">
        <BradixPopperContent Side="@Side"
                             SideOffset="@SideOffset"
                             Align="@Align"
                             AlignOffset="@AlignOffset"
                             ArrowPadding="@ArrowPadding"
                             AvoidCollisions="@AvoidCollisions"
                             CollisionPadding="@CollisionPadding"
                             HideWhenDetached="@HideWhenDetached"
                             Style="@PositionerStyle">
            <BradixPresence Present="IsPresent"
                            Tag="div"
                            Id="@ResolvedContentId"
                            Class="@Class"
                            Style="@Style"
                            AdditionalAttributes="@ContentAttributes"
                            OnElementReferenceCaptured="@HandleContentReferenceCaptured">
                <div @onpointerenter="HandlePointerEnter"
                     @onpointerleave="HandlePointerLeave"
                     @onpointerdown="HandlePointerDown">
                    @ChildContent
                </div>
            </BradixPresence>
        </BradixPopperContent>
    </BradixDismissableLayer>
}

@code {
    private ElementReference _contentElement;
    private bool _hasContentElement;
    private bool _selectionContainmentRegistered;
    private bool _tabNavigationDisabled;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _pointerDownOutsidePrevented;

    [CascadingParameter]
    private BradixHoverCard? HoverCard { get; set; }

    [CascadingParameter(Name = "BradixHoverCardPortalForceMount")]
    private bool PortalForceMount { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public BradixSide Side { get; set; } = BradixSide.Top;

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public BradixAlignment Align { get; set; } = BradixAlignment.Center;

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback OnInteractOutside { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback<BradixPointerDownOutsideEventArgs> OnPointerDownOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback<BradixFocusOutsideEventArgs> OnFocusOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback<BradixInteractOutsideEventArgs> OnInteractOutsideDetailed { get; set; }

    private bool IsPresent => ForceMount || PortalForceMount || HoverCard?.CurrentOpen == true;

    private string? ResolvedContentId => string.IsNullOrWhiteSpace(Id) ? HoverCard?.ContentId : Id;

    private string PositionerStyle =>
        "--radix-hover-card-content-transform-origin: var(--radix-popper-transform-origin); --radix-hover-card-content-available-width: var(--radix-popper-available-width); --radix-hover-card-content-available-height: var(--radix-popper-available-height); --radix-hover-card-trigger-width: var(--radix-popper-anchor-width); --radix-hover-card-trigger-height: var(--radix-popper-anchor-height);";

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["data-state"] = HoverCard?.CurrentOpen == true ? "open" : "closed";
            return attributes;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsPresent)
        {
            if (_selectionContainmentRegistered)
            {
                await Interop.UnregisterHoverCardSelectionContainment(_contentElement);
                _selectionContainmentRegistered = false;
            }

            _hasContentElement = false;
            _tabNavigationDisabled = false;
            return;
        }

        if (!_hasContentElement)
            return;

        if (!_tabNavigationDisabled)
        {
            await Interop.DisableHoverCardContentTabNavigation(_contentElement);
            _tabNavigationDisabled = true;
        }

        if (_selectionContainmentRegistered)
            return;

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);
        await Interop.RegisterHoverCardSelectionContainment(_contentElement, _dotNetReference);
        _selectionContainmentRegistered = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (_selectionContainmentRegistered)
            await Interop.UnregisterHoverCardSelectionContainment(_contentElement);

        _dotNetReference?.Dispose();
    }

    private Task HandleContentReferenceCaptured(ElementReference element)
    {
        _contentElement = element;
        _hasContentElement = true;
        _tabNavigationDisabled = false;
        return Task.CompletedTask;
    }

    private async Task HandleEscapeKeyDown(BradixEscapeKeyDownEventArgs args)
    {
        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        if (OnEscapeKeyDownDetailed.HasDelegate)
            await OnEscapeKeyDownDetailed.InvokeAsync(args);

        if (!args.DefaultPrevented && HoverCard is not null)
            await HoverCard.Dismiss();
    }

    private async Task HandlePointerDownOutside(BradixPointerDownOutsideEventArgs args)
    {
        if (OnPointerDownOutside.HasDelegate)
            await OnPointerDownOutside.InvokeAsync();

        if (OnPointerDownOutsideDetailed.HasDelegate)
            await OnPointerDownOutsideDetailed.InvokeAsync(args);

        _pointerDownOutsidePrevented = args.DefaultPrevented;
    }

    private async Task HandleFocusOutside(BradixFocusOutsideEventArgs args)
    {
        if (OnFocusOutside.HasDelegate)
            await OnFocusOutside.InvokeAsync();

        if (OnFocusOutsideDetailed.HasDelegate)
            await OnFocusOutsideDetailed.InvokeAsync(args);
    }

    private async Task HandleInteractOutside(BradixInteractOutsideEventArgs args)
    {
        if (OnInteractOutside.HasDelegate)
            await OnInteractOutside.InvokeAsync();

        if (OnInteractOutsideDetailed.HasDelegate)
            await OnInteractOutsideDetailed.InvokeAsync(args);

        bool shouldDismiss = string.Equals(args.OriginalEventType, "pointerdown", StringComparison.Ordinal) &&
            !_pointerDownOutsidePrevented &&
            !args.DefaultPrevented;

        _pointerDownOutsidePrevented = false;

        if (shouldDismiss && HoverCard is not null)
            await HoverCard.Dismiss();
    }

    private Task HandlePointerEnter(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return HoverCard?.HandleContentEnter() ?? Task.CompletedTask;
    }

    private Task HandlePointerLeave(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return HoverCard?.HandleContentLeave() ?? Task.CompletedTask;
    }

    private async Task HandlePointerDown(PointerEventArgs _)
    {
        if (_hasContentElement)
            await Interop.BeginHoverCardSelectionContainment(_contentElement);

        HoverCard?.NotifyContentPointerDown();
    }

    [JSInvokable]
    public Task HandleDocumentPointerUp(bool hasSelection)
    {
        HoverCard?.NotifyContentPointerUp(hasSelection);
        return Task.CompletedTask;
    }
}
