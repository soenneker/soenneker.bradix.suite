@namespace Soenneker.Bradix

@inherits BradixComponentBase

<BradixPopperAnchor>
    <button @onpointerenter="HandlePointerEnter"
            @onpointerleave="HandlePointerLeave"
            @onfocus="HandleFocus"
            @onblur="HandleBlur"
            @ontouchstart:preventDefault="true"
            @attributes="TriggerAttributes">
        @ChildContent
    </button>
</BradixPopperAnchor>

@code {
    [CascadingParameter]
    private BradixHoverCard? HoverCard { get; set; }

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("type", "button"),
        ("data-state", HoverCard?.CurrentOpen == true ? "open" : "closed"));

    private Task HandlePointerEnter(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return HoverCard?.HandleTriggerEnter() ?? Task.CompletedTask;
    }

    private Task HandlePointerLeave(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return HoverCard?.HandleTriggerLeave() ?? Task.CompletedTask;
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        return HoverCard?.HandleTriggerFocus() ?? Task.CompletedTask;
    }

    private Task HandleBlur(FocusEventArgs _)
    {
        return HoverCard?.HandleTriggerBlur() ?? Task.CompletedTask;
    }
}
