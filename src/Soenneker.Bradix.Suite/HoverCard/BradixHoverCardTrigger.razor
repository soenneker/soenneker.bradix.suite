@namespace Soenneker.Bradix

@inherits BradixComponentBase

<BradixPopperAnchor>
    <button @onpointerenter="HandlePointerEnterAsync"
            @onpointerleave="HandlePointerLeaveAsync"
            @onfocus="HandleFocusAsync"
            @onblur="HandleBlurAsync"
            @ontouchstart:preventDefault="true"
            @attributes="TriggerAttributes">
        @ChildContent
    </button>
</BradixPopperAnchor>

@code {
    [CascadingParameter]
    private BradixHoverCard? HoverCard { get; set; }

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("type", "button"),
        ("data-state", HoverCard?.CurrentOpen == true ? "open" : "closed"));

    private Task HandlePointerEnterAsync(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return HoverCard?.HandleTriggerEnterAsync() ?? Task.CompletedTask;
    }

    private Task HandlePointerLeaveAsync(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return HoverCard?.HandleTriggerLeaveAsync() ?? Task.CompletedTask;
    }

    private Task HandleFocusAsync(FocusEventArgs _)
    {
        return HoverCard?.HandleTriggerFocusAsync() ?? Task.CompletedTask;
    }

    private Task HandleBlurAsync(FocusEventArgs _)
    {
        return HoverCard?.HandleTriggerBlurAsync() ?? Task.CompletedTask;
    }
}
