@namespace Soenneker.Bradix

@implements IBradixFocusGuards

@inject IBradixSuiteInterop Interop

@ChildContent
@code {
    private bool _registered;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Interop.RegisterFocusGuards();
        _registered = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
            await Interop.UnregisterFocusGuards();
    }
}
