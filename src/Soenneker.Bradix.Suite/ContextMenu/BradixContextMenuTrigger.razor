@namespace Soenneker.Bradix

@using System.Threading

@inherits BradixComponent

@implements IBradixContextMenuTrigger
<span @oncontextmenu="HandleContextMenu"
      @oncontextmenu:preventDefault="@(!Disabled)"
      @onpointerdown="HandlePointerDown"
      @onpointermove="HandlePointerMove"
      @onpointercancel="HandlePointerCancel"
      @onpointerup="HandlePointerUp"
      @attributes="TriggerAttributes">
    @ChildContent
</span>

@code {
    private const int _longPressDelayMs = 700;
    private CancellationTokenSource? _longPressCancellationTokenSource;

    [CascadingParameter]
    private BradixContextMenu? ContextMenu { get; set; }

    [CascadingParameter]
    private BradixMenu? Menu { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("aria-haspopup", "menu"),
        ("aria-expanded", ContextMenu?.CurrentOpen == true ? "true" : "false"),
        ("aria-controls", Menu?.ContentId),
        ("data-state", ContextMenu?.CurrentOpen == true ? "open" : "closed"),
        ("data-disabled", Disabled ? string.Empty : null),
        ("style", BuildStyle()));

    public ValueTask DisposeAsync()
    {
        ClearLongPress();
        return ValueTask.CompletedTask;
    }

    private Task HandleContextMenu(MouseEventArgs args)
    {
        if (Disabled || ContextMenu is null)
            return Task.CompletedTask;

        ClearLongPress();
        return ContextMenu.OpenAtPoint(args.ClientX, args.ClientY);
    }

    private Task HandlePointerDown(PointerEventArgs args)
    {
        if (Disabled || ContextMenu is null || IsMousePointer(args))
            return Task.CompletedTask;

        ClearLongPress();
        _longPressCancellationTokenSource = new CancellationTokenSource();
        _ = StartLongPress(args.ClientX, args.ClientY, _longPressCancellationTokenSource.Token);
        return Task.CompletedTask;
    }

    private Task HandlePointerMove(PointerEventArgs args)
    {
        if (!IsMousePointer(args))
            ClearLongPress();

        return Task.CompletedTask;
    }

    private Task HandlePointerCancel(PointerEventArgs args)
    {
        if (!IsMousePointer(args))
            ClearLongPress();

        return Task.CompletedTask;
    }

    private Task HandlePointerUp(PointerEventArgs args)
    {
        if (!IsMousePointer(args))
            ClearLongPress();

        return Task.CompletedTask;
    }

    private async Task StartLongPress(double x, double y, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(_longPressDelayMs, cancellationToken);

            if (ContextMenu is not null)
                await InvokeAsync(() => ContextMenu.OpenAtPoint(x, y));
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void ClearLongPress()
    {
        _longPressCancellationTokenSource?.Cancel();
        _longPressCancellationTokenSource?.Dispose();
        _longPressCancellationTokenSource = null;
    }

    private string BuildStyle()
    {
        const string baseStyle = "-webkit-touch-callout: none;";
        return string.IsNullOrWhiteSpace(Style) ? baseStyle : $"{baseStyle} {Style}";
    }

    private static bool IsMousePointer(PointerEventArgs args)
    {
        return string.Equals(args.PointerType, "mouse", StringComparison.Ordinal);
    }
}
