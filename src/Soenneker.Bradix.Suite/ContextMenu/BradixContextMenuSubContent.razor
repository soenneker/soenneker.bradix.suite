@namespace Soenneker.Bradix

@using System.Collections.Generic

@implements IBradixContextMenuSubContent
<BradixMenuSubContent ForceMount="@ForceMount"
                      Loop="@Loop"
                      SideOffset="@SideOffset"
                      AlignOffset="@AlignOffset"
                      ArrowPadding="@ArrowPadding"
                      AvoidCollisions="@AvoidCollisions"
                      CollisionPadding="@CollisionPadding"
                      CollisionBoundarySelector="@CollisionBoundarySelector"
                      CollisionBoundarySelectors="@CollisionBoundarySelectors"
                      Sticky="@Sticky"
                      HideWhenDetached="@HideWhenDetached"
                      Class="@Class"
                      Style="@MergedStyle"
                      AdditionalAttributes="@AdditionalAttributes"
                      OnOpenAutoFocus="@OnOpenAutoFocus"
                      OnOpenAutoFocusDetailed="@OnOpenAutoFocusDetailed"
                      OnEscapeKeyDown="@OnEscapeKeyDown"
                      OnEscapeKeyDownDetailed="@OnEscapeKeyDownDetailed"
                      OnPointerDownOutside="@OnPointerDownOutside"
                      OnPointerDownOutsideDetailed="@OnPointerDownOutsideDetailed"
                      OnFocusOutside="@OnFocusOutside"
                      OnFocusOutsideDetailed="@OnFocusOutsideDetailed"
                      OnInteractOutside="@OnInteractOutside"
                      OnInteractOutsideDetailed="@OnInteractOutsideDetailed"
                      OnContentKeyDown="@OnContentKeyDown"
                      OnPlaced="@OnPlaced">
    @ChildContent
</BradixMenuSubContent>

@code {
    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public bool Loop { get; set; }

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnOpenAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback<BradixPointerDownOutsideEventArgs> OnPointerDownOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback<BradixFocusOutsideEventArgs> OnFocusOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnInteractOutside { get; set; }

    [Parameter]
    public EventCallback<BradixInteractOutsideEventArgs> OnInteractOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnContentKeyDown { get; set; }

    [Parameter]
    public EventCallback OnPlaced { get; set; }

    private string MergedStyle
    {
        get
        {
            const string contextMenuVariables =
                "--radix-context-menu-content-transform-origin: var(--radix-popper-transform-origin); --radix-context-menu-content-available-width: var(--radix-popper-available-width); --radix-context-menu-content-available-height: var(--radix-popper-available-height); --radix-context-menu-trigger-width: var(--radix-popper-anchor-width); --radix-context-menu-trigger-height: var(--radix-popper-anchor-height);";

            return BradixComponent.MergeStyleValues(contextMenuVariables, Style)!;
        }
    }
}
