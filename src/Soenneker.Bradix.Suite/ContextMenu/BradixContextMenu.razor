@namespace Soenneker.Bradix

@inherits BradixComponentBase

<BradixMenu @ref="_menu"
            Open="@_open"
            OpenChanged="HandleMenuOpenChanged"
            Dir="@Dir"
            Modal="@Modal">
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</BradixMenu>

@code {
    private bool _open;
    private BradixMenu? _menu;

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public bool Modal { get; set; } = true;

    internal bool CurrentOpen => _open;

    internal async Task OpenAtPoint(double x, double y)
    {
        _menu?.RegisterVirtualAnchor(x, y);

        if (_open)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        await SetOpen(true);
    }

    internal Task Close()
    {
        return SetOpen(false);
    }

    private async Task SetOpen(bool open)
    {
        if (_open == open)
            return;

        _open = open;

        if (OnOpenChange.HasDelegate)
            await OnOpenChange.InvokeAsync(open);

        await InvokeAsync(StateHasChanged);
    }

    private Task HandleMenuOpenChanged(bool open)
    {
        return SetOpen(open);
    }
}
