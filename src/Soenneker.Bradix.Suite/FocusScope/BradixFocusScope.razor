@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponentBase

@implements IBradixFocusScope

@inject IBradixSuiteInterop Interop
<div @ref="_element"
     @attributes="ScopeAttributes">
    @ChildContent
</div>

@code {
    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _registered;
    private bool? _lastLoop;
    private bool? _lastTrapped;
    private bool? _lastPreventMountAutoFocus;
    private bool? _lastPreventUnmountAutoFocus;

    [Parameter]
    public bool Loop { get; set; }

    [Parameter]
    public bool Trapped { get; set; }

    [Parameter]
    public EventCallback OnMountAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnMountAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnUnmountAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnUnmountAutoFocusDetailed { get; set; }

    [Parameter]
    public bool PreventMountAutoFocus { get; set; }

    [Parameter]
    public bool PreventUnmountAutoFocus { get; set; }

    private Dictionary<string, object> ScopeAttributes => BuildAttributes(
        ("tabindex", -1));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterFocusScope(_element, _dotNetReference, Loop, Trapped, PreventMountAutoFocus, PreventUnmountAutoFocus);
            _registered = true;
            _lastLoop = Loop;
            _lastTrapped = Trapped;
            _lastPreventMountAutoFocus = PreventMountAutoFocus;
            _lastPreventUnmountAutoFocus = PreventUnmountAutoFocus;
            return;
        }

        if (_lastLoop != Loop || _lastTrapped != Trapped || _lastPreventMountAutoFocus != PreventMountAutoFocus || _lastPreventUnmountAutoFocus != PreventUnmountAutoFocus)
        {
            await Interop.UpdateFocusScope(_element, Loop, Trapped, PreventMountAutoFocus, PreventUnmountAutoFocus);
            _lastLoop = Loop;
            _lastTrapped = Trapped;
            _lastPreventMountAutoFocus = PreventMountAutoFocus;
            _lastPreventUnmountAutoFocus = PreventUnmountAutoFocus;
        }
    }

    public async ValueTask DisposeAsync()
    {
        bool unmountAutoFocusPrevented = PreventUnmountAutoFocus;

        if (OnUnmountAutoFocus.HasDelegate || OnUnmountAutoFocusDetailed.HasDelegate)
            unmountAutoFocusPrevented = await HandleUnmountAutoFocusCore(new BradixAutoFocusEventArgs()) || unmountAutoFocusPrevented;

        if (_registered)
            await Interop.UnregisterFocusScope(_element, unmountAutoFocusPrevented);

        _dotNetReference?.Dispose();
    }

    [JSInvokable]
    public Task<bool> HandleMountAutoFocus()
    {
        return HandleMountAutoFocusCore(new BradixAutoFocusEventArgs());
    }

    [JSInvokable]
    public Task<bool> HandleUnmountAutoFocus()
    {
        return HandleUnmountAutoFocusCore(new BradixAutoFocusEventArgs());
    }

    private async Task<bool> HandleMountAutoFocusCore(BradixAutoFocusEventArgs args)
    {
        if (OnMountAutoFocus.HasDelegate)
            await OnMountAutoFocus.InvokeAsync();

        if (OnMountAutoFocusDetailed.HasDelegate)
            await OnMountAutoFocusDetailed.InvokeAsync(args);

        return args.DefaultPrevented;
    }

    private async Task<bool> HandleUnmountAutoFocusCore(BradixAutoFocusEventArgs args)
    {
        if (OnUnmountAutoFocus.HasDelegate)
            await OnUnmountAutoFocus.InvokeAsync();

        if (OnUnmountAutoFocusDetailed.HasDelegate)
            await OnUnmountAutoFocusDetailed.InvokeAsync(args);

        return args.DefaultPrevented;
    }
}
