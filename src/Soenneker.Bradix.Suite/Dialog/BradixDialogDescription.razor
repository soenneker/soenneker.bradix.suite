@namespace Soenneker.Bradix

@implements IDisposable
@inherits BradixComponentBase

<p @attributes="DescriptionAttributes">
    @ChildContent
</p>

@code {
    [CascadingParameter]
    private BradixDialog? Dialog { get; set; }

    private string ResolvedDescriptionId => string.IsNullOrWhiteSpace(Id) ? Dialog?.DescriptionId ?? string.Empty : Id;

    private Dictionary<string, object> DescriptionAttributes => BuildAttributes(
        ("id", ResolvedDescriptionId));

    protected override void OnParametersSet()
    {
        Dialog?.RegisterDescription(ResolvedDescriptionId);
    }

    public void Dispose()
    {
        Dialog?.UnregisterDescription(ResolvedDescriptionId);
    }
}
