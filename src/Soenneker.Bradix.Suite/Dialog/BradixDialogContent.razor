@namespace Soenneker.Bradix

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject BradixSuiteInterop Interop

@if (ShouldRenderContainer)
{
    @if (Dialog?.Modal == true)
    {
        <BradixRemoveScroll AllowPinchZoom>
            @RenderContentTree()
        </BradixRemoveScroll>
    }
    else
    {
        @RenderContentTree()
    }
}

@code {
    private bool _wasPresent;
    private bool _isExiting;
    private bool _hasInteractedOutside;
    private bool _hideOthersRegistered;
    private ElementReference _contentElement;

    [CascadingParameter]
    private BradixDialog? Dialog { get; set; }

    [CascadingParameter(Name = "BradixDialogPortalForceMount")]
    private bool PortalForceMount { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback OnCloseAutoFocus { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback OnInteractOutside { get; set; }

    [Parameter]
    public string Role { get; set; } = "dialog";

    [Parameter]
    public bool CloseOnEscapeKeyDown { get; set; } = true;

    [Parameter]
    public bool CloseOnPointerDownOutside { get; set; } = true;

    [Parameter]
    public bool CloseOnFocusOutside { get; set; } = true;

    private bool IsPresent => ForceMount || PortalForceMount || Dialog?.CurrentOpen == true;

    private bool ShouldRenderContainer => IsPresent || _isExiting;

    private bool ShouldTrapFocus => Dialog?.Modal == true && Dialog.CurrentOpen;

    private bool ShouldDisableOutsidePointerEvents => Dialog?.Modal == true && Dialog.CurrentOpen;

    private string? ResolvedContentId => string.IsNullOrWhiteSpace(Id) ? Dialog?.ContentId : Id;

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["role"] = string.IsNullOrWhiteSpace(Role) ? "dialog" : Role;
            attributes["data-state"] = Dialog?.CurrentOpen == true ? "open" : "closed";

            if (!string.IsNullOrWhiteSpace(Dialog?.TitleId))
                attributes["aria-labelledby"] = Dialog.TitleId;

            if (!string.IsNullOrWhiteSpace(Dialog?.DescriptionId))
                attributes["aria-describedby"] = Dialog.DescriptionId;

            if (Dialog?.Modal == true)
                attributes["aria-modal"] = "true";

            return attributes;
        }
    }

    protected override void OnParametersSet()
    {
        bool present = IsPresent;

        if (_wasPresent && !present)
            _isExiting = true;
        else if (present)
            _isExiting = false;

        _wasPresent = present;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hideOthersRegistered)
        {
            await Interop.UnregisterHideOthers(_contentElement);
            _hideOthersRegistered = false;
        }
    }

    private async Task HandleElementReferenceCapturedAsync(ElementReference element)
    {
        _contentElement = element;

        if (Dialog?.Modal == true && !_hideOthersRegistered)
        {
            await Interop.RegisterHideOthers(_contentElement);
            _hideOthersRegistered = true;
        }
    }

    private async Task HandleOpenAutoFocusAsync()
    {
        if (OnOpenAutoFocus.HasDelegate)
            await OnOpenAutoFocus.InvokeAsync();
    }

    private async Task HandleCloseAutoFocusAsync()
    {
        if (OnCloseAutoFocus.HasDelegate)
            await OnCloseAutoFocus.InvokeAsync();

        if (Dialog is not null && (Dialog.Modal || !_hasInteractedOutside))
            await Dialog.FocusTriggerAsync();

        _hasInteractedOutside = false;
    }

    private async Task HandleEscapeKeyDownAsync()
    {
        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        if (Dialog is not null && CloseOnEscapeKeyDown)
            await Dialog.SetOpenAsync(false);
    }

    private async Task HandlePointerDownOutsideAsync()
    {
        if (OnPointerDownOutside.HasDelegate)
            await OnPointerDownOutside.InvokeAsync();

        if (OnInteractOutside.HasDelegate)
            await OnInteractOutside.InvokeAsync();

        if (Dialog is not null && !Dialog.Modal)
            _hasInteractedOutside = true;

        if (Dialog is not null && CloseOnPointerDownOutside)
            await Dialog.SetOpenAsync(false);
    }

    private async Task HandleFocusOutsideAsync()
    {
        if (OnFocusOutside.HasDelegate)
            await OnFocusOutside.InvokeAsync();

        if (Dialog?.Modal == true)
            return;

        if (OnInteractOutside.HasDelegate)
            await OnInteractOutside.InvokeAsync();

        _hasInteractedOutside = true;

        if (Dialog is not null && CloseOnFocusOutside)
            await Dialog.SetOpenAsync(false);
    }

    private async Task HandleExitCompleteAsync()
    {
        _isExiting = false;

        if (_hideOthersRegistered)
        {
            await Interop.UnregisterHideOthers(_contentElement);
            _hideOthersRegistered = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private RenderFragment RenderContentTree() => @<BradixFocusGuards>
        <BradixFocusScope Loop
                          Trapped="ShouldTrapFocus"
                          PreventUnmountAutoFocus="true"
                          OnMountAutoFocus="HandleOpenAutoFocusAsync"
                          OnUnmountAutoFocus="HandleCloseAutoFocusAsync">
            <BradixDismissableLayer DisableOutsidePointerEvents="ShouldDisableOutsidePointerEvents"
                                    DismissOnEscapeKeyDown="false"
                                    DismissOnPointerDownOutside="false"
                                    DismissOnFocusOutside="false"
                                    OnEscapeKeyDown="@HandleEscapeKeyDownAsync"
                                    OnPointerDownOutside="@HandlePointerDownOutsideAsync"
                                    OnFocusOutside="@HandleFocusOutsideAsync"
                                    OnElementReferenceCaptured="@HandleElementReferenceCapturedAsync">
                <BradixPresence Present="IsPresent"
                                Tag="div"
                                Id="@ResolvedContentId"
                                Class="@Class"
                                Style="@Style"
                                AdditionalAttributes="@ContentAttributes"
                                OnExitComplete="@HandleExitCompleteAsync">
                    @ChildContent
                </BradixPresence>
            </BradixDismissableLayer>
        </BradixFocusScope>
    </BradixFocusGuards>;
}
