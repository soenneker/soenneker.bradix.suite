@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixDialog

@inject IBradixIdGenerator IdGenerator
<CascadingValue Value="this">
    @ChildContent
</CascadingValue>

@code {
    private bool _initialized;
    private bool _uncontrolledOpen;

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    [Parameter]
    public bool Modal { get; set; } = true;

    public string? BaseId { get; private set; }

    public bool CurrentOpen => Open ?? _uncontrolledOpen;

    public string ContentId => $"{BaseId}-content";
    public string TitleId => $"{BaseId}-title";
    public string DescriptionId => $"{BaseId}-description";
    public string DefaultTriggerId => $"{BaseId}-trigger";
    public string? RegisteredTitleId { get; private set; }
    public string? RegisteredDescriptionId { get; private set; }

    public ElementReference TriggerElement { get; private set; }
    public bool HasTrigger { get; private set; }
    public string ResolvedTriggerId { get; private set; } = string.Empty;

    protected override void OnInitialized()
    {
        BaseId ??= IdGenerator.New("bradix-dialog");
    }

    protected override void OnParametersSet()
    {
        if (_initialized)
            return;

        _uncontrolledOpen = DefaultOpen;
        _initialized = true;
    }

    public async Task SetOpen(bool open)
    {
        if (CurrentOpen == open)
            return;

        if (Open is null)
            _uncontrolledOpen = open;

        if (OpenChanged.HasDelegate)
            await OpenChanged.InvokeAsync(open);

        if (OnOpenChange.HasDelegate)
            await OnOpenChange.InvokeAsync(open);

        await InvokeAsync(StateHasChanged);
    }

    public Task ToggleOpen()
    {
        return SetOpen(!CurrentOpen);
    }

    public void RegisterTrigger(ElementReference element, string? triggerId = null)
    {
        TriggerElement = element;
        ResolvedTriggerId = string.IsNullOrWhiteSpace(triggerId) ? DefaultTriggerId : triggerId;
        HasTrigger = true;
    }

    public void RegisterTitle(string? titleId)
    {
        RegisteredTitleId = string.IsNullOrWhiteSpace(titleId) ? null : titleId;
    }

    public void UnregisterTitle(string? titleId)
    {
        if (string.Equals(RegisteredTitleId, titleId, StringComparison.Ordinal))
            RegisteredTitleId = null;
    }

    public void RegisterDescription(string? descriptionId)
    {
        RegisteredDescriptionId = string.IsNullOrWhiteSpace(descriptionId) ? null : descriptionId;
    }

    public void UnregisterDescription(string? descriptionId)
    {
        if (string.Equals(RegisteredDescriptionId, descriptionId, StringComparison.Ordinal))
            RegisteredDescriptionId = null;
    }

    public bool ContainsTriggerTarget(string? targetId, IEnumerable<string>? ancestorIds)
    {
        if (string.IsNullOrWhiteSpace(ResolvedTriggerId))
            return false;

        if (string.Equals(targetId, ResolvedTriggerId, StringComparison.Ordinal))
            return true;

        if (ancestorIds is null)
            return false;

        foreach (string ancestorId in ancestorIds)
        {
            if (string.Equals(ancestorId, ResolvedTriggerId, StringComparison.Ordinal))
                return true;
        }

        return false;
    }

    public async Task FocusTrigger()
    {
        if (!HasTrigger)
            return;

        try
        {
            await TriggerElement.FocusAsync();
        }
        catch
        {
        }
    }
}
