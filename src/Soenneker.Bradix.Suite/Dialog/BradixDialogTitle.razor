@namespace Soenneker.Bradix

@inherits BradixComponentBase

@implements IBradixDialogTitle
<h2 @attributes="TitleAttributes">
    @ChildContent
</h2>

@code {
    [CascadingParameter]
    private BradixDialog? Dialog { get; set; }

    private string ResolvedTitleId => string.IsNullOrWhiteSpace(Id) ? Dialog?.TitleId ?? string.Empty : Id;

    private Dictionary<string, object> TitleAttributes => BuildAttributes(
        ("id", ResolvedTitleId));

    protected override void OnParametersSet()
    {
        Dialog?.RegisterTitle(ResolvedTitleId);
    }

    public void Dispose()
    {
        Dialog?.UnregisterTitle(ResolvedTitleId);
    }
}
