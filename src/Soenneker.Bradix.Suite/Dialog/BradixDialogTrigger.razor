@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixDialogTrigger

@inject IBradixSuiteInterop Interop
<button @ref="_button"
        @onclick="HandleClick"
        @attributes="ButtonAttributes">
    @ChildContent
</button>

@code {
    private ElementReference _button;
    private bool _delegatedInteractionReady;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixDialog? Dialog { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private string ResolvedTriggerId => string.IsNullOrWhiteSpace(Id) ? Dialog?.DefaultTriggerId ?? string.Empty : Id;

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("type", "button"),
        ("id", ResolvedTriggerId),
        ("aria-haspopup", "dialog"),
        ("aria-expanded", Dialog?.CurrentOpen == true ? "true" : "false"),
        ("aria-controls", Dialog?.ContentId),
        ("data-state", Dialog?.CurrentOpen == true ? "open" : "closed"),
        ("data-disabled", Disabled ? string.Empty : null),
        ("disabled", Disabled ? true : null));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Dialog?.RegisterTrigger(_button, ResolvedTriggerId);
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterDelegatedInteraction(_button, _dotNetReference, new
            {
                readyMethod = nameof(HandleDelegatedInteractionReady),
                click = new
                {
                    method = nameof(HandleDelegatedClick),
                    currentTargetOnly = false
                }
            });
        }

        return;
    }

    private async Task HandleClick()
    {
        if (!Disabled && Dialog is not null && !_delegatedInteractionReady)
            await Dialog.ToggleOpen();

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterDelegatedInteraction(_button);
        _dotNetReference?.Dispose();
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReady()
    {
        _delegatedInteractionReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task HandleDelegatedClick(BradixDelegatedMouseEvent args)
    {
        if (!Disabled && Dialog is not null)
            await Dialog.ToggleOpen();

        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(new MouseEventArgs
            {
                Detail = args.Detail,
                Button = args.Button,
                CtrlKey = args.CtrlKey,
                ShiftKey = args.ShiftKey,
                AltKey = args.AltKey,
                MetaKey = args.MetaKey,
                PageX = args.PageX,
                PageY = args.PageY
            });
        }
    }
}
