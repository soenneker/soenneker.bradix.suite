@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

<button @ref="_element"
        @onmousedown="HandleMouseDown"
        @onkeydown="HandleKeyDown"
        @onfocus="HandleFocus"
        @attributes="TriggerAttributes">
    @ChildContent
</button>

@code {
    private ElementReference _element;
    private bool _delegatedInteractionReady;
    private bool _rovingFocusBridgeReady;
    private bool _registered;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    internal BradixTabs Tabs { get; set; } = null!;

    [CascadingParameter]
    internal BradixTabsList? List { get; set; }

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnMouseDown { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    [Parameter]
    public EventCallback<FocusEventArgs> OnFocus { get; set; }

    internal bool IsDisabled => Disabled;

    internal bool IsSelected => string.Equals(Tabs.CurrentValue, Value, StringComparison.Ordinal);

    internal string TabStopId => TriggerId;

    private string TriggerId => Tabs.MakeTriggerId(Value);

    private string ContentId => Tabs.MakeContentId(Value);

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("type", "button"),
        ("role", "tab"),
        ("aria-selected", IsSelected ? "true" : "false"),
        ("aria-controls", ContentId),
        ("data-state", IsSelected ? "active" : "inactive"),
        ("data-disabled", Disabled ? string.Empty : null),
        ("data-orientation", Tabs.Orientation),
        ("data-bradix-roving-group", Tabs.BaseId),
        ("data-bradix-roving-item", string.Empty),
        ("data-bradix-roving-item-id", TabStopId),
        ("data-bradix-roving-orientation", Tabs.Orientation),
        ("data-bradix-roving-dir", Tabs.ResolvedDirection),
        ("data-bradix-roving-loop", (List?.Loop ?? true) ? "true" : "false"),
        ("disabled", Disabled ? true : null),
        ("id", TriggerId),
        ("tabindex", Tabs.IsCurrentTabStop(this) ? 0 : -1));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        Tabs.RegisterTrigger(this);
        _registered = true;
        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterRovingFocusNavigationKeys(_element, _dotNetReference);
        await Interop.RegisterDelegatedInteraction(_element, _dotNetReference, new
        {
            readyMethod = nameof(HandleDelegatedInteractionReady),
            mousedown = new
            {
                method = nameof(HandleDelegatedMouseDown),
                filter = "primaryMousedown"
            },
            keydown = new
            {
                method = nameof(HandleDelegatedKeyDown),
                keys = new[] { "Enter", " ", "Spacebar" }
            }
        });
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterRovingFocusNavigationKeys(_element);
        await Interop.UnregisterDelegatedInteraction(_element);
        _dotNetReference?.Dispose();

        if (_registered)
            Tabs.UnregisterTrigger(this);
    }

    internal ValueTask Focus()
    {
        return _element.FocusAsync();
    }

    private async Task HandleMouseDown(MouseEventArgs args)
    {
        if (OnMouseDown.HasDelegate)
            await OnMouseDown.InvokeAsync(args);

        if (Disabled)
            return;

        if (_delegatedInteractionReady)
            return;

        // TODO: Match Radix non-primary/Ctrl+click mousedown preventDefault semantics via delegated JS
        // so the trigger does not steal focus on right/middle click or macOS Ctrl+click fallback paths.
        if (args.Button == 0 && !args.CtrlKey)
            await Tabs.SetValue(Value);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (OnKeyDown.HasDelegate)
            await OnKeyDown.InvokeAsync(args);

        if (Disabled)
            return;

        if (_rovingFocusBridgeReady && BradixRovingFocusNavigator.IsNavigationKey(args.Key))
            return;

        if (_delegatedInteractionReady)
            return;

        if (args.Key is " " or "Enter")
        {
            await Tabs.SetValue(Value);
            return;
        }

        await Tabs.HandleTriggerKeyDown(this, List?.Loop ?? true, args);
    }

    private async Task HandleFocus(FocusEventArgs args)
    {
        if (OnFocus.HasDelegate)
            await OnFocus.InvokeAsync(args);

        if (Disabled)
            return;

        Tabs.SetCurrentTabStop(TabStopId);

        if (!IsSelected && Tabs.IsAutomaticActivation)
            await Tabs.SetValue(Value);
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReady()
    {
        _delegatedInteractionReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleDelegatedMouseDown(BradixDelegatedMouseEvent _)
    {
        return Disabled ? Task.CompletedTask : Tabs.SetValue(Value);
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReady()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleDelegatedKeyDown(BradixDelegatedKeyboardEvent args)
    {
        if (Disabled)
            return Task.CompletedTask;

        return args.Key is " " or "Enter" or "Spacebar"
            ? Tabs.SetValue(Value)
            : Task.CompletedTask;
    }
}
