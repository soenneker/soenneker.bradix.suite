@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixTabsContent
<BradixPresence Present="Present"
                Tag="div"
                AdditionalAttributes="@ContentAttributes"
                OnExitComplete="@HandleExitComplete">
    @if (ShouldRenderChildren)
    {
        @ChildContent
    }
</BradixPresence>

@code {
    private bool _preventMountAnimation = true;
    private bool _isPresent;

    [CascadingParameter]
    internal BradixTabs Tabs { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool ForceMount { get; set; }

    private bool Present => ForceMount || IsSelected;

    private bool ShouldRenderChildren => Present || _isPresent;

    private bool IsSelected => string.Equals(Tabs.CurrentValue, Value, StringComparison.Ordinal);

    private string TriggerId => Tabs.MakeTriggerId(Value);

    private string ContentId => Tabs.MakeContentId(Value);

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes(
        ("role", "tabpanel"),
        ("aria-labelledby", TriggerId),
        ("hidden", !(Present || _isPresent)),
        ("id", ContentId),
        ("tabindex", 0),
        ("data-state", IsSelected ? "active" : "inactive"),
        ("data-orientation", Tabs.Orientation.Value),
        ("style", BuildContentStyle()));

    protected override void OnParametersSet()
    {
        if (Present)
            _isPresent = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return Task.CompletedTask;

        _preventMountAnimation = false;
        return InvokeAsync(StateHasChanged);
    }

    private string? BuildContentStyle()
    {
        var animationStyle = _preventMountAnimation ? "animation-duration: 0s;" : null;

        return MergeStyleValues(animationStyle, Style);
    }

    private async Task HandleExitComplete()
    {
        _isPresent = false;
        await InvokeAsync(StateHasChanged);
    }
}
