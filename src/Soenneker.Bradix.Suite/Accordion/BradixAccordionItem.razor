@namespace Soenneker.Bradix

@inherits BradixComponent

@using Soenneker.Blazor.Utils.Ids
@implements IBradixAccordionItem

<CascadingValue Value="this">
    <BradixCollapsible Id="@BaseId"
                       Class="@Class"
                       Style="@Style"
                       Open="@IsOpen"
                       Disabled="@IsDisabled"
                       OnOpenChange="HandleOpenChange"
                       AdditionalAttributes="ItemAttributes">
        @ChildContent
    </BradixCollapsible>
</CascadingValue>

@code {
    [CascadingParameter]
    internal BradixAccordion Accordion { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    private string? _generatedBaseId;

    internal string BaseId => Id.HasContent() ? Id! : _generatedBaseId ??= BlazorIdGenerator.New("bradix-accordion-item");

    internal string TriggerId => BlazorIdGenerator.Child(BaseId, "trigger");

    internal bool IsOpen => Accordion.IsItemOpen(Value);

    internal bool IsDisabled => Accordion.Disabled || Disabled;

    protected override void OnInitialized()
    {
        _ = BaseId;
    }

    private IReadOnlyDictionary<string, object> ItemAttributes
    {
        get
        {
            var attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : [];

            attributes["data-orientation"] = Accordion.Orientation.Value;

            return attributes;
        }
    }

    private Task HandleOpenChange(bool open)
    {
        return open
            ? Accordion.OpenItem(Value)
            : Accordion.CloseItem(Value);
    }
}
