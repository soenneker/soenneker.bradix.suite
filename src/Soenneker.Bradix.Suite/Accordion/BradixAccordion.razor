@namespace Soenneker.Bradix

@inherits BradixComponentBase

<CascadingValue Value="this">
    <div @attributes="RootAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private const string SingleType = "single";
    private const string MultipleType = "multiple";
    private const string VerticalOrientation = "vertical";
    private const string HorizontalOrientation = "horizontal";

    private readonly List<BradixAccordionTrigger> _triggers = [];
    private bool _initialized;
    private string? _uncontrolledValue;
    private List<string> _uncontrolledValues = [];

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public string Type { get; set; } = SingleType;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string Orientation { get; set; } = VerticalOrientation;

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public bool Collapsible { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string?> OnValueChange { get; set; }

    [Parameter]
    public IReadOnlyCollection<string>? Values { get; set; }

    [Parameter]
    public IEnumerable<string>? DefaultValues { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyCollection<string>> ValuesChanged { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyCollection<string>> OnValuesChange { get; set; }

    internal bool IsCollapsible => Type == MultipleType || Collapsible;
    internal string ResolvedDirection => Dir == "rtl" ? "rtl" : CascadedDirection == "rtl" ? "rtl" : "ltr";

    private bool IsSingle => Type == SingleType;

    private IReadOnlyDictionary<string, object> RootAttributes => BuildAttributes(
        ("data-orientation", Orientation),
        ("dir", ResolvedDirection));

    protected override void OnParametersSet()
    {
        Type = Type == MultipleType ? MultipleType : SingleType;
        Orientation = Orientation == HorizontalOrientation ? HorizontalOrientation : VerticalOrientation;

        if (_initialized)
            return;

        _uncontrolledValue = DefaultValue;
        _uncontrolledValues = DefaultValues is not null
            ? DefaultValues.Distinct(StringComparer.Ordinal).ToList()
            : [];

        _initialized = true;
    }

    internal bool IsItemOpen(string value)
    {
        if (IsSingle)
            return string.Equals(Value ?? _uncontrolledValue, value, StringComparison.Ordinal);

        IReadOnlyCollection<string> values = Values ?? _uncontrolledValues;
        return values.Contains(value);
    }

    internal async Task OpenItemAsync(string value)
    {
        if (IsSingle)
        {
            await SetSingleValueAsync(value);
            return;
        }

        List<string> next = Values is not null
            ? Values.Distinct(StringComparer.Ordinal).ToList()
            : [.. _uncontrolledValues];

        if (!next.Contains(value, StringComparer.Ordinal))
        {
            next.Add(value);
            await SetMultipleValuesAsync(next);
        }
    }

    internal async Task CloseItemAsync(string value)
    {
        if (IsSingle)
        {
            if (!IsCollapsible)
                return;

            await SetSingleValueAsync(null);
            return;
        }

        List<string> next = Values is not null
            ? Values.Distinct(StringComparer.Ordinal).ToList()
            : [.. _uncontrolledValues];

        if (next.RemoveAll(item => string.Equals(item, value, StringComparison.Ordinal)) > 0)
            await SetMultipleValuesAsync(next);
    }

    internal void RegisterTrigger(BradixAccordionTrigger trigger)
    {
        if (_triggers.Contains(trigger))
            return;

        _triggers.Add(trigger);
    }

    internal void UnregisterTrigger(BradixAccordionTrigger trigger)
    {
        _triggers.Remove(trigger);
    }

    internal async Task HandleTriggerKeyDownAsync(BradixAccordionTrigger trigger, KeyboardEventArgs args)
    {
        List<BradixAccordionTrigger> enabledTriggers = _triggers
            .Where(item => !item.IsDisabled)
            .ToList();

        if (enabledTriggers.Count == 0)
            return;

        int currentIndex = enabledTriggers.IndexOf(trigger);

        if (currentIndex < 0)
            return;

        int nextIndex = currentIndex;

        switch (args.Key)
        {
            case "Home":
                nextIndex = 0;
                break;
            case "End":
                nextIndex = enabledTriggers.Count - 1;
                break;
            case "ArrowDown" when Orientation == VerticalOrientation:
                nextIndex = (currentIndex + 1) % enabledTriggers.Count;
                break;
            case "ArrowUp" when Orientation == VerticalOrientation:
                nextIndex = (currentIndex - 1 + enabledTriggers.Count) % enabledTriggers.Count;
                break;
            case "ArrowRight" when Orientation == HorizontalOrientation:
                nextIndex = ResolvedDirection == "rtl"
                    ? (currentIndex - 1 + enabledTriggers.Count) % enabledTriggers.Count
                    : (currentIndex + 1) % enabledTriggers.Count;
                break;
            case "ArrowLeft" when Orientation == HorizontalOrientation:
                nextIndex = ResolvedDirection == "rtl"
                    ? (currentIndex + 1) % enabledTriggers.Count
                    : (currentIndex - 1 + enabledTriggers.Count) % enabledTriggers.Count;
                break;
            default:
                return;
        }

        await enabledTriggers[nextIndex].FocusAsync();
    }

    private async Task SetSingleValueAsync(string? value)
    {
        if (string.Equals(Value ?? _uncontrolledValue, value, StringComparison.Ordinal))
            return;

        if (Value is null)
            _uncontrolledValue = value;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(value);

        if (OnValueChange.HasDelegate)
            await OnValueChange.InvokeAsync(value);

        await InvokeAsync(StateHasChanged);
    }

    private async Task SetMultipleValuesAsync(List<string> next)
    {
        IReadOnlyCollection<string> ordered = next.ToArray();

        if (Values is null)
            _uncontrolledValues = [.. next];

        if (ValuesChanged.HasDelegate)
            await ValuesChanged.InvokeAsync(ordered);

        if (OnValuesChange.HasDelegate)
            await OnValuesChange.InvokeAsync(ordered);

        await InvokeAsync(StateHasChanged);
    }
}
