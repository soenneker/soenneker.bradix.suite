@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixAccordionTrigger

@inject IBradixSuiteInterop Interop
<BradixCollapsibleTrigger @ref="_trigger"
                          Id="@Item.TriggerId"
                          Class="@Class"
                          Style="@Style"
                          AriaDisabled="@AriaDisabled"
                          OnClick="@OnClick"
                          OnKeyDown="HandleKeyDown"
                          AdditionalAttributes="TriggerAttributes">
    @ChildContent
</BradixCollapsibleTrigger>

@code {
    private BradixCollapsibleTrigger? _trigger;
    private bool _rovingFocusBridgeReady;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    internal BradixAccordion Accordion { get; set; } = null!;

    [CascadingParameter]
    internal BradixAccordionItem Item { get; set; } = null!;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    internal bool IsDisabled => Item.IsDisabled;

    private string? AriaDisabled => Item.IsOpen && !Accordion.IsCollapsible ? "true" : null;

    private IReadOnlyDictionary<string, object> TriggerAttributes
    {
        get
        {
            var attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : [];

            attributes["data-orientation"] = Accordion.Orientation.Value;
            attributes["data-bradix-roving-group"] = Accordion.GroupId;
            attributes["data-bradix-roving-item"] = string.Empty;
            attributes["data-bradix-roving-orientation"] = Accordion.Orientation.Value;
            attributes["data-bradix-roving-dir"] = Accordion.ResolvedDirection;
            attributes["data-bradix-roving-loop"] = "true";
            attributes["data-bradix-roving-ignore-aria-disabled"] = "true";

            return attributes;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        Accordion.RegisterTrigger(this);

        if (_trigger is not null)
        {
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterRovingFocusNavigationKeys(_trigger.Element, _dotNetReference);
        }
    }

    public void Dispose()
    {
        Accordion.UnregisterTrigger(this);
    }

    public async ValueTask DisposeAsync()
    {
        if (_trigger is not null)
            await Interop.UnregisterRovingFocusNavigationKeys(_trigger.Element);

        _dotNetReference?.Dispose();
    }

    internal ValueTask Focus()
    {
        return _trigger?.Focus() ?? ValueTask.CompletedTask;
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (OnKeyDown.HasDelegate)
            await OnKeyDown.InvokeAsync(args);

        if (IsDisabled)
            return;

        if (_rovingFocusBridgeReady && BradixRovingFocusNavigator.IsNavigationKey(args.Key))
            return;

        await Accordion.HandleTriggerKeyDown(this, args);
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReady()
    {
        return HandleRovingFocusBridgeReady();
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReady()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleDelegatedKeyDown(BradixDelegatedKeyboardEvent args)
    {
        return HandleKeyDown(new KeyboardEventArgs
        {
            Key = args.Key,
            Code = args.Code,
            CtrlKey = args.CtrlKey,
            ShiftKey = args.ShiftKey,
            AltKey = args.AltKey,
            MetaKey = args.MetaKey,
            Repeat = args.Repeat
        });
    }
}
