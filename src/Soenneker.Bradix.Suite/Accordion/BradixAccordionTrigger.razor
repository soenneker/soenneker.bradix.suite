@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixAccordionTrigger

@inject IBradixSuiteInterop Interop
<BradixCollapsibleTrigger @ref="_trigger"
                          Id="@Item.TriggerId"
                          Class="@Class"
                          Style="@Style"
                          AriaDisabled="@AriaDisabled"
                          OnKeyDown="HandleKeyDown"
                          AdditionalAttributes="TriggerAttributes">
    @ChildContent
</BradixCollapsibleTrigger>

@code {
    private BradixCollapsibleTrigger? _trigger;
    private bool _delegatedInteractionReady;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    internal BradixAccordion Accordion { get; set; } = null!;

    [CascadingParameter]
    internal BradixAccordionItem Item { get; set; } = null!;

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    internal bool IsDisabled => Item.IsDisabled;

    private string? AriaDisabled => Item.IsOpen && !Accordion.IsCollapsible ? "true" : null;

    private IReadOnlyDictionary<string, object> TriggerAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : [];

            attributes["data-orientation"] = Accordion.Orientation;

            return attributes;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        Accordion.RegisterTrigger(this);

        if (_trigger is not null)
        {
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterDelegatedInteraction(_trigger.Element, _dotNetReference, new
            {
                readyMethod = nameof(HandleDelegatedInteractionReady),
                keydown = new
                {
                    method = nameof(HandleDelegatedKeyDown),
                    keys = new[] { "Home", "End", "ArrowDown", "ArrowUp", "ArrowLeft", "ArrowRight" },
                    preventDefault = true
                }
            });
        }
    }

    public void Dispose()
    {
        Accordion.UnregisterTrigger(this);
    }

    public async ValueTask DisposeAsync()
    {
        if (_trigger is not null)
            await Interop.UnregisterDelegatedInteraction(_trigger.Element);

        _dotNetReference?.Dispose();
    }

    internal ValueTask Focus()
    {
        return _trigger?.Focus() ?? ValueTask.CompletedTask;
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (OnKeyDown.HasDelegate)
            await OnKeyDown.InvokeAsync(args);

        if (_delegatedInteractionReady)
            return;

        await Accordion.HandleTriggerKeyDown(this, args);
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReady()
    {
        _delegatedInteractionReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleDelegatedKeyDown(BradixDelegatedKeyboardEvent args)
    {
        return Accordion.HandleTriggerKeyDown(this, new KeyboardEventArgs
        {
            Key = args.Key,
            Code = args.Code,
            CtrlKey = args.CtrlKey,
            ShiftKey = args.ShiftKey,
            AltKey = args.AltKey,
            MetaKey = args.MetaKey,
            Repeat = args.Repeat
        });
    }
}
