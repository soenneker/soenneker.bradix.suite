@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixScrollAreaScrollbar

@inject IBradixSuiteInterop Interop

@if (ScrollArea.ShouldRenderScrollbar(Orientation.Value, ForceMount))
{
    <CascadingValue Value="this">
        <div @ref="_scrollbar"
             @onpointerenter="HandlePointerEnter"
             @onpointerleave="HandlePointerLeave"
             @attributes="ScrollbarAttributes">
            @ChildContent
        </div>
    </CascadingValue>
}

@code {
    private ElementReference _scrollbar;
    private ElementReference _thumb;
    private bool _hasThumb;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _registered;

    [CascadingParameter]
    internal BradixScrollArea ScrollArea { get; set; } = null!;

    [Parameter]
    public BradixOrientation Orientation { get; set; } = BradixOrientation.Vertical;

    [Parameter]
    public bool ForceMount { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var orientation = Orientation.Value;
        var shouldRender = ScrollArea.ShouldRenderScrollbar(orientation, ForceMount);

        if (!shouldRender || !ScrollArea.HasViewport)
        {
            ScrollArea.UnregisterScrollbar(orientation);

            if (_registered)
            {
                await Interop.UnregisterScrollAreaScrollbar(_scrollbar);
                _registered = false;
            }

            return;
        }

        ScrollArea.RegisterScrollbar(orientation, ForceMount);

        if (_dotNetReference is null)
            _dotNetReference = DotNetObjectReference.Create<object>(ScrollArea);

        await Interop.RegisterScrollAreaScrollbar(_scrollbar, _thumb, ScrollArea.ViewportElement, orientation, ScrollArea.ResolvedDirection, _dotNetReference);
        _registered = true;
    }

    public async ValueTask DisposeAsync()
    {
        ScrollArea.UnregisterScrollbar(Orientation.Value);

        if (_registered)
            await Interop.UnregisterScrollAreaScrollbar(_scrollbar);

        _dotNetReference?.Dispose();
    }

    internal void RegisterThumb(ElementReference thumb)
    {
        _thumb = thumb;
        if (_hasThumb)
            return;

        _hasThumb = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private Task HandlePointerEnter(PointerEventArgs _)
    {
        return ScrollArea.HandleScrollbarPointerChanged(Orientation.Value, true);
    }

    private Task HandlePointerLeave(PointerEventArgs _)
    {
        return ScrollArea.HandleScrollbarPointerChanged(Orientation.Value, false);
    }

    private Dictionary<string, object> ScrollbarAttributes => BuildAttributes(
        ("data-orientation", Orientation.Value),
        ("data-state", ScrollArea.GetScrollbarState(Orientation.Value)),
        ("style", BuildScrollbarStyle()));

    private string BuildScrollbarStyle()
    {
        var baseStyle = ScrollArea.GetScrollbarStyle(Orientation.Value);

        return MergeStyleValues(baseStyle, Style)!;
    }
}
