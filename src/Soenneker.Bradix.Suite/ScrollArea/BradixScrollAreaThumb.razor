@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixScrollAreaThumb

@if (Scrollbar.ScrollArea.ShouldRenderThumb(Scrollbar.Orientation.Value, ForceMount))
{
    <div @ref="_thumb"
         @attributes="ThumbAttributes"></div>
}

@code {
    private ElementReference _thumb;

    [CascadingParameter]
    internal BradixScrollAreaScrollbar Scrollbar { get; set; } = null!;

    [Parameter]
    public bool ForceMount { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        Scrollbar.RegisterThumb(_thumb);
    }

    private Dictionary<string, object> ThumbAttributes => BuildAttributes(
        ("data-state", Scrollbar.ScrollArea.GetThumbState(Scrollbar.Orientation.Value)),
        ("style", BuildThumbStyle()));

    private string BuildThumbStyle()
    {
        var baseStyle = Scrollbar.ScrollArea.GetThumbStyle(Scrollbar.Orientation.Value);

        return MergeStyleValues(baseStyle, Style)!;
    }
}
