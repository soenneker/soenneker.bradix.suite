@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@using System.Threading

@inherits BradixComponentBase

@implements IBradixScrollArea

@inject IBradixSuiteInterop Interop
<CascadingValue Value="this">
    <div @ref="_element"
         @attributes="RootAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private const int ScrollEndDebounceMs = 100;

    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;
    private CancellationTokenSource? _hoverHideTokenSource;
    private CancellationTokenSource? _scrollEndXTokenSource;
    private CancellationTokenSource? _scrollEndYTokenSource;
    private CancellationTokenSource? _hideXTokenSource;
    private CancellationTokenSource? _hideYTokenSource;
    private bool _registered;

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public BradixScrollAreaType Type { get; set; } = BradixScrollAreaType.Hover;

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public int ScrollHideDelay { get; set; } = 600;

    internal ElementReference ViewportElement { get; private set; }
    internal ElementReference ContentElement { get; private set; }
    internal bool HasViewport { get; private set; }
    internal bool HasContent { get; private set; }

    internal string ResolvedDirection => Dir == "rtl" ? "rtl" : CascadedDirection == "rtl" ? "rtl" : "ltr";

    internal bool IsHovering { get; private set; }
    internal bool IsScrollingX { get; private set; }
    internal bool IsScrollingY { get; private set; }
    internal bool ScrollbarXMounted { get; private set; }
    internal bool ScrollbarYMounted { get; private set; }
    internal bool IsScrollbarInteractingX { get; private set; }
    internal bool IsScrollbarInteractingY { get; private set; }
    internal bool ForceMountThumbX { get; private set; }
    internal bool ForceMountThumbY { get; private set; }

    internal double ScrollLeft { get; private set; }
    internal double ScrollTop { get; private set; }
    internal double ViewportWidth { get; private set; }
    internal double ViewportHeight { get; private set; }
    internal double ContentWidth { get; private set; }
    internal double ContentHeight { get; private set; }
    internal double HorizontalScrollbarWidth { get; private set; }
    internal double HorizontalScrollbarHeight { get; private set; }
    internal double HorizontalScrollbarPaddingStart { get; private set; }
    internal double HorizontalScrollbarPaddingEnd { get; private set; }
    internal double VerticalScrollbarWidth { get; private set; }
    internal double VerticalScrollbarHeight { get; private set; }
    internal double VerticalScrollbarPaddingStart { get; private set; }
    internal double VerticalScrollbarPaddingEnd { get; private set; }

    internal double CornerWidth => VerticalScrollbarWidth;
    internal double CornerHeight => HorizontalScrollbarHeight;

    private Dictionary<string, object> RootAttributes => BuildAttributes(
        ("dir", ResolvedDirection),
        ("style", BuildRootStyle()));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterScrollAreaRoot(_element, _dotNetReference);
        _registered = true;
    }

    public async ValueTask DisposeAsync()
    {
        _hoverHideTokenSource?.Cancel();
        _scrollEndXTokenSource?.Cancel();
        _scrollEndYTokenSource?.Cancel();
        _hideXTokenSource?.Cancel();
        _hideYTokenSource?.Cancel();
        _hoverHideTokenSource?.Dispose();
        _scrollEndXTokenSource?.Dispose();
        _scrollEndYTokenSource?.Dispose();
        _hideXTokenSource?.Dispose();
        _hideYTokenSource?.Dispose();

        if (_registered)
            await Interop.UnregisterScrollAreaRoot(_element);

        _dotNetReference?.Dispose();
    }

    internal void RegisterViewport(ElementReference viewport, ElementReference content)
    {
        ViewportElement = viewport;
        ContentElement = content;
        HasViewport = true;
        HasContent = true;
    }

    internal void RegisterScrollbar(string orientation, bool forceMountThumb)
    {
        if (orientation == "horizontal")
        {
            bool changed = !ScrollbarXMounted || ForceMountThumbX != forceMountThumb;
            ScrollbarXMounted = true;
            ForceMountThumbX = forceMountThumb;
            if (changed)
                _ = InvokeAsync(StateHasChanged);
        }
        else
        {
            bool changed = !ScrollbarYMounted || ForceMountThumbY != forceMountThumb;
            ScrollbarYMounted = true;
            ForceMountThumbY = forceMountThumb;
            if (changed)
                _ = InvokeAsync(StateHasChanged);
        }
    }

    internal void UnregisterScrollbar(string orientation)
    {
        if (orientation == "horizontal")
        {
            bool changed = ScrollbarXMounted || ForceMountThumbX;
            ScrollbarXMounted = false;
            ForceMountThumbX = false;
            if (changed)
                _ = InvokeAsync(StateHasChanged);
        }
        else
        {
            bool changed = ScrollbarYMounted || ForceMountThumbY;
            ScrollbarYMounted = false;
            ForceMountThumbY = false;
            if (changed)
                _ = InvokeAsync(StateHasChanged);
        }
    }

    internal bool IsScrollbarVisible(string orientation)
    {
        bool mounted = orientation == "horizontal" ? ScrollbarXMounted : ScrollbarYMounted;
        bool overflow = orientation == "horizontal" ? HasOverflowX : HasOverflowY;

        if (!mounted)
            return false;

        return Type.Value switch
        {
            BradixScrollAreaType.AlwaysValue => true,
            BradixScrollAreaType.AutoValue => overflow,
            BradixScrollAreaType.HoverValue => overflow && IsHovering,
            BradixScrollAreaType.ScrollValue => overflow && (orientation == "horizontal" ? IsScrollingX : IsScrollingY),
            _ => overflow && IsHovering
        };
    }

    internal bool ShouldRenderScrollbar(string orientation, bool forceMount)
    {
        bool overflow = orientation == "horizontal" ? HasOverflowX : HasOverflowY;

        if (forceMount)
            return true;

        return Type.Value switch
        {
            BradixScrollAreaType.AlwaysValue => true,
            BradixScrollAreaType.AutoValue => overflow,
            BradixScrollAreaType.HoverValue => overflow && IsHovering,
            BradixScrollAreaType.ScrollValue => overflow && (orientation == "horizontal" ? IsScrollingX : IsScrollingY),
            _ => overflow && IsHovering
        };
    }

    internal bool ShouldRenderThumb(string orientation, bool forceMount)
    {
        if (forceMount)
            return true;

        return orientation == "horizontal" ? HasThumbX : HasThumbY;
    }

    internal string GetScrollbarState(string orientation)
    {
        return IsScrollbarVisible(orientation) ? "visible" : "hidden";
    }

    internal string GetThumbState(string orientation)
    {
        return orientation == "horizontal"
            ? (HasThumbX ? "visible" : "hidden")
            : (HasThumbY ? "visible" : "hidden");
    }

    internal string GetScrollbarStyle(string orientation)
    {
        return orientation == "horizontal"
            ? $"position: absolute; bottom: 0; left: {(ResolvedDirection == "rtl" ? "var(--radix-scroll-area-corner-width)" : "0")}; right: {(ResolvedDirection == "ltr" ? "var(--radix-scroll-area-corner-width)" : "0")};"
            : $"position: absolute; top: 0; {(ResolvedDirection == "ltr" ? "right: 0;" : "left: 0;")} bottom: var(--radix-scroll-area-corner-height);";
    }

    internal string GetThumbStyle(string orientation)
    {
        if (orientation == "horizontal")
        {
            double thumbSize = GetThumbSize(true);
            double offset = GetThumbOffset(true);
            return $"width: {thumbSize.ToString(System.Globalization.CultureInfo.InvariantCulture)}px; transform: translate3d({offset.ToString(System.Globalization.CultureInfo.InvariantCulture)}px, 0, 0);";
        }

        double verticalThumbSize = GetThumbSize(false);
        double verticalOffset = GetThumbOffset(false);
        return $"height: {verticalThumbSize.ToString(System.Globalization.CultureInfo.InvariantCulture)}px; transform: translate3d(0, {verticalOffset.ToString(System.Globalization.CultureInfo.InvariantCulture)}px, 0);";
    }

    internal bool ShouldRenderCorner => Type != BradixScrollAreaType.Scroll && ScrollbarXMounted && ScrollbarYMounted && IsScrollbarVisible("horizontal") && IsScrollbarVisible("vertical");

    internal string GetCornerStyle()
    {
        return $"width: {CornerWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)}px; height: {CornerHeight.ToString(System.Globalization.CultureInfo.InvariantCulture)}px; position: absolute; bottom: 0; {(ResolvedDirection == "ltr" ? "right: 0;" : "left: 0;")}";
    }

    [JSInvokable]
    public Task HandleHoverChanged(bool hovering)
    {
        if (hovering)
        {
            _hoverHideTokenSource?.Cancel();
            _hoverHideTokenSource?.Dispose();
            _hoverHideTokenSource = null;
            IsHovering = true;
            return InvokeAsync(StateHasChanged);
        }

        if (Type == BradixScrollAreaType.Hover)
        {
            _hoverHideTokenSource?.Cancel();
            _hoverHideTokenSource?.Dispose();
            _hoverHideTokenSource = new CancellationTokenSource();
            _ = HideHoverAfterDelay(_hoverHideTokenSource.Token);
            return Task.CompletedTask;
        }

        IsHovering = false;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleViewportMetricsChanged(double scrollLeft, double scrollTop, double scrollWidth, double scrollHeight, double viewportWidth, double viewportHeight)
    {
        bool xChanged = !AreClose(ScrollLeft, scrollLeft);
        bool yChanged = !AreClose(ScrollTop, scrollTop);
        bool widthChanged = !AreClose(ContentWidth, scrollWidth);
        bool heightChanged = !AreClose(ContentHeight, scrollHeight);
        bool viewportWidthChanged = !AreClose(ViewportWidth, viewportWidth);
        bool viewportHeightChanged = !AreClose(ViewportHeight, viewportHeight);

        if (!xChanged && !yChanged && !widthChanged && !heightChanged && !viewportWidthChanged && !viewportHeightChanged)
            return Task.CompletedTask;

        ScrollLeft = scrollLeft;
        ScrollTop = scrollTop;
        ContentWidth = scrollWidth;
        ContentHeight = scrollHeight;
        ViewportWidth = viewportWidth;
        ViewportHeight = viewportHeight;

        if (Type == BradixScrollAreaType.Scroll)
        {
            if (xChanged)
                NotifyScrollActivity(true);

            if (yChanged)
                NotifyScrollActivity(false);
        }

        return InvokeAsync(StateHasChanged);
    }

    internal Task HandleScrollbarPointerChanged(string orientation, bool entering)
    {
        bool horizontal = orientation == "horizontal";

        if (horizontal)
        {
            IsScrollbarInteractingX = entering;

            if (entering)
            {
                CancelToken(ref _hideXTokenSource);
                IsScrollingX = true;
            }
            else if (IsScrollingX)
            {
                _ = HideAfterDelay(true, ReplaceHideToken(ref _hideXTokenSource).Token);
            }
        }
        else
        {
            IsScrollbarInteractingY = entering;

            if (entering)
            {
                CancelToken(ref _hideYTokenSource);
                IsScrollingY = true;
            }
            else if (IsScrollingY)
            {
                _ = HideAfterDelay(false, ReplaceHideToken(ref _hideYTokenSource).Token);
            }
        }

        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleScrollbarMetricsChanged(string orientation, double clientWidth, double clientHeight, double paddingStart, double paddingEnd)
    {
        if (orientation == "horizontal")
        {
            if (AreClose(HorizontalScrollbarWidth, clientWidth) &&
                AreClose(HorizontalScrollbarHeight, clientHeight) &&
                AreClose(HorizontalScrollbarPaddingStart, paddingStart) &&
                AreClose(HorizontalScrollbarPaddingEnd, paddingEnd))
            {
                return Task.CompletedTask;
            }

            HorizontalScrollbarWidth = clientWidth;
            HorizontalScrollbarHeight = clientHeight;
            HorizontalScrollbarPaddingStart = paddingStart;
            HorizontalScrollbarPaddingEnd = paddingEnd;
        }
        else
        {
            if (AreClose(VerticalScrollbarWidth, clientWidth) &&
                AreClose(VerticalScrollbarHeight, clientHeight) &&
                AreClose(VerticalScrollbarPaddingStart, paddingStart) &&
                AreClose(VerticalScrollbarPaddingEnd, paddingEnd))
            {
                return Task.CompletedTask;
            }

            VerticalScrollbarWidth = clientWidth;
            VerticalScrollbarHeight = clientHeight;
            VerticalScrollbarPaddingStart = paddingStart;
            VerticalScrollbarPaddingEnd = paddingEnd;
        }

        return InvokeAsync(StateHasChanged);
    }

    private bool HasOverflowX => ViewportWidth > 0 && ContentWidth > ViewportWidth;
    private bool HasOverflowY => ViewportHeight > 0 && ContentHeight > ViewportHeight;
    private bool HasThumbX => GetThumbRatio(true) > 0 && GetThumbRatio(true) < 1;
    private bool HasThumbY => GetThumbRatio(false) > 0 && GetThumbRatio(false) < 1;

    private static bool AreClose(double left, double right)
    {
        return Math.Abs(left - right) < 0.1;
    }

    private string BuildRootStyle()
    {
        string cornerWidth = CornerWidth.ToString(System.Globalization.CultureInfo.InvariantCulture);
        string cornerHeight = CornerHeight.ToString(System.Globalization.CultureInfo.InvariantCulture);
        string scrollAreaStyle = $"position: relative; --radix-scroll-area-corner-width: {cornerWidth}px; --radix-scroll-area-corner-height: {cornerHeight}px;";

        if (string.IsNullOrWhiteSpace(Style))
            return scrollAreaStyle;

        return $"{scrollAreaStyle} {Style}";
    }

    private double GetThumbRatio(bool horizontal)
    {
        double viewport = horizontal ? ViewportWidth : ViewportHeight;
        double content = horizontal ? ContentWidth : ContentHeight;

        if (viewport <= 0 || content <= 0)
            return 0;

        double ratio = viewport / content;
        return double.IsNaN(ratio) ? 0 : ratio;
    }

    private double GetThumbSize(bool horizontal)
    {
        double ratio = GetThumbRatio(horizontal);
        double scrollbarSize = horizontal ? HorizontalScrollbarWidth : VerticalScrollbarHeight;
        double padding = horizontal
            ? HorizontalScrollbarPaddingStart + HorizontalScrollbarPaddingEnd
            : VerticalScrollbarPaddingStart + VerticalScrollbarPaddingEnd;

        double thumbSize = (scrollbarSize - padding) * ratio;
        return Math.Max(thumbSize, 18);
    }

    private double GetThumbOffset(bool horizontal)
    {
        double thumbSize = GetThumbSize(horizontal);
        double viewport = horizontal ? ViewportWidth : ViewportHeight;
        double content = horizontal ? ContentWidth : ContentHeight;
        double maxScrollPos = content - viewport;

        if (maxScrollPos <= 0)
            return 0;

        double scrollbarSize = horizontal ? HorizontalScrollbarWidth : VerticalScrollbarHeight;
        double padding = horizontal
            ? HorizontalScrollbarPaddingStart + HorizontalScrollbarPaddingEnd
            : VerticalScrollbarPaddingStart + VerticalScrollbarPaddingEnd;
        double maxThumbPos = (scrollbarSize - padding) - thumbSize;
        double scrollPos = horizontal ? ScrollLeft : ScrollTop;

        if (horizontal && ResolvedDirection == "rtl")
            scrollPos = Math.Clamp(scrollPos, -maxScrollPos, 0) + maxScrollPos;
        else
            scrollPos = Math.Clamp(scrollPos, 0, maxScrollPos);

        return maxScrollPos == 0 ? 0 : (scrollPos / maxScrollPos) * maxThumbPos;
    }

    private void NotifyScrollActivity(bool horizontal)
    {
        if (horizontal)
        {
            CancelToken(ref _hideXTokenSource);
            IsScrollingX = true;
            _ = CompleteScroll(true, ReplaceHideToken(ref _scrollEndXTokenSource).Token);
        }
        else
        {
            CancelToken(ref _hideYTokenSource);
            IsScrollingY = true;
            _ = CompleteScroll(false, ReplaceHideToken(ref _scrollEndYTokenSource).Token);
        }
    }

    private async Task CompleteScroll(bool horizontal, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(ScrollEndDebounceMs, cancellationToken);

            if (horizontal)
            {
                if (IsScrollbarInteractingX)
                    return;

                _ = HideAfterDelay(true, ReplaceHideToken(ref _hideXTokenSource).Token);
            }
            else
            {
                if (IsScrollbarInteractingY)
                    return;

                _ = HideAfterDelay(false, ReplaceHideToken(ref _hideYTokenSource).Token);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task HideAfterDelay(bool horizontal, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(ScrollHideDelay, cancellationToken);

            if (horizontal)
            {
                if (IsScrollbarInteractingX)
                    return;
                IsScrollingX = false;
            }
            else
            {
                if (IsScrollbarInteractingY)
                    return;
                IsScrollingY = false;
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task HideHoverAfterDelay(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(ScrollHideDelay, cancellationToken);
            IsHovering = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private static CancellationTokenSource ReplaceHideToken(ref CancellationTokenSource? existing)
    {
        existing?.Cancel();
        existing?.Dispose();
        existing = new CancellationTokenSource();
        return existing;
    }

    private static void CancelToken(ref CancellationTokenSource? existing)
    {
        existing?.Cancel();
        existing?.Dispose();
        existing = null;
    }
}
