@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixPopoverContent

@inject IBradixSuiteInterop Interop

@if (ShouldRenderContainer)
{
    @if (Popover?.Modal == true)
    {
        <BradixRemoveScroll AllowPinchZoom>
            @RenderContentTree()
        </BradixRemoveScroll>
    }
    else
    {
        @RenderContentTree()
    }
}

@code {
    private bool _wasPresent;
    private bool _isExiting;
    private bool _hasInteractedOutside;
    private bool _hasPointerDownOutside;
    private bool _hideOthersRegistered;
    private bool _isRightClickOutside;
    private ElementReference _contentElement;

    [CascadingParameter]
    private BradixPopover? Popover { get; set; }

    [CascadingParameter(Name = "BradixPopoverPortalForceMount")]
    private bool PortalForceMount { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public BradixSide Side { get; set; } = BradixSide.Bottom;

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public BradixAlignment Align { get; set; } = BradixAlignment.Center;

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnOpenAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnCloseAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnCloseAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback<BradixPointerDownOutsideEventArgs> OnPointerDownOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback<BradixFocusOutsideEventArgs> OnFocusOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnInteractOutside { get; set; }

    [Parameter]
    public EventCallback<BradixInteractOutsideEventArgs> OnInteractOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnPlaced { get; set; }

    [Parameter]
    public bool CloseOnEscapeKeyDown { get; set; } = true;

    [Parameter]
    public bool CloseOnPointerDownOutside { get; set; } = true;

    [Parameter]
    public bool CloseOnFocusOutside { get; set; } = true;

    private bool IsPresent => ForceMount || PortalForceMount || Popover?.CurrentOpen == true;

    private bool ShouldRenderContainer => IsPresent || _isExiting;

    private bool ShouldTrapFocus => Popover?.Modal == true && Popover.CurrentOpen;

    private bool ShouldDisableOutsidePointerEvents => Popover?.Modal == true && Popover.CurrentOpen;

    private string? ResolvedContentId => string.IsNullOrWhiteSpace(Id) ? Popover?.ContentId : Id;

    private string PositionerStyle =>
        "--radix-popover-content-transform-origin: var(--radix-popper-transform-origin); --radix-popover-content-available-width: var(--radix-popper-available-width); --radix-popover-content-available-height: var(--radix-popper-available-height); --radix-popover-trigger-width: var(--radix-popper-anchor-width); --radix-popover-trigger-height: var(--radix-popper-anchor-height);";

    private string? PresenceStyle
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Style))
                return null;

            return Style;
        }
    }

    private IReadOnlyDictionary<string, object> PresenceAttributes
    {
        get
        {
            var attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            var hasExplicitRole = attributes.ContainsKey("role");

            if (!hasExplicitRole)
                attributes["role"] = "dialog";

            var resolvedRole = attributes["role"]?.ToString() ?? "dialog";

            if (!attributes.ContainsKey("aria-modal") && string.Equals(resolvedRole, "dialog", StringComparison.Ordinal))
                attributes["aria-modal"] = Popover?.Modal == true ? "true" : "false";

            attributes["data-state"] = Popover?.CurrentOpen == true ? "open" : "closed";

            return attributes;
        }
    }

    protected override void OnParametersSet()
    {
        var present = IsPresent;

        if (_wasPresent && !present)
            _isExiting = true;
        else if (present)
            _isExiting = false;

        _wasPresent = present;
    }
    public async ValueTask DisposeAsync()
    {
        if (_hideOthersRegistered)
        {
            await Interop.UnregisterHideOthers(_contentElement);
            _hideOthersRegistered = false;
        }
    }

    private async Task HandleOpenAutoFocus(BradixAutoFocusEventArgs args)
    {
        if (OnOpenAutoFocus.HasDelegate)
            await OnOpenAutoFocus.InvokeAsync();

        if (OnOpenAutoFocusDetailed.HasDelegate)
            await OnOpenAutoFocusDetailed.InvokeAsync(args);
    }

    private async Task HandleCloseAutoFocus(BradixAutoFocusEventArgs args)
    {
        if (OnCloseAutoFocus.HasDelegate)
            await OnCloseAutoFocus.InvokeAsync();

        if (OnCloseAutoFocusDetailed.HasDelegate)
            await OnCloseAutoFocusDetailed.InvokeAsync(args);

        if (Popover?.Modal == true)
        {
            if (args.DefaultPrevented)
                goto ResetState;

            args.PreventDefault();

            if (!_isRightClickOutside)
                await Popover.FocusTrigger();
        }
        else if (!args.DefaultPrevented)
        {
            if (Popover is not null && !_hasInteractedOutside)
                await Popover.FocusTrigger();

            args.PreventDefault();
        }

ResetState:
        _hasInteractedOutside = false;
        _hasPointerDownOutside = false;
        _isRightClickOutside = false;
    }

    private async Task HandleEscapeKeyDown(BradixEscapeKeyDownEventArgs args)
    {
        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        if (OnEscapeKeyDownDetailed.HasDelegate)
            await OnEscapeKeyDownDetailed.InvokeAsync(args);
    }

    private async Task HandlePointerDownOutside(BradixPointerDownOutsideEventArgs args)
    {
        if (OnPointerDownOutside.HasDelegate)
            await OnPointerDownOutside.InvokeAsync();

        if (OnPointerDownOutsideDetailed.HasDelegate)
            await OnPointerDownOutsideDetailed.InvokeAsync(args);

        var ctrlLeftClick = args.OriginalEvent.Button == 0 && args.OriginalEvent.CtrlKey;
        _isRightClickOutside = args.OriginalEvent.Button == 2 || ctrlLeftClick;

        if (_isRightClickOutside)
            args.PreventDefault();
    }

    private async Task HandleFocusOutside(BradixFocusOutsideEventArgs args)
    {
        if (OnFocusOutside.HasDelegate)
            await OnFocusOutside.InvokeAsync();

        if (OnFocusOutsideDetailed.HasDelegate)
            await OnFocusOutsideDetailed.InvokeAsync(args);

        if (Popover?.Modal == true)
        {
            args.PreventDefault();
            return;
        }
    }

    private async Task HandleInteractOutside(BradixInteractOutsideEventArgs args)
    {
        if (OnInteractOutside.HasDelegate)
            await OnInteractOutside.InvokeAsync();

        if (OnInteractOutsideDetailed.HasDelegate)
            await OnInteractOutsideDetailed.InvokeAsync(args);

        if (Popover?.Modal == true)
            return;

        if (IsTriggerInteraction(args))
            args.PreventDefault();

        if (!args.DefaultPrevented)
        {
            _hasInteractedOutside = true;

            if (args.OriginalEventType == "pointerdown")
                _hasPointerDownOutside = true;
        }

        if (args.OriginalEventType == "focusin" && _hasPointerDownOutside)
            args.PreventDefault();
    }

    private bool IsTriggerInteraction(BradixInteractOutsideEventArgs args)
    {
        if (Popover is null || !Popover.HasTrigger)
            return false;

        return args.OriginalEventType switch
        {
            "pointerdown" => Popover.ContainsTriggerTarget(args.PointerDownOutsideEvent?.TargetId, args.PointerDownOutsideEvent?.AncestorIds),
            "focusin" => Popover.ContainsTriggerTarget(args.FocusOutsideEvent?.TargetId, args.FocusOutsideEvent?.AncestorIds),
            _ => false
        };
    }

    private Task HandleDismiss()
    {
        return Popover?.SetOpen(false) ?? Task.CompletedTask;
    }

    private Task HandleExitComplete()
    {
        _isExiting = false;
        return CleanupAfterExit();
    }

    private RenderFragment RenderContentTree() => @<BradixFocusGuards>
        <BradixFocusScope Loop
                          Trapped="ShouldTrapFocus"
                          PreventUnmountAutoFocus="true"
                          OnMountAutoFocusDetailed="HandleOpenAutoFocus"
                          OnUnmountAutoFocusDetailed="HandleCloseAutoFocus">
            <BradixDismissableLayer DisableOutsidePointerEvents="ShouldDisableOutsidePointerEvents"
                                    DismissOnEscapeKeyDown="CloseOnEscapeKeyDown"
                                    DismissOnPointerDownOutside="CloseOnPointerDownOutside"
                                    DismissOnFocusOutside="CloseOnFocusOutside"
                                    OnDismiss="@HandleDismiss"
                                    OnInteractOutsideDetailed="@HandleInteractOutside"
                                    OnEscapeKeyDownDetailed="@HandleEscapeKeyDown"
                                    OnPointerDownOutsideDetailed="@HandlePointerDownOutside"
                                    OnFocusOutsideDetailed="@HandleFocusOutside"
                                    OnElementReferenceCaptured="@HandleElementReferenceCaptured">
                <BradixPopperContent Side="@Side"
                                     SideOffset="SideOffset"
                                     Align="@Align"
                                     AlignOffset="AlignOffset"
                                     ArrowPadding="ArrowPadding"
                                     AvoidCollisions="AvoidCollisions"
                                     CollisionPadding="CollisionPadding"
                                     HideWhenDetached="HideWhenDetached"
                                     Anchor="@ResolvedAnchor"
                                     UseAnchor="@ShouldUseAnchor"
                                     Style="@PositionerStyle"
                                     OnPlaced="@OnPlaced">
                    <BradixPresence Present="IsPresent"
                                    Tag="div"
                                    Id="@ResolvedContentId"
                                    Class="@Class"
                                    Style="@PresenceStyle"
                                    AdditionalAttributes="@PresenceAttributes"
                                    OnExitComplete="@HandleExitComplete">
                        @ChildContent
                    </BradixPresence>
                </BradixPopperContent>
            </BradixDismissableLayer>
        </BradixFocusScope>
    </BradixFocusGuards>;

    private async Task HandleElementReferenceCaptured(ElementReference element)
    {
        _contentElement = element;

        if (Popover?.Modal == true && !_hideOthersRegistered)
        {
            await Interop.RegisterHideOthers(_contentElement);
            _hideOthersRegistered = true;
        }
    }

    private async Task CleanupAfterExit()
    {
        _isExiting = false;

        if (_hideOthersRegistered)
        {
            await Interop.UnregisterHideOthers(_contentElement);
            _hideOthersRegistered = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private ElementReference ResolvedAnchor =>
        Popover is null
            ? default
            : Popover.HasTrigger
                ? Popover.TriggerElement
                : Popover.AnchorElement;

    private bool ShouldUseAnchor => Popover?.HasTrigger == true || Popover?.HasAnchor == true;
}
