@using Soenneker.Bradix.Suite.Base
@implements IAsyncDisposable
@inherits BradixComponentBase

<BradixDismissableLayerBranch>
    <BradixPopperAnchor>
        @ChildContent
    </BradixPopperAnchor>
</BradixDismissableLayerBranch>

@code {
    [CascadingParameter]
    private BradixPopover? Popover { get; set; }

    protected override void OnInitialized()
    {
        Popover?.AddCustomAnchor();
    }

    public ValueTask DisposeAsync()
    {
        Popover?.RemoveCustomAnchor();
        return ValueTask.CompletedTask;
    }
}
