@namespace Soenneker.Bradix

@implements IBradixPopoverPortal
<CascadingValue Name="BradixPopoverPortalForceMount" Value="ForceMount">
    <BradixPortal ContainerSelector="@ContainerSelector"
                  Container="@Container">
        <BradixDismissableLayerBranch>
            @ChildContent
        </BradixDismissableLayerBranch>
    </BradixPortal>
</CascadingValue>

@code {
    [Parameter]
    public string? ContainerSelector { get; set; }

    [Parameter]
    public ElementReference Container { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
