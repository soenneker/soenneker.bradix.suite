@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

<BradixDismissableLayerBranch>
    @if (Popover?.HasCustomAnchor == true)
    {
        <button @ref="_button"
                @onclick="HandleClickAsync"
                @attributes="ButtonAttributes">
            @ChildContent
        </button>
    }
    else
    {
        <BradixPopperAnchor>
            <button @ref="_button"
                    @onclick="HandleClickAsync"
                    @attributes="ButtonAttributes">
                @ChildContent
            </button>
        </BradixPopperAnchor>
    }
</BradixDismissableLayerBranch>

@code {
    private ElementReference _button;
    private bool _delegatedInteractionReady;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixPopover? Popover { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private string ResolvedTriggerId => string.IsNullOrWhiteSpace(Id) ? Popover?.DefaultTriggerId ?? string.Empty : Id;

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("type", "button"),
        ("id", ResolvedTriggerId),
        ("aria-haspopup", "dialog"),
        ("aria-expanded", Popover?.CurrentOpen == true ? "true" : "false"),
        ("aria-controls", Popover?.ContentId),
        ("data-state", Popover?.CurrentOpen == true ? "open" : "closed"),
        ("data-disabled", Disabled ? string.Empty : null),
        ("disabled", Disabled ? true : null));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Popover?.RegisterTrigger(_button, ResolvedTriggerId);
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterDelegatedInteraction(_button, _dotNetReference, new
            {
                click = new
                {
                    method = nameof(HandleDelegatedClickAsync)
                }
            });
        }

        return;
    }

    private Task HandleClickAsync()
    {
        return Disabled || Popover is null || _delegatedInteractionReady
            ? Task.CompletedTask
            : Popover.ToggleOpenAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterDelegatedInteraction(_button);
        _dotNetReference?.Dispose();
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReadyAsync()
    {
        _delegatedInteractionReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleDelegatedClickAsync(BradixDelegatedMouseEvent _)
    {
        return Disabled || Popover is null ? Task.CompletedTask : Popover.ToggleOpenAsync();
    }
}
