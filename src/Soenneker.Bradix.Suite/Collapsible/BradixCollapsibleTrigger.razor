@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponentBase

@implements IBradixCollapsibleTrigger

@inject IBradixSuiteInterop Interop
<button @ref="_element"
        @onclick="HandleClick"
        @onkeydown="HandleKeyDown"
        @attributes="TriggerAttributes">
    @ChildContent
</button>

@code {
    private bool _delegatedInteractionReady;
    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    internal BradixCollapsible Collapsible { get; set; } = null!;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    [Parameter]
    public string? AriaDisabled { get; set; }

    internal ElementReference Element => _element;

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("type", "button"),
        ("aria-controls", Collapsible.ContentId),
        ("aria-expanded", Collapsible.IsOpen ? "true" : "false"),
        ("aria-disabled", AriaDisabled),
        ("data-state", DataState(Collapsible.IsOpen)),
        ("data-disabled", Collapsible.Disabled ? string.Empty : null),
        ("disabled", Collapsible.Disabled ? true : null));

    internal ValueTask Focus()
    {
        return _element.FocusAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterDelegatedInteraction(_element, _dotNetReference, new
        {
            readyMethod = nameof(HandleDelegatedInteractionReady),
            click = new
            {
                method = nameof(HandleDelegatedClick),
                currentTargetOnly = false
            }
        });
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterDelegatedInteraction(_element);
        _dotNetReference?.Dispose();
    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);

        if (_delegatedInteractionReady)
            return;

        await Collapsible.Toggle();
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (OnKeyDown.HasDelegate)
            await OnKeyDown.InvokeAsync(args);
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReady()
    {
        _delegatedInteractionReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleDelegatedClick(BradixDelegatedMouseEvent _)
    {
        return Collapsible.Toggle();
    }
}
