@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixCollapsibleContent

@inject IBradixSuiteInterop Interop
<BradixPresence Present="Present"
                Tag="div"
                AdditionalAttributes="@ContentAttributes"
                OnElementReferenceCaptured="@HandleElementCaptured"
                OnExitComplete="@HandleExitComplete">
    @if (ShouldRenderChildren)
    {
        @ChildContent
    }
</BradixPresence>

@code {
    private ElementReference _element;
    private bool _hasElement;
    private bool _isPresent;
    private bool _observing;

    [CascadingParameter]
    internal BradixCollapsible Collapsible { get; set; } = null!;

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public string? Role { get; set; }

    [Parameter]
    public string? AriaLabelledBy { get; set; }

    [Parameter]
    public string? AriaDescribedBy { get; set; }

    private bool Present => ForceMount || Collapsible.IsOpen;

    private bool IsOpenOrPresent => Present || _isPresent;

    private bool ShouldRenderChildren => IsOpenOrPresent;

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            var attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["id"] = Collapsible.ContentId!;
            attributes["hidden"] = !IsOpenOrPresent;
            attributes["data-state"] = OpenDataState(Collapsible.IsOpen);

            if (Collapsible.Disabled)
                attributes["data-disabled"] = string.Empty;

            if (!string.IsNullOrWhiteSpace(Role))
                attributes["role"] = Role;

            if (!string.IsNullOrWhiteSpace(AriaLabelledBy))
                attributes["aria-labelledby"] = AriaLabelledBy;

            if (!string.IsNullOrWhiteSpace(AriaDescribedBy))
                attributes["aria-describedby"] = AriaDescribedBy;

            if (!string.IsNullOrWhiteSpace(Class))
                attributes["class"] = Class;

            var mergedStyle = BuildMergedStyle(attributes.TryGetValue("style", out var existingStyle) ? existingStyle?.ToString() : null);

            if (!string.IsNullOrWhiteSpace(mergedStyle))
                attributes["style"] = mergedStyle;

            return attributes;
        }
    }

    protected override void OnParametersSet()
    {
        if (Present)
            _isPresent = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await EnsureObservation();
    }

    public async ValueTask DisposeAsync()
    {
        if (_observing)
            await Interop.UnobserveCollapsibleContent(_element);
    }

    private async Task HandleElementCaptured(ElementReference element)
    {
        _element = element;
        _hasElement = true;
        _observing = false;
        await EnsureObservation();
    }

    private async Task HandleExitComplete()
    {
        if (_observing)
        {
            await Interop.UnobserveCollapsibleContent(_element);
            _observing = false;
        }

        _isPresent = false;
        _hasElement = false;
        await InvokeAsync(StateHasChanged);
    }

    private string? BuildMergedStyle(string? additionalStyle)
    {
        return MergeStyleValues(additionalStyle, Style);
    }

    private async Task EnsureObservation()
    {
        if (!_hasElement || _observing)
            return;

        await Interop.ObserveCollapsibleContent(_element);
        _observing = true;
    }
}
