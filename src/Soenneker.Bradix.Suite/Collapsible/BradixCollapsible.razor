@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixCollapsible

@inject IBradixIdGenerator IdGenerator
<CascadingValue Value="this">
    <div @attributes="RootAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private bool _initialized;
    private bool _uncontrolledOpen;
    private string? _generatedBaseId;

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    public string BaseId => Id.HasContent() ? Id! : _generatedBaseId ??= IdGenerator.New("bradix-collapsible");

    public string TriggerId => $"{BaseId}-trigger";

    public string ContentId => $"{BaseId}-content";

    public bool IsOpen => Open ?? _uncontrolledOpen;

    private Dictionary<string, object> RootAttributes => BuildAttributes(
        ("data-state", DataState(IsOpen)),
        ("data-disabled", Disabled ? string.Empty : null));

    protected override void OnInitialized()
    {
        _ = BaseId;
    }

    protected override void OnParametersSet()
    {
        if (_initialized)
            return;

        _uncontrolledOpen = DefaultOpen;
        _initialized = true;
    }

    public Task Toggle()
    {
        return SetOpen(!IsOpen);
    }

    public async Task SetOpen(bool open)
    {
        if (Disabled || open == IsOpen)
            return;

        if (Open is null)
            _uncontrolledOpen = open;

        if (OpenChanged.HasDelegate)
            await OpenChanged.InvokeAsync(open);

        if (OnOpenChange.HasDelegate)
            await OnOpenChange.InvokeAsync(open);

        await InvokeAsync(StateHasChanged);
    }
}
