@namespace Soenneker.Bradix

@using System.Threading
@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixLabel

@inject IBradixSuiteInterop Interop
<label @ref="_element"
       @attributes="LabelAttributes" >
    @ChildContent
</label>

@code {
    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;
    private readonly SemaphoreSlim _interopLock = new(1, 1);
    private bool _registered;
    private bool _disposed;

    [Parameter]
    public string? For { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnMouseDown { get; set; }

    private Dictionary<string, object> LabelAttributes => BuildAttributes(("for", For));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _disposed)
            return;

        await _interopLock.WaitAsync();

        try
        {
            if (_disposed)
                return;

            _dotNetReference ??= DotNetObjectReference.Create<object>(this);
            await Interop.RegisterLabelTextSelectionGuard(_element, _dotNetReference);
            _registered = true;
        }
        finally
        {
            _interopLock.Release();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed)
            return;

        _disposed = true;
        await _interopLock.WaitAsync();

        try
        {
            if (_registered)
                await Interop.UnregisterLabelTextSelectionGuard(_element);

            _registered = false;

            if (_dotNetReference is not null)
                _ = DisposeReferenceLater(_dotNetReference);

            _dotNetReference = null;
        }
        catch (JSDisconnectedException)
        {
        }
        finally
        {
            _interopLock.Release();
        }
    }

    [JSInvokable]
    public Task HandleMouseDownFromJs(BradixDelegatedMouseEvent args)
    {
        if (_disposed)
            return Task.CompletedTask;

        return OnMouseDown.HasDelegate
            ? OnMouseDown.InvokeAsync(new MouseEventArgs
            {
                Detail = args.Detail,
                Button = args.Button,
                CtrlKey = args.CtrlKey,
                ShiftKey = args.ShiftKey,
                AltKey = args.AltKey,
                MetaKey = args.MetaKey
            })
            : Task.CompletedTask;
    }

    private static async Task DisposeReferenceLater(DotNetObjectReference<object> dotNetReference)
    {
        await Task.Delay(5000);
        dotNetReference.Dispose();
    }
}
