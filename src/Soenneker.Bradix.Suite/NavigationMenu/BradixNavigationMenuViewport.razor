@namespace Soenneker.Bradix

@using System.Globalization
@using Microsoft.JSInterop

@inherits BradixComponentBase

@implements IBradixNavigationMenuViewport

@inject IBradixSuiteInterop Interop

@if (ShouldRenderViewport)
{
    <BradixPresence Present="ForceMount || NavigationMenu?.HasOpenItem == true"
                    Tag="div"
                    Class="@Class"
                    Style="@ComputedStyle"
                    AdditionalAttributes="@ViewportAttributes"
                    OnElementReferenceCaptured="@HandleViewportCaptured">
        @if (Registrations.Count > 0)
        {
            @foreach (BradixNavigationMenuViewportRegistration registration in Registrations)
            {
                bool isActive = string.Equals(ActiveViewportValue, registration.Value, StringComparison.Ordinal);

                <BradixNavigationMenuViewportContentHost Registration="@registration"
                                                        Present="@(registration.ForceMount || isActive)"
                                                        IsOpen="@(NavigationMenu?.HasOpenItem == true && string.Equals(NavigationMenu.CurrentValue, registration.Value, StringComparison.Ordinal))"
                                                        Motion="@ResolveMotion(registration.Value)"
                                                        OnContentElementCaptured="@CreateContentCapturedCallback(registration.Value)"
                                                        OnPointerEnterContent="@HandleContentEnter"
                                                        OnPointerLeaveContent="@HandleContentLeave" />
            }
        }
    </BradixPresence>
}

@code {
    private ElementReference _viewportElement;
    private ElementReference _contentElement;
    private bool _hasViewportElement;
    private bool _hasContentElement;
    private bool _registered;
    private bool _viewportRegisteredWithRoot;
    private DotNetObjectReference<object>? _dotNetReference;
    private double? _width;
    private double? _height;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    private string ActiveViewportValue => NavigationMenu?.ActiveViewportValue ?? string.Empty;

    private IReadOnlyList<BradixNavigationMenuViewportRegistration> Registrations =>
        NavigationMenu?.GetViewportContents() ?? [];

    private bool ShouldRenderViewport => ForceMount || NavigationMenu?.HasOpenItem == true || Registrations.Count > 0;

    private string ResolvedViewportId =>
        string.IsNullOrWhiteSpace(Id)
            ? $"{NavigationMenu?.BaseId}-viewport"
            : Id;

    private IReadOnlyDictionary<string, object> ViewportAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["id"] = ResolvedViewportId;
            attributes["data-state"] = NavigationMenu?.HasOpenItem == true ? "open" : "closed";
            attributes["data-orientation"] = NavigationMenu?.Orientation?.Value ?? BradixOrientation.Horizontal.Value;
            return attributes;
        }
    }

    private string ComputedStyle
    {
        get
        {
            string viewportStyle = string.Empty;

            if (_width.HasValue)
                viewportStyle += $"--radix-navigation-menu-viewport-width:{_width.Value.ToString(CultureInfo.InvariantCulture)}px;";

            if (_height.HasValue)
                viewportStyle += $"--radix-navigation-menu-viewport-height:{_height.Value.ToString(CultureInfo.InvariantCulture)}px;";

            if (NavigationMenu?.HasOpenItem != true)
                viewportStyle += "pointer-events:none;";

            if (string.IsNullOrWhiteSpace(Style))
                return viewportStyle;

            return $"{viewportStyle} {Style}";
        }
    }

    protected override void OnParametersSet()
    {
        if (!_viewportRegisteredWithRoot && NavigationMenu is not null)
        {
            NavigationMenu.RegisterViewport(ResolvedViewportId);
            _viewportRegisteredWithRoot = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_hasViewportElement || !_hasContentElement)
        {
            if (_registered)
            {
                await Interop.UnregisterNavigationMenuViewport(_viewportElement);
                _registered = false;
            }

            return;
        }

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);

        if (_registered)
        {
            await Interop.UpdateNavigationMenuViewport(_viewportElement, _contentElement);
        }
        else
        {
            await Interop.RegisterNavigationMenuViewport(_viewportElement, _contentElement, _dotNetReference);
            _registered = true;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_viewportRegisteredWithRoot)
            NavigationMenu?.UnregisterViewport(ResolvedViewportId);

        if (_registered)
            await Interop.UnregisterNavigationMenuViewport(_viewportElement);

        _dotNetReference?.Dispose();
    }

    private Task HandleViewportCaptured(ElementReference element)
    {
        _viewportElement = element;
        _hasViewportElement = true;
        return Task.CompletedTask;
    }

    private Task HandleContentCaptured(string value, ElementReference element)
    {
        if (string.Equals(value, ActiveViewportValue, StringComparison.Ordinal))
        {
            _contentElement = element;
            _hasContentElement = true;
        }

        return Task.CompletedTask;
    }

    private EventCallback<ElementReference> CreateContentCapturedCallback(string value)
    {
        return EventCallback.Factory.Create<ElementReference>(this, element => HandleContentCaptured(value, element));
    }

    private Task HandleContentEnter()
    {
        return NavigationMenu?.HandleContentPointerEnter() ?? Task.CompletedTask;
    }

    private Task HandleContentLeave()
    {
        return NavigationMenu?.HandleContentPointerLeave() ?? Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleViewportSizeChanged(double width, double height)
    {
        if (Math.Abs((_width ?? -1) - width) < 0.1 &&
            Math.Abs((_height ?? -1) - height) < 0.1)
        {
            return Task.CompletedTask;
        }

        _width = width;
        _height = height;
        return InvokeAsync(StateHasChanged);
    }

    private string ResolveMotion(string value)
    {
        if (NavigationMenu is null || string.IsNullOrWhiteSpace(NavigationMenu.PreviousValue))
            return string.Empty;

        List<string> values = NavigationMenu.GetOrderedTriggerValues();
        int index = values.IndexOf(NavigationMenu.CurrentValue);
        int previousIndex = values.IndexOf(NavigationMenu.PreviousValue);
        int activeIndex = values.IndexOf(value);

        bool isSelected = value == NavigationMenu.CurrentValue;
        bool wasSelected = activeIndex == previousIndex;

        if (!isSelected && !wasSelected)
            return string.Empty;

        if (index != previousIndex)
        {
            if (isSelected && previousIndex != -1)
                return index > previousIndex ? "from-end" : "from-start";

            if (wasSelected && index != -1)
                return index > previousIndex ? "to-start" : "to-end";
        }

        return string.Empty;
    }
}
