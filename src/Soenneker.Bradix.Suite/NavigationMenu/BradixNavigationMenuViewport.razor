@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixNavigationMenuViewport

@using Soenneker.Blazor.Utils.Ids
@using Microsoft.JSInterop

@inject IBradixSuiteInterop Interop

@if (NavigationMenu?.IsRootMenu == true)
{
    <div @ref="_viewportElement"
         class="@Class"
         style="@ComputedStyle"
         @attributes="ViewportAttributes">
    </div>
}

@code {
    private ElementReference _viewportElement;
    private bool _viewportRegisteredWithRoot;
    private DotNetObjectReference<BradixNavigationMenuViewport>? _dotNetReference;
    private string? _observedContentValue;
    private string? _pendingContentRetryValue;
    private double _width;
    private double _height;
    private bool _disposed;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    private string ResolvedViewportId =>
        string.IsNullOrWhiteSpace(Id)
            ? BlazorIdGenerator.Child(NavigationMenu!.BaseId!, "viewport")
            : Id;

    private IReadOnlyDictionary<string, object> ViewportAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["id"] = ResolvedViewportId;
            attributes["data-state"] = NavigationMenu?.HasOpenItem == true ? "open" : "closed";
            attributes["data-orientation"] = NavigationMenu?.Orientation?.Value ?? BradixOrientation.Horizontal.Value;
            return attributes;
        }
    }

    private string? ComputedStyle
    {
        get
        {
            string sizeStyle = string.Empty;

            if (_width > 0 || _height > 0)
            {
                string width = _width > 0 ? $"{_width.ToString(System.Globalization.CultureInfo.InvariantCulture)}px" : "0px";
                string height = _height > 0 ? $"{_height.ToString(System.Globalization.CultureInfo.InvariantCulture)}px" : "0px";
                sizeStyle = $"--radix-navigation-menu-viewport-width:{width};--radix-navigation-menu-viewport-height:{height};";
            }

            string viewportStyle = NavigationMenu?.HasOpenItem == true
                ? string.Empty
                : "pointer-events:none;";

            return MergeStyleValues(MergeStyleValues(sizeStyle, viewportStyle), Style);
        }
    }

    protected override void OnParametersSet()
    {
        if (!_viewportRegisteredWithRoot && NavigationMenu is not null)
        {
            NavigationMenu.RegisterViewport(ResolvedViewportId);
            _viewportRegisteredWithRoot = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed || NavigationMenu is null)
            return;

        string? contentValue = NavigationMenu.HasOpenItem ? NavigationMenu.CurrentValue : null;

        if (string.IsNullOrWhiteSpace(contentValue) || !NavigationMenu.TryGetContent(contentValue, out ElementReference content))
        {
            if (!string.IsNullOrWhiteSpace(contentValue) &&
                !string.Equals(_pendingContentRetryValue, contentValue, StringComparison.Ordinal))
            {
                _pendingContentRetryValue = contentValue;
                await Task.Yield();

                if (!_disposed &&
                    string.Equals(_pendingContentRetryValue, contentValue, StringComparison.Ordinal))
                {
                    await InvokeAsync(StateHasChanged);
                }
            }

            if (!string.IsNullOrWhiteSpace(_observedContentValue))
            {
                try
                {
                    await Interop.UnregisterNavigationMenuViewport(_viewportElement);
                }
                catch (Exception ex) when (ShouldIgnoreInteropException(ex))
                {
                }

                _observedContentValue = null;
            }

            return;
        }

        _pendingContentRetryValue = null;
        _dotNetReference ??= DotNetObjectReference.Create(this);

        try
        {
            if (string.Equals(_observedContentValue, contentValue, StringComparison.Ordinal))
            {
                await Interop.UpdateNavigationMenuViewport(_viewportElement, content);
            }
            else
            {
                await Interop.RegisterNavigationMenuViewport(_viewportElement, content, _dotNetReference);
                _observedContentValue = contentValue;
            }
        }
        catch (Exception ex) when (ShouldIgnoreInteropException(ex))
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;

        if (!string.IsNullOrWhiteSpace(_observedContentValue))
        {
            try
            {
                await Interop.UnregisterNavigationMenuViewport(_viewportElement);
            }
            catch (Exception ex) when (ShouldIgnoreInteropException(ex))
            {
            }
        }

        _dotNetReference?.Dispose();
        _dotNetReference = null;

        if (_viewportRegisteredWithRoot)
            NavigationMenu?.UnregisterViewport(ResolvedViewportId);
    }

    [JSInvokable]
    public Task HandleViewportSizeChanged(double width, double height)
    {
        if (_disposed)
            return Task.CompletedTask;

        if (Math.Abs(_width - width) < 0.1 &&
            Math.Abs(_height - height) < 0.1)
        {
            return Task.CompletedTask;
        }

        _width = width;
        _height = height;
        return InvokeAsync(StateHasChanged);
    }

    private static bool ShouldIgnoreInteropException(Exception ex)
    {
        return ex is ObjectDisposedException or JSDisconnectedException;
    }
}
