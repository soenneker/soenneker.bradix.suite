@namespace Soenneker.Bradix

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

<BradixPresence Present="@Present"
                Tag="div">
    <BradixDismissableLayer DisableOutsidePointerEvents="false"
                            DismissOnEscapeKeyDown="false"
                            DismissOnPointerDownOutside="false"
                            DismissOnFocusOutside="false"
                            OnEscapeKeyDownDetailed="@HandleEscapeKeyDownAsync"
                            OnPointerDownOutsideDetailed="@HandlePointerDownOutsideAsync"
                            OnFocusOutsideDetailed="@HandleFocusOutsideAsync">
        <div @ref="_contentElement"
             tabindex="-1"
             @attributes="ContentAttributes">
            <CascadingValue Name="BradixNavigationMenuFocusGroupId" Value="@Registration.Value">
                @Registration.ChildContent
            </CascadingValue>
        </div>
        <span @ref="_exitProxyElement"
              aria-hidden="true"
              tabindex="0"
              style="position:absolute;opacity:0;pointer-events:none;width:1px;height:1px;overflow:hidden;" />
    </BradixDismissableLayer>
</BradixPresence>

@code {
    private ElementReference _contentElement;
    private ElementReference _exitProxyElement;
    private bool _contentCaptured;
    private bool _focusBridgeRegistered;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [Parameter]
    public required BradixNavigationMenuViewportRegistration Registration { get; set; }

    [Parameter]
    public bool Present { get; set; }

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string Motion { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<ElementReference> OnContentElementCaptured { get; set; }

    [Parameter]
    public EventCallback OnPointerEnterContent { get; set; }

    [Parameter]
    public EventCallback OnPointerLeaveContent { get; set; }

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = Registration.AdditionalAttributes is not null
                ? new Dictionary<string, object>(Registration.AdditionalAttributes)
                : new Dictionary<string, object>();

            if (!string.IsNullOrWhiteSpace(Registration.Class))
                attributes["class"] = Registration.Class;

            if (!string.IsNullOrWhiteSpace(Registration.Style))
                attributes["style"] = Registration.Style;

            attributes["id"] = Registration.ContentId;
            attributes["aria-labelledby"] = Registration.TriggerId;
            attributes["data-state"] = IsOpen ? "open" : "closed";
            attributes["data-orientation"] = NavigationMenu?.Orientation ?? "horizontal";
            attributes["tabindex"] = -1;
            attributes["onpointerenter"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerEnterAsync);
            attributes["onpointerleave"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerLeaveAsync);

            if (!string.IsNullOrWhiteSpace(Motion))
                attributes["data-motion"] = Motion;

            return attributes;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_contentCaptured)
        {
            NavigationMenu?.RegisterContent(Registration.Value, _contentElement);
            _contentCaptured = true;

            if (OnContentElementCaptured.HasDelegate)
                await OnContentElementCaptured.InvokeAsync(_contentElement);
        }

        if (NavigationMenu is not null &&
            NavigationMenu.TryGetFocusProxy(Registration.Value, out ElementReference startProxy) &&
            NavigationMenu.TryGetTrigger(Registration.Value, out IBradixNavigationMenuRegisteredTrigger trigger))
        {
            if (_focusBridgeRegistered)
            {
                await Interop.UpdateNavigationMenuContentFocusBridge(_contentElement, trigger.TriggerElement, startProxy, _exitProxyElement);
            }
            else
            {
                await Interop.RegisterNavigationMenuContentFocusBridge(_contentElement, trigger.TriggerElement, startProxy, _exitProxyElement);
                _focusBridgeRegistered = true;
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_focusBridgeRegistered)
            await Interop.UnregisterNavigationMenuContentFocusBridge(_contentElement);

        NavigationMenu?.UnregisterContent(Registration.Value);
    }

    private async Task HandleEscapeKeyDownAsync(BradixEscapeKeyDownEventArgs _)
    {
        if (NavigationMenu is not null)
        {
            NavigationMenu.MarkEscapeClosed(Registration.Value);
            await NavigationMenu.DismissAsync(Registration.Value);
        }
    }

    private async Task HandlePointerDownOutsideAsync(BradixPointerDownOutsideEventArgs args)
    {
        if (NavigationMenu is null)
            return;

        if (!NavigationMenu.IsRootMenu ||
            NavigationMenu.ContainsRegisteredTriggerId(args.OriginalEvent.AncestorIds) ||
            NavigationMenu.ContainsViewportId(args.OriginalEvent.AncestorIds))
        {
            args.PreventDefault();
            return;
        }

        await NavigationMenu.DismissAsync(args.OriginalEvent.ActiveElementInsideLayer ? Registration.Value : null);
    }

    private async Task HandleFocusOutsideAsync(BradixFocusOutsideEventArgs args)
    {
        if (NavigationMenu is null)
            return;

        if (NavigationMenu.ContainsRootNavigationMenuId(args.OriginalEvent.AncestorIds))
        {
            args.PreventDefault();
            return;
        }

        await NavigationMenu.DismissAsync(Registration.Value);
    }

    private Task HandlePointerEnterAsync(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return OnPointerEnterContent.HasDelegate
            ? OnPointerEnterContent.InvokeAsync()
            : Task.CompletedTask;
    }

    private Task HandlePointerLeaveAsync(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return OnPointerLeaveContent.HasDelegate
            ? OnPointerLeaveContent.InvokeAsync()
            : Task.CompletedTask;
    }
}
