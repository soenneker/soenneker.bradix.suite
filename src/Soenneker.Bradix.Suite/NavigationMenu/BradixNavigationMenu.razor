@namespace Soenneker.Bradix

@using System.Linq
@using System.Threading
@using Soenneker.Blazor.Utils.Ids

@inherits BradixComponent

@implements IBradixNavigationMenu

<CascadingValue Value="this">
    @if (IsRootMenu)
    {
        <nav @ref="_rootElement"
             @attributes="RootAttributes">
            <BradixDismissableLayerBranch Style="display:contents;">
                @ChildContent
            </BradixDismissableLayerBranch>
        </nav>
    }
    else
    {
        <div @ref="_rootElement"
             @attributes="RootAttributes">
            <BradixDismissableLayerBranch Style="display:contents;">
                @ChildContent
            </BradixDismissableLayerBranch>
        </div>
    }
</CascadingValue>

@code {
    private readonly BradixCollectionRegistry<IBradixNavigationMenuRegisteredTrigger> _triggers = new();
    private readonly Dictionary<string, ElementReference> _contentElements = new(StringComparer.Ordinal);
    private readonly Dictionary<string, ElementReference> _focusProxyElements = new(StringComparer.Ordinal);
    private readonly Dictionary<string, List<IBradixNavigationMenuFocusGroupItem>> _focusGroups = new(StringComparer.Ordinal);
    private readonly Dictionary<string, BradixNavigationMenuViewportRegistration> _viewportContents = new(StringComparer.Ordinal);
    private readonly Dictionary<string, int> _debugTriggerDisposeCounts = new(StringComparer.Ordinal);
    private readonly HashSet<string> _escapeClosedValues = new(StringComparer.Ordinal);
    private ElementReference _rootElement;
    private ElementReference _indicatorTrackElement;
    private bool _initialized;
    private bool _hasViewport;
    private bool _hasIndicatorTrack;
    private string? _uncontrolledValue;
    private string _previousValue = string.Empty;
    private string _lastObservedValue = string.Empty;
    private string? _viewportId;
    private CancellationTokenSource? _openDelayTokenSource;
    private CancellationTokenSource? _closeDelayTokenSource;
    private CancellationTokenSource? _skipDelayTokenSource;
    private bool _isOpenDelayed = true;
    private bool _pointerOverTrigger;

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string?> OnValueChange { get; set; }

    [Parameter]
    public BradixOrientation Orientation { get; set; } = BradixOrientation.Horizontal;

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public int DelayDuration { get; set; } = 200;

    [Parameter]
    public int SkipDelayDuration { get; set; } = 300;

    [Parameter]
    public bool IsRootMenu { get; set; } = true;

    internal string? BaseId { get; private set; }

    internal string CurrentValue => Value ?? _uncontrolledValue ?? string.Empty;

    internal string TriggerRovingGroupId => BlazorIdGenerator.Child(BaseId!, "triggers");

    internal string PreviousValue => _previousValue;

    internal string ResolvedDirection => BradixDirection.Resolve(Dir, CascadedDirection);

    internal string CurrentTabStopValue { get; private set; } = string.Empty;

    internal bool HasOpenItem => !string.IsNullOrWhiteSpace(CurrentValue);

    internal bool HasViewport => _hasViewport;

    internal string? ViewportId => _viewportId;

    internal ElementReference RootElement => _rootElement;

    internal bool HasIndicatorTrack => _hasIndicatorTrack;

    internal ElementReference IndicatorTrackElement => _indicatorTrackElement;

    internal string ActiveViewportValue => HasOpenItem ? CurrentValue : PreviousValue;

    internal string RootId =>
        string.IsNullOrWhiteSpace(Id) ? BlazorIdGenerator.Child(BaseId!, "root") : Id;

    private Dictionary<string, object> RootAttributes => BuildAttributes(
        ("id", RootId),
        ("aria-label", IsRootMenu ? "Main" : null),
        ("style", IsRootMenu ? "position:relative;" : null),
        ("data-orientation", Orientation.Value),
        ("dir", ResolvedDirection));

    protected override void OnInitialized()
    {
        BaseId ??= BlazorIdGenerator.New("bradix-navigation-menu");
    }

    protected override void OnParametersSet()
    {
        if (!_initialized)
        {
            _uncontrolledValue = DefaultValue;
            _lastObservedValue = CurrentValue;
            _initialized = true;
        }

        if (!string.Equals(_lastObservedValue, CurrentValue, StringComparison.Ordinal))
        {
            _previousValue = _lastObservedValue;
            _lastObservedValue = CurrentValue;
        }

        EnsureCurrentTabStopValue();
    }

    internal string MakeTriggerId(string value) =>
        BlazorIdGenerator.Child(BlazorIdGenerator.Child(BaseId!, "trigger"), value);

    internal string MakeContentId(string value) =>
        BlazorIdGenerator.Child(BlazorIdGenerator.Child(BaseId!, "content"), value);

    internal bool IsCurrentTabStop(BradixNavigationMenuItem item)
    {
        return string.Equals(CurrentTabStopValue, item.ResolvedValue, StringComparison.Ordinal);
    }

    internal bool IsOpen(BradixNavigationMenuItem item)
    {
        return string.Equals(CurrentValue, item.ResolvedValue, StringComparison.Ordinal);
    }

    internal bool TryGetOpenTrigger(out IBradixNavigationMenuRegisteredTrigger trigger)
    {
        var resolvedTrigger = _triggers.Snapshot()
                                       .Select(entry => entry.Item)
                                       .FirstOrDefault(candidate => string.Equals(candidate.Value, CurrentValue, StringComparison.Ordinal));

        trigger = resolvedTrigger!;
        return resolvedTrigger is not null;
    }

    internal bool TryGetTrigger(string value, out IBradixNavigationMenuRegisteredTrigger trigger)
    {
        var resolvedTrigger = _triggers.Snapshot()
                                       .Select(entry => entry.Item)
                                       .FirstOrDefault(candidate => string.Equals(candidate.Value, value, StringComparison.Ordinal));

        trigger = resolvedTrigger!;
        return resolvedTrigger is not null;
    }

    internal bool ContainsRegisteredTriggerId(IEnumerable<string>? ids)
    {
        if (ids is null)
            return false;

        var triggerIds = _triggers.Snapshot()
                                  .Select(entry => entry.Item.TriggerId)
                                  .ToHashSet(StringComparer.Ordinal);

        foreach (var id in ids)
        {
            if (triggerIds.Contains(id))
                return true;
        }

        return false;
    }

    internal bool ContainsRootNavigationMenuId(IEnumerable<string>? ids)
    {
        if (ids is null || string.IsNullOrWhiteSpace(RootId))
            return false;

        foreach (var id in ids)
        {
            if (string.Equals(id, RootId, StringComparison.Ordinal))
                return true;
        }

        return false;
    }

    internal bool ContainsViewportId(IEnumerable<string>? ids)
    {
        if (ids is null || string.IsNullOrWhiteSpace(_viewportId))
            return false;

        foreach (var id in ids)
        {
            if (string.Equals(id, _viewportId, StringComparison.Ordinal))
                return true;
        }

        return false;
    }

    internal void RecordTriggerDisposed(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        _debugTriggerDisposeCounts[value] = _debugTriggerDisposeCounts.TryGetValue(value, out var count) ? count + 1 : 1;
    }

    internal int GetDebugTriggerDisposeCount(string? value)
    {
        return !string.IsNullOrWhiteSpace(value) && _debugTriggerDisposeCounts.TryGetValue(value, out var count) ? count : 0;
    }

    internal void RegisterTrigger(IBradixNavigationMenuRegisteredTrigger trigger)
    {
        _triggers.Register(trigger.Value, trigger);
        EnsureCurrentTabStopValue();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void UnregisterTrigger(IBradixNavigationMenuRegisteredTrigger trigger)
    {
        _triggers.Unregister(trigger.Value);
        EnsureCurrentTabStopValue();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void RegisterContent(string value, ElementReference element)
    {
        _contentElements[value] = element;

        if (IsRootMenu &&
            HasViewport &&
            string.Equals(CurrentValue, value, StringComparison.Ordinal))
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    internal void UnregisterContent(string value)
    {
        _contentElements.Remove(value);
    }

    internal bool TryGetContent(string value, out ElementReference element)
    {
        return _contentElements.TryGetValue(value, out element);
    }

    internal void RegisterFocusProxy(string value, ElementReference element)
    {
        _focusProxyElements[value] = element;
    }

    internal void UnregisterFocusProxy(string value)
    {
        _focusProxyElements.Remove(value);
    }

    internal bool TryGetFocusProxy(string value, out ElementReference element)
    {
        return _focusProxyElements.TryGetValue(value, out element);
    }

    internal void RegisterFocusGroupItem(string groupId, IBradixNavigationMenuFocusGroupItem item)
    {
        if (!_focusGroups.TryGetValue(groupId, out var items))
        {
            items = [];
            _focusGroups[groupId] = items;
        }

        if (!items.Contains(item))
            items.Add(item);
    }

    internal void UnregisterFocusGroupItem(string groupId, IBradixNavigationMenuFocusGroupItem item)
    {
        if (!_focusGroups.TryGetValue(groupId, out var items))
            return;

        items.Remove(item);

        if (items.Count == 0)
            _focusGroups.Remove(groupId);
    }

    internal async Task HandleFocusGroupItemKeyDown(string groupId, IBradixNavigationMenuFocusGroupItem item, KeyboardEventArgs args)
    {
        if (args.CtrlKey || args.AltKey || args.MetaKey)
            return;

        if (!_focusGroups.TryGetValue(groupId, out var items) || items.Count == 0)
            return;

        var previousKey = ResolvedDirection == "rtl" ? "ArrowRight" : "ArrowLeft";
        var nextKey = ResolvedDirection == "rtl" ? "ArrowLeft" : "ArrowRight";

        var target = args.Key switch
        {
            "Home" => items[0],
            "End" => items[^1],
            var key when key == previousKey || key == "ArrowUp" => ResolveAdjacentFocusGroupItem(items, item, -1),
            var key when key == nextKey || key == "ArrowDown" => ResolveAdjacentFocusGroupItem(items, item, 1),
            _ => null
        };

        if (target is not null)
            await target.Focus();
    }

    internal void RegisterViewport(string viewportId)
    {
        if (!IsRootMenu)
            return;

        _viewportId = viewportId;

        if (_hasViewport)
            return;

        _hasViewport = true;
        _ = InvokeAsync(StateHasChanged);
    }

    internal void UnregisterViewport(string viewportId)
    {
        if (!IsRootMenu)
            return;

        if (string.Equals(_viewportId, viewportId, StringComparison.Ordinal))
            _viewportId = null;

        if (!_hasViewport)
            return;

        _hasViewport = false;
        _ = InvokeAsync(StateHasChanged);
    }

    internal void RegisterIndicatorTrack(ElementReference element)
    {
        _indicatorTrackElement = element;
        _hasIndicatorTrack = true;
    }

    internal void UnregisterIndicatorTrack()
    {
        _hasIndicatorTrack = false;
    }

    internal void RegisterViewportContent(BradixNavigationMenuViewportRegistration registration)
    {
        if (!IsRootMenu)
            return;

        if (_viewportContents.TryGetValue(registration.Value, out var existing) &&
            string.Equals(existing.TriggerId, registration.TriggerId, StringComparison.Ordinal) &&
            string.Equals(existing.ContentId, registration.ContentId, StringComparison.Ordinal) &&
            string.Equals(existing.Class, registration.Class, StringComparison.Ordinal) &&
            string.Equals(existing.Style, registration.Style, StringComparison.Ordinal) &&
            existing.ForceMount == registration.ForceMount)
        {
            _viewportContents[registration.Value] = registration;
            return;
        }

        _viewportContents[registration.Value] = registration;
        _ = InvokeAsync(StateHasChanged);
    }

    internal void UnregisterViewportContent(string value)
    {
        if (!IsRootMenu)
            return;

        if (_viewportContents.Remove(value))
            _ = InvokeAsync(StateHasChanged);
    }

    internal bool TryGetViewportContent(string value, out BradixNavigationMenuViewportRegistration registration)
    {
        if (!IsRootMenu)
        {
            registration = null!;
            return false;
        }

        return _viewportContents.TryGetValue(value, out registration!);
    }

    internal IReadOnlyList<BradixNavigationMenuViewportRegistration> GetViewportContents()
    {
        if (!IsRootMenu || _viewportContents.Count == 0)
            return [];

        List<BradixNavigationMenuViewportRegistration> ordered = [];

        foreach (var value in GetOrderedTriggerValues())
        {
            if (_viewportContents.TryGetValue(value, out var registration))
                ordered.Add(registration);
        }

        foreach (var registration in _viewportContents.Values)
        {
            if (!ordered.Any(existing => string.Equals(existing.Value, registration.Value, StringComparison.Ordinal)))
                ordered.Add(registration);
        }

        return ordered;
    }

    internal List<string> GetOrderedTriggerValues()
    {
        var values = _triggers.Snapshot()
                              .Select(entry => entry.Item.Value)
                              .ToList();

        if (ResolvedDirection == "rtl")
            values.Reverse();

        return values;
    }

    internal void HandleTriggerPointerEnter()
    {
        _pointerOverTrigger = true;
        CancelCloseDelay();
    }

    internal async Task HandleTriggerPointerMove(string value)
    {
        _pointerOverTrigger = true;

        if (!IsRootMenu)
        {
            await OpenValue(value);
            return;
        }

        CancelCloseDelay();

        if (_isOpenDelayed)
        {
            CancelOpenDelay();
            _openDelayTokenSource = new CancellationTokenSource();
            _ = OpenAfterDelay(value, _openDelayTokenSource.Token);
            return;
        }

        await OpenValue(value);
    }

    internal Task HandleTriggerPointerLeave()
    {
        _pointerOverTrigger = false;

        if (!IsRootMenu)
            return Task.CompletedTask;

        CancelOpenDelay();
        StartCloseDelay();
        return Task.CompletedTask;
    }

    internal Task HandleContentPointerEnter()
    {
        CancelCloseDelay();
        return Task.CompletedTask;
    }

    internal Task HandleContentPointerLeave()
    {
        if (_pointerOverTrigger)
            return Task.CompletedTask;

        if (!IsRootMenu)
            return Task.CompletedTask;

        StartCloseDelay();
        return Task.CompletedTask;
    }

    internal async Task ToggleItem(string value)
    {
        CancelOpenDelay();
        CancelCloseDelay();

        var nextValue = !IsRootMenu
            ? value
            : string.Equals(CurrentValue, value, StringComparison.Ordinal)
                ? string.Empty
                : value;

        await SetValue(nextValue);
        SetCurrentTabStop(value);
    }

    internal async Task Dismiss(string? focusTriggerValue = null)
    {
        CancelOpenDelay();
        CancelCloseDelay();
        await SetValue(string.Empty);

        if (!string.IsNullOrWhiteSpace(focusTriggerValue))
            await FocusTrigger(focusTriggerValue);
    }

    internal async Task FocusTrigger(string value)
    {
        var trigger = GetFocusableTriggers().FirstOrDefault(candidate => string.Equals(candidate.Value, value, StringComparison.Ordinal));
        if (trigger is not null)
            await trigger.Focus();
    }

    internal async Task FocusContent(string value)
    {
        if (_contentElements.TryGetValue(value, out var element))
            await element.FocusAsync();
    }

    internal void SetCurrentTabStop(string value)
    {
        if (string.Equals(CurrentTabStopValue, value, StringComparison.Ordinal))
            return;

        CurrentTabStopValue = value;
        _ = InvokeAsync(StateHasChanged);
    }

    internal bool WasEscapeClosed(string value)
    {
        return _escapeClosedValues.Contains(value);
    }

    internal void MarkEscapeClosed(string value)
    {
        if (!string.IsNullOrWhiteSpace(value))
            _escapeClosedValues.Add(value);
    }

    internal void ClearEscapeClosed(string value)
    {
        if (!string.IsNullOrWhiteSpace(value))
            _escapeClosedValues.Remove(value);
    }

    internal async Task HandleTriggerNavigation(IBradixNavigationMenuRegisteredTrigger trigger, KeyboardEventArgs args)
    {
        if (args.CtrlKey || args.AltKey || args.MetaKey || args.ShiftKey)
            return;

        var focusableTriggers = GetFocusableTriggers();
        var currentIndex = focusableTriggers.IndexOf(trigger);

        if (currentIndex < 0)
            return;

        if (!BradixRovingFocusNavigator.TryGetTargetIndex(
                args.Key,
                Orientation.Value,
                ResolvedDirection,
                currentIndex,
                focusableTriggers.Count,
                false,
                out var targetIndex))
        {
            return;
        }

        var target = focusableTriggers[targetIndex];
        CurrentTabStopValue = target.Value;
        await target.Focus();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenAfterDelay(string value, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(DelayDuration, cancellationToken);
            await OpenValue(value);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task OpenValue(string value)
    {
        await SetValue(value);
        SetCurrentTabStop(value);
    }

    private void StartCloseDelay()
    {
        CancelCloseDelay();
        _closeDelayTokenSource = new CancellationTokenSource();
        _ = CloseAfterDelay(_closeDelayTokenSource.Token);
    }

    private async Task CloseAfterDelay(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(150, cancellationToken);
            await SetValue(string.Empty);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task SetValue(string? value)
    {
        var nextValue = value ?? string.Empty;
        var isControlled = ValueChanged.HasDelegate;

        if (string.Equals(CurrentValue, nextValue, StringComparison.Ordinal))
            return;

        _previousValue = CurrentValue;
        _lastObservedValue = nextValue;

        if (!isControlled)
            _uncontrolledValue = nextValue;

        if (!string.IsNullOrWhiteSpace(nextValue))
        {
            CancelSkipDelay();
            if (SkipDelayDuration > 0)
                _isOpenDelayed = false;
        }
        else
        {
            StartSkipDelay();
        }

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(nextValue);

        if (OnValueChange.HasDelegate)
            await OnValueChange.InvokeAsync(nextValue);

        if (!isControlled)
            await InvokeAsync(StateHasChanged);
    }

    private void EnsureCurrentTabStopValue()
    {
        var focusableTriggers = GetFocusableTriggers();

        if (focusableTriggers.Count == 0)
        {
            CurrentTabStopValue = string.Empty;
            return;
        }

        if (!string.IsNullOrWhiteSpace(CurrentTabStopValue) &&
            focusableTriggers.Any(trigger => string.Equals(trigger.Value, CurrentTabStopValue, StringComparison.Ordinal)))
        {
            return;
        }

        var activeTrigger = focusableTriggers.FirstOrDefault(trigger => string.Equals(trigger.Value, CurrentValue, StringComparison.Ordinal));
        CurrentTabStopValue = activeTrigger?.Value ?? focusableTriggers[0].Value;
    }

    private List<IBradixNavigationMenuRegisteredTrigger> GetFocusableTriggers()
    {
        return _triggers.Snapshot()
            .Select(entry => entry.Item)
            .Where(trigger => !trigger.Disabled)
            .ToList();
    }

    private static IBradixNavigationMenuFocusGroupItem? ResolveAdjacentFocusGroupItem(List<IBradixNavigationMenuFocusGroupItem> items,
        IBradixNavigationMenuFocusGroupItem currentItem, int delta)
    {
        var currentIndex = items.IndexOf(currentItem);
        if (currentIndex < 0)
            return null;

        var nextIndex = currentIndex + delta;
        if (nextIndex < 0 || nextIndex >= items.Count)
            return null;

        return items[nextIndex];
    }

    private void StartSkipDelay()
    {
        CancelSkipDelay();
        _skipDelayTokenSource = new CancellationTokenSource();
        _ = ResetOpenDelay(_skipDelayTokenSource.Token);
    }

    private async Task ResetOpenDelay(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(SkipDelayDuration, cancellationToken);
            _isOpenDelayed = true;
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void CancelOpenDelay()
    {
        _openDelayTokenSource?.Cancel();
        _openDelayTokenSource?.Dispose();
        _openDelayTokenSource = null;
    }

    private void CancelCloseDelay()
    {
        _closeDelayTokenSource?.Cancel();
        _closeDelayTokenSource?.Dispose();
        _closeDelayTokenSource = null;
    }

    private void CancelSkipDelay()
    {
        _skipDelayTokenSource?.Cancel();
        _skipDelayTokenSource?.Dispose();
        _skipDelayTokenSource = null;
    }
}
