@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixNavigationMenuLink

@inject IBradixSuiteInterop Interop
<a @ref="_element"
   @onclick="HandleClick"
   @onfocus="HandleFocus"
   @onkeydown="HandleKeyDown"
   @attributes="LinkAttributes">
    @ChildContent
</a>

@code {
    private ElementReference _element;
    private DotNetObjectReference<BradixNavigationMenuLink>? _dotNetReference;
    private bool _registered;
    private bool _rovingFocusBridgeReady;
    private bool _disposed;
    private RootLinkRegistration? _rootRegistration;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [CascadingParameter]
    private BradixNavigationMenuItem? Item { get; set; }

    [CascadingParameter(Name = "BradixNavigationMenuInContent")]
    private bool IsInContent { get; set; }

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public EventCallback OnSelect { get; set; }

    private string? RovingGroupId => !IsInContent && NavigationMenu?.IsRootMenu == true ? NavigationMenu.TriggerRovingGroupId : null;

    private string? RovingItemId => !IsInContent ? Item?.ResolvedValue : null;

    private int? TabIndex => !IsInContent && NavigationMenu?.IsRootMenu == true && Item is not null
        ? (NavigationMenu.CurrentTabStopValue == Item.ResolvedValue ? 0 : -1)
        : null;

    private Dictionary<string, object> LinkAttributes => BuildAttributes(
        ("data-active", Active ? string.Empty : null),
        ("aria-current", Active ? "page" : null),
        ("data-bradix-roving-group", RovingGroupId),
        ("data-bradix-roving-item", string.Empty),
        ("data-bradix-roving-item-id", RovingItemId),
        ("data-bradix-roving-orientation", NavigationMenu?.Orientation?.Value),
        ("data-bradix-roving-dir", NavigationMenu?.ResolvedDirection),
        ("data-bradix-roving-loop", "true"),
        ("tabindex", TabIndex));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _disposed)
            return;

        if (NavigationMenu?.IsRootMenu == true && !IsInContent && Item is not null)
        {
            _rootRegistration = new RootLinkRegistration(Item.ResolvedValue, Item.TriggerId, _element);
            NavigationMenu.RegisterTrigger(_rootRegistration);
        }

        _dotNetReference ??= DotNetObjectReference.Create(this);

        try
        {
            await Interop.RegisterRovingFocusNavigationKeys(_element, _dotNetReference);
            _registered = true;
        }
        catch (Exception ex) when (ShouldIgnoreInteropException(ex))
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;

        if (_registered)
        {
            try
            {
                await Interop.UnregisterRovingFocusNavigationKeys(_element);
            }
            catch (Exception ex) when (ShouldIgnoreInteropException(ex))
            {
            }
        }

        _dotNetReference?.Dispose();
        _dotNetReference = null;

        if (_rootRegistration is not null)
            NavigationMenu?.UnregisterTrigger(_rootRegistration);
    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (OnSelect.HasDelegate)
            await OnSelect.InvokeAsync();

        if (!args.MetaKey && NavigationMenu?.IsRootMenu == true)
            await NavigationMenu.Dismiss();
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (NavigationMenu is not null && Item is not null && !IsInContent)
            NavigationMenu.SetCurrentTabStop(Item.ResolvedValue);

        return Task.CompletedTask;
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (NavigationMenu is null || string.IsNullOrWhiteSpace(RovingGroupId))
            return;

        if (_rovingFocusBridgeReady &&
            BradixRovingFocusNavigator.IsNavigationKey(args.Key))
            return;

        if (Item is null)
            return;

        if (NavigationMenu.TryGetTrigger(Item.ResolvedValue, out IBradixNavigationMenuRegisteredTrigger trigger))
            await NavigationMenu.HandleTriggerNavigation(trigger, args);
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReady()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }

    private static bool ShouldIgnoreInteropException(Exception ex)
    {
        return ex is ObjectDisposedException or JSDisconnectedException;
    }

    private sealed class RootLinkRegistration(string value, string triggerId, ElementReference triggerElement) : IBradixNavigationMenuRegisteredTrigger
    {
        public string Value { get; } = value;
        public string TriggerId { get; } = triggerId;
        public bool Disabled => false;
        public ElementReference TriggerElement { get; } = triggerElement;

        public ValueTask Focus()
        {
            return TriggerElement.FocusAsync();
        }
    }
}
