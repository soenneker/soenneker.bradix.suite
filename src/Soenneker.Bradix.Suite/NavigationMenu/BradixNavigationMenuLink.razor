@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixNavigationMenuFocusGroupItem
@implements IBradixNavigationMenuLink

@inject IBradixSuiteInterop Interop
<a @ref="_element"
   @onclick="HandleClick"
   @onkeydown="HandleKeyDown"
   @attributes="LinkAttributes">
    @ChildContent
</a>

@code {
    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _registered;
    private bool _rovingFocusBridgeReady;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [CascadingParameter(Name = "BradixNavigationMenuFocusGroupId")]
    private string? FocusGroupId { get; set; }

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public EventCallback OnSelect { get; set; }

    private Dictionary<string, object> LinkAttributes => BuildAttributes(
        ("data-active", Active ? string.Empty : null),
        ("aria-current", Active ? "page" : null),
        ("data-bradix-roving-group", FocusGroupId),
        ("data-bradix-roving-item", string.Empty),
        ("data-bradix-roving-orientation", NavigationMenu?.Orientation?.Value),
        ("data-bradix-roving-dir", NavigationMenu?.ResolvedDirection),
        ("data-bradix-roving-loop", "true"));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (NavigationMenu is not null && !string.IsNullOrWhiteSpace(FocusGroupId))
        {
            NavigationMenu.RegisterFocusGroupItem(FocusGroupId, this);
            _registered = true;
        }

        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterRovingFocusNavigationKeys(_element, _dotNetReference);
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterRovingFocusNavigationKeys(_element);
        _dotNetReference?.Dispose();

        if (_registered && NavigationMenu is not null && !string.IsNullOrWhiteSpace(FocusGroupId))
            NavigationMenu.UnregisterFocusGroupItem(FocusGroupId, this);
    }

    ValueTask IBradixNavigationMenuFocusGroupItem.Focus() => _element.FocusAsync();

    private async Task HandleClick(MouseEventArgs args)
    {
        if (OnSelect.HasDelegate)
            await OnSelect.InvokeAsync();

        if (!args.MetaKey && NavigationMenu?.IsRootMenu == true)
            await NavigationMenu.Dismiss();
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (NavigationMenu is null || string.IsNullOrWhiteSpace(FocusGroupId))
            return;

        if (_rovingFocusBridgeReady && BradixRovingFocusNavigator.IsNavigationKey(args.Key))
            return;

        await NavigationMenu.HandleFocusGroupItemKeyDown(FocusGroupId, this, args);
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReady()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }
}
