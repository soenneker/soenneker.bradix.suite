@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixNavigationMenuSub
<BradixNavigationMenu Value="@Value"
                      DefaultValue="@DefaultValue"
                      ValueChanged="@ValueChanged"
                      OnValueChange="@OnValueChange"
                      Orientation="@Orientation"
                      IsRootMenu="false"
                      Class="@Class"
                      Style="@Style"
                      AdditionalAttributes="@AdditionalAttributes">
    @ChildContent
</BradixNavigationMenu>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string?> OnValueChange { get; set; }

    [Parameter]
    public BradixOrientation Orientation { get; set; } = BradixOrientation.Horizontal;
}
