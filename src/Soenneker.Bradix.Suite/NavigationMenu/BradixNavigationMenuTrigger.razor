@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixNavigationMenuTrigger

@inject IBradixSuiteInterop Interop
<button @ref="_button"
        @onpointerover="HandlePointerOver"
        @onpointerenter="HandlePointerEnter"
        @onpointermove="HandlePointerMove"
        @onpointerleave="HandlePointerLeave"
        @onmouseover="HandleMouseOver"
        @onmouseenter="HandleMouseEnter"
        @onmousemove="HandleMouseMove"
        @onmouseleave="HandleMouseLeave"
        @onclick="HandleClick"
        @onfocus="HandleFocus"
        @onkeydown="HandleKeyDown"
        @attributes="TriggerAttributes">
    @ChildContent
</button>

@if (IsOpen)
{

        <span @ref="_focusProxy"
              aria-hidden="true"
              tabindex="0"
              style="position:absolute;opacity:0;pointer-events:none;width:1px;height:1px;overflow:hidden;" />

        @if (NavigationMenu?.IsRootMenu == true && NavigationMenu.HasViewport && Item is not null)
        {
            <span aria-owns="@Item.ContentId"></span>
        }
}

@code {
    private ElementReference _button;
    private ElementReference _focusProxy;
    private bool _hasPointerMoveOpened;
    private bool _rovingFocusBridgeReady;
    private bool _wasClickClose;
    private bool _focusProxyRegistered;
    private bool _delegatedInteractionRegistered;
    private DotNetObjectReference<object>? _dotNetReference;
    private TriggerRegistration? _registration;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [CascadingParameter]
    private BradixNavigationMenuItem? Item { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private bool IsOpen => Item?.IsOpen == true;

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("id", Item?.TriggerId),
        ("type", "button"),
        ("disabled", Disabled ? true : null),
        ("data-disabled", Disabled ? string.Empty : null),
        ("data-state", IsOpen ? "open" : "closed"),
        ("data-bradix-roving-group", NavigationMenu?.TriggerRovingGroupId),
        ("data-bradix-roving-item", string.Empty),
        ("data-bradix-roving-item-id", Item?.ResolvedValue),
        ("data-bradix-roving-orientation", NavigationMenu?.Orientation?.Value),
        ("data-bradix-roving-dir", NavigationMenu?.ResolvedDirection),
        ("data-bradix-roving-loop", "true"),
        ("aria-expanded", IsOpen ? "true" : "false"),
        ("aria-controls", Item?.ContentId),
        ("tabindex", NavigationMenu is not null && Item is not null && NavigationMenu.IsCurrentTabStop(Item) ? 0 : -1));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && NavigationMenu is not null && Item is not null)
        {
            _registration = new TriggerRegistration(Item.ResolvedValue, Item.TriggerId, Disabled, _button);
            NavigationMenu.RegisterTrigger(_registration);
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterRovingFocusNavigationKeys(_button, _dotNetReference);
            await Interop.RegisterDelegatedInteraction(_button, _dotNetReference, new
            {
                mouseenter = new
                {
                    method = nameof(HandleDelegatedMouseEnter),
                    currentTargetOnly = false
                },
                mouseover = new
                {
                    method = nameof(HandleDelegatedMouseOver),
                    currentTargetOnly = false
                },
                pointermove = new
                {
                    method = nameof(HandleDelegatedPointerMove),
                    currentTargetOnly = false
                },
                pointerover = new
                {
                    method = nameof(HandleDelegatedPointerOver),
                    currentTargetOnly = false
                },
                keydown = new
                {
                    method = nameof(HandleDelegatedKeyDown),
                    currentTargetOnly = true,
                    preventDefaultKeys = new[] { "ArrowLeft", "ArrowRight", "ArrowUp", "ArrowDown", "Home", "End" }
                }
            });
            _delegatedInteractionRegistered = true;
        }

        if (NavigationMenu is not null && Item is not null)
        {
            if (IsOpen)
            {
                NavigationMenu.RegisterFocusProxy(Item.ResolvedValue, _focusProxy);
                _focusProxyRegistered = true;
            }
            else if (_focusProxyRegistered)
            {
                NavigationMenu.UnregisterFocusProxy(Item.ResolvedValue);
                _focusProxyRegistered = false;
            }
        }

    }

    public async ValueTask DisposeAsync()
    {
        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_button);

        await Interop.UnregisterRovingFocusNavigationKeys(_button);
        _dotNetReference?.Dispose();

        if (_focusProxyRegistered && Item is not null)
            NavigationMenu?.UnregisterFocusProxy(Item.ResolvedValue);

        if (_registration is not null)
            NavigationMenu?.UnregisterTrigger(_registration);
    }

    private async Task HandlePointerEnter(PointerEventArgs args)
    {
        _wasClickClose = false;

        if (NavigationMenu is not null)
            NavigationMenu.HandleTriggerPointerEnter();

        if (NavigationMenu is not null && Item is not null)
            NavigationMenu.ClearEscapeClosed(Item.ResolvedValue);

        if (args.PointerType == "touch" ||
            Disabled ||
            NavigationMenu is null ||
            Item is null ||
            _hasPointerMoveOpened ||
            !NavigationMenu.HasOpenItem ||
            IsOpen)
            return;

        await NavigationMenu.HandleTriggerPointerMove(Item.ResolvedValue);
        _hasPointerMoveOpened = true;
    }

    private async Task HandlePointerMove(PointerEventArgs args)
    {
        if (args.PointerType == "touch" ||
            Disabled ||
            NavigationMenu is null ||
            Item is null ||
            _wasClickClose ||
            NavigationMenu.WasEscapeClosed(Item.ResolvedValue) ||
            _hasPointerMoveOpened)
            return;

        await NavigationMenu.HandleTriggerPointerMove(Item.ResolvedValue);
        _hasPointerMoveOpened = true;
    }

    private Task HandlePointerOver(PointerEventArgs args)
    {
        return HandlePointerMove(args);
    }

    private Task HandleMouseEnter()
    {
        return HandleHoverEnter();
    }

    private Task HandleMouseMove()
    {
        return HandleHoverMove();
    }

    private Task HandleMouseOver()
    {
        return HandleHoverMove();
    }

    private Task HandleMouseLeave()
    {
        return HandleHoverLeave();
    }

    private async Task HandlePointerLeave(PointerEventArgs args)
    {
        if (args.PointerType == "touch" || Disabled || NavigationMenu is null)
            return;

        await HandleHoverLeave();
    }

    private async Task HandleHoverEnter()
    {
        if (Disabled)
            return;

        if (NavigationMenu is not null)
            NavigationMenu.HandleTriggerPointerEnter();

        _wasClickClose = false;

        if (NavigationMenu is not null && Item is not null)
            NavigationMenu.ClearEscapeClosed(Item.ResolvedValue);

        if (NavigationMenu is null ||
            Item is null ||
            _hasPointerMoveOpened ||
            !NavigationMenu.HasOpenItem ||
            IsOpen)
        {
            return;
        }

        await NavigationMenu.HandleTriggerPointerMove(Item.ResolvedValue);
        _hasPointerMoveOpened = true;
    }

    private async Task HandleHoverMove()
    {
        if (Disabled ||
            NavigationMenu is null ||
            Item is null ||
            _wasClickClose ||
            NavigationMenu.WasEscapeClosed(Item.ResolvedValue) ||
            _hasPointerMoveOpened)
            return;

        await NavigationMenu.HandleTriggerPointerMove(Item.ResolvedValue);
        _hasPointerMoveOpened = true;
    }

    private async Task HandleHoverLeave()
    {
        if (Disabled || NavigationMenu is null)
            return;

        _hasPointerMoveOpened = false;
        await NavigationMenu.HandleTriggerPointerLeave();
    }

    private async Task HandleClick()
    {
        if (Disabled || NavigationMenu is null || Item is null)
            return;

        bool wasOpen = IsOpen;
        await NavigationMenu.ToggleItem(Item.ResolvedValue);
        _wasClickClose = wasOpen;
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (NavigationMenu is not null && Item is not null)
            NavigationMenu.SetCurrentTabStop(Item.ResolvedValue);

        return Task.CompletedTask;
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Disabled || NavigationMenu is null || Item is null)
            return;

        string verticalEntryKey = NavigationMenu.ResolvedDirection == "rtl" ? "ArrowLeft" : "ArrowRight";
        string entryKey = NavigationMenu.Orientation == BradixOrientation.Vertical ? verticalEntryKey : "ArrowDown";

        if (IsOpen && string.Equals(args.Key, entryKey, StringComparison.Ordinal))
        {
            await NavigationMenu.FocusContent(Item.ResolvedValue);
            return;
        }

        if (args.Key is "ArrowLeft" or "ArrowRight" or "ArrowUp" or "ArrowDown" or "Home" or "End")
        {
            if (_rovingFocusBridgeReady && args.Key is "ArrowLeft" or "ArrowRight")
                return;

            if (_registration is not null)
                await NavigationMenu.HandleTriggerNavigation(_registration, args);

            return;
        }

        if (args.Key is "Enter" or " " or "Spacebar")
            await NavigationMenu.ToggleItem(Item.ResolvedValue);
    }

    [JSInvokable]
    public Task HandleDelegatedMouseEnter(BradixDelegatedMouseEvent _)
    {
        return HandleHoverEnter();
    }

    [JSInvokable]
    public Task HandleDelegatedMouseOver(BradixDelegatedMouseEvent _)
    {
        return HandleHoverMove();
    }

    [JSInvokable]
    public Task HandleDelegatedPointerMove(BradixDelegatedMouseEvent args)
    {
        if (string.Equals(args.PointerType, "touch", StringComparison.Ordinal))
            return Task.CompletedTask;

        return HandleHoverMove();
    }

    [JSInvokable]
    public Task HandleDelegatedPointerOver(BradixDelegatedMouseEvent args)
    {
        if (string.Equals(args.PointerType, "touch", StringComparison.Ordinal))
            return Task.CompletedTask;

        return HandleHoverEnter();
    }

    [JSInvokable]
    public Task HandleDelegatedKeyDown(BradixDelegatedKeyboardEvent args)
    {
        return HandleKeyDown(new KeyboardEventArgs
        {
            Key = args.Key,
            Code = args.Code,
            CtrlKey = args.CtrlKey,
            ShiftKey = args.ShiftKey,
            AltKey = args.AltKey,
            MetaKey = args.MetaKey,
            Repeat = args.Repeat
        });
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReady()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }

    private sealed class TriggerRegistration(string value, string triggerId, bool disabled, ElementReference triggerElement) : IBradixNavigationMenuRegisteredTrigger
    {
        public string Value { get; } = value;
        public string TriggerId { get; } = triggerId;
        public bool Disabled { get; } = disabled;
        public ElementReference TriggerElement { get; } = triggerElement;

        public ValueTask Focus()
        {
            return TriggerElement.FocusAsync();
        }
    }
}
