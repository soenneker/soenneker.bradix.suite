@namespace Soenneker.Bradix
@using System.Globalization
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

@if (ForceMount || NavigationMenu?.HasOpenItem == true)
{
    <BradixPresence Present="ForceMount || NavigationMenu?.HasOpenItem == true"
                    Tag="div"
                    Class="@Class"
                    Style="@ComputedStyle"
                    AdditionalAttributes="@IndicatorAttributes"
                    OnElementReferenceCaptured="@HandleElementCaptured">
        @ChildContent
    </BradixPresence>
}

@code {
    private ElementReference _element;
    private bool _hasElement;
    private bool _registered;
    private DotNetObjectReference<object>? _dotNetReference;
    private double? _size;
    private double? _offset;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    private IReadOnlyDictionary<string, object> IndicatorAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["aria-hidden"] = "true";
            attributes["data-state"] = NavigationMenu?.HasOpenItem == true ? "visible" : "hidden";
            attributes["data-orientation"] = NavigationMenu?.Orientation ?? "horizontal";
            return attributes;
        }
    }

    private string ComputedStyle
    {
        get
        {
            string orientation = NavigationMenu?.Orientation ?? "horizontal";
            string baseStyle = "position:absolute;";

            if (_size.HasValue && _offset.HasValue)
            {
                if (orientation == "vertical")
                {
                    baseStyle += $" top:0;height:{_size.Value.ToString(CultureInfo.InvariantCulture)}px;transform:translateY({_offset.Value.ToString(CultureInfo.InvariantCulture)}px);";
                }
                else
                {
                    baseStyle += $" left:0;width:{_size.Value.ToString(CultureInfo.InvariantCulture)}px;transform:translateX({_offset.Value.ToString(CultureInfo.InvariantCulture)}px);";
                }
            }

            if (string.IsNullOrWhiteSpace(Style))
                return baseStyle;

            return $"{baseStyle} {Style}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        BradixNavigationMenu? navigationMenu = NavigationMenu;

        if (!_hasElement ||
            navigationMenu is null ||
            !navigationMenu.HasIndicatorTrack ||
            !navigationMenu.HasOpenItem ||
            !navigationMenu.TryGetOpenTrigger(out IBradixNavigationMenuRegisteredTrigger trigger))
        {
            if (_registered)
            {
                await Interop.UnregisterNavigationMenuIndicator(_element);
                _registered = false;
            }

            return;
        }

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);

        if (_registered)
        {
            await Interop.UpdateNavigationMenuIndicator(_element, trigger.TriggerElement, navigationMenu.IndicatorTrackElement, navigationMenu.Orientation);
        }
        else
        {
            await Interop.RegisterNavigationMenuIndicator(_element, trigger.TriggerElement, navigationMenu.IndicatorTrackElement, _dotNetReference,
                navigationMenu.Orientation);
            _registered = true;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
            await Interop.UnregisterNavigationMenuIndicator(_element);

        _dotNetReference?.Dispose();
    }

    private Task HandleElementCaptured(ElementReference element)
    {
        _element = element;
        _hasElement = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleIndicatorPositionChanged(double size, double offset)
    {
        if (Math.Abs((_size ?? -1) - size) < 0.1 &&
            Math.Abs((_offset ?? -1) - offset) < 0.1)
        {
            return Task.CompletedTask;
        }

        _size = size;
        _offset = offset;
        return InvokeAsync(StateHasChanged);
    }
}
