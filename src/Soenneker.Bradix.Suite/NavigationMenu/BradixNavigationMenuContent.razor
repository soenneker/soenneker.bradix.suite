@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixNavigationMenuContent

@inject IBradixSuiteInterop Interop

@if (ShouldRenderContent)
{
    @if (ShouldUseViewport)
    {
        <BradixPortal ContainerSelector="@ViewportSelector">
            @ContentBody
        </BradixPortal>
    }
    else
    {
        @ContentBody
    }
}

@code {
    private ElementReference _contentElement;
    private ElementReference _exitProxyElement;
    private bool _registered;
    private bool _focusBridgeRegistered;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [CascadingParameter]
    private BradixNavigationMenuItem? Item { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    private bool IsOpen => Item?.IsOpen == true;

    private bool ShouldRenderInline => NavigationMenu?.IsRootMenu != true || NavigationMenu.HasViewport != true;

    private bool ShouldUseViewport =>
        NavigationMenu?.IsRootMenu == true &&
        NavigationMenu.HasViewport &&
        !string.IsNullOrWhiteSpace(NavigationMenu.ViewportId);

    private bool ShouldRenderContent =>
        (ForceMount || IsOpen) &&
        (!ShouldUseViewport || !string.IsNullOrWhiteSpace(ViewportSelector));

    private string? ViewportSelector => !string.IsNullOrWhiteSpace(NavigationMenu?.ViewportId)
        ? $"#{NavigationMenu.ViewportId}"
        : null;

    private RenderFragment ContentBody => @<BradixPresence Present="ForceMount || IsOpen"
                                                           Tag="div">
        <BradixDismissableLayer DisableOutsidePointerEvents="false"
                                DismissOnEscapeKeyDown="false"
                                DismissOnPointerDownOutside="false"
                                DismissOnFocusOutside="false"
                                OnEscapeKeyDownDetailed="@HandleEscapeKeyDown"
                                OnPointerDownOutsideDetailed="@HandlePointerDownOutside"
                                OnFocusOutsideDetailed="@HandleFocusOutside">
            <div @ref="_contentElement"
                 tabindex="-1"
                 @attributes="ContentAttributes"
                 @onpointerenter="HandlePointerEnter"
                 @onpointerleave="HandlePointerLeave">
                <CascadingValue Name="BradixNavigationMenuInContent" Value="true" IsFixed="true">
                    @ChildContent
                </CascadingValue>
            </div>
            <span @ref="_exitProxyElement"
                  aria-hidden="true"
                  tabindex="0"
                  style="position:absolute;opacity:0;pointer-events:none;width:1px;height:1px;overflow:hidden;" />
        </BradixDismissableLayer>
    </BradixPresence>;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ShouldRenderContent)
        {
            if (_focusBridgeRegistered)
            {
                await Interop.UnregisterNavigationMenuContentFocusBridge(_contentElement);
                _focusBridgeRegistered = false;
            }

            return;
        }

        if (_registered is false && NavigationMenu is not null && Item is not null)
        {
            NavigationMenu.RegisterContent(Item.ResolvedValue, _contentElement);
            _registered = true;
        }

        if (NavigationMenu is not null &&
            Item is not null &&
            NavigationMenu.TryGetFocusProxy(Item.ResolvedValue, out ElementReference startProxy) &&
            NavigationMenu.TryGetTrigger(Item.ResolvedValue, out IBradixNavigationMenuRegisteredTrigger trigger))
        {
            if (_focusBridgeRegistered)
            {
                await Interop.UpdateNavigationMenuContentFocusBridge(_contentElement, trigger.TriggerElement, startProxy, _exitProxyElement);
            }
            else
            {
                await Interop.RegisterNavigationMenuContentFocusBridge(_contentElement, trigger.TriggerElement, startProxy, _exitProxyElement);
                _focusBridgeRegistered = true;
            }
        }
    }

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            if (!string.IsNullOrWhiteSpace(Item?.ContentId))
                attributes["id"] = Item.ContentId;

            if (!string.IsNullOrWhiteSpace(Class))
                attributes["class"] = Class;

            if (!string.IsNullOrWhiteSpace(Style))
                attributes["style"] = Style;

            attributes["data-state"] = IsOpen ? "open" : "closed";
            attributes["data-orientation"] = NavigationMenu?.Orientation?.Value ?? BradixOrientation.Horizontal.Value;
            attributes["aria-labelledby"] = Item?.TriggerId ?? string.Empty;

            string motion = ResolveMotion();
            if (!string.IsNullOrWhiteSpace(motion))
                attributes["data-motion"] = motion;

            return attributes;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_focusBridgeRegistered)
            await Interop.UnregisterNavigationMenuContentFocusBridge(_contentElement);

        if (_registered && Item is not null)
            NavigationMenu?.UnregisterContent(Item.ResolvedValue);
    }

    private async Task HandleEscapeKeyDown(BradixEscapeKeyDownEventArgs _)
    {
        if (NavigationMenu is not null && Item is not null)
        {
            NavigationMenu.MarkEscapeClosed(Item.ResolvedValue);
            await NavigationMenu.Dismiss(Item.ResolvedValue);
        }
    }

    private async Task HandlePointerDownOutside(BradixPointerDownOutsideEventArgs args)
    {
        if (NavigationMenu is null)
            return;

        if (!NavigationMenu.IsRootMenu ||
            NavigationMenu.ContainsRegisteredTriggerId(args.OriginalEvent.AncestorIds) ||
            NavigationMenu.ContainsViewportId(args.OriginalEvent.AncestorIds))
        {
            args.PreventDefault();
            return;
        }

        await NavigationMenu.Dismiss(args.OriginalEvent.ActiveElementInsideLayer && Item is not null ? Item.ResolvedValue : null);
    }

    private async Task HandleFocusOutside(BradixFocusOutsideEventArgs args)
    {
        if (NavigationMenu is null)
            return;

        if (NavigationMenu.ContainsRootNavigationMenuId(args.OriginalEvent.AncestorIds))
        {
            args.PreventDefault();
            return;
        }

        await NavigationMenu.Dismiss(Item?.ResolvedValue);
    }

    private Task HandlePointerEnter(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return NavigationMenu?.HandleContentPointerEnter() ?? Task.CompletedTask;
    }

    private Task HandlePointerLeave(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return NavigationMenu?.HandleContentPointerLeave() ?? Task.CompletedTask;
    }

    private string ResolveMotion()
    {
        if (!ShouldUseViewport ||
            NavigationMenu is null ||
            Item is null ||
            string.IsNullOrWhiteSpace(NavigationMenu.PreviousValue))
        {
            return string.Empty;
        }

        List<string> values = NavigationMenu.GetOrderedTriggerValues();
        int index = values.IndexOf(NavigationMenu.CurrentValue);
        int previousIndex = values.IndexOf(NavigationMenu.PreviousValue);
        int activeIndex = values.IndexOf(Item.ResolvedValue);

        bool isSelected = Item.ResolvedValue == NavigationMenu.CurrentValue;
        bool wasSelected = activeIndex == previousIndex;

        if (!isSelected && !wasSelected)
            return string.Empty;

        if (index != previousIndex)
        {
            if (isSelected && previousIndex != -1)
                return index > previousIndex ? "from-end" : "from-start";

            if (wasSelected && index != -1)
                return index > previousIndex ? "to-start" : "to-end";
        }

        return string.Empty;
    }
}
