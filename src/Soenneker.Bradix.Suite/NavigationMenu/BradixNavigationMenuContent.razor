@using Soenneker.Bradix.Suite.Base
@implements IAsyncDisposable
@inherits BradixComponentBase
@inject Soenneker.Bradix.Suite.Interop.BradixSuiteInterop Interop

@if (ShouldRenderInline && (ForceMount || IsOpen))
{
    <BradixPresence Present="ForceMount || IsOpen"
                    Tag="div"
                    Id="@Item?.ContentId"
                    Class="@Class"
                    Style="@Style"
                    AdditionalAttributes="@ContentAttributes">
        <BradixDismissableLayer DisableOutsidePointerEvents="false"
                                DismissOnEscapeKeyDown="false"
                                DismissOnPointerDownOutside="false"
                                DismissOnFocusOutside="false"
                                OnEscapeKeyDown="@HandleEscapeKeyDownAsync"
                                OnPointerDownOutside="@HandlePointerDownOutsideAsync">
            <div @ref="_contentElement"
                 tabindex="-1"
                 @onpointerenter="HandlePointerEnterAsync"
                 @onpointerleave="HandlePointerLeaveAsync">
                <CascadingValue Name="BradixNavigationMenuFocusGroupId" Value="@(Item?.ResolvedValue)">
                    @ChildContent
                </CascadingValue>
            </div>
            <span @ref="_exitProxyElement"
                  data-bradix-navigation-menu-focus-proxy-end=""
                  aria-hidden="true"
                  tabindex="0"
                  style="position:absolute;opacity:0;pointer-events:none;width:1px;height:1px;overflow:hidden;" />
        </BradixDismissableLayer>
    </BradixPresence>
}

@code {
    private ElementReference _contentElement;
    private ElementReference _exitProxyElement;
    private bool _registered;
    private bool _viewportContentRegistered;
    private bool _focusBridgeRegistered;

    [CascadingParameter]
    private BradixNavigationMenu? NavigationMenu { get; set; }

    [CascadingParameter]
    private BradixNavigationMenuItem? Item { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    private bool IsOpen => Item?.IsOpen == true;

    private bool ShouldRenderInline => NavigationMenu?.IsRootMenu != true || NavigationMenu.HasViewport != true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ShouldRenderInline && !_viewportContentRegistered && NavigationMenu is not null && Item is not null)
        {
            NavigationMenu.RegisterViewportContent(new BradixNavigationMenuViewportRegistration
            {
                Value = Item.ResolvedValue,
                TriggerId = Item.TriggerId,
                ContentId = Item.ContentId,
                Class = Class,
                Style = Style,
                AdditionalAttributes = AdditionalAttributes,
                ChildContent = ChildContent,
                ForceMount = ForceMount
            });

            _viewportContentRegistered = true;
        }

        if (!ShouldRenderInline || !(ForceMount || IsOpen))
        {
            if (_focusBridgeRegistered)
            {
                await Interop.UnregisterNavigationMenuContentFocusBridge(_contentElement);
                _focusBridgeRegistered = false;
            }

            return;
        }

        if (_registered is false && NavigationMenu is not null && Item is not null)
        {
            NavigationMenu.RegisterContent(Item.ResolvedValue, _contentElement);
            _registered = true;
        }

        if (NavigationMenu is not null &&
            Item is not null &&
            NavigationMenu.TryGetFocusProxy(Item.ResolvedValue, out ElementReference startProxy) &&
            NavigationMenu.TryGetTrigger(Item.ResolvedValue, out IBradixNavigationMenuTrigger trigger))
        {
            if (_focusBridgeRegistered)
            {
                await Interop.UpdateNavigationMenuContentFocusBridge(_contentElement, trigger.TriggerElement, startProxy, _exitProxyElement);
            }
            else
            {
                await Interop.RegisterNavigationMenuContentFocusBridge(_contentElement, trigger.TriggerElement, startProxy, _exitProxyElement);
                _focusBridgeRegistered = true;
            }
        }
    }

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["data-state"] = IsOpen ? "open" : "closed";
            attributes["data-orientation"] = NavigationMenu?.Orientation ?? "horizontal";
            attributes["aria-labelledby"] = Item?.TriggerId ?? string.Empty;
            return attributes;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_focusBridgeRegistered)
            await Interop.UnregisterNavigationMenuContentFocusBridge(_contentElement);

        if (_registered && Item is not null)
            NavigationMenu?.UnregisterContent(Item.ResolvedValue);

        if (Item is not null)
            NavigationMenu?.UnregisterViewportContent(Item.ResolvedValue);
    }

    private async Task HandleEscapeKeyDownAsync()
    {
        if (NavigationMenu is not null && Item is not null)
            await NavigationMenu.DismissAsync(Item.ResolvedValue);
    }

    private async Task HandlePointerDownOutsideAsync()
    {
        if (NavigationMenu?.IsRootMenu == true)
            await NavigationMenu.DismissAsync();
    }

    private Task HandlePointerEnterAsync(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return NavigationMenu?.HandleContentPointerEnterAsync() ?? Task.CompletedTask;
    }

    private Task HandlePointerLeaveAsync(PointerEventArgs args)
    {
        if (args.PointerType == "touch")
            return Task.CompletedTask;

        return NavigationMenu?.HandleContentPointerLeaveAsync() ?? Task.CompletedTask;
    }
}
