@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixSliderRange
<span @attributes="RangeAttributes"></span>

@code {
    [CascadingParameter]
    internal BradixSlider Slider { get; set; } = null!;

    private Dictionary<string, object> RangeAttributes => BuildAttributes(
        ("data-orientation", Slider.Orientation.Value),
        ("data-disabled", Slider.Disabled ? string.Empty : null),
        ("style", BuildRangeStyle()));

    private string BuildRangeStyle()
    {
        var values = Slider.CurrentValues;
        var percentages = values.Select(Slider.GetPercentForValue).ToList();
        var offsetStart = percentages.Count > 1 ? percentages.Min() : 0;
        var offsetEnd = 100 - percentages.Max();

        string startEdge;
        string endEdge;

        if (Slider.Orientation == BradixOrientation.Horizontal)
        {
            var fromLeft = (Slider.ResolvedDirection == "ltr" && !Slider.Inverted) || (Slider.ResolvedDirection == "rtl" && Slider.Inverted);
            startEdge = fromLeft ? "left" : "right";
            endEdge = fromLeft ? "right" : "left";
        }
        else
        {
            var fromBottom = !Slider.Inverted;
            startEdge = fromBottom ? "bottom" : "top";
            endEdge = fromBottom ? "top" : "bottom";
        }

        return $"{startEdge}: {offsetStart.ToString(System.Globalization.CultureInfo.InvariantCulture)}%; {endEdge}: {offsetEnd.ToString(System.Globalization.CultureInfo.InvariantCulture)}%;";
    }
}
