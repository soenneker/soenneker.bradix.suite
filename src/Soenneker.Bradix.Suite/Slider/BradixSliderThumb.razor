@namespace Soenneker.Bradix

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

<span @attributes="WrapperAttributes">
    <span @ref="_element"
          @onfocus="HandleFocus"
          @onkeydown="HandleKeyDown"
          @attributes="ThumbAttributes">
    </span>

    @if (ShouldRenderBubbleInput && Value is not null)
    {
        <input @ref="_bubbleInputElement"
               @attributes="BubbleInputAttributes" />
    }
</span>

@code {
    private ElementReference _element;
    private ElementReference _bubbleInputElement;
    private bool _hasSyncedBubbleInput;
    private bool _isFormControl = true;
    private bool _formControlStateResolved;
    private double? _lastRenderedValue;
    private string? _lastResolvedForm;
    private bool _registered;

    [CascadingParameter]
    internal BradixSlider Slider { get; set; } = null!;

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    private int Index => Slider.GetThumbIndex(this);

    private double? Value => Slider.GetThumbValue(Index);

    private string? InputName => Slider.GetThumbInputName(this);

    private bool ShouldRenderBubbleInput => _isFormControl || !string.IsNullOrWhiteSpace(Slider.Form);

    private Dictionary<string, object> WrapperAttributes
    {
        get
        {
            if (Value is null)
            {
                return BuildAttributes(("style", "display: none;"));
            }

            double percent = Slider.GetPercentForValue(Value.Value);
            string startEdge;
            string transform;

            if (Slider.Orientation == "horizontal")
            {
                bool fromLeft = (Slider.ResolvedDirection == "ltr" && !Slider.Inverted) || (Slider.ResolvedDirection == "rtl" && Slider.Inverted);
                startEdge = fromLeft ? "left" : "right";
                transform = "translateX(-50%)";
            }
            else
            {
                bool fromBottom = !Slider.Inverted;
                startEdge = fromBottom ? "bottom" : "top";
                transform = "translateY(50%)";
            }

            string style = $"position: absolute; {startEdge}: {percent.ToString(System.Globalization.CultureInfo.InvariantCulture)}%; transform: {transform};";
            return BuildAttributes(("style", style));
        }
    }

    private Dictionary<string, object> ThumbAttributes
    {
        get
        {
            Dictionary<string, object> attributes = BuildAttributes(
                ("role", "slider"),
                ("aria-label", AriaLabel ?? BradixSliderMath.GetThumbLabel(Index, Slider.CurrentValues.Count)),
                ("aria-valuemin", Slider.Min.ToString(System.Globalization.CultureInfo.InvariantCulture)),
                ("aria-valuenow", Value?.ToString(System.Globalization.CultureInfo.InvariantCulture)),
                ("aria-valuemax", Slider.Max.ToString(System.Globalization.CultureInfo.InvariantCulture)),
                ("aria-orientation", Slider.Orientation),
                ("data-orientation", Slider.Orientation),
                ("data-disabled", Slider.Disabled ? string.Empty : null),
                ("tabindex", Slider.Disabled ? null : 0),
                ("style", Value is null ? "display: none;" : null));

            return attributes;
        }
    }

    private IReadOnlyDictionary<string, object> BubbleInputAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new()
            {
                ["style"] = "display:none;",
                ["value"] = Value?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty
            };

            if (InputName is not null)
                attributes["name"] = InputName;

            if (!string.IsNullOrWhiteSpace(Slider.Form))
                attributes["form"] = Slider.Form;

            return attributes;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Slider.RegisterThumb(this);
            _registered = true;
            _lastRenderedValue = Value;
        }

        if (!_formControlStateResolved || !string.Equals(_lastResolvedForm, Slider.Form, StringComparison.Ordinal))
        {
            bool isFormControl = await Interop.IsFormControl(_element, Slider.Form);
            _formControlStateResolved = true;
            _lastResolvedForm = Slider.Form;

            if (_isFormControl != isFormControl)
            {
                _isFormControl = isFormControl;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        if (ShouldRenderBubbleInput && Value is not null)
        {
            bool dispatchEvent = _hasSyncedBubbleInput && _lastRenderedValue != Value;
            await Interop.SyncSliderBubbleInputValue(_bubbleInputElement, Value.Value, dispatchEvent);
            _hasSyncedBubbleInput = true;
        }

        _lastRenderedValue = Value;
    }

    public ValueTask DisposeAsync()
    {
        if (_registered)
            Slider.UnregisterThumb(this);

        return ValueTask.CompletedTask;
    }

    internal ValueTask FocusAsync() => _element.FocusAsync();

    private Task HandleFocus(FocusEventArgs _)
    {
        Slider.HandleThumbFocus(Index);
        return Task.CompletedTask;
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        return Slider.HandleThumbKeyDownAsync(Index, args);
    }
}
