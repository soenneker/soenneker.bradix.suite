@namespace Soenneker.Bradix

@using System.Threading
@using Microsoft.JSInterop

@inherits BradixComponentBase

@implements IBradixToast

@inject IBradixSuiteInterop Interop

@if (_announceVisible)
{
    <BradixPortal>
        <BradixVisuallyHidden AdditionalAttributes="@AnnounceAttributes">
            @if (_renderAnnounceText)
            {
                @Provider?.Label
                @(" ")
                @for (var i = 0; i < _announceTextSegments.Length; i++)
                {
                    @(_announceTextSegments[i])
                    @if (i < _announceTextSegments.Length - 1)
                    {
                        @(" ")
                    }
                }
            }
        </BradixVisuallyHidden>
    </BradixPortal>
}

@if (Provider?.HasViewport == true)
{
    <CascadingValue Value="this">
        <BradixPresence Present="ShouldPresent"
                        Tag="li"
                        Class="@Class"
                        Style="@ResolvedStyle"
                        AdditionalAttributes="@ToastAttributes"
                        OnElementReferenceCaptured="HandleElementReferenceCaptured"
                        OnExitComplete="HandleExitComplete">
            @ChildContent
        </BradixPresence>
    </CascadingValue>
}

@code {
    private bool _initialized;
    private bool _uncontrolledOpen = true;
    private bool _registered;
    private bool _portalMounted;
    private bool _announceVisible;
    private bool _renderAnnounceText;
    private bool _announceRenderScheduled;
    private bool _announceDismissScheduled;
    private bool _timerPaused;
    private DateTime _timerStartedUtc;
    private double _remainingDuration;
    private CancellationTokenSource? _closeTimerCts;
    private CancellationTokenSource? _announceCts;
    private ElementReference _toastElement;
    private string[] _announceTextSegments = [];
    private double? _pointerStartX;
    private double? _pointerStartY;
    private string? _swipeState;
    private double _swipeMoveX;
    private double _swipeMoveY;
    private double _swipeEndX;
    private double _swipeEndY;
    private bool _lastKnownOpen;
    private long? _activePointerId;
    private bool _delegatedInteractionRegistered;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixToastProvider? Provider { get; set; }

    [CascadingParameter(Name = "BradixToastPortalDisabled")]
    private bool PortalDisabled { get; set; }

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; } = true;

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public BradixToastType Type { get; set; } = BradixToastType.Foreground;

    [Parameter]
    public int? Duration { get; set; }

    [Parameter]
    public EventCallback OnPause { get; set; }

    [Parameter]
    public EventCallback OnResume { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback<BradixToastSwipeEventArgs> OnSwipeStart { get; set; }

    [Parameter]
    public EventCallback<BradixToastSwipeEventArgs> OnSwipeMove { get; set; }

    [Parameter]
    public EventCallback<BradixToastSwipeEventArgs> OnSwipeCancel { get; set; }

    [Parameter]
    public EventCallback<BradixToastSwipeEventArgs> OnSwipeEnd { get; set; }

    internal bool CurrentOpen => Open ?? _uncontrolledOpen;

    private bool ShouldPresent => ForceMount || CurrentOpen;

    private bool IsForeground => Type != BradixToastType.Background;

    private int ResolvedDuration => Duration ?? Provider?.Duration ?? 5000;

    private string ResolvedStyle
    {
        get
        {
            string swipeStyles = "user-select:none;touch-action:none;";
            if (_swipeMoveX != 0)
                swipeStyles += $"--radix-toast-swipe-move-x:{_swipeMoveX}px;";
            if (_swipeMoveY != 0)
                swipeStyles += $"--radix-toast-swipe-move-y:{_swipeMoveY}px;";
            if (_swipeEndX != 0)
                swipeStyles += $"--radix-toast-swipe-end-x:{_swipeEndX}px;";
            if (_swipeEndY != 0)
                swipeStyles += $"--radix-toast-swipe-end-y:{_swipeEndY}px;";

            return string.IsNullOrWhiteSpace(Style) ? swipeStyles : $"{swipeStyles} {Style}";
        }
    }

    private IReadOnlyDictionary<string, object> ToastAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : [];

            attributes["tabindex"] = 0;
            attributes["data-radix-toast-root"] = string.Empty;
            attributes["data-state"] = CurrentOpen ? "open" : "closed";
            attributes["data-swipe-direction"] = (Provider?.SwipeDirection ?? BradixSwipeDirection.Right).Value;

            if (!string.IsNullOrWhiteSpace(_swipeState))
                attributes["data-swipe"] = _swipeState;

            attributes["onpointerdown"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerDown);
            attributes["onpointermove"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerMove);
            attributes["onpointerup"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerUp);
            attributes["onpointercancel"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerCancel);

            return attributes;
        }
    }

    private IReadOnlyDictionary<string, object> AnnounceAttributes => BuildAttributes(
        ("role", "status"),
        ("aria-live", IsForeground ? "assertive" : "polite"));

    protected override void OnParametersSet()
    {
        if (!_initialized)
        {
            _uncontrolledOpen = DefaultOpen;
            _remainingDuration = ResolvedDuration;
            _lastKnownOpen = CurrentOpen;
            _initialized = true;
            return;
        }

        if (_lastKnownOpen != CurrentOpen)
        {
            _lastKnownOpen = CurrentOpen;

            if (CurrentOpen)
            {
                _remainingDuration = ResolvedDuration;
                _timerPaused = false;
                ResetAnnouncement();

                if (_registered && !(Provider?.IsClosePaused ?? false))
                    StartCloseTimer();
            }
            else
            {
                CancelCloseTimer();
                CancelAnnouncement();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_announceVisible && !_renderAnnounceText && !_announceRenderScheduled)
        {
            _announceRenderScheduled = true;
            await Task.Yield();
            _renderAnnounceText = true;
            _announceRenderScheduled = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_announceVisible && _renderAnnounceText && !_announceDismissScheduled)
        {
            _announceDismissScheduled = true;
            CancelAnnouncementTimer();
            _announceCts = new CancellationTokenSource();
            _ = CompleteAnnouncement(_announceCts.Token);
        }
    }

    public async ValueTask DisposeAsync()
    {
        CancelCloseTimer();
        CancelAnnouncement();

        if (_registered)
            Provider?.UnregisterToast(this);

        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_toastElement);

        if (_portalMounted)
            await Interop.UnmountPortal(_toastElement);

        _dotNetReference?.Dispose();
    }

    internal Task Pause()
    {
        if (!CurrentOpen || _timerPaused || ResolvedDuration == int.MaxValue)
            return Task.CompletedTask;

        _timerPaused = true;

        if (_closeTimerCts is not null)
        {
            TimeSpan elapsed = DateTime.UtcNow - _timerStartedUtc;
            _remainingDuration = Math.Max(0, _remainingDuration - elapsed.TotalMilliseconds);
        }

        CancelCloseTimer();

        return OnPause.HasDelegate ? OnPause.InvokeAsync() : Task.CompletedTask;
    }

    internal Task Resume()
    {
        if (!CurrentOpen || !_timerPaused)
            return Task.CompletedTask;

        _timerPaused = false;
        StartCloseTimer();
        return OnResume.HasDelegate ? OnResume.InvokeAsync() : Task.CompletedTask;
    }

    internal async Task Close()
    {
        bool wasFocused = await Interop.IsToastFocused(_toastElement);
        await SetOpen(false);

        if (wasFocused && Provider?.HasViewport == true)
            await Interop.FocusElementById(Provider.ViewportId);
    }

    internal Task TriggerClose() => Close();

    private async Task HandleElementReferenceCaptured(ElementReference element)
    {
        _toastElement = element;
        _dotNetReference ??= DotNetObjectReference.Create<object>(this);

        if (!PortalDisabled && !_portalMounted && Provider?.HasViewport == true)
        {
            await Interop.MountPortal(_toastElement, $"#{Provider.ViewportId}");
            _portalMounted = true;
        }

        if (!_delegatedInteractionRegistered)
        {
            await Interop.RegisterDelegatedInteraction(_toastElement, _dotNetReference, new
            {
                keydown = new
                {
                    method = nameof(HandleDelegatedKeyDown),
                    keys = new[] { "Escape" }
                }
            });
            _delegatedInteractionRegistered = true;
        }

        if (!_registered)
        {
            Provider?.RegisterToast(this);
            _registered = true;
        }

        await UpdateAnnounceText();

        if (CurrentOpen && !(Provider?.IsClosePaused ?? false))
            StartCloseTimer();
    }

    private async Task HandleExitComplete()
    {
        CancelCloseTimer();

        if (_registered)
        {
            Provider?.UnregisterToast(this);
            _registered = false;
        }

        if (_delegatedInteractionRegistered)
        {
            await Interop.UnregisterDelegatedInteraction(_toastElement);
            _delegatedInteractionRegistered = false;
        }

        if (_portalMounted)
        {
            await Interop.UnmountPortal(_toastElement);
            _portalMounted = false;
        }
    }

    private async Task SetOpen(bool open)
    {
        if (CurrentOpen == open)
            return;

        if (Open is null)
            _uncontrolledOpen = open;

        if (open)
        {
            _remainingDuration = ResolvedDuration;
            _timerPaused = false;
            StartCloseTimer();
        }
        else
        {
            CancelCloseTimer();
        }

        if (OpenChanged.HasDelegate)
            await OpenChanged.InvokeAsync(open);

        if (OnOpenChange.HasDelegate)
            await OnOpenChange.InvokeAsync(open);

        await InvokeAsync(StateHasChanged);
    }

    private void StartCloseTimer()
    {
        CancelCloseTimer();

        if (!CurrentOpen || _timerPaused || ResolvedDuration <= 0)
            return;

        if (ResolvedDuration == int.MaxValue || double.IsInfinity(_remainingDuration))
            return;

        if (_remainingDuration <= 0)
            _remainingDuration = ResolvedDuration;

        _closeTimerCts = new CancellationTokenSource();
        CancellationToken token = _closeTimerCts.Token;
        _timerStartedUtc = DateTime.UtcNow;

        _ = RunCloseTimer(_remainingDuration, token);
    }

    private async Task RunCloseTimer(double duration, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(duration), cancellationToken);
            await InvokeAsync(Close);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void CancelCloseTimer()
    {
        if (_closeTimerCts is null)
            return;

        _closeTimerCts.Cancel();
        _closeTimerCts.Dispose();
        _closeTimerCts = null;
    }

    [JSInvokable]
    public async Task HandleDelegatedKeyDown(BradixDelegatedKeyboardEvent args)
    {
        if (!string.Equals(args.Key, "Escape", StringComparison.Ordinal))
            return;

        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        var eventArgs = new BradixEscapeKeyDownEventArgs(args);

        if (OnEscapeKeyDownDetailed.HasDelegate)
            await OnEscapeKeyDownDetailed.InvokeAsync(eventArgs);

        if (!eventArgs.DefaultPrevented)
            await Close();
    }

    private Task HandlePointerDown(PointerEventArgs args)
    {
        if (args.Button != 0)
            return Task.CompletedTask;

        _activePointerId = args.PointerId;
        _pointerStartX = args.ClientX;
        _pointerStartY = args.ClientY;
        _swipeState = null;
        _swipeMoveX = 0;
        _swipeMoveY = 0;
        _swipeEndX = 0;
        _swipeEndY = 0;
        return TryCapturePointer(args.PointerId);
    }

    private async Task HandlePointerMove(PointerEventArgs args)
    {
        if (_pointerStartX is null || _pointerStartY is null || Provider is null)
            return;

        double x = args.ClientX - _pointerStartX.Value;
        double y = args.ClientY - _pointerStartY.Value;
        bool horizontal = Provider.SwipeDirection.Value is BradixSwipeDirection.LeftValue or BradixSwipeDirection.RightValue;
        double clampedX = horizontal ? ClampInDirection(x, Provider.SwipeDirection) : 0;
        double clampedY = horizontal ? 0 : ClampInDirection(y, Provider.SwipeDirection);
        double moveStartBuffer = string.Equals(args.PointerType, "touch", StringComparison.OrdinalIgnoreCase) ? 10 : 2;

        if (string.IsNullOrWhiteSpace(_swipeState))
        {
            if (!IsDeltaInDirection(clampedX, clampedY, Provider.SwipeDirection, moveStartBuffer))
            {
                if (Math.Abs(x) > moveStartBuffer || Math.Abs(y) > moveStartBuffer)
                {
                    _pointerStartX = null;
                    _pointerStartY = null;
                }

                return;
            }

            _swipeState = "start";

            if (OnSwipeStart.HasDelegate)
                await OnSwipeStart.InvokeAsync(new BradixToastSwipeEventArgs { DeltaX = clampedX, DeltaY = clampedY });
        }

        _swipeState = "move";
        _swipeMoveX = clampedX;
        _swipeMoveY = clampedY;

        if (OnSwipeMove.HasDelegate)
            await OnSwipeMove.InvokeAsync(new BradixToastSwipeEventArgs { DeltaX = clampedX, DeltaY = clampedY });

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandlePointerUp(PointerEventArgs _)
    {
        await TryReleasePointer();

        if (Provider is null || string.IsNullOrWhiteSpace(_swipeState))
        {
            ResetSwipeTracking();
            return;
        }

        BradixToastSwipeEventArgs args = new()
        {
            DeltaX = _swipeMoveX,
            DeltaY = _swipeMoveY
        };

        if (IsDeltaInDirection(_swipeMoveX, _swipeMoveY, Provider.SwipeDirection, Provider.SwipeThreshold))
        {
            _swipeState = "end";
            _swipeEndX = _swipeMoveX;
            _swipeEndY = _swipeMoveY;
            _swipeMoveX = 0;
            _swipeMoveY = 0;

            if (OnSwipeEnd.HasDelegate)
                await OnSwipeEnd.InvokeAsync(args);

            await Interop.SuppressNextClick(_toastElement);
            await Close();
        }
        else
        {
            _swipeState = "cancel";
            _swipeMoveX = 0;
            _swipeMoveY = 0;
            _swipeEndX = 0;
            _swipeEndY = 0;

            if (OnSwipeCancel.HasDelegate)
                await OnSwipeCancel.InvokeAsync(args);

            await Interop.SuppressNextClick(_toastElement);
            await InvokeAsync(StateHasChanged);
        }

        ResetSwipeTracking(clearState: false);
    }

    private async Task HandlePointerCancel(PointerEventArgs _)
    {
        await TryReleasePointer();

        if (string.IsNullOrWhiteSpace(_swipeState))
        {
            ResetSwipeTracking();
            return;
        }

        BradixToastSwipeEventArgs args = new()
        {
            DeltaX = _swipeMoveX,
            DeltaY = _swipeMoveY
        };

        _swipeState = "cancel";
        _swipeMoveX = 0;
        _swipeMoveY = 0;
        _swipeEndX = 0;
        _swipeEndY = 0;

        if (OnSwipeCancel.HasDelegate)
            await OnSwipeCancel.InvokeAsync(args);

        ResetSwipeTracking(clearState: false);
        await InvokeAsync(StateHasChanged);
    }

    private void ResetSwipeTracking(bool clearState = true)
    {
        _activePointerId = null;
        _pointerStartX = null;
        _pointerStartY = null;

        if (clearState)
            _swipeState = null;
    }

    private Task TryCapturePointer(long pointerId)
    {
        return pointerId > 0
            ? Interop.CapturePointer(_toastElement, pointerId).AsTask()
            : Task.CompletedTask;
    }

    private async Task TryReleasePointer()
    {
        if (_activePointerId is null || _activePointerId.Value <= 0)
            return;

        long pointerId = _activePointerId.Value;
        _activePointerId = null;
        await Interop.ReleasePointer(_toastElement, pointerId);
    }

    private static bool IsDeltaInDirection(double x, double y, BradixSwipeDirection direction, double threshold)
    {
        double deltaX = Math.Abs(x);
        double deltaY = Math.Abs(y);
        bool isDeltaX = deltaX > deltaY;

        return direction.Value switch
        {
            BradixSwipeDirection.RightValue => isDeltaX && x > threshold,
            BradixSwipeDirection.LeftValue => isDeltaX && x < -threshold,
            BradixSwipeDirection.DownValue => !isDeltaX && y > threshold,
            BradixSwipeDirection.UpValue => !isDeltaX && y < -threshold,
            _ => false
        };
    }

    private static double ClampInDirection(double delta, BradixSwipeDirection direction)
    {
        return direction.Value is BradixSwipeDirection.LeftValue or BradixSwipeDirection.UpValue
            ? Math.Min(0, delta)
            : Math.Max(0, delta);
    }

    private async Task UpdateAnnounceText()
    {
        if (!CurrentOpen)
            return;

        string[] announceText = await Interop.GetToastAnnounceText(_toastElement);

        if (_announceTextSegments.SequenceEqual(announceText, StringComparer.Ordinal))
            return;

        _announceTextSegments = announceText;

        if (_announceTextSegments.Length == 0)
        {
            CancelAnnouncement();
            await InvokeAsync(StateHasChanged);
            return;
        }

        _announceVisible = true;
        _renderAnnounceText = false;
        _announceDismissScheduled = false;
        CancelAnnouncementTimer();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CompleteAnnouncement(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(1), cancellationToken);
            _announceVisible = false;
            _renderAnnounceText = false;
            _announceDismissScheduled = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void ResetAnnouncement()
    {
        _announceVisible = false;
        _renderAnnounceText = false;
        _announceRenderScheduled = false;
        _announceDismissScheduled = false;
        _announceTextSegments = [];
        CancelAnnouncementTimer();
    }

    private void CancelAnnouncement()
    {
        ResetAnnouncement();
    }

    private void CancelAnnouncementTimer()
    {
        _announceCts?.Cancel();
        _announceCts?.Dispose();
        _announceCts = null;
    }
}
