@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixToastAction
<button @onclick="HandleClick"
        @attributes="ButtonAttributes">
    @ChildContent
</button>

@code {
    [CascadingParameter]
    private BradixToast? Toast { get; set; }

    [Parameter]
    public string AltText { get; set; } = string.Empty;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("type", "button"),
        ("disabled", Disabled ? true : null),
        ("data-radix-toast-announce-exclude", string.Empty),
        ("data-radix-toast-announce-alt", AltText));

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(AltText))
            throw new InvalidOperationException("BradixToastAction requires a non-empty AltText.");
    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (Disabled)
            return;

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);

        if (Toast is not null)
            await Toast.TriggerClose();
    }
}
