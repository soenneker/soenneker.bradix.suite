@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixToastClose
<button @onclick="HandleClick"
        @attributes="ButtonAttributes">
    @ChildContent
</button>

@code {
    [CascadingParameter]
    private BradixToast? Toast { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("type", "button"),
        ("disabled", Disabled ? true : null),
        ("data-radix-toast-announce-exclude", string.Empty));

    private async Task HandleClick(MouseEventArgs args)
    {
        if (Disabled)
            return;

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);

        if (Toast is not null)
            await Toast.TriggerClose();
    }
}
