@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixCheckboxIndicator

@if (ForceMount || Checkbox.CurrentChecked != BradixCheckboxCheckedState.Unchecked)
{
    <span @attributes="IndicatorAttributes">
        @ChildContent
    </span>
}

@code {
    [CascadingParameter]
    internal BradixCheckbox Checkbox { get; set; } = null!;

    [Parameter]
    public bool ForceMount { get; set; }

    private Dictionary<string, object> IndicatorAttributes => BuildAttributes(
        ("data-state", GetDataState(Checkbox.CurrentChecked)),
        ("data-disabled", Checkbox.IsDisabled ? string.Empty : null),
        ("style", "pointer-events: none;"));

    private static string GetDataState(BradixCheckboxCheckedState state)
    {
        return state.Value switch
        {
            BradixCheckboxCheckedState.CheckedValue => BradixCheckboxCheckedState.CheckedValue,
            BradixCheckboxCheckedState.IndeterminateValue => BradixCheckboxCheckedState.IndeterminateValue,
            _ => BradixCheckboxCheckedState.UncheckedValue
        };
    }
}
