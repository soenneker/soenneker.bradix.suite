@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

<CascadingValue Value="this">
    <button @ref="_buttonElement"
            @onclick="HandleClick"
            @onclick:stopPropagation="ShouldRenderBubbleInput"
            @attributes="ButtonAttributes">
        @ChildContent
    </button>
</CascadingValue>

@if (ShouldRenderBubbleInput)
{
    <input @ref="_bubbleInputElement"
           @attributes="BubbleInputAttributes" />
}

@code {
    private bool _initialized;
    private bool _delegatedInteractionReady;
    private bool _isFormControl = true;
    private bool _registered;
    private bool _formControlStateResolved;
    private bool _hasSyncedBubbleInput;
    private BradixCheckboxCheckedState _initialUncheckedState;
    private BradixCheckboxCheckedState _uncontrolledChecked;
    private BradixCheckboxCheckedState _lastRenderedState;
    private ElementReference _buttonElement;
    private ElementReference _bubbleInputElement;
    private DotNetObjectReference<object>? _dotNetReference;
    private string? _lastResolvedForm;

    [Parameter]
    public BradixCheckboxCheckedState? Checked { get; set; }

    [Parameter]
    public BradixCheckboxCheckedState DefaultChecked { get; set; } = BradixCheckboxCheckedState.Unchecked;

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Form { get; set; }

    [Parameter]
    public string Value { get; set; } = "on";

    [Parameter]
    public EventCallback<BradixCheckboxCheckedState> CheckedChanged { get; set; }

    [Parameter]
    public EventCallback<BradixCheckboxCheckedState> OnCheckedChange { get; set; }

    internal BradixCheckboxCheckedState CurrentChecked => Checked ?? _uncontrolledChecked;

    internal bool IsDisabled => Disabled;

    internal bool IsChecked => CurrentChecked == BradixCheckboxCheckedState.Checked;

    internal bool IsIndeterminate => CurrentChecked == BradixCheckboxCheckedState.Indeterminate;

    private bool ShouldRenderBubbleInput => _isFormControl || !string.IsNullOrWhiteSpace(Form);

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("type", "button"),
        ("role", "checkbox"),
        ("aria-checked", IsIndeterminate ? "mixed" : IsChecked ? "true" : "false"),
        ("aria-required", Required ? "true" : null),
        ("data-state", GetDataState(CurrentChecked)),
        ("data-disabled", Disabled ? string.Empty : null),
        ("disabled", Disabled ? true : null),
        ("value", Value));

    private Dictionary<string, object> BubbleInputAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new()
            {
                ["type"] = "checkbox",
                ["value"] = Value,
                ["checked"] = IsChecked,
                ["required"] = Required,
                ["disabled"] = Disabled,
                ["tabindex"] = -1,
                ["aria-hidden"] = "true",
                ["style"] = "position:absolute;pointer-events:none;opacity:0;margin:0;transform:translateX(-100%);"
            };

            if (!string.IsNullOrWhiteSpace(Name))
                attributes["name"] = Name;

            if (!string.IsNullOrWhiteSpace(Form))
                attributes["form"] = Form;

            return attributes;
        }
    }

    protected override void OnParametersSet()
    {
        if (_initialized)
            return;

        _initialUncheckedState = DefaultChecked;
        _uncontrolledChecked = DefaultChecked;
        _lastRenderedState = CurrentChecked;
        _initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterCheckboxRoot(_buttonElement, _dotNetReference, Form);
            await Interop.RegisterDelegatedInteraction(_buttonElement, _dotNetReference, new
            {
                readyMethod = nameof(HandleDelegatedInteractionReadyAsync),
                click = new
                {
                    method = nameof(HandleDelegatedClickAsync),
                    currentTargetOnly = false
                },
                keydown = new
                {
                    keys = new[] { "Enter" },
                    preventDefault = true
                }
            });
            _registered = true;
        }

        if (!_formControlStateResolved || !string.Equals(_lastResolvedForm, Form, StringComparison.Ordinal))
        {
            bool isFormControl = await Interop.IsFormControl(_buttonElement, Form);
            _formControlStateResolved = true;
            _lastResolvedForm = Form;

            if (_isFormControl != isFormControl)
            {
                _isFormControl = isFormControl;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        if (ShouldRenderBubbleInput)
        {
            bool dispatchEvent = _hasSyncedBubbleInput && _lastRenderedState != CurrentChecked;
            await Interop.SyncCheckboxBubbleInputState(_bubbleInputElement, IsChecked, IsIndeterminate, dispatchEvent);
            _hasSyncedBubbleInput = true;
        }

        _lastRenderedState = CurrentChecked;
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
        {
            await Interop.UnregisterDelegatedInteraction(_buttonElement);
            await Interop.UnregisterCheckboxRoot(_buttonElement);
        }

        _dotNetReference?.Dispose();
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReadyAsync()
    {
        _delegatedInteractionReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleFormResetAsync()
    {
        if (Checked is not null)
            return Task.CompletedTask;

        _uncontrolledChecked = _initialUncheckedState;
        return InvokeAsync(StateHasChanged);
    }

    private Task HandleClick()
    {
        return Disabled || _delegatedInteractionReady ? Task.CompletedTask : SetCheckedAsync(GetNextState(CurrentChecked));
    }

    [JSInvokable]
    public Task HandleDelegatedClickAsync(BradixDelegatedMouseEvent _)
    {
        return Disabled ? Task.CompletedTask : SetCheckedAsync(GetNextState(CurrentChecked));
    }

    private async Task SetCheckedAsync(BradixCheckboxCheckedState state)
    {
        if (Checked is null)
            _uncontrolledChecked = state;

        if (CheckedChanged.HasDelegate)
            await CheckedChanged.InvokeAsync(state);

        if (OnCheckedChange.HasDelegate)
            await OnCheckedChange.InvokeAsync(state);

        await InvokeAsync(StateHasChanged);
    }

    private static BradixCheckboxCheckedState GetNextState(BradixCheckboxCheckedState state)
    {
        return state == BradixCheckboxCheckedState.Indeterminate
            ? BradixCheckboxCheckedState.Checked
            : state == BradixCheckboxCheckedState.Checked
                ? BradixCheckboxCheckedState.Unchecked
                : BradixCheckboxCheckedState.Checked;
    }

    private static string GetDataState(BradixCheckboxCheckedState state)
    {
        return state switch
        {
            BradixCheckboxCheckedState.Checked => "checked",
            BradixCheckboxCheckedState.Indeterminate => "indeterminate",
            _ => "unchecked"
        };
    }
}
