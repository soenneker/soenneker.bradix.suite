@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

<button @ref="_element"
        @onclick="HandleClick"
        @onmousedown="HandleMouseDown"
        @onfocus="HandleFocus"
        @onkeydown="HandleKeyDown"
        @attributes="ButtonAttributes">
    @ChildContent
</button>

@code {
    private bool _initialized;
    private bool _uncontrolledPressed;
    private bool _delegatedInteractionReady;
    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;

    [Parameter]
    public bool? Pressed { get; set; }

    [Parameter]
    public bool DefaultPressed { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool RenderAriaPressed { get; set; } = true;

    [Parameter]
    public EventCallback<bool> PressedChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnPressedChange { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnMouseDown { get; set; }

    [Parameter]
    public EventCallback<FocusEventArgs> OnFocus { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    internal bool IsPressed => Pressed ?? _uncontrolledPressed;
    internal ElementReference Element => _element;

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("type", "button"),
        ("aria-pressed", RenderAriaPressed ? (IsPressed ? "true" : "false") : null),
        ("data-state", IsPressed ? "on" : "off"),
        ("data-disabled", Disabled ? string.Empty : null),
        ("disabled", Disabled ? true : null));

    protected override void OnParametersSet()
    {
        if (_initialized)
            return;

        _uncontrolledPressed = DefaultPressed;
        _initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterDelegatedInteraction(_element, _dotNetReference, new
        {
            readyMethod = nameof(HandleDelegatedInteractionReady),
            click = new
            {
                method = nameof(HandleDelegatedClick),
                currentTargetOnly = false
            }
        });
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterDelegatedInteraction(_element);
        _dotNetReference?.Dispose();
    }

    internal ValueTask Focus()
    {
        return _element.FocusAsync();
    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);

        if (_delegatedInteractionReady || Disabled)
            return;

        await SetPressed(!IsPressed);
    }

    private Task HandleMouseDown(MouseEventArgs args)
    {
        return OnMouseDown.HasDelegate
            ? OnMouseDown.InvokeAsync(args)
            : Task.CompletedTask;
    }

    private Task HandleFocus(FocusEventArgs args)
    {
        return OnFocus.HasDelegate
            ? OnFocus.InvokeAsync(args)
            : Task.CompletedTask;
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        return OnKeyDown.HasDelegate
            ? OnKeyDown.InvokeAsync(args)
            : Task.CompletedTask;
    }

    private async Task SetPressed(bool pressed)
    {
        if (Pressed is null)
            _uncontrolledPressed = pressed;

        if (PressedChanged.HasDelegate)
            await PressedChanged.InvokeAsync(pressed);

        if (OnPressedChange.HasDelegate)
            await OnPressedChange.InvokeAsync(pressed);

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReady()
    {
        _delegatedInteractionReady = true;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleDelegatedClick(BradixDelegatedMouseEvent _)
    {
        return Disabled ? Task.CompletedTask : SetPressed(!IsPressed);
    }
}
