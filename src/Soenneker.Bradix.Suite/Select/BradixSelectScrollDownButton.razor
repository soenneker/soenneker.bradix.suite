@namespace Soenneker.Bradix

@inherits BradixComponentBase

@if (Content?.CanScrollDown == true)
{
    <div aria-hidden="true"
         @onpointerdown="HandlePointerDownAsync"
         @onpointermove="HandlePointerMoveAsync"
         @onpointerleave="HandlePointerLeave"
         @onpointerup="HandlePointerUp"
         @attributes="ButtonAttributes">
        @ChildContent
    </div>
}

@code {
    private bool _didNotifyContent;

    [CascadingParameter]
    private BradixSelectContent? Content { get; set; }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (Content is null)
        {
            _didNotifyContent = false;
            return Task.CompletedTask;
        }

        if (_didNotifyContent)
            return Task.CompletedTask;

        _didNotifyContent = true;
        return Content.HandleScrollButtonMountedAsync();
    }

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("data-radix-select-scroll-down-button", string.Empty),
        ("style", BuildStyle()));

    private string BuildStyle()
    {
        const string baseStyle = "flex-shrink:0;";
        return string.IsNullOrWhiteSpace(Style) ? baseStyle : $"{baseStyle} {Style}";
    }

    private Task HandlePointerDownAsync(PointerEventArgs _)
    {
        return Content?.StartAutoScrollAsync(false) ?? Task.CompletedTask;
    }

    private Task HandlePointerMoveAsync(PointerEventArgs _)
    {
        return Content?.StartAutoScrollAsync(false) ?? Task.CompletedTask;
    }

    private void HandlePointerLeave(PointerEventArgs _)
    {
        Content?.StopAutoScroll();
    }

    private void HandlePointerUp(PointerEventArgs _)
    {
        Content?.StopAutoScroll();
    }
}
