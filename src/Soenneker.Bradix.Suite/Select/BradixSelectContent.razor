@namespace Soenneker.Bradix
@using System.Threading

@using Microsoft.JSInterop
@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

@if (Select?.CurrentOpen == true || ForceMount)
{
    <BradixRemoveScroll AllowPinchZoom>
        <BradixFocusGuards>
            <BradixFocusScope Trapped="@(Select?.CurrentOpen == true)"
                              PreventMountAutoFocus="true"
                              PreventUnmountAutoFocus="true"
                              OnMountAutoFocusDetailed="@HandleOpenAutoFocus"
                              OnUnmountAutoFocusDetailed="@HandleCloseAutoFocus">
                <BradixDismissableLayer DisableOutsidePointerEvents="@ShouldDisableOutsidePointerEvents"
                                        DismissOnEscapeKeyDown="true"
                                        DismissOnPointerDownOutside="true"
                                        DismissOnFocusOutside="true"
                                        OnDismiss="@HandleDismiss"
                                        OnEscapeKeyDownDetailed="@HandleEscapeKeyDown"
                                        OnPointerDownOutsideDetailed="@HandlePointerDownOutside"
                                        OnFocusOutsideDetailed="@HandleFocusOutside">
                    @if (UseItemAlignedPosition)
                    {
                        <div @ref="_wrapperElement"
                             data-radix-select-position="item-aligned"
                             style="display:flex;flex-direction:column;position:fixed;">
                            <BradixPresence Present="true"
                                            Tag="div"
                                            Id="@Select?.ContentId"
                                            Class="@Class"
                                            Style="@MergedStyle"
                                            AdditionalAttributes="@ContentAttributes"
                                            OnElementReferenceCaptured="@HandleContentElementCaptured">
                                <CascadingValue Value="this">
                                    @ChildContent
                                </CascadingValue>
                            </BradixPresence>
                        </div>
                    }
                    else
                    {
                        <BradixPopperContent Side="@Side"
                                             SideOffset="@SideOffset"
                                             Align="@Align"
                                             AlignOffset="@AlignOffset"
                                             ArrowPadding="@ArrowPadding"
                                             AvoidCollisions="@AvoidCollisions"
                                             CollisionPadding="@CollisionPadding"
                                             HideWhenDetached="@HideWhenDetached"
                                             Style="@PositionerStyle"
                                             OnPlaced="@OnPlaced">
                            <BradixPresence Present="true"
                                            Tag="div"
                                            Id="@Select?.ContentId"
                                            Class="@Class"
                                            Style="@MergedStyle"
                                            AdditionalAttributes="@ContentAttributes"
                                            OnElementReferenceCaptured="@HandleContentElementCaptured">
                                <CascadingValue Value="this">
                                    @ChildContent
                                </CascadingValue>
                            </BradixPresence>
                        </BradixPopperContent>
                    }
                </BradixDismissableLayer>
            </BradixFocusScope>
        </BradixFocusGuards>
    </BradixRemoveScroll>
}
else
{
    <div hidden
         style="display:none;">
        @ChildContent
    </div>
}

@code {
    private bool _didFocusOpenItem;
    private bool _hasContentElement;
    private bool _hasViewportElement;
    private bool _itemAlignedRegistered;
    private bool _viewportRegistered;
    private bool _shouldRepositionOnScrollButton = true;
    private bool _pointerTrackerRegistered;
    private bool _windowDismissRegistered;
    private bool _delegatedInteractionRegistered;
    private bool _hideOthersRegistered;
    private double _viewportScrollTop;
    private double _viewportScrollHeight;
    private double _viewportHeight;
    private CancellationTokenSource? _autoScrollCts;
    private ElementReference _contentElement;
    private ElementReference _viewportElement;
    private ElementReference _wrapperElement;
    private ElementReference _viewportContentElement;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixSelect? Select { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public string Position { get; set; } = "item-aligned";

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public string Align { get; set; } = "start";

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback<BradixPointerDownOutsideEventArgs> OnPointerDownOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnCloseAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnCloseAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnPlaced { get; set; }

    internal bool CanScrollUp => _viewportRegistered && _viewportScrollTop > 0;

    internal bool CanScrollDown => _viewportRegistered && Math.Ceiling(_viewportScrollTop) < Math.Max(_viewportScrollHeight - _viewportHeight, 0);

    private bool UseItemAlignedPosition => !string.Equals(Position, "popper", StringComparison.OrdinalIgnoreCase);
    
    private bool ShouldDisableOutsidePointerEvents => Select?.CurrentOpen == true;

    private string PositionerStyle =>
        "--radix-select-content-transform-origin: var(--radix-popper-transform-origin); --radix-select-content-available-width: var(--radix-popper-available-width); --radix-select-content-available-height: var(--radix-popper-available-height); --radix-select-trigger-width: var(--radix-popper-anchor-width); --radix-select-trigger-height: var(--radix-popper-anchor-height);";

    private string MergedStyle => string.IsNullOrWhiteSpace(Style) ? "display:flex;flex-direction:column;outline:none;" : $"display:flex;flex-direction:column;outline:none; {Style}";

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["role"] = "listbox";
            attributes["dir"] = Select?.ResolvedDirection ?? "ltr";
            attributes["data-state"] = Select?.CurrentOpen == true ? "open" : "closed";
            attributes["data-position"] = UseItemAlignedPosition ? "item-aligned" : "popper";
            attributes["tabindex"] = -1;
            return attributes;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Select?.CurrentOpen == true)
        {
            if (UseItemAlignedPosition)
                await UpdateItemAlignedPosition();

            await EnsurePointerTracker();
            await EnsureWindowDismiss();
            await EnsureHideOthers();
        }
        else
        {
            _didFocusOpenItem = false;
            _shouldRepositionOnScrollButton = true;

            StopAutoScroll();

            if (_itemAlignedRegistered)
            {
                await Interop.UnregisterSelectItemAlignedPosition(_wrapperElement);
                _itemAlignedRegistered = false;
            }

            if (_viewportRegistered)
            {
                await Interop.UnregisterSelectViewport(_viewportElement);
                _viewportRegistered = false;
            }

            if (_pointerTrackerRegistered)
            {
                await Interop.UnregisterSelectContentPointerTracker(_contentElement);
                _pointerTrackerRegistered = false;
            }

            if (_delegatedInteractionRegistered)
            {
                await Interop.UnregisterDelegatedInteraction(_contentElement);
                _delegatedInteractionRegistered = false;
            }

            if (_windowDismissRegistered)
            {
                await Interop.UnregisterSelectWindowDismiss(_contentElement);
                _windowDismissRegistered = false;
            }

            if (_hideOthersRegistered)
            {
                await Interop.UnregisterHideOthers(_contentElement);
                _hideOthersRegistered = false;
            }

            _hasContentElement = false;
            _hasViewportElement = false;
            _contentElement = default;
            _viewportElement = default;
            _wrapperElement = default;
            _viewportContentElement = default;
        }
    }

    public async ValueTask DisposeAsync()
    {
        StopAutoScroll();

        if (_itemAlignedRegistered)
            await Interop.UnregisterSelectItemAlignedPosition(_wrapperElement);

        if (_viewportRegistered)
            await Interop.UnregisterSelectViewport(_viewportElement);

        if (_pointerTrackerRegistered)
            await Interop.UnregisterSelectContentPointerTracker(_contentElement);

        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_contentElement);

        if (_windowDismissRegistered)
            await Interop.UnregisterSelectWindowDismiss(_contentElement);

        if (_hideOthersRegistered)
            await Interop.UnregisterHideOthers(_contentElement);

        _dotNetReference?.Dispose();
    }

    internal async Task RegisterViewport(ElementReference element)
    {
        _viewportElement = element;
        _hasViewportElement = true;

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);
        await Interop.RegisterSelectViewport(_viewportElement, _viewportContentElement, _wrapperElement, _dotNetReference);
        _viewportRegistered = true;
    }

    internal void RegisterViewportContent(ElementReference element)
    {
        _viewportContentElement = element;
    }

    internal Task FocusViewport()
    {
        return Select?.FocusSelectedOrFirstItem() ?? Task.CompletedTask;
    }

    internal async Task FocusContent()
    {
        if (!_hasContentElement)
            return;

        Select?.SetFocusedItem(null);
        await Interop.FocusElementPreventScroll(_contentElement);
    }

    internal Task StartAutoScroll(bool upward)
    {
        StopAutoScroll();
        _autoScrollCts = new CancellationTokenSource();
        return RunAutoScroll(upward, _autoScrollCts.Token);
    }

    internal void StopAutoScroll()
    {
        _autoScrollCts?.Cancel();
        _autoScrollCts?.Dispose();
        _autoScrollCts = null;
    }

    internal async Task HandleScrollButtonMounted()
    {
        if (!UseItemAlignedPosition || !_shouldRepositionOnScrollButton)
            return;

        _shouldRepositionOnScrollButton = false;
        await UpdateItemAlignedPosition();
        await FocusViewport();
    }

    [JSInvokable]
    public Task HandleViewportMetricsChanged(double scrollTop, double scrollHeight, double viewportHeight)
    {
        _viewportScrollTop = scrollTop;
        _viewportScrollHeight = scrollHeight;
        _viewportHeight = viewportHeight;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task HandleTriggerPointerGuardResult(bool suppressSelection, bool shouldClose)
    {
        if (suppressSelection)
            Select?.SuppressNextMouseUpSelection();

        Select?.ClearTriggerPointerDownPosition();

        if (shouldClose && Select is not null)
            await Select.SetOpen(false);

        _pointerTrackerRegistered = false;
    }

    [JSInvokable]
    public async Task HandleWindowDismiss()
    {
        if (Select is not null && Select.CurrentOpen)
            await Select.SetOpen(false);
    }

    private Task HandleContentElementCaptured(ElementReference element)
    {
        _contentElement = element;
        _hasContentElement = true;
        return EnsureDelegatedInteraction();
    }

    private async Task HandleEscapeKeyDown(BradixEscapeKeyDownEventArgs args)
    {
        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        if (OnEscapeKeyDownDetailed.HasDelegate)
            await OnEscapeKeyDownDetailed.InvokeAsync(args);
    }

    private async Task HandlePointerDownOutside(BradixPointerDownOutsideEventArgs args)
    {
        if (OnPointerDownOutside.HasDelegate)
            await OnPointerDownOutside.InvokeAsync();

        if (OnPointerDownOutsideDetailed.HasDelegate)
            await OnPointerDownOutsideDetailed.InvokeAsync(args);
    }

    private Task HandleFocusOutside(BradixFocusOutsideEventArgs args)
    {
        args.PreventDefault();
        return Task.CompletedTask;
    }

    private async Task HandleOpenAutoFocus(BradixAutoFocusEventArgs args)
    {
        if (_didFocusOpenItem || Select is null || args.DefaultPrevented)
            return;

        _didFocusOpenItem = true;
        await Select.FocusSelectedOrFirstItem();
    }

    private async Task HandleCloseAutoFocus(BradixAutoFocusEventArgs args)
    {
        if (OnCloseAutoFocus.HasDelegate)
            await OnCloseAutoFocus.InvokeAsync();

        if (OnCloseAutoFocusDetailed.HasDelegate)
            await OnCloseAutoFocusDetailed.InvokeAsync(args);

        if (args.DefaultPrevented || Select is null)
            return;

        await Select.FocusTrigger();
        args.PreventDefault();
    }

    private Task HandleDismiss()
    {
        return Select?.SetOpen(false) ?? Task.CompletedTask;
    }

    [JSInvokable]
    public async Task HandleDelegatedContentKeyDown(BradixDelegatedKeyboardEvent args)
    {
        if (Select is null || args.CtrlKey || args.AltKey || args.MetaKey)
            return;

        if (args.Key == "Tab")
            return;

        if (args.Key.Length == 1)
        {
            await Select.HandleContentTypeahead(args.Key);
            return;
        }

        if (args.Key is "ArrowUp" or "ArrowDown" or "Home" or "End" or "PageUp" or "PageDown")
            await Select.HandleContentNavigation(args.Key);
    }

    private async Task UpdateItemAlignedPosition()
    {
        if (Select is null || !UseItemAlignedPosition || !_hasContentElement || !_hasViewportElement || !Select.HasTrigger || !Select.HasValueNode)
            return;

        IBradixSelectCollectionItem? selectedItem = Select.GetSelectedOrFirstEnabledItem();

        if (selectedItem is null || !selectedItem.HasItemTextElement)
            return;

        if (_itemAlignedRegistered)
        {
            await Interop.UpdateSelectItemAlignedPosition(_wrapperElement, _contentElement, _viewportElement, Select.TriggerElement, Select.ValueNodeElement,
                selectedItem.ItemElement, selectedItem.ItemTextElement, Select.ResolvedDirection);
        }
        else
        {
            await Interop.RegisterSelectItemAlignedPosition(_wrapperElement, _contentElement, _viewportElement, Select.TriggerElement, Select.ValueNodeElement,
                selectedItem.ItemElement, selectedItem.ItemTextElement, Select.ResolvedDirection);
            _itemAlignedRegistered = true;

            if (OnPlaced.HasDelegate)
                await OnPlaced.InvokeAsync();
        }
    }

    private async Task RunAutoScroll(bool upward, CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            if (Select is null)
                return;

            IBradixSelectCollectionItem? item = Select.GetSelectedOrFirstEnabledItem();

            if (item is not null)
                await Interop.ScrollSelectViewportByItem(_viewportElement, item.ItemElement, upward, cancellationToken);

            try
            {
                await Task.Delay(50, cancellationToken);
            }
            catch (OperationCanceledException)
            {
                return;
            }
        }
    }

    private async Task EnsurePointerTracker()
    {
        if (Select is null || !_hasContentElement || _pointerTrackerRegistered || !Select.HasTriggerPointerDownPosition)
            return;

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);
        await Interop.RegisterSelectContentPointerTracker(_contentElement, _dotNetReference, Select.TriggerPointerDownX, Select.TriggerPointerDownY);
        _pointerTrackerRegistered = true;
    }

    private async Task EnsureDelegatedInteraction()
    {
        if (!_hasContentElement || _delegatedInteractionRegistered)
            return;

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);
        await Interop.RegisterDelegatedInteraction(_contentElement, _dotNetReference, new
        {
            keydown = new
            {
                method = nameof(HandleDelegatedContentKeyDown),
                currentTargetOnly = false,
                preventDefaultKeys = new[] { "Tab", "ArrowUp", "ArrowDown", "Home", "End", "PageUp", "PageDown" }
            }
        });
        _delegatedInteractionRegistered = true;
    }

    private async Task EnsureWindowDismiss()
    {
        if (!_hasContentElement || _windowDismissRegistered)
            return;

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);
        await Interop.RegisterSelectWindowDismiss(_contentElement, _dotNetReference);
        _windowDismissRegistered = true;
    }

    private async Task EnsureHideOthers()
    {
        if (!_hasContentElement || _hideOthersRegistered)
            return;

        await Interop.RegisterHideOthers(_contentElement);
        _hideOthersRegistered = true;
    }

}
