@namespace Soenneker.Bradix
@implements IAsyncDisposable
@implements IBradixSelectCollectionItem
@inherits BradixComponentBase
@inject IBradixIdGenerator IdGenerator
@inject IBradixSuiteInterop Interop
@using Microsoft.JSInterop

<CascadingValue Value="this">
    <div @ref="_element"
         @onclick="HandleClick"
         @onfocus="HandleFocus"
         @onblur="HandleBlur"
         @onkeydown="HandleKeyDown"
         @onpointerdown="HandlePointerDown"
         @onpointerup="HandlePointerUp"
         @onpointermove="HandlePointerMove"
         @onpointerleave="HandlePointerLeave"
         @attributes="ItemAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private ElementReference _element;
    private bool _registered;
    private bool _isFocused;
    private string _pointerType = "mouse";
    private string? _resolvedTextValue;
    private ElementReference _itemTextElement;
    private bool _hasItemTextElement;
    private bool _delegatedInteractionRegistered;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixSelect? Select { get; set; }

    [CascadingParameter]
    private BradixSelectContent? Content { get; set; }

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? TextValue { get; set; }

    internal string? TextId { get; private set; }

    string IBradixSelectCollectionItem.Value => Value;

    bool IBradixSelectCollectionItem.Disabled => Disabled;

    string IBradixSelectCollectionItem.TextValue => string.IsNullOrWhiteSpace(TextValue)
        ? _resolvedTextValue ?? string.Empty
        : TextValue;

    ElementReference IBradixSelectCollectionItem.ItemElement => _element;

    ElementReference IBradixSelectCollectionItem.ItemTextElement => _itemTextElement;

    bool IBradixSelectCollectionItem.HasItemTextElement => _hasItemTextElement;

    internal bool IsSelected => string.Equals(Select?.CurrentValue, Value, StringComparison.Ordinal);

    private Dictionary<string, object> ItemAttributes => BuildAttributes(
        ("role", "option"),
        ("aria-labelledby", TextId),
        ("aria-selected", IsSelected && _isFocused ? "true" : "false"),
        ("aria-disabled", Disabled ? "true" : null),
        ("data-state", IsSelected ? "checked" : "unchecked"),
        ("data-highlighted", _isFocused ? string.Empty : null),
        ("data-disabled", Disabled ? string.Empty : null),
        ("tabindex", Disabled ? null : Select?.IsFocusedItem(this) == true ? 0 : -1));

    protected override void OnInitialized()
    {
        TextId ??= IdGenerator.New("bradix-select-item-text");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Select is not null)
        {
            if (string.IsNullOrWhiteSpace(Value))
                throw new InvalidOperationException("A BradixSelectItem value cannot be empty.");

            Select.RegisterItem(this);
            _registered = true;
        }

        if (Select?.CurrentOpen == true && !_delegatedInteractionRegistered)
        {
            _dotNetReference ??= DotNetObjectReference.Create<object>(this);
            await Interop.RegisterDelegatedInteraction(_element, _dotNetReference, new
            {
                keydown = new
                {
                    currentTargetOnly = true,
                    preventDefaultKeys = new[] { " ", "Spacebar" }
                }
            });
            _delegatedInteractionRegistered = true;
        }
        else if (Select?.CurrentOpen != true && _delegatedInteractionRegistered)
        {
            await Interop.UnregisterDelegatedInteraction(_element);
            _delegatedInteractionRegistered = false;
        }

        if (string.IsNullOrWhiteSpace(TextValue) && !_hasItemTextElement && string.IsNullOrWhiteSpace(_resolvedTextValue))
        {
            string textContent = await Interop.GetTextContent(_element);

            if (!string.Equals(_resolvedTextValue, textContent, StringComparison.Ordinal))
            {
                _resolvedTextValue = textContent;

                if (Select is not null)
                    await Select.NotifyItemTextChanged();
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_element);

        if (_registered)
            Select?.UnregisterItem(this);

        _dotNetReference?.Dispose();
    }

    ValueTask IBradixSelectCollectionItem.Focus() => Interop.FocusElementPreventScroll(_element);

    ValueTask IBradixSelectCollectionItem.ScrollIntoView() => Interop.ScrollElementIntoViewNearest(_element);

    internal async Task NotifyResolvedText(string? text)
    {
        if (string.IsNullOrWhiteSpace(TextValue))
            _resolvedTextValue = text;

        if (Select is not null)
            await Select.NotifyItemTextChanged();
    }

    internal void RegisterTextElement(ElementReference element)
    {
        _itemTextElement = element;
        _hasItemTextElement = true;
    }

    private async Task HandleClick(MouseEventArgs _)
    {
        if (Disabled || Select is null || _pointerType == "mouse")
            return;

        await Select.SetValue(Value);
        await Select.SetOpen(false);
        await Select.FocusTrigger();
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (Disabled || Select is null)
            return Task.CompletedTask;

        _isFocused = true;
        Select.SetFocusedItem(Value);
        return InvokeAsync(StateHasChanged);
    }

    private Task HandleBlur(FocusEventArgs _)
    {
        _isFocused = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Disabled || Select is null || args.CtrlKey || args.AltKey || args.MetaKey)
            return;

        bool isTypingAhead = Select.HasActiveTypeahead;

        if (isTypingAhead && args.Key is " " or "Spacebar")
            return;

        if (args.Key is " " or "Spacebar" or "Enter")
        {
            await Select.SetValue(Value);
            await Select.SetOpen(false);
            await Select.FocusTrigger();
            return;
        }

    }

    private Task HandlePointerDown(PointerEventArgs args)
    {
        _pointerType = args.PointerType ?? "mouse";
        return Task.CompletedTask;
    }

    private async Task HandlePointerUp(PointerEventArgs _)
    {
        if (Disabled || Select is null || _pointerType != "mouse")
            return;

        if (Select.TryConsumeSuppressedMouseUpSelection())
            return;

        await Select.SetValue(Value);
        await Select.SetOpen(false);
        await Select.FocusTrigger();
    }

    private async Task HandlePointerMove(PointerEventArgs args)
    {
        _pointerType = args.PointerType ?? _pointerType;

        if (Disabled || Select is null || !string.Equals(_pointerType, "mouse", StringComparison.Ordinal))
        {
            if (Disabled)
                await (Content?.FocusContent() ?? Task.CompletedTask);

            return;
        }

        Select.SetFocusedItem(Value);
        await Interop.FocusElementPreventScroll(_element);
    }

    private async Task HandlePointerLeave(PointerEventArgs _)
    {
        if (Content is null || !string.Equals(_pointerType, "mouse", StringComparison.Ordinal))
            return;

        await Content.FocusContent();
    }
}
