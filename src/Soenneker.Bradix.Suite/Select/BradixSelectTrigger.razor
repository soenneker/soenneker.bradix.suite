@namespace Soenneker.Bradix

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop
@using Microsoft.JSInterop

<BradixPopperAnchor>
    <button @ref="_button"
            @onclick="HandleClickAsync"
            @onpointerdown="HandlePointerDownAsync"
            @onkeydown="HandleKeyDownAsync"
            @attributes="TriggerAttributes">
        @ChildContent
    </button>
</BradixPopperAnchor>

@code {
    private ElementReference _button;
    private bool _delegatedInteractionRegistered;
    private string _pointerType = "touch";
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixSelect? Select { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private bool IsDisabled => Select?.Disabled == true || Disabled;

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("type", "button"),
        ("role", "combobox"),
        ("aria-controls", Select?.ContentId),
        ("aria-expanded", Select?.CurrentOpen == true ? "true" : "false"),
        ("aria-required", Select?.Required == true ? "true" : null),
        ("aria-autocomplete", "none"),
        ("dir", Select?.ResolvedDirection),
        ("data-state", Select?.CurrentOpen == true ? "open" : "closed"),
        ("data-disabled", IsDisabled ? string.Empty : null),
        ("data-placeholder", Select?.ShouldShowPlaceholder == true ? string.Empty : null),
        ("disabled", IsDisabled ? true : null));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Select?.RegisterTrigger(_button);
            _dotNetReference ??= DotNetObjectReference.Create<object>(this);
            await Interop.RegisterDelegatedInteraction(_button, _dotNetReference, new
            {
                keydown = new
                {
                    currentTargetOnly = true,
                    preventDefaultKeys = new[] { " ", "Spacebar", "Enter", "ArrowUp", "ArrowDown" }
                }
            });
            _delegatedInteractionRegistered = true;
        }

    }

    public async ValueTask DisposeAsync()
    {
        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_button);

        _dotNetReference?.Dispose();
    }

    private async Task HandleClickAsync(MouseEventArgs _)
    {
        if (IsDisabled || Select is null)
            return;

        await _button.FocusAsync();

        if (!Select.CurrentOpen && !string.Equals(_pointerType, "mouse", StringComparison.Ordinal))
            await Select.OpenFromTriggerAsync();
    }

    private async Task HandlePointerDownAsync(PointerEventArgs args)
    {
        if (IsDisabled || Select is null)
            return;

        _pointerType = args.PointerType ?? "touch";

        if (args.Button == 0 && !args.CtrlKey && string.Equals(_pointerType, "mouse", StringComparison.Ordinal))
            await Select.OpenFromTriggerAsync(args.PageX, args.PageY);
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        if (IsDisabled || Select is null || args.CtrlKey || args.AltKey || args.MetaKey)
            return;

        if (!Select.CurrentOpen && args.Key.Length == 1)
        {
            await Select.HandleTriggerTypeaheadAsync(args.Key);
            return;
        }

        if (args.Key is " " or "Spacebar" or "Enter" or "ArrowUp" or "ArrowDown")
            await Select.OpenFromTriggerAsync();
    }

    [JSInvokable]
    public Task HandleDelegatedInteractionReadyAsync()
    {
        return Task.CompletedTask;
    }
}
