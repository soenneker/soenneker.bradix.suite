@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixSelectTrigger

@inject IBradixSuiteInterop Interop
<BradixDismissableLayerBranch>
    <BradixPopperAnchor>
        <button @ref="_button"
                @onclick="HandleClick"
                @onpointerdown="HandlePointerDown"
                @onpointerdown:preventDefault="PreventPointerDownDefault"
                @onkeydown="HandleKeyDown"
                @attributes="TriggerAttributes">
            @ChildContent
        </button>
    </BradixPopperAnchor>
</BradixDismissableLayerBranch>

@code {
    private ElementReference _button;
    private bool _delegatedInteractionRegistered;
    private string _pointerType = "touch";
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixSelect? Select { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private bool IsDisabled => Select?.Disabled == true || Disabled;
    private bool PreventPointerDownDefault => !IsDisabled && Select?.CurrentOpen != true;

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("type", "button"),
        ("role", "combobox"),
        ("aria-haspopup", "listbox"),
        ("aria-controls", Select?.ContentId),
        ("aria-expanded", Select?.CurrentOpen == true ? "true" : "false"),
        ("aria-required", Select?.Required == true ? "true" : null),
        ("aria-autocomplete", "none"),
        ("dir", Select?.ResolvedDirection),
        ("data-state", Select?.CurrentOpen == true ? "open" : "closed"),
        ("data-disabled", IsDisabled ? string.Empty : null),
        ("data-placeholder", Select?.ShouldShowPlaceholder == true ? string.Empty : null),
        ("disabled", IsDisabled ? true : null));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Select?.RegisterTrigger(_button);
            _dotNetReference ??= DotNetObjectReference.Create<object>(this);
            await Interop.RegisterDelegatedInteraction(_button, _dotNetReference, new
            {
                pointerdown = new
                {
                    currentTargetOnly = true,
                    filter = "primaryMousePointerDown",
                    preventDefault = true,
                    method = nameof(HandleDelegatedPointerDown)
                },
                keydown = new
                {
                    currentTargetOnly = true,
                    preventDefaultKeys = new[] { " ", "Spacebar", "Enter", "ArrowUp", "ArrowDown", "Home", "End", "PageUp", "PageDown" }
                }
            });
            _delegatedInteractionRegistered = true;
        }

    }

    public async ValueTask DisposeAsync()
    {
        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_button);

        _dotNetReference?.Dispose();
    }

    private async Task HandleClick(MouseEventArgs _)
    {
        if (IsDisabled || Select is null)
            return;

        if (string.Equals(_pointerType, "mouse", StringComparison.Ordinal))
            return;

        await _button.FocusAsync();

        if (!Select.CurrentOpen)
            await Select.OpenFromTrigger();
    }

    private async Task HandlePointerDown(PointerEventArgs args)
    {
        if (IsDisabled || Select is null)
            return;

        _pointerType = args.PointerType ?? "touch";

        if (string.Equals(_pointerType, "mouse", StringComparison.Ordinal) && args.Button == 0 && !args.CtrlKey && !Select.CurrentOpen)
            await Select.OpenFromTrigger(args.PageX, args.PageY);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (IsDisabled || Select is null || args.CtrlKey || args.AltKey || args.MetaKey)
            return;

        if (!Select.CurrentOpen && args.Key.Length == 1)
        {
            await Select.HandleTriggerTypeahead(args.Key);
            return;
        }

        if (Select.CurrentOpen)
        {
            if (args.Key.Length == 1)
            {
                await Select.HandleContentTypeahead(args.Key);
                return;
            }

            if (args.Key is "ArrowUp" or "ArrowDown" or "Home" or "End" or "PageUp" or "PageDown")
            {
                await Select.HandleContentNavigation(args.Key);
                return;
            }
        }

        if (args.Key is " " or "Spacebar" or "Enter" or "ArrowUp" or "ArrowDown")
            await Select.OpenFromTrigger();
    }

    [JSInvokable]
    public Task HandleDelegatedPointerDown(BradixDelegatedMouseEvent args)
    {
        if (IsDisabled || Select is null)
            return Task.CompletedTask;

        _pointerType = string.IsNullOrWhiteSpace(args.PointerType) ? "mouse" : args.PointerType;
        return Select.OpenFromTrigger(args.PageX, args.PageY);
    }
}
