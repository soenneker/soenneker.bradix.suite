@namespace Soenneker.Bradix

@using System.Linq
@using Soenneker.Blazor.Utils.Ids

@inherits BradixComponent

@implements IBradixSelect

@inject IBradixSuiteInterop Interop
<BradixPopper>
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</BradixPopper>

@if (ShouldRenderBubbleSelect)
{
    <select @ref="_bubbleSelectElement"
            @onchange="HandleNativeChange"
            @attributes="BubbleSelectAttributes">
        @if (string.IsNullOrWhiteSpace(CurrentValue))
        {
            <option value="" selected="true"></option>
        }

        @foreach (BradixCollectionEntry<IBradixSelectCollectionItem> entry in _items.Snapshot())
        {
            <option value="@entry.Item.Value"
                    disabled="@entry.Item.Disabled"
                    selected="@string.Equals(entry.Item.Value, CurrentValue, StringComparison.Ordinal)">
                @entry.Item.TextValue
            </option>
        }
    </select>
}

@code {
    private readonly BradixCollectionRegistry<IBradixSelectCollectionItem> _items = new();
    private readonly BradixTypeaheadBuffer _typeahead = new();
    private bool _initialized;
    private bool _refreshQueued;
    private bool _uncontrolledOpen;
    private string? _uncontrolledValue;
    private ElementReference _bubbleSelectElement;
    private bool _hasBubbleSelectElement;
    private bool _bubbleSelectValueInitialized;
    private string? _lastBubbleSelectValue;
    private bool _isFormControl = true;
    private bool _formControlStateResolved;
    private string? _lastResolvedForm;
    private (double X, double Y)? _triggerPointerDownPosition;
    private bool _suppressNextMouseUpSelection;
    private string? _currentText;

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string?> OnValueChange { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? AutoComplete { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public string? Form { get; set; }

    internal string? BaseId { get; private set; }

    internal bool CurrentOpen => Open ?? _uncontrolledOpen;

    internal string? CurrentValue => Value ?? _uncontrolledValue;

    internal bool HasActiveTypeahead => !string.IsNullOrEmpty(_typeahead.CurrentSearch);

    internal string ContentId => BlazorIdGenerator.Child(BaseId!, "content");

    internal string ResolvedDirection => Dir == "rtl" ? "rtl" : CascadedDirection == "rtl" ? "rtl" : "ltr";

    internal string CurrentText => _currentText ?? string.Empty;

    internal bool ShouldShowPlaceholder => string.IsNullOrWhiteSpace(CurrentValue);

    internal ElementReference TriggerElement { get; private set; }

    internal bool HasTrigger { get; private set; }

    internal ElementReference ValueNodeElement { get; private set; }

    internal bool HasValueNode { get; private set; }

    internal bool ValueNodeHasChildren { get; private set; }

    internal string? CurrentFocusedItemValue { get; private set; }

    internal bool HasTriggerPointerDownPosition => _triggerPointerDownPosition is not null;

    internal double TriggerPointerDownX => _triggerPointerDownPosition?.X ?? 0;

    internal double TriggerPointerDownY => _triggerPointerDownPosition?.Y ?? 0;

    private bool ShouldRenderBubbleSelect => _isFormControl;

    private Dictionary<string, object> BubbleSelectAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new()
            {
                ["tabindex"] = -1,
                ["aria-hidden"] = "true",
                ["required"] = Required,
                ["disabled"] = Disabled,
                ["style"] = "position:absolute;pointer-events:none;opacity:0;margin:0;transform:translateX(-100%);"
            };

            if (!string.IsNullOrWhiteSpace(Name))
                attributes["name"] = Name;

            if (!string.IsNullOrWhiteSpace(Form))
                attributes["form"] = Form;

            if (!string.IsNullOrWhiteSpace(AutoComplete))
                attributes["autocomplete"] = AutoComplete;

            return attributes;
        }
    }

    protected override void OnInitialized()
    {
        BaseId ??= BlazorIdGenerator.New("bradix-select");
    }

    protected override void OnParametersSet()
    {
        if (!_initialized)
        {
            _uncontrolledOpen = DefaultOpen;
            _uncontrolledValue = DefaultValue;
            _initialized = true;
        }

        UpdateCurrentText();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (HasTrigger && (!_formControlStateResolved || !string.Equals(_lastResolvedForm, Form, StringComparison.Ordinal)))
        {
            bool isFormControl = await Interop.IsFormControl(TriggerElement, Form);
            _formControlStateResolved = true;
            _lastResolvedForm = Form;

            if (_isFormControl != isFormControl)
            {
                _isFormControl = isFormControl;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        if (ShouldRenderBubbleSelect)
        {
            RegisterBubbleSelect(_bubbleSelectElement);
            await SyncBubbleSelectValue();
        }
        else
        {
            _hasBubbleSelectElement = false;
            _bubbleSelectValueInitialized = false;
            _lastBubbleSelectValue = null;
        }
    }

    internal void RegisterItem(IBradixSelectCollectionItem item)
    {
        _items.Register(item.Value, item);

        if (string.Equals(item.Value, CurrentValue, StringComparison.Ordinal))
            UpdateCurrentText(item.TextValue);

        if (ShouldRenderBubbleSelect || string.Equals(item.Value, CurrentValue, StringComparison.Ordinal))
            QueueRefresh();
    }

    internal void UnregisterItem(IBradixSelectCollectionItem item)
    {
        _items.Unregister(item.Value);

        if (string.Equals(CurrentFocusedItemValue, item.Value, StringComparison.Ordinal))
            CurrentFocusedItemValue = null;

        if (ShouldRenderBubbleSelect || string.Equals(CurrentValue, item.Value, StringComparison.Ordinal))
            QueueRefresh();
    }

    internal void RegisterTrigger(ElementReference element)
    {
        TriggerElement = element;
        HasTrigger = true;
    }

    internal void RegisterValueNode(ElementReference element)
    {
        ValueNodeElement = element;
        HasValueNode = true;
    }

    internal void RegisterBubbleSelect(ElementReference element)
    {
        _bubbleSelectElement = element;
        _hasBubbleSelectElement = true;
    }

    internal void SetValueNodeHasChildren(bool hasChildren)
    {
        if (ValueNodeHasChildren == hasChildren)
            return;

        ValueNodeHasChildren = hasChildren;
        _ = InvokeAsync(StateHasChanged);
    }

    internal Task FocusTrigger()
    {
        return HasTrigger ? Interop.FocusElementPreventScroll(TriggerElement).AsTask() : Task.CompletedTask;
    }

    internal async Task SetValue(string? value)
    {
        if (string.Equals(CurrentValue, value, StringComparison.Ordinal))
            return;

        UpdateCurrentText(GetItemText(value));

        if (Value is null)
            _uncontrolledValue = value;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(value);

        if (OnValueChange.HasDelegate)
            await OnValueChange.InvokeAsync(value);

        await InvokeAsync(StateHasChanged);
    }

    internal async Task SetOpen(bool open)
    {
        if (CurrentOpen == open)
            return;

        if (Open is null)
            _uncontrolledOpen = open;

        if (!open)
        {
            _typeahead.Reset();
            _triggerPointerDownPosition = null;
            _suppressNextMouseUpSelection = false;
        }

        if (OpenChanged.HasDelegate)
            await OpenChanged.InvokeAsync(open);

        if (OnOpenChange.HasDelegate)
            await OnOpenChange.InvokeAsync(open);

        await InvokeAsync(StateHasChanged);
    }

    internal Task ToggleOpen()
    {
        return SetOpen(!CurrentOpen);
    }

    internal Task OpenFromTrigger(double? pageX = null, double? pageY = null)
    {
        _typeahead.Reset();

        if (pageX.HasValue && pageY.HasValue)
            _triggerPointerDownPosition = (pageX.Value, pageY.Value);
        else
            _triggerPointerDownPosition = null;

        return SetOpen(true);
    }

    internal void ClearTriggerPointerDownPosition()
    {
        _triggerPointerDownPosition = null;
    }

    internal void SetFocusedItem(string? value)
    {
        if (string.Equals(CurrentFocusedItemValue, value, StringComparison.Ordinal))
            return;

        CurrentFocusedItemValue = value;
        _ = InvokeAsync(StateHasChanged);
    }

    internal bool IsFocusedItem(IBradixSelectCollectionItem item)
    {
        return string.Equals(CurrentFocusedItemValue, item.Value, StringComparison.Ordinal);
    }

    internal async Task FocusSelectedOrFirstItem()
    {
        IBradixSelectCollectionItem? target = GetSelectedOrFirstEnabledItem();

        if (target is null)
            return;

        await FocusItem(target);
    }

    internal async Task FocusFirstItem()
    {
        IBradixSelectCollectionItem? first = GetEnabledItems().FirstOrDefault();

        if (first is null)
            return;

        await FocusItem(first);
    }

    internal async Task FocusLastItem()
    {
        IBradixSelectCollectionItem? last = GetEnabledItems().LastOrDefault();

        if (last is null)
            return;

        await FocusItem(last);
    }

    internal async Task HandleTriggerTypeahead(string key)
    {
        string search = _typeahead.Append(key);
        List<IBradixSelectCollectionItem> enabledItems = GetEnabledItems();
        IBradixSelectCollectionItem? currentItem = enabledItems.FirstOrDefault(item => string.Equals(item.Value, CurrentValue, StringComparison.Ordinal));
        IBradixSelectCollectionItem? nextItem = BradixTypeaheadMatcher.FindNextItem(enabledItems, search, currentItem, item => item.TextValue);

        if (nextItem is null)
            return;

        await SetValue(nextItem.Value);
    }

    internal async Task HandleContentTypeahead(string key)
    {
        string search = _typeahead.Append(key);
        List<IBradixSelectCollectionItem> enabledItems = GetEnabledItems();
        IBradixSelectCollectionItem? currentItem = enabledItems.FirstOrDefault(item => string.Equals(item.Value, CurrentFocusedItemValue, StringComparison.Ordinal));
        IBradixSelectCollectionItem? nextItem = BradixTypeaheadMatcher.FindNextItem(enabledItems, search, currentItem, item => item.TextValue);

        if (nextItem is null)
            return;

        await FocusItem(nextItem);
    }

    internal async Task HandleContentNavigation(string key)
    {
        switch (key)
        {
            case "Home":
            case "PageUp":
                await FocusFirstItem();
                return;
            case "End":
            case "PageDown":
                await FocusLastItem();
                return;
        }

        List<IBradixSelectCollectionItem> enabledItems = GetEnabledItems();
        IBradixSelectCollectionItem? currentItem = enabledItems.FirstOrDefault(item => string.Equals(item.Value, CurrentFocusedItemValue, StringComparison.Ordinal))
            ?? enabledItems.FirstOrDefault(item => string.Equals(item.Value, CurrentValue, StringComparison.Ordinal));

        if (currentItem is null)
            return;

        int currentIndex = enabledItems.IndexOf(currentItem);

        if (currentIndex < 0)
            return;

        if (!BradixRovingFocusNavigator.TryGetTargetIndex(key, "vertical", ResolvedDirection, currentIndex, enabledItems.Count, true, out int targetIndex))
            return;

        IBradixSelectCollectionItem target = enabledItems[targetIndex];
        await FocusItem(target);
    }

    internal Task NotifyItemTextChanged()
    {
        UpdateCurrentText();

        if (ShouldRenderBubbleSelect || !ValueNodeHasChildren)
            QueueRefresh();

        return Task.CompletedTask;
    }

    private string? GetItemText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        return _items.Snapshot()
            .Select(entry => entry.Item)
            .FirstOrDefault(item => string.Equals(item.Value, value, StringComparison.Ordinal))
            ?.TextValue;
    }

    private void UpdateCurrentText(string? preferredText = null)
    {
        if (string.IsNullOrWhiteSpace(CurrentValue))
        {
            _currentText = string.Empty;
            return;
        }

        if (!string.IsNullOrWhiteSpace(preferredText))
        {
            _currentText = preferredText;
            return;
        }

        string? resolvedText = GetItemText(CurrentValue);

        if (!string.IsNullOrWhiteSpace(resolvedText))
            _currentText = resolvedText;
    }

    internal void SuppressNextMouseUpSelection()
    {
        _suppressNextMouseUpSelection = true;
    }

    private async Task FocusItem(IBradixSelectCollectionItem item)
    {
        CurrentFocusedItemValue = item.Value;
        await item.ScrollIntoView();
        await item.Focus();
        await InvokeAsync(StateHasChanged);
    }

    internal bool TryConsumeSuppressedMouseUpSelection()
    {
        if (!_suppressNextMouseUpSelection)
            return false;

        _suppressNextMouseUpSelection = false;
        return true;
    }

    internal IBradixSelectCollectionItem? GetSelectedOrFirstEnabledItem()
    {
        List<IBradixSelectCollectionItem> enabledItems = GetEnabledItems();
        return enabledItems.FirstOrDefault(item => string.Equals(item.Value, CurrentValue, StringComparison.Ordinal))
            ?? enabledItems.FirstOrDefault();
    }

    internal IBradixSelectCollectionItem? GetSelectedItem()
    {
        return _items.Snapshot()
            .Select(entry => entry.Item)
            .FirstOrDefault(item => string.Equals(item.Value, CurrentValue, StringComparison.Ordinal));
    }

    private Task HandleNativeChange(ChangeEventArgs args)
    {
        string? value = args.Value?.ToString();
        return SetValue(string.IsNullOrEmpty(value) ? null : value);
    }

    private void QueueRefresh()
    {
        if (_refreshQueued)
            return;

        _refreshQueued = true;

        _ = InvokeAsync(() =>
        {
            _refreshQueued = false;
            StateHasChanged();
        });
    }

    private List<IBradixSelectCollectionItem> GetEnabledItems()
    {
        return _items.Snapshot()
            .Select(entry => entry.Item)
            .Where(item => !item.Disabled)
            .ToList();
    }

    private async Task SyncBubbleSelectValue()
    {
        if (!_hasBubbleSelectElement)
            return;

        string? nextValue = CurrentValue;
        bool dispatchEvent = _bubbleSelectValueInitialized && !string.Equals(_lastBubbleSelectValue, nextValue, StringComparison.Ordinal);

        await Interop.SyncSelectBubbleInputValue(_bubbleSelectElement, nextValue, dispatchEvent);

        _lastBubbleSelectValue = nextValue;
        _bubbleSelectValueInitialized = true;
    }
}
