@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixAspectRatio
<div style="@WrapperStyle" data-radix-aspect-ratio-wrapper="">
    <div @attributes="ContentAttributes">
        @ChildContent
    </div>
</div>

@code {
    [Parameter]
    public double Ratio { get; set; } = 1;

    private double SafeRatio => Ratio > 0 ? Ratio : 1;

    private string WrapperStyle => $"position: relative; width: 100%; padding-bottom: {100 / SafeRatio:F6}%;";

    private Dictionary<string, object> ContentAttributes => BuildAttributes(
        ("style", BuildContentStyle()));

    private string BuildContentStyle()
    {
        const string contentStyle = "position: absolute; top: 0; right: 0; bottom: 0; left: 0;";

        return string.IsNullOrWhiteSpace(Style)
            ? contentStyle
            : $"{contentStyle} {Style}";
    }
}
