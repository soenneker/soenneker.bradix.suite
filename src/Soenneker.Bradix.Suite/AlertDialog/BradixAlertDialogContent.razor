@namespace Soenneker.Bradix

@implements IBradixAlertDialogContent

@inject IBradixSuiteInterop Interop
<CascadingValue Value="this">
    <BradixDialogContent Class="@Class"
                         Style="@Style"
                         Id="@Id"
                         AdditionalAttributes="@AdditionalAttributes"
                         ForceMount="ForceMount"
                         Role="alertdialog"
                         PreventMountAutoFocus="true"
                         CloseOnEscapeKeyDown="CloseOnEscapeKeyDown"
                         CloseOnPointerDownOutside="false"
                         CloseOnFocusOutside="false"
                         OnOpenAutoFocusDetailed="@HandleOpenAutoFocus"
                         OnElementReferenceCaptured="@HandleContentElementCaptured"
                         OnPointerDownOutsideDetailed="@HandlePointerDownOutside"
                         OnInteractOutsideDetailed="@HandleInteractOutside"
                         OnCloseAutoFocus="OnCloseAutoFocus"
                         OnCloseAutoFocusDetailed="@OnCloseAutoFocusDetailed"
                         OnEscapeKeyDown="OnEscapeKeyDown"
                         OnEscapeKeyDownDetailed="@OnEscapeKeyDownDetailed"
                         OnFocusOutside="OnFocusOutside"
                         OnFocusOutsideDetailed="@OnFocusOutsideDetailed">
        @ChildContent
    </BradixDialogContent>
</CascadingValue>

@code {
    private ElementReference _cancelElement;
    private ElementReference _contentElement;
    private bool _hasCancelElement;
    private bool _pendingCancelFocus;
    private bool _didFocusCancelForCurrentOpen;

    [CascadingParameter]
    private BradixDialog? Dialog { get; set; }

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnOpenAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnCloseAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnCloseAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public bool CloseOnEscapeKeyDown { get; set; } = true;

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback<BradixFocusOutsideEventArgs> OnFocusOutsideDetailed { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    internal void RegisterCancelElement(ElementReference element)
    {
        _cancelElement = element;
        _hasCancelElement = true;
        _ = InvokeAsync(async () =>
        {
            await FocusCancelIfPendingAsync();
            await InvokeAsync(StateHasChanged);
        });
    }

    private Task HandleContentElementCaptured(ElementReference element)
    {
        _contentElement = element;
        return Task.CompletedTask;
    }

    private async Task HandleOpenAutoFocus(BradixAutoFocusEventArgs args)
    {
        if (OnOpenAutoFocus.HasDelegate)
            await OnOpenAutoFocus.InvokeAsync();

        if (OnOpenAutoFocusDetailed.HasDelegate)
            await OnOpenAutoFocusDetailed.InvokeAsync(args);

        if (args.DefaultPrevented)
            return;

        args.PreventDefault();
        _pendingCancelFocus = true;
        await FocusCancelIfPendingAsync();
    }

    private Task HandlePointerDownOutside(BradixPointerDownOutsideEventArgs args)
    {
        args.PreventDefault();
        _pendingCancelFocus = true;
        _ = InvokeAsync(FocusCancelIfPendingAsync);
        return Task.CompletedTask;
    }

    private Task HandleInteractOutside(BradixInteractOutsideEventArgs args)
    {
        args.PreventDefault();
        _pendingCancelFocus = true;
        _ = InvokeAsync(FocusCancelIfPendingAsync);
        return Task.CompletedTask;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            if (Dialog?.CurrentOpen == true && !_didFocusCancelForCurrentOpen)
                _ = InvokeAsync(FocusCancelForOpenAsync);
            else if (Dialog?.CurrentOpen != true)
                _didFocusCancelForCurrentOpen = false;
        }

        if (_pendingCancelFocus)
            _ = InvokeAsync(FocusCancelIfPendingAsync);

        return Task.CompletedTask;
    }

    private async Task FocusCancelIfPendingAsync()
    {
        if (!_pendingCancelFocus)
            return;

        try
        {
            await Task.Yield();
            if (await TryFocusCancelAsync())
            {
                _pendingCancelFocus = false;
                _didFocusCancelForCurrentOpen = true;
            }
        }
        catch
        {
        }
    }

    private async Task FocusCancelForOpenAsync()
    {
        if (Dialog?.CurrentOpen != true)
            return;

        try
        {
            await Task.Yield();
            if (await TryFocusCancelAsync())
                _didFocusCancelForCurrentOpen = true;
        }
        catch
        {
        }
    }

    private async Task<bool> TryFocusCancelAsync()
    {
        if (await Interop.FocusFirstMatchingDescendant(_contentElement, "[data-bradix-alert-dialog-cancel]"))
            return true;

        if (_hasCancelElement)
        {
            await Interop.FocusElementPreventScroll(_cancelElement);
            return true;
        }

        return await Interop.FocusFirstMatchingDescendant(_contentElement, "[autofocus]");
    }
}
