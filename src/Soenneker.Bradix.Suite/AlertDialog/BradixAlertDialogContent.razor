@namespace Soenneker.Bradix
@inject IBradixSuiteInterop Interop
<CascadingValue Value="this">
    <BradixDialogContent Class="@Class"
                         Style="@Style"
                         Id="@Id"
                         AdditionalAttributes="@AdditionalAttributes"
                         ForceMount="ForceMount"
                         Role="alertdialog"
                         CloseOnPointerDownOutside="false"
                         CloseOnFocusOutside="false"
                         OnOpenAutoFocusDetailed="@HandleOpenAutoFocusAsync"
                         OnPointerDownOutsideDetailed="@HandlePointerDownOutsideAsync"
                         OnInteractOutsideDetailed="@HandleInteractOutsideAsync"
                         OnCloseAutoFocus="OnCloseAutoFocus"
                         OnCloseAutoFocusDetailed="@OnCloseAutoFocusDetailed"
                         OnEscapeKeyDown="OnEscapeKeyDown"
                         OnEscapeKeyDownDetailed="@OnEscapeKeyDownDetailed"
                         OnFocusOutside="OnFocusOutside"
                         OnFocusOutsideDetailed="@OnFocusOutsideDetailed">
        @ChildContent
    </BradixDialogContent>
</CascadingValue>

@code {
    private ElementReference _cancelElement;
    private bool _hasCancelElement;

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnOpenAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnCloseAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnCloseAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback<BradixFocusOutsideEventArgs> OnFocusOutsideDetailed { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    internal void RegisterCancelElement(ElementReference element)
    {
        _cancelElement = element;
        _hasCancelElement = true;
    }

    private async Task HandleOpenAutoFocusAsync(BradixAutoFocusEventArgs args)
    {
        if (OnOpenAutoFocus.HasDelegate)
            await OnOpenAutoFocus.InvokeAsync();

        if (OnOpenAutoFocusDetailed.HasDelegate)
            await OnOpenAutoFocusDetailed.InvokeAsync(args);

        if (args.DefaultPrevented || !_hasCancelElement)
            return;

        try
        {
            await Interop.FocusElementPreventScroll(_cancelElement);
            args.PreventDefault();
        }
        catch
        {
        }
    }

    private static Task HandlePointerDownOutsideAsync(BradixPointerDownOutsideEventArgs args)
    {
        args.PreventDefault();
        return Task.CompletedTask;
    }

    private static Task HandleInteractOutsideAsync(BradixInteractOutsideEventArgs args)
    {
        args.PreventDefault();
        return Task.CompletedTask;
    }
}
