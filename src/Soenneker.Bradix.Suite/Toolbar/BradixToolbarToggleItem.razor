@namespace Soenneker.Bradix
@using Microsoft.JSInterop
@implements IAsyncDisposable
@implements IBradixToolbarItem
@inherits BradixComponentBase
@inject IBradixIdGenerator IdGenerator
@inject IBradixSuiteInterop Interop

<button @ref="_element"
        @onclick="HandleClick"
        @onmousedown="HandleMouseDown"
        @onfocus="HandleFocus"
        @onkeydown="HandleKeyDown"
        @attributes="ButtonAttributes">
    @ChildContent
</button>

@code {
    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _registered;
    private bool _rovingFocusBridgeReady;

    [CascadingParameter]
    internal BradixToolbar Toolbar { get; set; } = null!;

    [CascadingParameter]
    internal BradixToolbarToggleGroup Group { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    public string? TabStopId { get; private set; }

    internal bool IsPressed => Group.IsItemPressed(Value);

    bool IBradixToolbarItem.IsDisabled => IsDisabled;

    private bool IsDisabled => Group.Disabled || Disabled;

    private Dictionary<string, object> ButtonAttributes
    {
        get
        {
            Dictionary<string, object> attributes = BuildAttributes(
                ("type", "button"),
                ("data-state", IsPressed ? "on" : "off"),
                ("data-disabled", IsDisabled ? string.Empty : null),
                ("data-orientation", Toolbar.Orientation),
                ("data-bradix-roving-group", Toolbar.GroupId),
                ("data-bradix-roving-item", string.Empty),
                ("data-bradix-roving-item-id", TabStopId),
                ("data-bradix-roving-orientation", Toolbar.Orientation),
                ("data-bradix-roving-dir", Toolbar.ResolvedDirection),
                ("data-bradix-roving-loop", Toolbar.Loop ? "true" : "false"),
                ("data-bradix-prevent-mousedown-when-disabled", "true"),
                ("disabled", IsDisabled ? true : null),
                ("tabindex", Toolbar.IsCurrentTabStop(this) ? 0 : -1));

            if (Group.IsSingle)
            {
                attributes["role"] = "radio";
                attributes["aria-checked"] = IsPressed ? "true" : "false";
            }
            else
            {
                attributes["aria-pressed"] = IsPressed ? "true" : "false";
            }

            return attributes;
        }
    }

    protected override void OnInitialized()
    {
        TabStopId ??= IdGenerator.New("bradix-toolbar-toggle-item");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        Toolbar.RegisterItem(this);
        _registered = true;
        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterRovingFocusNavigationKeys(_element, _dotNetReference);
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterRovingFocusNavigationKeys(_element);
        _dotNetReference?.Dispose();

        if (_registered)
            Toolbar.UnregisterItem(this);
    }

    public ValueTask FocusAsync() => _element.FocusAsync();

    private async Task HandleClick()
    {
        if (IsDisabled)
            return;

        if (IsPressed)
            await Group.DeactivateItemAsync(Value);
        else
            await Group.ActivateItemAsync(Value);
    }

    private Task HandleMouseDown(MouseEventArgs _)
    {
        if (!IsDisabled)
            Toolbar.SetCurrentTabStop(TabStopId);

        return Task.CompletedTask;
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (!IsDisabled)
            Toolbar.SetCurrentTabStop(TabStopId);

        return Task.CompletedTask;
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (_rovingFocusBridgeReady && BradixRovingFocusNavigator.IsNavigationKey(args.Key))
            return Task.CompletedTask;

        return IsDisabled ? Task.CompletedTask : Toolbar.HandleItemKeyDownAsync(this, args);
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReadyAsync()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }
}
