@using Soenneker.Bradix.Suite.Base
@implements IAsyncDisposable
@implements IBradixToolbarItem
@inherits BradixComponentBase
@inject Soenneker.Bradix.Suite.Id.IBradixIdGenerator IdGenerator
@inject Soenneker.Bradix.Suite.Interop.BradixSuiteInterop Interop

<button @ref="_element"
        @onclick="HandleClick"
        @onmousedown="HandleMouseDown"
        @onfocus="HandleFocus"
        @onkeydown="HandleKeyDown"
        @attributes="ButtonAttributes">
    @ChildContent
</button>

@code {
    private ElementReference _element;
    private bool _registered;

    [CascadingParameter]
    internal BradixToolbar Toolbar { get; set; } = null!;

    [CascadingParameter]
    internal BradixToolbarToggleGroup Group { get; set; } = null!;

    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Microsoft.AspNetCore.Components.PersistentState]
    public string? TabStopId { get; private set; }

    internal bool IsPressed => Group.IsItemPressed(Value);

    bool IBradixToolbarItem.IsDisabled => IsDisabled;

    private bool IsDisabled => Group.Disabled || Disabled;

    private Dictionary<string, object> ButtonAttributes
    {
        get
        {
            Dictionary<string, object> attributes = BuildAttributes(
                ("type", "button"),
                ("data-state", IsPressed ? "on" : "off"),
                ("data-disabled", IsDisabled ? string.Empty : null),
                ("data-orientation", Toolbar.Orientation),
                ("disabled", IsDisabled ? true : null),
                ("tabindex", Toolbar.IsCurrentTabStop(this) ? 0 : -1));

            if (Group.IsSingle)
            {
                attributes["role"] = "radio";
                attributes["aria-checked"] = IsPressed ? "true" : "false";
            }
            else
            {
                attributes["aria-pressed"] = IsPressed ? "true" : "false";
            }

            return attributes;
        }
    }

    protected override void OnInitialized()
    {
        TabStopId ??= IdGenerator.New("bradix-toolbar-toggle-item");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        Toolbar.RegisterItem(this);
        _registered = true;
        await Interop.RegisterRovingFocusNavigationKeys(_element);
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterRovingFocusNavigationKeys(_element);

        if (_registered)
            Toolbar.UnregisterItem(this);
    }

    public ValueTask FocusAsync() => _element.FocusAsync();

    private async Task HandleClick()
    {
        if (IsDisabled)
            return;

        if (IsPressed)
            await Group.DeactivateItemAsync(Value);
        else
            await Group.ActivateItemAsync(Value);
    }

    private Task HandleMouseDown(MouseEventArgs _)
    {
        if (!IsDisabled)
            Toolbar.SetCurrentTabStop(TabStopId);

        return Task.CompletedTask;
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (!IsDisabled)
            Toolbar.SetCurrentTabStop(TabStopId);

        return Task.CompletedTask;
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        return IsDisabled ? Task.CompletedTask : Toolbar.HandleItemKeyDownAsync(this, args);
    }
}
