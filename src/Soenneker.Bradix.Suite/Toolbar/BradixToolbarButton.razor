@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@using Soenneker.Blazor.Utils.Ids

@inherits BradixComponent

@implements IBradixToolbarRovingItem
@implements IBradixToolbarButton

@inject IBradixSuiteInterop Interop
<button @ref="_element"
        @onclick="HandleClick"
        @onmousedown="HandleMouseDown"
        @onfocus="HandleFocus"
        @onkeydown="HandleKeyDown"
        @attributes="ButtonAttributes">
    @ChildContent
</button>

@code {
    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _registered;
    private bool _rovingFocusBridgeReady;

    [CascadingParameter]
    internal BradixToolbar Toolbar { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    public string? TabStopId { get; private set; }

    bool IBradixToolbarRovingItem.IsDisabled => Disabled;

    private Dictionary<string, object> ButtonAttributes => BuildAttributes(
        ("type", "button"),
        ("data-bradix-roving-group", Toolbar.GroupId),
        ("data-bradix-roving-item", string.Empty),
        ("data-bradix-roving-item-id", TabStopId),
        ("data-bradix-roving-orientation", Toolbar.Orientation.Value),
        ("data-bradix-roving-dir", Toolbar.ResolvedDirection),
        ("data-bradix-roving-loop", Toolbar.Loop ? "true" : "false"),
        ("data-bradix-prevent-nonprimary-mousedown", "true"),
        ("data-bradix-prevent-mousedown-when-disabled", "true"),
        ("tabindex", Toolbar.IsCurrentTabStop(this) ? 0 : -1),
        ("disabled", Disabled ? true : null));

    protected override void OnInitialized()
    {
        TabStopId ??= BlazorIdGenerator.New("bradix-toolbar-button");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        Toolbar.RegisterItem(this);
        _registered = true;
        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterRovingFocusNavigationKeys(_element, _dotNetReference);
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterRovingFocusNavigationKeys(_element);
        _dotNetReference?.Dispose();

        if (_registered)
            Toolbar.UnregisterItem(this);
    }

    public ValueTask Focus() => _element.FocusAsync();

    private async Task HandleClick(MouseEventArgs args)
    {
        if (Disabled)
            return;

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);
    }

    private Task HandleMouseDown(MouseEventArgs _)
    {
        if (!Disabled)
            Toolbar.SetCurrentTabStop(TabStopId);

        return Task.CompletedTask;
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (!Disabled)
            Toolbar.SetCurrentTabStop(TabStopId);

        return Task.CompletedTask;
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (_rovingFocusBridgeReady && BradixRovingFocusNavigator.IsNavigationKey(args.Key))
            return Task.CompletedTask;

        return Disabled ? Task.CompletedTask : Toolbar.HandleItemKeyDown(this, args);
    }

    [JSInvokable]
    public Task HandleRovingFocusBridgeReady()
    {
        _rovingFocusBridgeReady = true;
        return Task.CompletedTask;
    }
}
