@namespace Soenneker.Bradix

@inherits BradixComponent

@using Soenneker.Blazor.Utils.Ids
@implements IBradixToolbar

<CascadingValue Value="this">
    <div @attributes="RootAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly List<IBradixToolbarRovingItem> _items = [];

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public BradixOrientation Orientation { get; set; } = BradixOrientation.Horizontal;

    [Parameter]
    public bool Loop { get; set; } = true;

    [Parameter]
    public string? Dir { get; set; }

    internal string GroupId { get; private set; } = string.Empty;

    internal string ResolvedDirection => BradixDirection.Resolve(Dir, CascadedDirection);

    internal string? CurrentTabStopId { get; private set; }

    private Dictionary<string, object> RootAttributes => BuildAttributes(
        ("role", "toolbar"),
        ("aria-orientation", Orientation.Value),
        ("dir", ResolvedDirection));

    protected override void OnInitialized()
    {
        GroupId = BlazorIdGenerator.New("bradix-toolbar");
    }

    protected override void OnParametersSet()
    {
        EnsureCurrentTabStopId();
    }

    internal bool IsCurrentTabStop(IBradixToolbarRovingItem item)
    {
        return string.Equals(CurrentTabStopId, item.TabStopId, StringComparison.Ordinal);
    }

    internal void RegisterItem(IBradixToolbarRovingItem item)
    {
        if (_items.Contains(item))
            return;

        _items.Add(item);
        EnsureCurrentTabStopId();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void UnregisterItem(IBradixToolbarRovingItem item)
    {
        _items.Remove(item);
        EnsureCurrentTabStopId();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void SetCurrentTabStop(string? tabStopId)
    {
        if (string.Equals(CurrentTabStopId, tabStopId, StringComparison.Ordinal))
            return;

        CurrentTabStopId = tabStopId;
        _ = InvokeAsync(StateHasChanged);
    }

    internal async Task HandleItemKeyDown(IBradixToolbarRovingItem item, KeyboardEventArgs args)
    {
        if (args.CtrlKey || args.AltKey || args.MetaKey || args.ShiftKey)
            return;

        var focusableItems = _items
                             .Where(candidate => !candidate.IsDisabled)
                             .ToList();

        var currentIndex = focusableItems.IndexOf(item);

        if (currentIndex < 0)
            return;

        if (!BradixRovingFocusNavigator.TryGetTargetIndex(
                args.Key,
                Orientation.Value,
                ResolvedDirection,
                currentIndex,
                focusableItems.Count,
                Loop,
                out var targetIndex))
        {
            return;
        }

        var target = focusableItems[targetIndex];
        CurrentTabStopId = target.TabStopId;
        await target.Focus();
        await InvokeAsync(StateHasChanged);
    }

    private void EnsureCurrentTabStopId()
    {
        var focusableItems = _items
                             .Where(item => !item.IsDisabled)
                             .ToList();

        if (focusableItems.Count == 0)
        {
            CurrentTabStopId = null;
            return;
        }

        if (CurrentTabStopId is not null && focusableItems.Any(item => string.Equals(item.TabStopId, CurrentTabStopId, StringComparison.Ordinal)))
            return;

        CurrentTabStopId = focusableItems[0].TabStopId;
    }
}
