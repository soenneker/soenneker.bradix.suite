@namespace Soenneker.Bradix

@inherits BradixComponentBase

@implements IBradixMenubarMenu

@inject IBradixIdGenerator IdGenerator
<BradixMenu Open="@IsOpen"
            OpenChanged="HandleMenuOpenChanged"
            Dir="@Menubar?.ResolvedDirection"
            Modal="false">
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</BradixMenu>

@code {
    [CascadingParameter]
    internal BradixMenubar? Menubar { get; set; }

    [Parameter]
    public string? Value { get; set; }

    internal string? AutoValue { get; private set; }

    public string? BaseId { get; private set; }

    internal bool WasKeyboardTriggerOpen { get; private set; }

    internal string CurrentValue => Value ?? AutoValue!;

    internal string TriggerId => $"{BaseId}-trigger";

    internal string ContentId => $"{BaseId}-content";

    internal bool IsOpen => string.Equals(Menubar?.CurrentValue, CurrentValue, StringComparison.Ordinal);

    protected override void OnInitialized()
    {
        BaseId ??= IdGenerator.New("bradix-menubar-menu");
        AutoValue ??= IdGenerator.New("bradix-menubar-value");
    }

    internal void MarkKeyboardTriggerOpen()
    {
        WasKeyboardTriggerOpen = true;
    }

    internal void ResetKeyboardTriggerOpen()
    {
        WasKeyboardTriggerOpen = false;
    }

    private Task HandleMenuOpenChanged(bool open)
    {
        if (open)
            return Menubar?.OpenMenu(CurrentValue) ?? Task.CompletedTask;

        ResetKeyboardTriggerOpen();
        return Menubar?.CloseMenu() ?? Task.CompletedTask;
    }
}
