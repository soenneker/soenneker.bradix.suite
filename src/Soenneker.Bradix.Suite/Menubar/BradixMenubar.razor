@namespace Soenneker.Bradix

@using Microsoft.JSInterop
@using System.Linq
@using Soenneker.Blazor.Utils.Ids

@inherits BradixComponent

@implements IBradixMenubar

@inject IBradixSuiteInterop Interop
<CascadingValue Value="this">
    <div @ref="_element"
         @attributes="RootAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly BradixCollectionRegistry<IBradixMenubarTriggerEntry> _triggers = new();
    private ElementReference _element;
    private DotNetObjectReference<BradixMenubar>? _dotNetReference;
    private bool _documentDismissRegistered;
    private bool _initialized;
    private string? _uncontrolledValue;

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string?> OnValueChange { get; set; }

    [Parameter]
    public bool Loop { get; set; } = true;

    [Parameter]
    public string? Dir { get; set; }

    internal string MenubarId { get; private set; } = string.Empty;

    internal string ResolvedDirection => Dir == "rtl" ? "rtl" : CascadedDirection == "rtl" ? "rtl" : "ltr";

    internal string? CurrentValue => Value ?? _uncontrolledValue;

    internal bool HasOpenMenu => !string.IsNullOrWhiteSpace(CurrentValue);

    internal string? CurrentTabStopId { get; private set; }

    private Dictionary<string, object> RootAttributes => BuildAttributes(
        ("role", "menubar"),
        ("aria-orientation", "horizontal"),
        ("dir", ResolvedDirection),
        ("data-bradix-menubar-id", MenubarId));

    protected override void OnInitialized()
    {
        MenubarId = BlazorIdGenerator.New("bradix-menubar");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _dotNetReference = DotNetObjectReference.Create(this);
        await Interop.RegisterMenubarDocumentDismiss(_element, _dotNetReference, MenubarId);
        _documentDismissRegistered = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (_documentDismissRegistered)
            await Interop.UnregisterMenubarDocumentDismiss(_element);

        _dotNetReference?.Dispose();
    }

    protected override void OnParametersSet()
    {
        if (!_initialized)
        {
            _uncontrolledValue = DefaultValue;
            _initialized = true;
        }

        EnsureCurrentTabStopId();
    }

    internal bool IsCurrentTabStop(BradixMenubarMenu menu)
    {
        return string.Equals(CurrentTabStopId, menu.CurrentValue, StringComparison.Ordinal);
    }

    internal void RegisterTrigger(IBradixMenubarTriggerEntry trigger)
    {
        _triggers.Register(trigger.Value, trigger);
        EnsureCurrentTabStopId();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void UnregisterTrigger(IBradixMenubarTriggerEntry trigger)
    {
        _triggers.Unregister(trigger.Value);
        EnsureCurrentTabStopId();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void SetCurrentTabStop(string? value)
    {
        if (string.Equals(CurrentTabStopId, value, StringComparison.Ordinal))
            return;

        CurrentTabStopId = value;
        _ = InvokeAsync(StateHasChanged);
    }

    internal async Task OpenMenu(string value)
    {
        await SetValue(value);
        SetCurrentTabStop(value);
    }

    internal Task CloseMenu()
    {
        return SetValue(null);
    }

    internal async Task ToggleMenu(string value)
    {
        var nextValue = string.Equals(CurrentValue, value, StringComparison.Ordinal)
            ? null
            : value;

        await SetValue(nextValue);
        SetCurrentTabStop(value);
    }

    internal async Task HandleTriggerKeyDown(IBradixMenubarTriggerEntry trigger, KeyboardEventArgs args)
    {
        if (args.CtrlKey || args.AltKey || args.MetaKey || args.ShiftKey)
            return;

        var focusableTriggers = GetFocusableTriggers();
        var currentIndex = focusableTriggers.IndexOf(trigger);

        if (currentIndex < 0)
            return;

        if (!BradixRovingFocusNavigator.TryGetTargetIndex(args.Key, "horizontal", ResolvedDirection, currentIndex, focusableTriggers.Count, Loop, out var targetIndex))
            return;

        var target = focusableTriggers[targetIndex];
        CurrentTabStopId = target.Value;
        await target.Focus();

        if (HasOpenMenu)
            await SetValue(target.Value);

        await InvokeAsync(StateHasChanged);
    }

    internal async Task MoveToAdjacentMenu(string value, string key)
    {
        var focusableTriggers = GetFocusableTriggers();
        var candidateValues = focusableTriggers.Select(trigger => trigger.Value).ToList();

        var previousMenuKey = ResolvedDirection == "rtl" ? "ArrowRight" : "ArrowLeft";
        var isPreviousKey = string.Equals(previousMenuKey, key, StringComparison.Ordinal);

        if (isPreviousKey)
            candidateValues.Reverse();

        var currentIndex = candidateValues.IndexOf(value);

        if (currentIndex < 0)
            return;

        var rotatedValues = Loop
            ? WrapArray(candidateValues, currentIndex + 1)
            : candidateValues.Skip(currentIndex + 1).ToList();

        var nextValue = rotatedValues.FirstOrDefault();

        if (string.IsNullOrWhiteSpace(nextValue))
            return;

        await SetValue(nextValue);
        SetCurrentTabStop(nextValue);
    }

    internal bool IsRegisteredTriggerId(string? triggerId)
    {
        if (string.IsNullOrWhiteSpace(triggerId))
            return false;

        return _triggers.Snapshot().Any(entry => string.Equals(entry.Item.TriggerId, triggerId, StringComparison.Ordinal));
    }

    internal bool ContainsRegisteredTriggerTarget(string? targetId, IEnumerable<string>? ancestorIds)
    {
        if (IsRegisteredTriggerId(targetId))
            return true;

        if (ancestorIds is null)
            return false;

        foreach (var ancestorId in ancestorIds)
        {
            if (IsRegisteredTriggerId(ancestorId))
                return true;
        }

        return false;
    }

    private async Task SetValue(string? value)
    {
        if (string.Equals(CurrentValue, value, StringComparison.Ordinal))
            return;

        if (Value is null)
            _uncontrolledValue = value;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(value);

        if (OnValueChange.HasDelegate)
            await OnValueChange.InvokeAsync(value);

        await InvokeAsync(StateHasChanged);
    }

    private List<IBradixMenubarTriggerEntry> GetFocusableTriggers()
    {
        return _triggers.Snapshot()
            .Select(entry => entry.Item)
            .Where(trigger => !trigger.Disabled)
            .ToList();
    }

    private void EnsureCurrentTabStopId()
    {
        var focusableTriggers = GetFocusableTriggers();

        if (focusableTriggers.Count == 0)
        {
            CurrentTabStopId = null;
            return;
        }

        if (CurrentTabStopId is not null && focusableTriggers.Any(trigger => string.Equals(trigger.Value, CurrentTabStopId, StringComparison.Ordinal)))
            return;

        CurrentTabStopId = focusableTriggers[0].Value;
    }

    private static List<string> WrapArray(IReadOnlyList<string> values, int startIndex)
    {
        if (values.Count == 0)
            return [];

        return Enumerable.Range(0, values.Count)
            .Select(index => values[(startIndex + index) % values.Count])
            .ToList();
    }

    [JSInvokable]
    public Task HandleDocumentPointerDownOutside()
    {
        return HasOpenMenu ? CloseMenu() : Task.CompletedTask;
    }
}
