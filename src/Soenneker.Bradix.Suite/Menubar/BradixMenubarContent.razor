@namespace Soenneker.Bradix

@using System.Collections.Generic
@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixMenuContentController
@implements IBradixMenubarContent

@inject IBradixSuiteInterop Interop

@if (ShouldRenderContainer)
{
    @_contentTree
}

@code {
    private readonly HashSet<string> _submenuPointerGraceItems = [];
    private bool _wasPresent;
    private bool _isExiting;
    private bool _hasInteractedOutside;
    private ElementReference _contentElement;
    private DotNetObjectReference<BradixMenubarContent>? _dotNetReference;
    private bool _delegatedInteractionRegistered;
    private RenderFragment? _contentTree;

    [CascadingParameter]
    private BradixMenubar? Menubar { get; set; }

    [CascadingParameter]
    private BradixMenubarMenu? MenubarMenu { get; set; }

    [CascadingParameter]
    private BradixMenu? Menu { get; set; }

    [CascadingParameter(Name = "BradixMenuPortalForceMount")]
    private bool PortalForceMount { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public bool Loop { get; set; }

    [Parameter]
    public BradixAlignment Align { get; set; } = BradixAlignment.Start;

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public EventCallback OnOpenAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnOpenAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnCloseAutoFocus { get; set; }

    [Parameter]
    public EventCallback<BradixAutoFocusEventArgs> OnCloseAutoFocusDetailed { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback<BradixPointerDownOutsideEventArgs> OnPointerDownOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnFocusOutside { get; set; }

    [Parameter]
    public EventCallback<BradixFocusOutsideEventArgs> OnFocusOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnInteractOutside { get; set; }

    [Parameter]
    public EventCallback<BradixInteractOutsideEventArgs> OnInteractOutsideDetailed { get; set; }

    [Parameter]
    public EventCallback OnPlaced { get; set; }

    private bool IsPresent => ForceMount || PortalForceMount || MenubarMenu?.IsOpen == true;

    private bool ShouldRenderContainer => IsPresent || _isExiting;

    private string? ResolvedContentId => MenubarMenu?.ContentId;

    private string PositionerStyle =>
        "--radix-menubar-content-transform-origin: var(--radix-popper-transform-origin); --radix-menubar-content-available-width: var(--radix-popper-available-width); --radix-menubar-content-available-height: var(--radix-popper-available-height); --radix-menubar-trigger-width: var(--radix-popper-anchor-width); --radix-menubar-trigger-height: var(--radix-popper-anchor-height);";

    private string MergedContentStyle => MergeStyleValues("outline:none;", Style)!;

    private IReadOnlyDictionary<string, object> PresenceAttributes
    {
        get
        {
            var attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["role"] = "menu";
            attributes["tabindex"] = -1;
            attributes["dir"] = Menubar?.ResolvedDirection ?? "ltr";
            attributes["aria-orientation"] = "vertical";
            if (!string.IsNullOrWhiteSpace(MenubarMenu?.TriggerId))
                attributes["aria-labelledby"] = MenubarMenu.TriggerId;
            attributes["data-state"] = MenubarMenu?.IsOpen == true ? "open" : "closed";
            attributes["data-radix-menubar-content"] = string.Empty;
            if (!string.IsNullOrWhiteSpace(Menubar?.MenubarId))
                attributes["data-bradix-menubar-id"] = Menubar.MenubarId;

            return attributes;
        }
    }

    protected override void OnInitialized()
    {
        _contentTree = RenderContentTree();
    }

    protected override void OnParametersSet()
    {
        var present = IsPresent;

        if (_wasPresent && !present)
            _isExiting = true;
        else if (present)
            _isExiting = false;

        _wasPresent = present;
    }

    public async ValueTask DisposeAsync()
    {
        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_contentElement);

        _submenuPointerGraceItems.Clear();
        _dotNetReference?.Dispose();
    }

    private async Task HandleOpenAutoFocus(BradixAutoFocusEventArgs args)
    {
        if (OnOpenAutoFocus.HasDelegate)
            await OnOpenAutoFocus.InvokeAsync();

        if (OnOpenAutoFocusDetailed.HasDelegate)
            await OnOpenAutoFocusDetailed.InvokeAsync(args);

        if (args.DefaultPrevented)
            return;

        if (Menu is null)
            return;

        if (MenubarMenu?.WasKeyboardTriggerOpen == true)
            await Menu.FocusFirstItem();
        else
            await Interop.FocusElementPreventScroll(_contentElement);
    }

    private async Task HandleCloseAutoFocus(BradixAutoFocusEventArgs args)
    {
        if (OnCloseAutoFocus.HasDelegate)
            await OnCloseAutoFocus.InvokeAsync();

        if (OnCloseAutoFocusDetailed.HasDelegate)
            await OnCloseAutoFocusDetailed.InvokeAsync(args);

        if (MenubarMenu is not null)
            MenubarMenu.ResetKeyboardTriggerOpen();

        if (!args.DefaultPrevented && Menu is not null && MenubarMenu is not null && Menubar?.HasOpenMenu != true && !_hasInteractedOutside)
            await Menu.FocusTrigger();

        args.PreventDefault();

        _hasInteractedOutside = false;
    }

    private async Task HandleEscapeKeyDown(BradixEscapeKeyDownEventArgs args)
    {
        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        if (OnEscapeKeyDownDetailed.HasDelegate)
            await OnEscapeKeyDownDetailed.InvokeAsync(args);

        if (args.DefaultPrevented)
            return;

        args.PreventDefault();
        await HandleDismiss();

        if (Menu is not null)
            await Menu.FocusTrigger();
    }

    private async Task HandlePointerDownOutside(BradixPointerDownOutsideEventArgs args)
    {
        if (OnPointerDownOutside.HasDelegate)
            await OnPointerDownOutside.InvokeAsync();

        if (OnPointerDownOutsideDetailed.HasDelegate)
            await OnPointerDownOutsideDetailed.InvokeAsync(args);
    }

    private async Task HandleFocusOutside(BradixFocusOutsideEventArgs args)
    {
        if (OnFocusOutside.HasDelegate)
            await OnFocusOutside.InvokeAsync();

        if (OnFocusOutsideDetailed.HasDelegate)
            await OnFocusOutsideDetailed.InvokeAsync(args);

        if (Menubar?.ContainsRegisteredTriggerTarget(args.OriginalEvent.TargetId, args.OriginalEvent.AncestorIds) == true)
        {
            args.PreventDefault();
            return;
        }
    }

    private async Task HandleInteractOutside(BradixInteractOutsideEventArgs args)
    {
        if (OnInteractOutside.HasDelegate)
            await OnInteractOutside.InvokeAsync();

        if (OnInteractOutsideDetailed.HasDelegate)
            await OnInteractOutsideDetailed.InvokeAsync(args);

        if (!args.DefaultPrevented)
            _hasInteractedOutside = true;
    }

    private Task HandleDismiss()
    {
        return Menubar?.CloseMenu() ?? Task.CompletedTask;
    }

    [JSInvokable]
    public async Task HandleDelegatedContentKeyDown(BradixDelegatedKeyboardEvent args)
    {
        if (Menu is null || args.CtrlKey || args.AltKey || args.MetaKey)
            return;

        if (args.Key == "Tab")
            return;

        var contentId = ResolvedContentId;
        var isContentTarget = !string.IsNullOrWhiteSpace(contentId) && string.Equals(args.TargetId, contentId, StringComparison.Ordinal);

        if (isContentTarget && args.Key.Length == 1)
        {
            await Menu.HandleTypeahead(null, args.Key);
            return;
        }

        if (isContentTarget)
        {
            switch (args.Key)
            {
                case "PageUp":
                case "Home":
                    await Menu.FocusFirstItem();
                    return;
                case "PageDown":
                case "End":
                    await Menu.FocusLastItem();
                    return;
            }
        }

        if (args.Key is not "ArrowRight" and not "ArrowLeft")
            return;

        if (Menubar is null || MenubarMenu is null || string.IsNullOrWhiteSpace(contentId))
            return;

        var previousMenuKey = Menubar.ResolvedDirection == "rtl" ? "ArrowRight" : "ArrowLeft";
        var isPreviousKey = previousMenuKey == args.Key;
        var isNextKey = !isPreviousKey;
        var isInsideNestedContent = !string.IsNullOrWhiteSpace(args.ClosestMenubarContentId)
                                    && !string.Equals(args.ClosestMenubarContentId, contentId, StringComparison.Ordinal);

        if (isNextKey && args.IsMenubarSubTrigger)
            return;

        if (isInsideNestedContent && isPreviousKey)
            return;

        await Menubar.OpenMenu(MenubarMenu.CurrentValue);
        await Menubar.MoveToAdjacentMenu(MenubarMenu.CurrentValue, args.Key);
    }

    [JSInvokable]
    public Task HandleDelegatedContentFocusOut(BradixDelegatedFocusEvent args)
    {
        if (Menu is null || !IsWithinContent(args.TargetId, args.AncestorIds))
            return Task.CompletedTask;

        if (!IsWithinContent(args.RelatedTargetId, args.RelatedTargetAncestorIds))
            Menu.ResetTypeahead();

        return Task.CompletedTask;
    }

    private async Task HandleExitComplete()
    {
        if (_delegatedInteractionRegistered)
        {
            await Interop.UnregisterDelegatedInteraction(_contentElement);
            _delegatedInteractionRegistered = false;
        }

        _submenuPointerGraceItems.Clear();
        _isExiting = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleContentElementCaptured(ElementReference element)
    {
        _contentElement = element;

        if (!_delegatedInteractionRegistered)
        {
            _dotNetReference ??= DotNetObjectReference.Create(this);
            await Interop.RegisterDelegatedInteraction(_contentElement, _dotNetReference, new
            {
                focusout = new
                {
                    method = nameof(HandleDelegatedContentFocusOut),
                    currentTargetOnly = false
                },
                keydown = new
                {
                    method = nameof(HandleDelegatedContentKeyDown),
                    currentTargetOnly = false,
                    preventDefaultKeys = new[] { "Tab", "Home", "End", "PageUp", "PageDown" }
                }
            });
            _delegatedInteractionRegistered = true;
        }
    }

    private bool IsWithinContent(string? targetId, IReadOnlyList<string>? ancestorIds)
    {
        var contentId = ResolvedContentId;

        if (string.IsNullOrWhiteSpace(contentId))
            return false;

        if (string.Equals(targetId, contentId, StringComparison.Ordinal))
            return true;

        return ancestorIds?.Contains(contentId) == true;
    }

    Task IBradixMenuContentController.HandleItemKeyDown(IBradixMenuRovingItem item, KeyboardEventArgs args)
    {
        return Menu is null
            ? Task.CompletedTask
            : Menu.HandleItemNavigation(item, args.Key, Loop);
    }

    Task IBradixMenuContentController.HandleTypeaheadKey(IBradixMenuRovingItem item, string key)
    {
        return Menu is null ? Task.CompletedTask : Menu.HandleTypeahead(item, key);
    }

    Task IBradixMenuContentController.HandlePointerMove(IBradixMenuRovingItem item, string? pointerType)
    {
        if (Menu is null || !string.Equals(pointerType, "mouse", StringComparison.Ordinal))
            return Task.CompletedTask;

        if (_submenuPointerGraceItems.Count > 0)
            return Task.CompletedTask;

        Menu.SetCurrentTabStop(item.TabStopId);
        return item.Focus().AsTask();
    }

    Task IBradixMenuContentController.HandleItemLeave()
    {
        if (_submenuPointerGraceItems.Count > 0)
            return Task.CompletedTask;

        Menu?.ClearCurrentTabStop();
        return Interop.FocusElementPreventScroll(_contentElement).AsTask();
    }

    void IBradixMenuContentController.SetSubmenuPointerGrace(string? tabStopId, bool active)
    {
        if (string.IsNullOrWhiteSpace(tabStopId))
            return;

        if (active)
            _submenuPointerGraceItems.Add(tabStopId);
        else
            _submenuPointerGraceItems.Remove(tabStopId);
    }

    private RenderFragment RenderContentTree() => @<CascadingValue Value="this">
        <BradixFocusGuards>
            <BradixFocusScope Trapped="false"
                              PreventMountAutoFocus="true"
                              PreventUnmountAutoFocus="true"
                              OnMountAutoFocusDetailed="HandleOpenAutoFocus"
                              OnUnmountAutoFocusDetailed="HandleCloseAutoFocus">
                <BradixDismissableLayer DisableOutsidePointerEvents="false"
                                        DismissOnEscapeKeyDown="true"
                                        DismissOnPointerDownOutside="true"
                                        DismissOnFocusOutside="true"
                                        OnDismiss="@HandleDismiss"
                                        OnEscapeKeyDownDetailed="@HandleEscapeKeyDown"
                                        OnPointerDownOutsideDetailed="@HandlePointerDownOutside"
                                        OnFocusOutsideDetailed="@HandleFocusOutside"
                                        OnInteractOutsideDetailed="@HandleInteractOutside">
                    <BradixPopperContent Side="@BradixSide.Bottom"
                                         SideOffset="@SideOffset"
                                         Align="@Align"
                                         AlignOffset="@AlignOffset"
                                         ArrowPadding="@ArrowPadding"
                                         AvoidCollisions="@AvoidCollisions"
                                         CollisionPadding="@CollisionPadding"
                                         CollisionBoundarySelector="@CollisionBoundarySelector"
                                         CollisionBoundarySelectors="@CollisionBoundarySelectors"
                                         Sticky="@Sticky"
                                         HideWhenDetached="@HideWhenDetached"
                                         Style="@PositionerStyle"
                                         OnPlaced="@OnPlaced">
                        <BradixPresence Present="IsPresent"
                                        Tag="div"
                                        Id="@ResolvedContentId"
                                        Class="@Class"
                                        Style="@MergedContentStyle"
                                        AdditionalAttributes="@PresenceAttributes"
                                        OnElementReferenceCaptured="@HandleContentElementCaptured"
                                        OnExitComplete="@HandleExitComplete">
                            @ChildContent
                        </BradixPresence>
                    </BradixPopperContent>
                </BradixDismissableLayer>
            </BradixFocusScope>
        </BradixFocusGuards>
    </CascadingValue>;
}
