@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixMenubarTriggerEntry

@inject IBradixSuiteInterop Interop
<BradixMenuAnchor>
    <button @ref="_button"
            @onpointerdown="HandlePointerDown"
            @onpointerdown:preventDefault="PreventTriggerFocusOnOpen"
            @onpointerenter="HandlePointerEnter"
            @onkeydown="HandleKeyDown"
            @onfocus="HandleFocus"
            @onblur="HandleBlur"
            @attributes="TriggerAttributes">
        @ChildContent
    </button>
</BradixMenuAnchor>

@code {
    private ElementReference _button;
    private bool _registered;
    private bool _isFocused;
    private bool _delegatedInteractionRegistered;
    private DotNetObjectReference<BradixMenubarTrigger>? _dotNetReference;

    [CascadingParameter]
    private BradixMenubar? Menubar { get; set; }

    [CascadingParameter]
    private BradixMenubarMenu? MenubarMenu { get; set; }

    [CascadingParameter]
    private BradixMenu? Menu { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<ElementReference> OnElementReferenceCaptured { get; set; }

    string IBradixMenubarTriggerEntry.Value => MenubarMenu!.CurrentValue;

    string IBradixMenubarTriggerEntry.TriggerId => MenubarMenu!.TriggerId;

    bool IBradixMenubarTriggerEntry.Disabled => Disabled;

    private bool IsOpen => MenubarMenu?.IsOpen == true;
    private bool PreventTriggerFocusOnOpen => !Disabled && !IsOpen;

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("type", "button"),
        ("role", "menuitem"),
        ("id", MenubarMenu?.TriggerId),
        ("tabindex", Menubar?.IsCurrentTabStop(MenubarMenu!) == true ? 0 : -1),
        ("aria-haspopup", "menu"),
        ("aria-expanded", IsOpen ? "true" : "false"),
        ("aria-controls", MenubarMenu?.ContentId),
        ("data-highlighted", _isFocused ? string.Empty : null),
        ("data-state", IsOpen ? "open" : "closed"),
        ("data-disabled", Disabled ? string.Empty : null),
        ("disabled", Disabled ? true : null));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Menubar is null || MenubarMenu is null || Menu is null)
            return;

        Menubar.RegisterTrigger(this);
        Menu.RegisterTrigger(_button);

        if (OnElementReferenceCaptured.HasDelegate)
            await OnElementReferenceCaptured.InvokeAsync(_button);

        _dotNetReference ??= DotNetObjectReference.Create(this);
        await Interop.RegisterDelegatedInteraction(_button, _dotNetReference, new
        {
            keydown = new
            {
                currentTargetOnly = true,
                preventDefaultKeys = new[] { "Enter", " ", "Spacebar", "ArrowDown" }
            }
        });
        _delegatedInteractionRegistered = true;
        _registered = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (_delegatedInteractionRegistered)
            await Interop.UnregisterDelegatedInteraction(_button);

        if (_registered && Menubar is not null)
            Menubar.UnregisterTrigger(this);

        _dotNetReference?.Dispose();
    }

    ValueTask IBradixMenubarTriggerEntry.Focus() => _button.FocusAsync();

    private Task HandlePointerDown(PointerEventArgs args)
    {
        if (Disabled || Menubar is null || MenubarMenu is null || args.Button != 0 || args.CtrlKey)
            return Task.CompletedTask;

        MenubarMenu.ResetKeyboardTriggerOpen();
        return IsOpen
            ? Menubar.CloseMenu()
            : Menubar.OpenMenu(MenubarMenu.CurrentValue);
    }

    private async Task HandlePointerEnter(PointerEventArgs _)
    {
        if (Disabled || Menubar is null || MenubarMenu is null || !Menubar.HasOpenMenu || IsOpen)
            return;

        await Menubar.OpenMenu(MenubarMenu.CurrentValue);
        await _button.FocusAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Disabled || Menubar is null || MenubarMenu is null)
            return;

        if (args.Key is "Enter" or " " or "Spacebar")
        {
            MenubarMenu.MarkKeyboardTriggerOpen();
            await Menubar.ToggleMenu(MenubarMenu.CurrentValue);
            return;
        }

        if (args.Key == "ArrowDown")
        {
            MenubarMenu.MarkKeyboardTriggerOpen();
            await Menubar.OpenMenu(MenubarMenu.CurrentValue);
            return;
        }

        await Menubar.HandleTriggerKeyDown(this, args);
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        if (Disabled || MenubarMenu is null || Menubar is null)
            return Task.CompletedTask;

        _isFocused = true;
        Menubar.SetCurrentTabStop(MenubarMenu.CurrentValue);
        return InvokeAsync(StateHasChanged);
    }

    private Task HandleBlur(FocusEventArgs _)
    {
        _isFocused = false;
        return InvokeAsync(StateHasChanged);
    }

}
