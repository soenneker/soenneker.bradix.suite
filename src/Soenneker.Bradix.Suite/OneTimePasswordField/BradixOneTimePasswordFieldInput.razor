@namespace Soenneker.Bradix

@using System.Linq
@using Microsoft.JSInterop

@inherits BradixComponentBase

@implements IBradixOneTimePasswordFieldInput

@inject IBradixSuiteInterop Interop
<input @ref="_element"
       value="@CurrentCharacter"
       @onfocus="HandleFocus"
       @oninput="HandleInput"
       @onkeydown="HandleKeyDown"
       @attributes="InputAttributes" />

@code {
    private ElementReference _element;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _registered;
    private int _resolvedIndex = -1;

    [CascadingParameter]
    private BradixOneTimePasswordField? Root { get; set; }

    [Parameter]
    public int? Index { get; set; }

    [Parameter]
    public EventCallback<string> OnInvalidChange { get; set; }

    private string CurrentCharacter => Root?.GetCharacterAt(_resolvedIndex) ?? string.Empty;

    private string? CurrentPlaceholder => Root?.GetPlaceholderAt(_resolvedIndex);

    private bool SupportsAutoComplete => Root?.SupportsAutoComplete(_resolvedIndex) == true;
    private bool IsTabStop => Root?.IsInputTabStop(_resolvedIndex) == true;
    private string? ResolvedAriaLabel => Root?.InputCount > 0 && _resolvedIndex >= 0 ? $"Character {_resolvedIndex + 1} of {Root.InputCount}" : null;

    private IReadOnlyDictionary<string, object> InputAttributes => BuildAttributes(
        ("data-index", _resolvedIndex >= 0 ? _resolvedIndex : null),
        ("data-radix-otp-input", string.Empty),
        ("data-radix-index", _resolvedIndex >= 0 ? _resolvedIndex : null),
        ("autocomplete", SupportsAutoComplete ? Root?.AutoComplete : "off"),
        ("autofocus", Root?.AutoFocus == true && _resolvedIndex == 0 ? true : null),
        ("data-1p-ignore", SupportsAutoComplete ? null : "true"),
        ("data-lpignore", SupportsAutoComplete ? null : "true"),
        ("data-protonpass-ignore", SupportsAutoComplete ? null : "true"),
        ("data-bwignore", SupportsAutoComplete ? null : "true"),
        ("disabled", Root?.Disabled == true ? true : null),
        ("readonly", Root?.ReadOnly == true ? true : null),
        ("form", Root?.Form),
        ("inputmode", ResolveInputMode()),
        ("maxlength", SupportsAutoComplete ? Root?.InputCount : 1),
        ("name", null),
        ("pattern", ResolvePattern()),
        ("placeholder", CurrentPlaceholder),
        ("tabindex", IsTabStop ? 0 : -1),
        ("type", Root?.Type),
        ("aria-label", ResolvedAriaLabel));

    protected override void OnInitialized()
    {
        _resolvedIndex = Root?.RegisterInput(this, Index) ?? (Index ?? -1);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetReference = DotNetObjectReference.Create<object>(this);
            await Interop.RegisterOneTimePasswordInput(_element, _dotNetReference);
            _registered = true;
        }
    }

    public async ValueTask DisposeAsync()
    {
        Root?.UnregisterInput(this);

        if (_registered)
            await Interop.UnregisterOneTimePasswordInput(_element);

        _dotNetReference?.Dispose();
    }

    internal ValueTask Focus() => _element.FocusAsync();

    [JSInvokable]
    public Task HandlePaste(string value)
    {
        return Root?.ApplyPastedValue(value) ?? Task.CompletedTask;
    }

    private async Task HandleFocus(FocusEventArgs _)
    {
        Root?.SetActiveInput(_resolvedIndex);
        await Interop.SelectInputText(_element);
    }

    private async Task HandleInput(ChangeEventArgs args)
    {
        if (Root is null)
            return;

        string value = args.Value?.ToString() ?? string.Empty;

        if (value.Length > 1)
        {
            await Root.ApplyPastedValue(value);
            return;
        }

        if (!string.IsNullOrEmpty(value))
        {
            if (!IsValueValid(value))
            {
                if (OnInvalidChange.HasDelegate)
                    await OnInvalidChange.InvokeAsync(value);

                return;
            }

            await Root.SetCharacter(_resolvedIndex, value);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Root is null)
            return;

        switch (args.Key)
        {
            case "Backspace":
            {
                if (args.MetaKey || args.CtrlKey)
                {
                    await Root.Clear("Backspace");
                    return;
                }

                if (string.IsNullOrEmpty(CurrentCharacter))
                    await Root.MoveFocus(_resolvedIndex, -1);
                else
                    await Root.ClearCharacter(_resolvedIndex, "Backspace");

                return;
            }
            case "Delete":
            case "Clear":
            {
                if (args.MetaKey || args.CtrlKey || args.Key == "Clear")
                {
                    await Root.Clear("Delete");
                    return;
                }

                if (!string.IsNullOrEmpty(CurrentCharacter))
                    await Root.ClearCharacter(_resolvedIndex, "Delete");

                return;
            }
            case "Enter":
                await Root.AttemptSubmit();
                return;
            case "ArrowLeft":
                await Root.MoveFocus(_resolvedIndex, Root.ResolvedDirection == "rtl" ? 1 : -1);
                return;
            case "ArrowRight":
                await Root.MoveFocus(_resolvedIndex, Root.ResolvedDirection == "rtl" ? -1 : 1);
                return;
            case "ArrowUp":
                if (Root.Orientation == "vertical")
                    await Root.MoveFocus(_resolvedIndex, -1);
                return;
            case "ArrowDown":
                if (Root.Orientation == "vertical")
                    await Root.MoveFocus(_resolvedIndex, 1);
                return;
            default:
            {
                if (args.Key.Length == 1 && CurrentCharacter == args.Key)
                    await Root.MoveFocus(_resolvedIndex, 1);

                return;
            }
        }
    }

    private string? ResolvePattern()
    {
        return Root?.ValidationType switch
        {
            "alpha" => "[a-zA-Z]{1}",
            "alphanumeric" => "[a-zA-Z0-9]{1}",
            "numeric" => "\\d{1}",
            _ => null
        };
    }

    private string ResolveInputMode()
    {
        return Root?.ValidationType == "numeric" ? "numeric" : "text";
    }

    private bool IsValueValid(string value)
    {
        return Root?.ValidationType switch
        {
            "alpha" => value.All(char.IsLetter),
            "alphanumeric" => value.All(char.IsLetterOrDigit),
            "numeric" => value.All(char.IsDigit),
            _ => true
        };
    }
}
