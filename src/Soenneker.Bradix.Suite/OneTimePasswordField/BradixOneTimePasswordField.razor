@namespace Soenneker.Bradix

@using System.Linq
@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixOneTimePasswordField

@inject IBradixSuiteInterop Interop
<CascadingValue Value="this">
    <div @attributes="RootAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly Dictionary<BradixOneTimePasswordFieldInput, int> _inputs = [];
    private int _nextDynamicIndex;
    private bool _initialized;
    private string _uncontrolledValue = string.Empty;
    private string? _lastAutoSubmittedValue;
    private ElementReference _hiddenInputElement;
    private int _activeInputIndex;
    private bool _hasHiddenInput;
    private bool _formResetRegistered;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public string AutoComplete { get; set; } = "one-time-code";

    [Parameter]
    public string? InputMode { get; set; }

    [Parameter]
    public bool AutoFocus { get; set; }

    [Parameter]
    public bool AutoSubmit { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string> OnValueChange { get; set; }

    [Parameter]
    public EventCallback<string> OnAutoSubmit { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public string Orientation { get; set; } = "horizontal";

    [Parameter]
    public string? Form { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public string Type { get; set; } = "text";

    [Parameter]
    public string ValidationType { get; set; } = "numeric";

    [Parameter]
    public string? Pattern { get; set; }

    [Parameter]
    public Func<string, string>? SanitizeValue { get; set; }

    internal string CurrentValue => Value ?? _uncontrolledValue;

    internal string ResolvedDirection => Dir is "rtl" or "ltr" ? Dir : CascadedDirection is "rtl" ? "rtl" : "ltr";

    internal int InputCount => _inputs.Count;

    internal int LastSelectableIndex => Math.Clamp(CurrentValue.Trim().Length, 0, Math.Max(0, InputCount - 1));

    private IReadOnlyDictionary<string, object> RootAttributes => BuildAttributes(
        ("role", "group"),
        ("data-orientation", ResolvedOrientation),
        ("dir", ResolvedDirection));

    private string ResolvedOrientation => Orientation == "vertical" ? "vertical" : "horizontal";

    protected override void OnParametersSet()
    {
        if (_initialized)
            return;

        _uncontrolledValue = Sanitize(DefaultValue ?? string.Empty);
        _initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_hasHiddenInput || _formResetRegistered)
            return;

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);
        await Interop.RegisterAssociatedFormReset(_hiddenInputElement, _dotNetReference, Form);
        _formResetRegistered = true;
    }

    internal int RegisterInput(BradixOneTimePasswordFieldInput input, int? explicitIndex)
    {
        int resolvedIndex = explicitIndex ?? _nextDynamicIndex++;
        _inputs[input] = resolvedIndex;
        return resolvedIndex;
    }

    internal void UnregisterInput(BradixOneTimePasswordFieldInput input)
    {
        _inputs.Remove(input);
    }

    internal void SetActiveInput(int index)
    {
        int nextIndex = Math.Clamp(index, 0, Math.Max(0, InputCount - 1));

        if (_activeInputIndex == nextIndex)
            return;

        _activeInputIndex = nextIndex;
        _ = InvokeAsync(StateHasChanged);
    }

    internal bool IsInputTabStop(int index)
    {
        return index == Math.Min(_activeInputIndex, LastSelectableIndex);
    }

    internal bool SupportsAutoComplete(int index)
    {
        return index == 0 || IsInputTabStop(index);
    }

    internal string GetCharacterAt(int index)
    {
        string current = Sanitize(CurrentValue);
        return index >= 0 && index < current.Length ? current[index].ToString() : string.Empty;
    }

    internal string? GetPlaceholderAt(int index)
    {
        if (string.IsNullOrEmpty(Placeholder) || !string.IsNullOrEmpty(Sanitize(CurrentValue)))
            return null;

        return index >= 0 && index < Placeholder.Length ? Placeholder[index].ToString() : null;
    }

    internal async Task SetCharacter(int index, string attemptedValue)
    {
        string sanitized = Sanitize(attemptedValue);
        if (string.IsNullOrEmpty(sanitized))
            return;

        char character = sanitized[0];
        List<char> characters = [.. Sanitize(CurrentValue)];
        int clampedIndex = Math.Clamp(index, 0, Math.Max(0, InputCount - 1));

        if (characters.Count >= InputCount && clampedIndex < characters.Count)
        {
            characters[clampedIndex] = character;
        }
        else if (clampedIndex >= characters.Count)
        {
            characters.Add(character);
        }
        else
        {
            characters[clampedIndex] = character;
        }

        string nextValue = new(characters.Take(InputCount).ToArray());
        await SetValue(nextValue);

        if (clampedIndex < InputCount - 1)
            await FocusInput(clampedIndex + 1);
    }

    internal async Task ClearCharacter(int index, string reason)
    {
        List<char> characters = [.. Sanitize(CurrentValue)];
        if (index < 0 || index >= characters.Count)
            return;

        characters.RemoveAt(index);
        await SetValue(new string(characters.ToArray()));

        if (reason == "Backspace")
            await FocusInput(index - 1);
        else
            await FocusInput(index);
    }

    internal async Task Clear(string reason)
    {
        if (string.IsNullOrEmpty(CurrentValue))
            return;

        await SetValue(string.Empty);

        if (reason is "Backspace" or "Delete")
            await FocusInput(0);
    }

    internal async Task ApplyPastedValue(string pastedValue)
    {
        string sanitized = Sanitize(pastedValue);
        if (string.IsNullOrEmpty(sanitized))
            return;

        string truncated = sanitized[..Math.Min(sanitized.Length, InputCount)];
        await SetValue(truncated);
        await FocusInput(Math.Min(truncated.Length - 1, InputCount - 1));
    }

    internal async Task MoveFocus(int currentIndex, int delta)
    {
        await FocusInput(currentIndex + delta);
    }

    internal async Task AttemptSubmit()
    {
        if (InputCount == 0)
            return;

        await Interop.RequestFormSubmit(_hiddenInputElement, Form);
    }

    internal void RegisterHiddenInput(ElementReference element)
    {
        _hiddenInputElement = element;
        _hasHiddenInput = true;
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleFormReset()
    {
        if (Value is not null || string.IsNullOrEmpty(CurrentValue))
            return Task.CompletedTask;

        _lastAutoSubmittedValue = null;
        return Clear("Reset");
    }

    public async ValueTask DisposeAsync()
    {
        if (_formResetRegistered)
            await Interop.UnregisterAssociatedFormReset(_hiddenInputElement);

        _dotNetReference?.Dispose();
    }

    private async Task FocusInput(int index)
    {
        int clampedIndex = Math.Clamp(index, 0, Math.Max(0, InputCount - 1));
        SetActiveInput(clampedIndex);
        KeyValuePair<BradixOneTimePasswordFieldInput, int> pair = _inputs
            .OrderBy(entry => entry.Value)
            .FirstOrDefault(entry => entry.Value == clampedIndex);

        if (pair.Key is not null)
            await pair.Key.Focus();
    }

    private async Task SetValue(string nextValue)
    {
        string sanitized = Sanitize(nextValue);

        if (Value is null)
            _uncontrolledValue = sanitized;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(sanitized);

        if (OnValueChange.HasDelegate)
            await OnValueChange.InvokeAsync(sanitized);

        if (AutoSubmit && InputCount > 0 && sanitized.Length == InputCount && sanitized != _lastAutoSubmittedValue)
        {
            _lastAutoSubmittedValue = sanitized;

            if (OnAutoSubmit.HasDelegate)
                await OnAutoSubmit.InvokeAsync(sanitized);

            await AttemptSubmit();
        }
        else if (sanitized.Length != InputCount)
        {
            _lastAutoSubmittedValue = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private string Sanitize(string value)
    {
        string stripped = string.Concat(value.Where(character => !char.IsWhiteSpace(character)));

        stripped = ValidationType switch
        {
            "alpha" => string.Concat(stripped.Where(char.IsLetter)),
            "alphanumeric" => string.Concat(stripped.Where(char.IsLetterOrDigit)),
            "numeric" => string.Concat(stripped.Where(char.IsDigit)),
            "none" when SanitizeValue is not null => SanitizeValue(stripped),
            _ => stripped
        };

        return InputCount > 0 && stripped.Length > InputCount
            ? stripped[..InputCount]
            : stripped;
    }
}
