@namespace Soenneker.Bradix

@inherits BradixComponentBase

<input @ref="_element"
       @attributes="InputAttributes" />

@code {
    private ElementReference _element;

    [CascadingParameter]
    private BradixOneTimePasswordField? Root { get; set; }

    private IReadOnlyDictionary<string, object> InputAttributes => BuildAttributes(
        ("type", "hidden"),
        ("value", Root?.CurrentValue.Trim()),
        ("name", Root?.Name),
        ("form", Root?.Form),
        ("autocomplete", "off"),
        ("autocapitalize", "off"),
        ("autocorrect", "off"),
        ("autosave", "off"),
        ("spellcheck", "false"),
        ("readonly", Root?.ReadOnly == true ? true : null),
        ("disabled", Root?.Disabled == true ? true : null));

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            Root?.RegisterHiddenInput(_element);

        return Task.CompletedTask;
    }
}
