@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixDismissableLayerBranch

@inject IBradixSuiteInterop Interop
<div @ref="_element"
     @attributes="BranchAttributes">
    @ChildContent
</div>

@code {
    private ElementReference _element;
    private bool _registered;

    private Dictionary<string, object> BranchAttributes => BuildAttributes(
        ("data-bradix-dismissable-layer-branch", string.Empty));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Interop.RegisterDismissableLayerBranch(_element);
        _registered = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
            await Interop.UnregisterDismissableLayerBranch(_element);
    }
}
