@namespace Soenneker.Bradix

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject BradixSuiteInterop Interop

<div @ref="_element"
     @attributes="BranchAttributes">
    @ChildContent
</div>

@code {
    private ElementReference _element;
    private bool _registered;

    private Dictionary<string, object> BranchAttributes => BuildAttributes();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Interop.RegisterDismissableLayerBranch(_element);
        _registered = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
            await Interop.UnregisterDismissableLayerBranch(_element);
    }
}
