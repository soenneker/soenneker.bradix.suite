@using System
@using Soenneker.Bradix.Suite.Base
@using Soenneker.Bradix.Suite.Slot
@inherits BradixComponentBase

@if (AsChild)
{
    <BradixSlot ElementName="@ResolvedChildElementName"
                Id="@Id"
                Class="@Class"
                Style="@ResolvedStyle"
                AdditionalAttributes="@AdditionalAttributes"
                ChildAttributes="@ChildAttributes">
        @ChildContent
    </BradixSlot>
}
else
{
    <span @attributes="SpanAttributes">
        @ChildContent
    </span>
}

@code {
    private const string HiddenStyles =
        "position: absolute; border: 0; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; word-wrap: normal;";

    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public string? ChildElementName { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, object>? ChildAttributes { get; set; }

    private string ResolvedStyle => string.IsNullOrWhiteSpace(Style) ? HiddenStyles : $"{HiddenStyles} {Style}";

    private string ResolvedChildElementName => ChildElementName ?? string.Empty;

    private Dictionary<string, object> SpanAttributes => BuildAttributes(
        ("style", ResolvedStyle));

    protected override void OnParametersSet()
    {
        if (AsChild && string.IsNullOrWhiteSpace(ChildElementName))
            throw new InvalidOperationException("BradixVisuallyHidden requires ChildElementName when AsChild is true.");
    }
}
