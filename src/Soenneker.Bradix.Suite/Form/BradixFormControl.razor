@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixFormControl

@inject IBradixSuiteInterop Interop
<input @ref="_element"
       @oninvalid:preventDefault="true"
       @oninvalid="HandleInvalid"
       @oninput="HandleInput"
       @onchange="HandleChange"
       @attributes="ControlAttributes" />

@code {
    private ElementReference _element;
    private bool? _lastServerInvalid;
    private bool _registeredWithForm;

    [CascadingParameter]
    private BradixForm? Form { get; set; }

    [CascadingParameter]
    private BradixFormField? Field { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Type { get; set; }

    internal string ResolvedName => Name ?? Field?.Name ?? string.Empty;

    private string ResolvedId => Id ?? Field?.FieldId ?? string.Empty;

    private Dictionary<string, object> ControlAttributes => BuildAttributes(
        ("name", ResolvedName),
        ("id", ResolvedId),
        ("type", string.IsNullOrWhiteSpace(Type) ? null : Type),
        ("data-valid", Field?.IsValid == true ? string.Empty : null),
        ("data-invalid", Field?.IsInvalid == true ? string.Empty : null),
        ("aria-invalid", Field?.ServerInvalid == true ? "true" : null),
        ("aria-describedby", !string.IsNullOrWhiteSpace(ResolvedName) ? Form?.GetFieldDescription(ResolvedName) : null),
        ("title", string.Empty));

    public async Task HandleValidityChanged(BradixFormValiditySnapshot? validity)
    {
        if (!string.IsNullOrWhiteSpace(ResolvedName))
            Form?.SetFieldValidity(ResolvedName, validity);

        await InvokeAsync(StateHasChanged);
    }

    public async Task HandleControlStateChanged(BradixFormControlSnapshot snapshot)
    {
        if (Form is null || string.IsNullOrWhiteSpace(ResolvedName))
            return;

        await Form.UpdateControlState(_element, ResolvedName, snapshot);
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Form is not null && !string.IsNullOrWhiteSpace(ResolvedName))
        {
            Form.RegisterControl(ResolvedName, _element);
            _registeredWithForm = true;
        }

        bool serverInvalid = Field?.ServerInvalid == true;

        if (serverInvalid && (_lastServerInvalid != true || firstRender))
            await Interop.FocusServerInvalidFormControl(_element);

        _lastServerInvalid = serverInvalid;
    }

    public ValueTask DisposeAsync()
    {
        if (_registeredWithForm && Form is not null && !string.IsNullOrWhiteSpace(ResolvedName))
            Form.UnregisterControl(ResolvedName, _element);

        return ValueTask.CompletedTask;
    }

    private async Task HandleInvalid()
    {
        BradixFormControlSnapshot snapshot = await Interop.GetFormControlState(_element);
        await HandleControlStateChanged(snapshot);
    }

    private async Task HandleChange(ChangeEventArgs _)
    {
        BradixFormControlSnapshot snapshot = await Interop.GetFormControlState(_element);
        await HandleControlStateChanged(snapshot);
    }

    private async Task HandleInput(ChangeEventArgs _)
    {
        await Interop.SetFormControlCustomValidity(_element, null);

        if (!string.IsNullOrWhiteSpace(ResolvedName))
            Form?.ClearFieldValidation(ResolvedName);

        await InvokeAsync(StateHasChanged);
    }
}
