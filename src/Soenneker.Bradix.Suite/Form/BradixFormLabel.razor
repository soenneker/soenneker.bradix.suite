@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixFormLabel
<BradixLabel For="@HtmlFor"
             Class="@LabelClass"
             Style="@Style"
             AdditionalAttributes="@LabelAdditionalAttributes">
    @ChildContent
</BradixLabel>

@code {
    [CascadingParameter]
    private BradixFormField? Field { get; set; }

    [Parameter]
    public string? For { get; set; }

    private string HtmlFor => For ?? Field?.FieldId ?? string.Empty;

    private string? LabelClass => Class;

    private IReadOnlyDictionary<string, object>? LabelAdditionalAttributes
    {
        get
        {
            var attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : [];

            if (Field?.IsValid == true)
                attributes["data-valid"] = string.Empty;

            if (Field?.IsInvalid == true)
                attributes["data-invalid"] = string.Empty;

            return attributes;
        }
    }
}
