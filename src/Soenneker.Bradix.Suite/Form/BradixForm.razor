@namespace Soenneker.Bradix

@using System.Linq
@using Microsoft.JSInterop

@inherits BradixComponent

@implements IBradixForm

@inject IBradixSuiteInterop Interop
<CascadingValue Value="this">
    <form @ref="_formElement"
          @onsubmit="HandleSubmit"
          @onreset="HandleReset"
          @attributes="FormAttributes">
        @ChildContent
    </form>
</CascadingValue>

@code {
    private const string _defaultInvalidMessage = "This value is not valid";

    private readonly Dictionary<string, BradixFormValiditySnapshot?> _validityMap = new(StringComparer.Ordinal);
    private readonly Dictionary<string, Dictionary<string, BradixFormCustomMatcherEntry>> _customMatchersByField = new(StringComparer.Ordinal);
    private readonly Dictionary<string, Dictionary<string, bool>> _customErrorsByField = new(StringComparer.Ordinal);
    private readonly Dictionary<string, long> _validationVersions = new(StringComparer.Ordinal);
    private readonly Dictionary<string, HashSet<string>> _messageIdsByField = new(StringComparer.Ordinal);
    private readonly Dictionary<string, ElementReference> _controlsByField = new(StringComparer.Ordinal);
    private ElementReference _formElement;
    private bool _registered;
    private DotNetObjectReference<object>? _dotNetReference;

    [Parameter]
    public EventCallback OnClearServerErrors { get; set; }

    [Parameter]
    public EventCallback<EventArgs> OnSubmit { get; set; }

    [Parameter]
    public EventCallback<EventArgs> OnReset { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyList<string>> OnInvalid { get; set; }

    private Dictionary<string, object> FormAttributes => BuildAttributes();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterFormRoot(_formElement, _dotNetReference);
        _registered = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
            await Interop.UnregisterFormRoot(_formElement);

        _dotNetReference?.Dispose();
    }

    internal BradixFormValiditySnapshot? GetFieldValidity(string fieldName)
    {
        return _validityMap.TryGetValue(fieldName, out var validity)
            ? validity
            : null;
    }

    internal string? GetFieldDescription(string fieldName)
    {
        if (!_messageIdsByField.TryGetValue(fieldName, out var ids) || ids.Count == 0)
            return null;

        return string.Join(" ", ids);
    }

    internal bool GetFieldCustomError(string fieldName, string matcherId)
    {
        return _customErrorsByField.TryGetValue(fieldName, out var fieldErrors) &&
               fieldErrors.TryGetValue(matcherId, out var matches) &&
               matches;
    }

    internal void SetFieldValidity(string fieldName, BradixFormValiditySnapshot? validity)
    {
        if (validity is null)
            _validityMap.Remove(fieldName);
        else
            _validityMap[fieldName] = validity;

        _ = InvokeAsync(StateHasChanged);
    }

    internal void ClearFieldValidation(string fieldName)
    {
        _validityMap.Remove(fieldName);
        _customErrorsByField.Remove(fieldName);
        _validationVersions.Remove(fieldName);
        _ = InvokeAsync(StateHasChanged);
    }

    internal void RegisterFieldCustomMatcher(string fieldName, BradixFormCustomMatcherEntry entry)
    {
        if (!_customMatchersByField.TryGetValue(fieldName, out var fieldEntries))
        {
            fieldEntries = new Dictionary<string, BradixFormCustomMatcherEntry>(StringComparer.Ordinal);
            _customMatchersByField[fieldName] = fieldEntries;
        }

        fieldEntries[entry.Id] = entry;
    }

    internal void UnregisterFieldCustomMatcher(string fieldName, string matcherId)
    {
        if (!_customMatchersByField.TryGetValue(fieldName, out var fieldEntries))
            return;

        fieldEntries.Remove(matcherId);

        if (fieldEntries.Count == 0)
            _customMatchersByField.Remove(fieldName);

        if (_customErrorsByField.TryGetValue(fieldName, out var fieldErrors))
        {
            fieldErrors.Remove(matcherId);

            if (fieldErrors.Count == 0)
                _customErrorsByField.Remove(fieldName);
        }
    }

    internal async Task UpdateControlState(ElementReference element, string fieldName, BradixFormControlSnapshot snapshot)
    {
        var version = NextValidationVersion(fieldName);
        var validity = snapshot.Validity ?? new BradixFormValiditySnapshot();

        if (HasBuiltInError(validity))
        {
            await Interop.SetFormControlCustomValidity(element, null);
            SetFieldCustomErrors(fieldName, null);
            SetFieldValidity(fieldName, validity);
            return;
        }

        if (!_customMatchersByField.TryGetValue(fieldName, out var matcherEntries) ||
            matcherEntries.Count == 0)
        {
            await Interop.SetFormControlCustomValidity(element, null);
            SetFieldCustomErrors(fieldName, null);
            SetFieldValidity(fieldName, validity);
            return;
        }

        Dictionary<string, bool> syncResults = [];
        List<BradixFormCustomMatcherEntry> asyncMatchers = [];

        foreach (var entry in matcherEntries.Values)
        {
            var task = entry.Match(snapshot.Value, snapshot.FormData);

            if (task.IsCompletedSuccessfully)
            {
                syncResults[entry.Id] = task.Result;
                continue;
            }

            asyncMatchers.Add(entry);
        }

        var hasSyncErrors = syncResults.Values.Any(static value => value);

        await Interop.SetFormControlCustomValidity(element, hasSyncErrors ? _defaultInvalidMessage : null);

        var syncValidity = await Interop.GetFormControlValidity(element);
        SetFieldCustomErrors(fieldName, syncResults);
        SetFieldValidity(fieldName, syncValidity);

        if (hasSyncErrors || asyncMatchers.Count == 0 || !IsLatestValidation(fieldName, version))
            return;

        Dictionary<string, bool> asyncResults = new(syncResults, StringComparer.Ordinal);

        foreach (var entry in asyncMatchers)
        {
            asyncResults[entry.Id] = await entry.Match(snapshot.Value, snapshot.FormData);

            if (!IsLatestValidation(fieldName, version))
                return;
        }

        var hasAsyncErrors = asyncResults.Values.Any(static value => value);

        await Interop.SetFormControlCustomValidity(element, hasAsyncErrors ? _defaultInvalidMessage : null);

        var asyncValidity = await Interop.GetFormControlValidity(element);

        if (!IsLatestValidation(fieldName, version))
            return;

        SetFieldCustomErrors(fieldName, asyncResults);
        SetFieldValidity(fieldName, asyncValidity);
    }

    internal void RegisterFieldMessageId(string fieldName, string id)
    {
        if (!_messageIdsByField.TryGetValue(fieldName, out var ids))
        {
            ids = new HashSet<string>(StringComparer.Ordinal);
            _messageIdsByField[fieldName] = ids;
        }

        if (ids.Add(id))
            _ = InvokeAsync(StateHasChanged);
    }

    internal void UnregisterFieldMessageId(string fieldName, string id)
    {
        if (!_messageIdsByField.TryGetValue(fieldName, out var ids))
            return;

        if (ids.Remove(id))
        {
            if (ids.Count == 0)
                _messageIdsByField.Remove(fieldName);

            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleSubmit(EventArgs args)
    {
        if (OnSubmit.HasDelegate)
            await OnSubmit.InvokeAsync(args);

        if (OnClearServerErrors.HasDelegate)
            await OnClearServerErrors.InvokeAsync();
    }

    private async Task HandleReset(EventArgs args)
    {
        if (OnReset.HasDelegate)
            await OnReset.InvokeAsync(args);

        await Interop.ClearFormCustomValidity(_formElement);

        _validityMap.Clear();
        _customErrorsByField.Clear();
        _validationVersions.Clear();

        if (OnClearServerErrors.HasDelegate)
            await OnClearServerErrors.InvokeAsync();

        await InvokeAsync(StateHasChanged);
    }

    private static bool HasBuiltInError(BradixFormValiditySnapshot validity)
    {
        return validity.BadInput ||
               validity.PatternMismatch ||
               validity.RangeOverflow ||
               validity.RangeUnderflow ||
               validity.StepMismatch ||
               validity.TooLong ||
               validity.TooShort ||
               validity.TypeMismatch ||
               validity.ValueMissing;
    }

    private long NextValidationVersion(string fieldName)
    {
        var next = _validationVersions.TryGetValue(fieldName, out var current)
            ? current + 1
            : 1;

        _validationVersions[fieldName] = next;
        return next;
    }

    private bool IsLatestValidation(string fieldName, long version)
    {
        return _validationVersions.TryGetValue(fieldName, out var current) && current == version;
    }

    private void SetFieldCustomErrors(string fieldName, IReadOnlyDictionary<string, bool>? errors)
    {
        if (errors is null || errors.Count == 0)
        {
            _customErrorsByField.Remove(fieldName);
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        _customErrorsByField[fieldName] = new Dictionary<string, bool>(errors, StringComparer.Ordinal);
        _ = InvokeAsync(StateHasChanged);
    }

    internal void RegisterControl(string fieldName, ElementReference element)
    {
        if (string.IsNullOrWhiteSpace(fieldName))
            return;

        _controlsByField[fieldName] = element;
    }

    internal void UnregisterControl(string fieldName, ElementReference element)
    {
        if (string.IsNullOrWhiteSpace(fieldName))
            return;

        if (_controlsByField.TryGetValue(fieldName, out var existing) && string.Equals(existing.Id, element.Id, StringComparison.Ordinal))
            _controlsByField.Remove(fieldName);
    }

    [JSInvokable]
    public async Task HandleInvalidControls(string[] fieldNames)
    {
        string[] distinctFieldNames = fieldNames.Distinct(StringComparer.Ordinal).ToArray();

        foreach (var fieldName in distinctFieldNames)
        {
            if (!_controlsByField.TryGetValue(fieldName, out var element))
                continue;

            var snapshot = await Interop.GetFormControlState(element);
            await UpdateControlState(element, fieldName, snapshot);
        }

        if (OnInvalid.HasDelegate)
            await OnInvalid.InvokeAsync(distinctFieldNames);
    }
}
