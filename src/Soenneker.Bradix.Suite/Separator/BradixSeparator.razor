@namespace Soenneker.Bradix

@inherits BradixComponent

@implements IBradixSeparator

@if (AsChild)
{
    <BradixSlot ElementName="@ResolvedChildElementName"
                Id="@Id"
                Class="@Class"
                Style="@Style"
                AdditionalAttributes="@SeparatorAttributes"
                ChildAttributes="@ChildAttributes">
        @ChildContent
    </BradixSlot>
}
else
{
    <div @attributes="SeparatorAttributes">
        @ChildContent
    </div>
}

@code {
    [Parameter]
    public BradixOrientation Orientation { get; set; } = BradixOrientation.Horizontal;

    [Parameter]
    public bool Decorative { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public string? ChildElementName { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, object>? ChildAttributes { get; set; }

    private BradixOrientation ResolvedOrientation => Orientation;

    private string ResolvedChildElementName => ChildElementName ?? string.Empty;

    private Dictionary<string, object> SeparatorAttributes => BuildAttributes(
        ("role", Decorative ? "none" : "separator"),
        ("aria-orientation", !Decorative && ResolvedOrientation == BradixOrientation.Vertical ? BradixOrientation.Vertical.Value : null),
        ("data-orientation", ResolvedOrientation.Value));

    protected override void OnParametersSet()
    {
        if (AsChild && string.IsNullOrWhiteSpace(ChildElementName))
            throw new InvalidOperationException("BradixSeparator requires ChildElementName when AsChild is true.");
    }
}
