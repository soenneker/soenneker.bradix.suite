@namespace Soenneker.Bradix

@inherits BradixComponent

@using Soenneker.Blazor.Utils.Ids
@implements IBradixToggleGroup

<CascadingValue Value="this">
    <div @attributes="RootAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly List<BradixToggleGroupItem> _items = [];
    private bool _initialized;
    private string _uncontrolledValue = string.Empty;
    private List<string> _uncontrolledValues = [];

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public BradixSelectionMode Type { get; set; } = BradixSelectionMode.Single;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool RovingFocus { get; set; } = true;

    [Parameter]
    public bool Loop { get; set; } = true;

    [Parameter]
    public BradixOrientation? Orientation { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string?> OnValueChange { get; set; }

    [Parameter]
    public IReadOnlyCollection<string>? Values { get; set; }

    [Parameter]
    public IEnumerable<string>? DefaultValues { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyCollection<string>> ValuesChanged { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyCollection<string>> OnValuesChange { get; set; }

    internal string GroupId { get; private set; } = string.Empty;

    internal string? CurrentTabStopId { get; private set; }

    internal string ResolvedDirection => BradixDirection.Resolve(Dir, CascadedDirection);

    private bool IsSingle => Type != BradixSelectionMode.Multiple;

    private string? NormalizedOrientation => Orientation?.Value;

    private Dictionary<string, object> RootAttributes => BuildAttributes(
        ("role", "group"),
        ("aria-orientation", NormalizedOrientation),
        ("data-orientation", NormalizedOrientation),
        ("dir", ResolvedDirection));

    protected override void OnInitialized()
    {
        GroupId = BlazorIdGenerator.New("bradix-toggle-group");
    }

    protected override void OnParametersSet()
    {
        if (_initialized)
        {
            EnsureCurrentTabStopId();
            return;
        }

        _uncontrolledValue = NormalizeSingleValue(DefaultValue);
        _uncontrolledValues = DefaultValues?.Distinct(StringComparer.Ordinal).ToList() ?? [];
        _initialized = true;
        EnsureCurrentTabStopId();
    }

    internal bool IsItemPressed(string value)
    {
        if (IsSingle)
            return string.Equals(NormalizeSingleValue(Value ?? _uncontrolledValue), value, StringComparison.Ordinal);

        var values = Values ?? _uncontrolledValues;
        return values.Contains(value);
    }

    internal bool IsCurrentTabStop(BradixToggleGroupItem item)
    {
        return !RovingFocus || string.Equals(CurrentTabStopId, item.TabStopId, StringComparison.Ordinal);
    }

    internal void RegisterItem(BradixToggleGroupItem item)
    {
        if (_items.Contains(item))
            return;

        _items.Add(item);
        EnsureCurrentTabStopId();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void UnregisterItem(BradixToggleGroupItem item)
    {
        _items.Remove(item);
        EnsureCurrentTabStopId();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void SetCurrentTabStop(string? tabStopId)
    {
        if (!RovingFocus || string.Equals(CurrentTabStopId, tabStopId, StringComparison.Ordinal))
            return;

        CurrentTabStopId = tabStopId;
        _ = InvokeAsync(StateHasChanged);
    }

    internal async Task ActivateItem(string value)
    {
        if (IsSingle)
        {
            await SetSingleValue(value);
            return;
        }

        var next = Values?.ToList() ?? [.. _uncontrolledValues];

        if (next.Contains(value, StringComparer.Ordinal))
            return;

        next.Add(value);
        await SetMultipleValues(next);
    }

    internal async Task DeactivateItem(string value)
    {
        if (IsSingle)
        {
            await SetSingleValue(string.Empty);
            return;
        }

        var next = Values?.ToList() ?? [.. _uncontrolledValues];

        if (!next.Remove(value))
            return;

        await SetMultipleValues(next);
    }

    internal async Task HandleItemKeyDown(BradixToggleGroupItem item, KeyboardEventArgs args)
    {
        if (!RovingFocus || args.CtrlKey || args.AltKey || args.MetaKey || args.ShiftKey)
            return;

        var focusableItems = _items
                             .Where(candidate => candidate.IsFocusable)
                             .ToList();

        var currentIndex = focusableItems.IndexOf(item);

        if (currentIndex < 0)
            return;

        if (!BradixRovingFocusNavigator.TryGetTargetIndex(
                args.Key,
                NormalizedOrientation,
                ResolvedDirection,
                currentIndex,
                focusableItems.Count,
                Loop,
                out var targetIndex))
        {
            return;
        }

        var target = focusableItems[targetIndex];
        CurrentTabStopId = target.TabStopId;
        await target.Focus();
        await InvokeAsync(StateHasChanged);
    }

    private void EnsureCurrentTabStopId()
    {
        var focusableItems = _items
                             .Where(item => item.IsFocusable)
                             .ToList();

        if (focusableItems.Count == 0)
        {
            CurrentTabStopId = null;
            return;
        }

        if (CurrentTabStopId is not null && focusableItems.Any(item => string.Equals(item.TabStopId, CurrentTabStopId, StringComparison.Ordinal)))
            return;

        var activeItem = focusableItems.FirstOrDefault(item => item.IsPressed);
        CurrentTabStopId = activeItem?.TabStopId ?? focusableItems[0].TabStopId;
    }

    private async Task SetSingleValue(string? value)
    {
        var normalizedValue = NormalizeSingleValue(value);

        if (string.Equals(NormalizeSingleValue(Value ?? _uncontrolledValue), normalizedValue, StringComparison.Ordinal))
            return;

        if (Value is null)
            _uncontrolledValue = normalizedValue;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(normalizedValue);

        if (OnValueChange.HasDelegate)
            await OnValueChange.InvokeAsync(normalizedValue);

        EnsureCurrentTabStopId();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetMultipleValues(IReadOnlyCollection<string> values)
    {
        var next = values.Distinct(StringComparer.Ordinal).ToList();

        if (Values is null)
            _uncontrolledValues = next;

        IReadOnlyCollection<string> result = next.ToArray();

        if (ValuesChanged.HasDelegate)
            await ValuesChanged.InvokeAsync(result);

        if (OnValuesChange.HasDelegate)
            await OnValuesChange.InvokeAsync(result);

        EnsureCurrentTabStopId();
        await InvokeAsync(StateHasChanged);
    }

    private static string NormalizeSingleValue(string? value)
    {
        return value ?? string.Empty;
    }
}
