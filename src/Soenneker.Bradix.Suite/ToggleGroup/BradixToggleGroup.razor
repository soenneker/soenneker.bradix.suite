@namespace Soenneker.Bradix

@inherits BradixComponentBase
@inject IBradixIdGenerator IdGenerator

<CascadingValue Value="this">
    <div @attributes="RootAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private const string SingleType = "single";
    private const string MultipleType = "multiple";

    private readonly List<BradixToggleGroupItem> _items = [];
    private bool _initialized;
    private string? _uncontrolledValue;
    private List<string> _uncontrolledValues = [];

    [CascadingParameter(Name = "BradixDirection")]
    private string? CascadedDirection { get; set; }

    [Parameter]
    public string Type { get; set; } = SingleType;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool RovingFocus { get; set; } = true;

    [Parameter]
    public bool Loop { get; set; } = true;

    [Parameter]
    public string? Orientation { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string?> OnValueChange { get; set; }

    [Parameter]
    public IReadOnlyCollection<string>? Values { get; set; }

    [Parameter]
    public IEnumerable<string>? DefaultValues { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyCollection<string>> ValuesChanged { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyCollection<string>> OnValuesChange { get; set; }

    internal string GroupId { get; private set; } = string.Empty;

    internal string? CurrentTabStopId { get; private set; }

    internal string ResolvedDirection => Dir == "rtl" ? "rtl" : CascadedDirection == "rtl" ? "rtl" : "ltr";

    private bool IsSingle => Type != MultipleType;

    private string? NormalizedOrientation => Orientation is "horizontal" or "vertical" ? Orientation : null;

    private Dictionary<string, object> RootAttributes => BuildAttributes(
        ("role", "group"),
        ("dir", ResolvedDirection),
        ("data-orientation", NormalizedOrientation));

    protected override void OnInitialized()
    {
        GroupId = IdGenerator.New("bradix-toggle-group");
    }

    protected override void OnParametersSet()
    {
        Type = Type == MultipleType ? MultipleType : SingleType;

        if (_initialized)
        {
            EnsureCurrentTabStopId();
            return;
        }

        _uncontrolledValue = DefaultValue;
        _uncontrolledValues = DefaultValues?.Distinct(StringComparer.Ordinal).ToList() ?? [];
        _initialized = true;
        EnsureCurrentTabStopId();
    }

    internal bool IsItemPressed(string value)
    {
        if (IsSingle)
            return string.Equals(Value ?? _uncontrolledValue, value, StringComparison.Ordinal);

        IReadOnlyCollection<string> values = Values ?? _uncontrolledValues;
        return values.Contains(value);
    }

    internal bool IsCurrentTabStop(BradixToggleGroupItem item)
    {
        return !RovingFocus || string.Equals(CurrentTabStopId, item.TabStopId, StringComparison.Ordinal);
    }

    internal void RegisterItem(BradixToggleGroupItem item)
    {
        if (_items.Contains(item))
            return;

        _items.Add(item);
        EnsureCurrentTabStopId();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void UnregisterItem(BradixToggleGroupItem item)
    {
        _items.Remove(item);
        EnsureCurrentTabStopId();
        _ = InvokeAsync(StateHasChanged);
    }

    internal void SetCurrentTabStop(string? tabStopId)
    {
        if (!RovingFocus || string.Equals(CurrentTabStopId, tabStopId, StringComparison.Ordinal))
            return;

        CurrentTabStopId = tabStopId;
        _ = InvokeAsync(StateHasChanged);
    }

    internal async Task ActivateItemAsync(string value)
    {
        if (IsSingle)
        {
            await SetSingleValueAsync(value);
            return;
        }

        List<string> next = Values?.ToList() ?? [.. _uncontrolledValues];

        if (next.Contains(value, StringComparer.Ordinal))
            return;

        next.Add(value);
        await SetMultipleValuesAsync(next);
    }

    internal async Task DeactivateItemAsync(string value)
    {
        if (IsSingle)
        {
            await SetSingleValueAsync(null);
            return;
        }

        List<string> next = Values?.ToList() ?? [.. _uncontrolledValues];

        if (!next.Remove(value))
            return;

        await SetMultipleValuesAsync(next);
    }

    internal async Task HandleItemKeyDownAsync(BradixToggleGroupItem item, KeyboardEventArgs args)
    {
        if (!RovingFocus || args.CtrlKey || args.AltKey || args.MetaKey || args.ShiftKey)
            return;

        List<BradixToggleGroupItem> focusableItems = _items
            .Where(candidate => candidate.IsFocusable)
            .ToList();

        int currentIndex = focusableItems.IndexOf(item);

        if (currentIndex < 0)
            return;

        if (!BradixRovingFocusNavigator.TryGetTargetIndex(
                args.Key,
                NormalizedOrientation,
                ResolvedDirection,
                currentIndex,
                focusableItems.Count,
                Loop,
                out int targetIndex))
        {
            return;
        }

        BradixToggleGroupItem target = focusableItems[targetIndex];
        CurrentTabStopId = target.TabStopId;
        await target.FocusAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void EnsureCurrentTabStopId()
    {
        List<BradixToggleGroupItem> focusableItems = _items
            .Where(item => item.IsFocusable)
            .ToList();

        if (focusableItems.Count == 0)
        {
            CurrentTabStopId = null;
            return;
        }

        if (CurrentTabStopId is not null && focusableItems.Any(item => string.Equals(item.TabStopId, CurrentTabStopId, StringComparison.Ordinal)))
            return;

        BradixToggleGroupItem? activeItem = focusableItems.FirstOrDefault(item => item.IsPressed);
        CurrentTabStopId = activeItem?.TabStopId ?? focusableItems[0].TabStopId;
    }

    private async Task SetSingleValueAsync(string? value)
    {
        if (string.Equals(Value ?? _uncontrolledValue, value, StringComparison.Ordinal))
            return;

        if (Value is null)
            _uncontrolledValue = value;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(value);

        if (OnValueChange.HasDelegate)
            await OnValueChange.InvokeAsync(value);

        EnsureCurrentTabStopId();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetMultipleValuesAsync(IReadOnlyCollection<string> values)
    {
        List<string> next = values.Distinct(StringComparer.Ordinal).ToList();

        if (Values is null)
            _uncontrolledValues = next;

        IReadOnlyCollection<string> result = next.ToArray();

        if (ValuesChanged.HasDelegate)
            await ValuesChanged.InvokeAsync(result);

        if (OnValuesChange.HasDelegate)
            await OnValuesChange.InvokeAsync(result);

        EnsureCurrentTabStopId();
        await InvokeAsync(StateHasChanged);
    }
}
