@namespace Soenneker.Bradix

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

@if (_isMounted)
{
    <div @ref="_element"
         @attributes="PortalAttributes">
        @ChildContent
    </div>
}

@code {
    private ElementReference _element;
    private bool _isMounted;
    private bool _mounted;
    private ElementReference _lastContainer;
    private bool _lastContainerCaptured;
    private string? _lastContainerSelector;

    [Parameter]
    public string? ContainerSelector { get; set; }

    [Parameter]
    public ElementReference Container { get; set; }

    private Dictionary<string, object> PortalAttributes => BuildAttributes();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isMounted)
        {
            _isMounted = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!_isMounted)
            return;

        bool containerChanged = !_lastContainerCaptured || !EqualityComparer<ElementReference>.Default.Equals(_lastContainer, Container);

        if (_mounted && !firstRender && !containerChanged && string.Equals(_lastContainerSelector, ContainerSelector, StringComparison.Ordinal))
            return;

        await Interop.MountPortal(_element, ContainerSelector, Container);
        _mounted = true;
        _lastContainer = Container;
        _lastContainerCaptured = true;
        _lastContainerSelector = ContainerSelector;
    }

    public async ValueTask DisposeAsync()
    {
        if (_mounted)
            await Interop.UnmountPortal(_element);
    }
}
