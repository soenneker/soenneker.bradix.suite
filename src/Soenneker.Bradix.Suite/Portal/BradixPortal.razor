@namespace Soenneker.Bradix

@implements IAsyncDisposable
@inherits BradixComponentBase
@inject IBradixSuiteInterop Interop

@if (_isMounted)
{
    <div @ref="_element"
         @attributes="PortalAttributes">
        @ChildContent
    </div>
}

@code {
    private ElementReference _element;
    private bool _isMounted;
    private bool _mounted;
    private string? _lastContainerSelector;

    [Parameter]
    public string? ContainerSelector { get; set; }

    private Dictionary<string, object> PortalAttributes => BuildAttributes(
        ("data-bradix-portal", string.Empty));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isMounted)
        {
            _isMounted = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!_isMounted)
            return;

        if (_mounted && !firstRender && string.Equals(_lastContainerSelector, ContainerSelector, StringComparison.Ordinal))
            return;

        await Interop.MountPortal(_element, ContainerSelector);
        _mounted = true;
        _lastContainerSelector = ContainerSelector;
    }

    public async ValueTask DisposeAsync()
    {
        if (_mounted)
            await Interop.UnmountPortal(_element);
    }
}
