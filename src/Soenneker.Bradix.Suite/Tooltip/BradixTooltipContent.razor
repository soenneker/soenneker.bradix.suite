@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponentBase

@implements IBradixTooltipContent

@inject IBradixSuiteInterop Interop

@if (IsPresent)
{
    <BradixDismissableLayer DisableOutsidePointerEvents="false"
                            DismissOnEscapeKeyDown="false"
                            DismissOnPointerDownOutside="false"
                            DismissOnFocusOutside="false"
                            OnEscapeKeyDownDetailed="@HandleEscapeKeyDown"
                            OnFocusOutsideDetailed="@HandleFocusOutside"
                            OnPointerDownOutsideDetailed="@HandlePointerDownOutside">
        <BradixPopperContent Side="@Side"
                             SideOffset="SideOffset"
                             Align="@Align"
                             AlignOffset="AlignOffset"
                             ArrowPadding="ArrowPadding"
                             AvoidCollisions="AvoidCollisions"
                             CollisionPadding="CollisionPadding"
                             HideWhenDetached="HideWhenDetached"
                             Style="@PositionerStyle">
            <BradixPresence Present="IsPresent"
                            Tag="div"
                            Class="@Class"
                            Style="@Style"
                            AdditionalAttributes="@TooltipAttributes">
                <div @ref="_contentElement"
                     @onpointerenter="HandlePointerEnter"
                     @onpointerleave="HandlePointerLeave">
                    @ChildContent
                </div>
                <BradixVisuallyHidden Id="@Tooltip?.ContentId"
                                      AdditionalAttributes="@AccessibleTooltipAttributes">
                    @AccessibleTooltipContent
                </BradixVisuallyHidden>
            </BradixPresence>
        </BradixPopperContent>
    </BradixDismissableLayer>
}

@code {
    private ElementReference _contentElement;
    private DotNetObjectReference<object>? _dotNetReference;
    private bool _contentRegistered;
    private string? _accessibleLabel;
    private bool? _lastHoverableContent;
    private string? _lastTriggerId;

    [CascadingParameter]
    private BradixTooltip? Tooltip { get; set; }

    [CascadingParameter(Name = "BradixTooltipPortalForceMount")]
    private bool PortalForceMount { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public string Side { get; set; } = "top";

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public string Align { get; set; } = "center";

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    [Parameter]
    public EventCallback OnEscapeKeyDown { get; set; }

    [Parameter]
    public EventCallback OnPointerDownOutside { get; set; }

    [Parameter]
    public EventCallback<BradixEscapeKeyDownEventArgs> OnEscapeKeyDownDetailed { get; set; }

    [Parameter]
    public EventCallback<BradixPointerDownOutsideEventArgs> OnPointerDownOutsideDetailed { get; set; }

    private bool IsPresent => ForceMount || PortalForceMount || Tooltip?.CurrentOpen == true;

    private string PositionerStyle =>
        "--radix-tooltip-content-transform-origin: var(--radix-popper-transform-origin); --radix-tooltip-content-available-width: var(--radix-popper-available-width); --radix-tooltip-content-available-height: var(--radix-popper-available-height); --radix-tooltip-trigger-width: var(--radix-popper-anchor-width); --radix-tooltip-trigger-height: var(--radix-popper-anchor-height);";

    private string AccessibleTooltipContent => AriaLabel ?? _accessibleLabel ?? string.Empty;

    private IReadOnlyDictionary<string, object> TooltipAttributes
    {
        get
        {
            Dictionary<string, object> attributes = AdditionalAttributes is not null
                ? new Dictionary<string, object>(AdditionalAttributes)
                : new Dictionary<string, object>();

            attributes["data-state"] = Tooltip?.StateAttribute ?? "closed";

            return attributes;
        }
    }

    private IReadOnlyDictionary<string, object> AccessibleTooltipAttributes =>
        new Dictionary<string, object>
        {
            ["role"] = "tooltip"
        };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsPresent || Tooltip is null)
        {
            if (_contentRegistered)
            {
                await Interop.UnregisterTooltipContent(_contentElement);
                _contentRegistered = false;
            }

            return;
        }

        _dotNetReference ??= DotNetObjectReference.Create<object>(this);

        bool hoverableContent = !Tooltip.EffectiveDisableHoverableContent;
        string? triggerId = Tooltip.TriggerElement.Id;
        bool shouldRegister = !_contentRegistered ||
            _lastHoverableContent != hoverableContent ||
            !string.Equals(_lastTriggerId, triggerId, StringComparison.Ordinal);

        if (shouldRegister)
        {
            await Interop.RegisterTooltipContent(_contentElement, Tooltip.TriggerElement, _dotNetReference, Tooltip.ContentId,
                hoverableContent);
            _contentRegistered = true;
            _lastHoverableContent = hoverableContent;
            _lastTriggerId = triggerId;
        }

        if (string.IsNullOrWhiteSpace(AriaLabel))
        {
            string textContent = await Interop.GetTextContent(_contentElement);

            if (!string.Equals(_accessibleLabel, textContent, StringComparison.Ordinal))
            {
                _accessibleLabel = textContent;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_contentRegistered)
            await Interop.UnregisterTooltipContent(_contentElement);

        _dotNetReference?.Dispose();
    }

    private async Task HandleEscapeKeyDown(BradixEscapeKeyDownEventArgs args)
    {
        if (OnEscapeKeyDown.HasDelegate)
            await OnEscapeKeyDown.InvokeAsync();

        if (OnEscapeKeyDownDetailed.HasDelegate)
            await OnEscapeKeyDownDetailed.InvokeAsync(args);

        if (!args.DefaultPrevented && Tooltip is not null)
            await Tooltip.Close();
    }

    private async Task HandlePointerDownOutside(BradixPointerDownOutsideEventArgs args)
    {
        if (OnPointerDownOutside.HasDelegate)
            await OnPointerDownOutside.InvokeAsync();

        if (OnPointerDownOutsideDetailed.HasDelegate)
            await OnPointerDownOutsideDetailed.InvokeAsync(args);

        if (!args.DefaultPrevented && Tooltip is not null)
            await Tooltip.Close();
    }

    private static Task HandleFocusOutside(BradixFocusOutsideEventArgs args)
    {
        args.PreventDefault();
        return Task.CompletedTask;
    }

    private Task HandlePointerEnter(PointerEventArgs _)
    {
        if (Tooltip?.EffectiveDisableHoverableContent == true)
            return Task.CompletedTask;

        return Tooltip?.HandleContentEnter() ?? Task.CompletedTask;
    }

    private Task HandlePointerLeave(PointerEventArgs _)
    {
        if (Tooltip?.EffectiveDisableHoverableContent == true)
            return Task.CompletedTask;

        return Tooltip?.HandleContentLeave() ?? Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleTooltipOpenFromOutside()
    {
        return Tooltip?.Close() ?? Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleTooltipTriggerScroll()
    {
        return Tooltip?.Close() ?? Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleTooltipGraceAreaExit()
    {
        return Tooltip?.Close() ?? Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandlePointerGraceAreaChanged(bool inTransit)
    {
        Tooltip?.SetPointerInTransit(inTransit);
        return Task.CompletedTask;
    }
}
