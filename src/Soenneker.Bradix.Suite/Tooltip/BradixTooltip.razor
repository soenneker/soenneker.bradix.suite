@namespace Soenneker.Bradix

@using System.Threading
@using Soenneker.Blazor.Utils.Ids

@inherits BradixComponent

@implements IBradixTooltip

@inject IBradixSuiteInterop Interop
<BradixPopper>
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</BradixPopper>

@code {
    private bool _initialized;
    private bool _uncontrolledOpen;
    private bool _openedWithDelay;
    private CancellationTokenSource? _openDelayTokenSource;

    [CascadingParameter]
    private BradixTooltipProvider? Provider { get; set; }

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    [Parameter]
    public int? DelayDuration { get; set; }

    [Parameter]
    public bool? DisableHoverableContent { get; set; }

    public ElementReference TriggerElement { get; private set; }

    public string? BaseId { get; private set; }

    public bool CurrentOpen => Open ?? _uncontrolledOpen;

    public string ContentId => BlazorIdGenerator.Child(BaseId!, "content");

    public string StateAttribute => CurrentOpen
        ? (_openedWithDelay ? "delayed-open" : "instant-open")
        : "closed";

    public bool EffectiveDisableHoverableContent => DisableHoverableContent ?? Provider?.DisableHoverableContent ?? false;

    public int EffectiveDelayDuration => DelayDuration ?? Provider?.DelayDuration ?? 700;

    public bool IsPointerInTransit => Provider?.IsPointerInTransit ?? false;

    public void SetPointerInTransit(bool inTransit)
    {
        Provider?.SetPointerInTransit(inTransit);
    }

    public void RegisterTrigger(ElementReference triggerElement)
    {
        TriggerElement = triggerElement;
    }

    protected override void OnInitialized()
    {
        BaseId ??= BlazorIdGenerator.New("bradix-tooltip");
    }

    protected override void OnParametersSet()
    {
        if (_initialized)
            return;

        _uncontrolledOpen = DefaultOpen;
        _initialized = true;
    }

    public ValueTask DisposeAsync()
    {
        CancelOpenDelay();
        return ValueTask.CompletedTask;
    }

    public async Task HandleTriggerEnter()
    {
        if ((Provider?.IsOpenDelayed).GetValueOrDefault(true))
        {
            StartOpenDelay();
        }
        else
        {
            await OpenNow(false);
        }
    }

    public Task HandleTriggerLeave()
    {
        if (EffectiveDisableHoverableContent)
            return Close();

        CancelOpenDelay();
        return Task.CompletedTask;
    }

    public Task HandleContentEnter()
    {
        return Task.CompletedTask;
    }

    public Task HandleContentLeave()
    {
        return Task.CompletedTask;
    }

    public Task HandleTriggerFocus(bool pointerDown)
    {
        return pointerDown ? Task.CompletedTask : OpenNow(false);
    }

    public Task HandleTriggerBlur()
    {
        return Close();
    }

    public Task HandleTriggerClick()
    {
        return Close();
    }

    public async Task CloseFromProvider()
    {
        await SetOpen(false, false, false);
    }

    public async Task Close()
    {
        CancelOpenDelay();
        await SetOpen(false, false, true);
    }

    private void StartOpenDelay()
    {
        CancelOpenDelay();
        _openDelayTokenSource = new CancellationTokenSource();
        _ = OpenAfterDelay(_openDelayTokenSource.Token);
    }

    private async Task OpenAfterDelay(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(EffectiveDelayDuration, cancellationToken);
            await OpenNow(true);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task OpenNow(bool delayed)
    {
        CancelOpenDelay();
        await SetOpen(true, delayed, true);
    }

    private async Task SetOpen(bool open, bool delayed, bool notifyProvider)
    {
        if (CurrentOpen == open)
        {
            if (open)
                _openedWithDelay = delayed;

            return;
        }

        if (open && notifyProvider && Provider is not null)
            await Provider.NotifyOpen(this);

        if (Open is null)
            _uncontrolledOpen = open;

        _openedWithDelay = open && delayed;

        if (open)
            await Interop.DispatchTooltipOpen(ContentId);

        if (OpenChanged.HasDelegate)
            await OpenChanged.InvokeAsync(open);

        if (OnOpenChange.HasDelegate)
            await OnOpenChange.InvokeAsync(open);

        if (!open && notifyProvider)
            Provider?.NotifyClose(this);

        await InvokeAsync(StateHasChanged);
    }

    private void CancelOpenDelay()
    {
        _openDelayTokenSource?.Cancel();
        _openDelayTokenSource?.Dispose();
        _openDelayTokenSource = null;
    }
}
