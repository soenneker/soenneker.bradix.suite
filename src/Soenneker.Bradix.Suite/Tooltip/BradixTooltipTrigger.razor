@namespace Soenneker.Bradix

@using Microsoft.JSInterop

@inherits BradixComponentBase

@implements IBradixTooltipTrigger

@inject IBradixSuiteInterop Interop
<BradixPopperAnchor>
    <button @ref="_triggerElement"
            @onclick="HandleClick"
            @onpointermove="HandlePointerMove"
            @onpointerleave="HandlePointerLeave"
            @onpointerdown="HandlePointerDown"
            @onpointerup="HandlePointerUp"
            @onfocus="HandleFocus"
            @onblur="HandleBlur"
            @attributes="TriggerAttributes">
        @ChildContent
    </button>
</BradixPopperAnchor>

@code {
    private bool _hasPointerMoveOpened;
    private bool _pointerDown;
    private ElementReference _triggerElement;
    private DotNetObjectReference<object>? _dotNetReference;

    [CascadingParameter]
    private BradixTooltip? Tooltip { get; set; }

    private Dictionary<string, object> TriggerAttributes => BuildAttributes(
        ("type", "button"),
        ("aria-describedby", Tooltip?.CurrentOpen == true ? Tooltip.ContentId : null),
        ("data-state", Tooltip?.StateAttribute));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Tooltip is null)
            return;

        Tooltip.RegisterTrigger(_triggerElement);
        _dotNetReference = DotNetObjectReference.Create<object>(this);
        await Interop.RegisterTooltipTrigger(_triggerElement, _dotNetReference);
    }

    public async ValueTask DisposeAsync()
    {
        await Interop.UnregisterTooltipTrigger(_triggerElement);
        _dotNetReference?.Dispose();
    }

    private Task HandlePointerMove(PointerEventArgs args)
    {
        if (args.PointerType == "touch" || Tooltip is null || _hasPointerMoveOpened || Tooltip.IsPointerInTransit)
            return Task.CompletedTask;

        _hasPointerMoveOpened = true;
        return Tooltip.HandleTriggerEnter();
    }

    private Task HandlePointerLeave(PointerEventArgs args)
    {
        _hasPointerMoveOpened = false;

        if (Tooltip is null)
            return Task.CompletedTask;

        return Tooltip.HandleTriggerLeave();
    }

    private void HandlePointerDown(PointerEventArgs args)
    {
        _pointerDown = true;

        if (Tooltip is not null)
            _ = Tooltip.Close();
    }

    private void HandlePointerUp(PointerEventArgs args)
    {
        _pointerDown = false;
    }

    private Task HandleFocus(FocusEventArgs _)
    {
        return Tooltip is null
            ? Task.CompletedTask
            : Tooltip.HandleTriggerFocus(_pointerDown);
    }

    private Task HandleBlur(FocusEventArgs _)
    {
        return Tooltip is null
            ? Task.CompletedTask
            : Tooltip.HandleTriggerBlur();
    }

    private Task HandleClick()
    {
        _pointerDown = false;

        return Tooltip is null
            ? Task.CompletedTask
            : Tooltip.HandleTriggerClick();
    }

    [JSInvokable]
    public Task HandleDocumentPointerUp()
    {
        _pointerDown = false;
        return Task.CompletedTask;
    }
}
