@page "/accessible-icon"

<PageTitle>Bradix AccessibleIcon</PageTitle>

<section class="stack">
    <header class="stack stack--compact">
        <h2>BradixAccessibleIcon</h2>
        <p>Makes icon-only UI affordances readable to assistive technology by hiding the visual icon subtree and supplying a meaningful screen-reader label.</p>
    </header>

    <div class="demo-grid">
        <section class="card stack stack--compact">
            <h3>Icon-only button</h3>
            <button type="button" class="primitive__trigger icon-button">
                <BradixAccessibleIcon Label="Close panel">
                    <svg aria-hidden="true" viewBox="0 0 16 16" width="16" height="16">
                        <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </BradixAccessibleIcon>
            </button>
        </section>

        <section class="card stack stack--compact">
            <h3>Status glyph with hidden meaning</h3>
            <div class="primitive__trigger" style="display:inline-flex;align-items:center;gap:0.5rem;">
                <BradixAccessibleIcon Label="Warning status">
                    <svg aria-hidden="true" viewBox="0 0 16 16" width="16" height="16">
                        <path d="M8 2l6 11H2L8 2z" fill="none" stroke="currentColor" stroke-width="1.25" />
                        <path d="M8 6v3.5M8 11.5h.01" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
                    </svg>
                </BradixAccessibleIcon>
                <span aria-hidden="true">Alert</span>
            </div>
        </section>
    </div>
</section>
