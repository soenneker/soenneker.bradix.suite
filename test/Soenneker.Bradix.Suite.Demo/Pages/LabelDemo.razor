@page "/label"

<PageTitle>Bradix Label</PageTitle>

<section class="stack">
    <header class="stack stack--compact">
        <h2>BradixLabel</h2>
        <p>Preserves native label relationships and Radix’s mousedown guard for double-click selection around nested form controls.</p>
    </header>

    <div class="demo-grid">
        <section class="card stack stack--compact">
            <h3>Wrapping a control</h3>
            <p class="state-line"><strong>Notifications:</strong> @(_notificationsEnabled ? "Enabled" : "Disabled")</p>
            <BradixLabel Class="field">
                <input type="checkbox"
                       checked="@_notificationsEnabled"
                       @onchange="HandleNotificationsChanged" />
                <span>Email me when deployments finish</span>
            </BradixLabel>
        </section>

        <section class="card stack stack--compact">
            <h3>Referencing a control</h3>
            <p class="state-line"><strong>Current value:</strong> @_displayName</p>
            <input id="label-demo-input"
                   class="text-input"
                   @bind="_displayName"
                   placeholder="Name" />
            <BradixLabel For="label-demo-input">Display name</BradixLabel>
        </section>
    </div>
</section>

@code {
    private bool _notificationsEnabled = true;
    private string _displayName = "Jake";

    private Task HandleNotificationsChanged(ChangeEventArgs args)
    {
        _notificationsEnabled = args.Value as bool? ?? false;
        return Task.CompletedTask;
    }
}
