@page "/label"

<PageTitle>Bradix Label</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <div class="website-demo-row website-demo-row--padded">
            <BradixLabel Class="label-demo__label" For="firstName">First name</BradixLabel>
            <input class="label-demo__input"
                   type="text"
                   id="firstName"
                   value="Pedro Duarte" />
        </div>
    </section>

    <section class="card website-demo-card">
        <div class="website-demo-row website-demo-row--padded">
            <input id="newsletter"
                   type="checkbox" />
            <BradixLabel Class="label-demo__label" For="newsletter">Email me product updates</BradixLabel>
        </div>
    </section>
</section>
