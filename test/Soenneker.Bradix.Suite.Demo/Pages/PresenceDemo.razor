@page "/presence"

<PageTitle>Bradix Presence</PageTitle>

<section class="stack">
    <header class="stack stack--compact">
        <h2>BradixPresence</h2>
        <p>Keeps a node mounted while its exit animation runs, then unmounts it cleanly when the animation finishes.</p>
    </header>

    <div class="demo-grid">
        <section class="card stack stack--compact">
            <h3>Animated mount / unmount</h3>
            <div class="button-row">
                <button class="primitive__trigger" type="button" @onclick="TogglePresent">Toggle presence</button>
                <span class="state-line">Present: <strong>@_present</strong></span>
                <span class="state-line">Exit complete count: <strong>@_exitCompleteCount</strong></span>
            </div>

            <BradixPresence Present="_present"
                            Class="@(_present ? "presence-surface presence-surface--open" : "presence-surface presence-surface--closed")"
                            OnExitComplete="HandleExitComplete">
                <p class="state-line">This node stays mounted for the close animation.</p>
            </BradixPresence>
        </section>

    </div>
</section>

@code {
    private bool _present = true;
    private int _exitCompleteCount;

    private void TogglePresent()
    {
        _present = !_present;
    }

    private Task HandleExitComplete()
    {
        _exitCompleteCount++;
        return Task.CompletedTask;
    }
}
