@page "/progress"

<PageTitle>Bradix Progress</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixProgress Id="progress-loading" Class="progress-demo__root" Value="@_progress">
            <BradixProgressIndicator Class="progress-demo__indicator"
                                     Style="@IndicatorStyle" />
        </BradixProgress>
    </section>

    <section class="card website-demo-card">
        <BradixProgress Id="progress-complete" Class="progress-demo__root" Value="100">
            <BradixProgressIndicator Class="progress-demo__indicator"
                                     Style="transform: translateX(0%);" />
        </BradixProgress>
    </section>

    <section class="card website-demo-card">
        <BradixProgress Id="progress-indeterminate" Class="progress-demo__root">
            <BradixProgressIndicator Class="progress-demo__indicator" />
        </BradixProgress>
    </section>
</section>

@code {
    private double _progress = 66;

    private string IndicatorStyle => $"transform: translateX(-{100 - _progress}%);";
}
