@page "/select"

<PageTitle>Select Demo</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixSelect Value="@_selectedValue"
                      ValueChanged="HandleSelectedValueChanged">
            <BradixSelectTrigger Class="primitive__trigger primitive__trigger--fit select-demo__trigger">
                <BradixSelectValue Placeholder="@_placeholder" />
                <BradixSelectIcon />
            </BradixSelectTrigger>

            <BradixSelectPortal>
                <BradixSelectContent Class="select-surface stack stack--compact"
                                     SideOffset="6">
                    <BradixSelectViewport Class="stack">
                        <BradixSelectGroup>
                            <BradixSelectLabel>Fruits</BradixSelectLabel>
                            <BradixSelectItem Value="apple" TextValue="Apple">
                                <BradixSelectItemText>Apple</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="banana" TextValue="Banana">
                                <BradixSelectItemText>Banana</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="blueberry" TextValue="Blueberry">
                                <BradixSelectItemText>Blueberry</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="grapes" TextValue="Grapes">
                                <BradixSelectItemText>Grapes</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="pineapple" TextValue="Pineapple">
                                <BradixSelectItemText>Pineapple</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                        </BradixSelectGroup>

                        <BradixSelectSeparator />

                        <BradixSelectGroup>
                            <BradixSelectLabel>Vegetables</BradixSelectLabel>
                            <BradixSelectItem Value="aubergine" TextValue="Aubergine">
                                <BradixSelectItemText>Aubergine</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="broccoli" TextValue="Broccoli">
                                <BradixSelectItemText>Broccoli</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="carrot" TextValue="Carrot" Disabled="true">
                                <BradixSelectItemText>Carrot</BradixSelectItemText>
                            </BradixSelectItem>
                            <BradixSelectItem Value="courgette" TextValue="Courgette">
                                <BradixSelectItemText>Courgette</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="leek" TextValue="Leek">
                                <BradixSelectItemText>Leek</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                        </BradixSelectGroup>

                        <BradixSelectSeparator />

                        <BradixSelectGroup>
                            <BradixSelectLabel>Meat</BradixSelectLabel>
                            <BradixSelectItem Value="beef" TextValue="Beef">
                                <BradixSelectItemText>Beef</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="chicken" TextValue="Chicken">
                                <BradixSelectItemText>Chicken</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="lamb" TextValue="Lamb">
                                <BradixSelectItemText>Lamb</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                            <BradixSelectItem Value="pork" TextValue="Pork">
                                <BradixSelectItemText>Pork</BradixSelectItemText>
                                <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                            </BradixSelectItem>
                        </BradixSelectGroup>
                    </BradixSelectViewport>
                </BradixSelectContent>
            </BradixSelectPortal>
        </BradixSelect>
    </section>
</section>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixDialog>
            <BradixDialogTrigger Class="dialog-demo__button dialog-demo__button--violet">
                Open select dialog
            </BradixDialogTrigger>

            <BradixDialogPortal>
                <BradixDialogOverlay Class="dialog-demo__overlay" />

                <BradixDialogContent Class="dialog-demo__content"
                                     aria-label="Select dialog">
                    <BradixDialogTitle Class="dialog-demo__title">Select dialog</BradixDialogTitle>
                    <BradixDialogDescription Class="dialog-demo__description">
                        Open the nested select without hiding its listbox from assistive technology.
                    </BradixDialogDescription>

                    <BradixSelect Value="@_dialogSelectedValue"
                                  ValueChanged="HandleDialogSelectedValueChanged">
                        <BradixSelectTrigger Class="primitive__trigger primitive__trigger--fit select-demo__trigger"
                                             aria-label="Open nested select">
                            <BradixSelectValue Placeholder="@_dialogPlaceholder" />
                            <BradixSelectIcon />
                        </BradixSelectTrigger>

                        <BradixSelectPortal>
                            <BradixSelectContent Class="select-surface stack stack--compact"
                                                 SideOffset="6">
                                <BradixSelectViewport Class="stack">
                                    <BradixSelectGroup>
                                        <BradixSelectLabel>Frameworks</BradixSelectLabel>
                                        <BradixSelectItem Value="astro" TextValue="Astro">
                                            <BradixSelectItemText>Astro</BradixSelectItemText>
                                            <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                                        </BradixSelectItem>
                                        <BradixSelectItem Value="remix" TextValue="Remix">
                                            <BradixSelectItemText>Remix</BradixSelectItemText>
                                            <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                                        </BradixSelectItem>
                                        <BradixSelectItem Value="sveltekit" TextValue="SvelteKit">
                                            <BradixSelectItemText>SvelteKit</BradixSelectItemText>
                                            <BradixSelectItemIndicator>✓</BradixSelectItemIndicator>
                                        </BradixSelectItem>
                                    </BradixSelectGroup>
                                </BradixSelectViewport>
                            </BradixSelectContent>
                        </BradixSelectPortal>
                    </BradixSelect>
                </BradixDialogContent>
            </BradixDialogPortal>
        </BradixDialog>
    </section>
</section>

@code {
    private string _selectedValue = string.Empty;
    private string _dialogSelectedValue = string.Empty;

    private RenderFragment _placeholder => builder => builder.AddContent(0, "Select a fruit…");
    private RenderFragment _dialogPlaceholder => builder => builder.AddContent(0, "Select a framework…");

    private Task HandleSelectedValueChanged(string? value)
    {
        _selectedValue = value ?? _selectedValue;
        return Task.CompletedTask;
    }

    private Task HandleDialogSelectedValueChanged(string? value)
    {
        _dialogSelectedValue = value ?? _dialogSelectedValue;
        return Task.CompletedTask;
    }
}
