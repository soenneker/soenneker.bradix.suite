@page "/alert-dialog"

<PageTitle>Bradix AlertDialog</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixAlertDialog Open="@_open"
                           OpenChanged="HandleOpenChanged">
            <BradixAlertDialogTrigger Class="dialog-demo__button dialog-demo__button--violet">
                Delete account
            </BradixAlertDialogTrigger>

            <BradixAlertDialogPortal>
                <BradixAlertDialogOverlay Class="dialog-demo__overlay" />

                <BradixAlertDialogContent Class="dialog-demo__content">
                    <BradixAlertDialogTitle Class="dialog-demo__title">Are you absolutely sure?</BradixAlertDialogTitle>
                    <BradixAlertDialogDescription Class="dialog-demo__description">
                        This action cannot be undone. This will permanently delete your account and remove your data from our servers.
                    </BradixAlertDialogDescription>

                    <div class="dialog-demo__actions">
                        <BradixAlertDialogCancel Class="dialog-demo__button dialog-demo__button--mauve"
                                                 OnClick="HandleCancelClicked">
                            Cancel
                        </BradixAlertDialogCancel>
                        <BradixAlertDialogAction Class="dialog-demo__button dialog-demo__button--red"
                                                 OnClick="HandleDeleteClicked">
                            Yes, delete account
                        </BradixAlertDialogAction>
                    </div>
                </BradixAlertDialogContent>
            </BradixAlertDialogPortal>
        </BradixAlertDialog>
    </section>

    <section class="card website-demo-card">
        <BradixAlertDialog Open="@_guardEscapeOpen"
                           OpenChanged="HandleGuardEscapeOpenChanged">
            <BradixAlertDialogTrigger Class="dialog-demo__button dialog-demo__button--violet">
                Guard escape dismissal
            </BradixAlertDialogTrigger>

            <BradixAlertDialogPortal>
                <BradixAlertDialogOverlay Class="dialog-demo__overlay" />

                <BradixAlertDialogContent Class="dialog-demo__content"
                                          CloseOnEscapeKeyDown="false">
                    <BradixAlertDialogTitle Class="dialog-demo__title">Stay open on escape</BradixAlertDialogTitle>
                    <BradixAlertDialogDescription Class="dialog-demo__description">
                        Escape should not dismiss this alert dialog.
                    </BradixAlertDialogDescription>

                    <div class="dialog-demo__actions">
                        <BradixAlertDialogCancel Class="dialog-demo__button dialog-demo__button--mauve">Cancel</BradixAlertDialogCancel>
                        <BradixAlertDialogAction Class="dialog-demo__button dialog-demo__button--red">Continue</BradixAlertDialogAction>
                    </div>
                </BradixAlertDialogContent>
            </BradixAlertDialogPortal>
        </BradixAlertDialog>
    </section>
</section>

@code {
    private bool _open;
    private bool _guardEscapeOpen;

    private Task HandleOpenChanged(bool open)
    {
        _open = open;
        return Task.CompletedTask;
    }

    private Task HandleGuardEscapeOpenChanged(bool open)
    {
        _guardEscapeOpen = open;
        return Task.CompletedTask;
    }

    private Task HandleCancelClicked()
    {
        return Task.CompletedTask;
    }

    private Task HandleDeleteClicked()
    {
        return Task.CompletedTask;
    }
}
