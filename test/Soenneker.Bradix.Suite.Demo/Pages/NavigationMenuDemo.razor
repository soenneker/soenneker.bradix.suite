@page "/navigation-menu"

<PageTitle>NavigationMenu Demo</PageTitle>

<section class="stack">
    <div class="card">
        <h2>NavigationMenu</h2>
        <p>
            Delayed root navigation content with roving trigger focus, dismissable flyout panels,
            active link semantics, and indicator positioning for application-style top navigation.
        </p>
    </div>

    <div class="grid">
        <article class="card stack">
            <h3>Application navigation</h3>

            <BradixNavigationMenu Value="@_openValue"
                                  ValueChanged="HandleOpenValueChanged"
                                  DelayDuration="0"
                                  Class="stack"
                                  Style="position:relative;">
                <BradixNavigationMenuList Style="display:flex;gap:0.75rem;list-style:none;padding:0;margin:0;">
                    <BradixNavigationMenuItem Value="products">
                        <BradixNavigationMenuTrigger Class="primitive__trigger">Products</BradixNavigationMenuTrigger>
                        <BradixNavigationMenuContent Class="card stack" Style="margin-top:0.5rem;">
                            <BradixNavigationMenuLink Href="#buttons"
                                                      Active="@(_activeLink == "buttons")"
                                                      OnSelect='@(() => SetActiveLink("buttons"))'>
                                Buttons
                            </BradixNavigationMenuLink>
                            <BradixNavigationMenuLink Href="#inputs"
                                                      Active="@(_activeLink == "inputs")"
                                                      OnSelect='@(() => SetActiveLink("inputs"))'>
                                Inputs
                            </BradixNavigationMenuLink>
                        </BradixNavigationMenuContent>
                    </BradixNavigationMenuItem>

                    <BradixNavigationMenuItem Value="docs">
                        <BradixNavigationMenuTrigger Class="primitive__trigger">Docs</BradixNavigationMenuTrigger>
                        <BradixNavigationMenuContent Class="card stack" Style="margin-top:0.5rem;">
                            <BradixNavigationMenuLink Href="#getting-started"
                                                      Active="@(_activeLink == "getting-started")"
                                                      OnSelect='@(() => SetActiveLink("getting-started"))'>
                                Getting started
                            </BradixNavigationMenuLink>
                            <BradixNavigationMenuLink Href="#components"
                                                      Active="@(_activeLink == "components")"
                                                      OnSelect='@(() => SetActiveLink("components"))'>
                                Components
                            </BradixNavigationMenuLink>
                        </BradixNavigationMenuContent>
                    </BradixNavigationMenuItem>

                    <BradixNavigationMenuItem Value="about">
                        <BradixNavigationMenuTrigger Class="primitive__trigger">About</BradixNavigationMenuTrigger>
                        <BradixNavigationMenuContent Class="card stack" Style="margin-top:0.5rem;">
                            <p>Bradix is a behavior-first Blazor primitive library modeled after Radix UI.</p>
                        </BradixNavigationMenuContent>
                    </BradixNavigationMenuItem>
                </BradixNavigationMenuList>
                <BradixNavigationMenuIndicator Style="top:2.75rem;height:2px;background:currentColor;" />
            </BradixNavigationMenu>

            <p><strong>Open panel:</strong> @(_openValue ?? "(none)")</p>
            <p><strong>Active link:</strong> @_activeLink</p>
        </article>

        <article class="card stack">
            <h3>Viewport-backed navigation</h3>

            <BradixNavigationMenu DelayDuration="0"
                                  Class="stack"
                                  Style="position:relative;">
                <BradixNavigationMenuList Style="display:flex;gap:0.75rem;list-style:none;padding:0;margin:0;">
                    <BradixNavigationMenuItem Value="platform">
                        <BradixNavigationMenuTrigger Class="primitive__trigger">Platform</BradixNavigationMenuTrigger>
                        <BradixNavigationMenuContent Class="stack" Style="padding:1rem;">
                            <BradixNavigationMenuLink Href="#api">API</BradixNavigationMenuLink>
                            <BradixNavigationMenuLink Href="#cli">CLI</BradixNavigationMenuLink>
                        </BradixNavigationMenuContent>
                    </BradixNavigationMenuItem>

                    <BradixNavigationMenuItem Value="resources">
                        <BradixNavigationMenuTrigger Class="primitive__trigger">Resources</BradixNavigationMenuTrigger>
                        <BradixNavigationMenuContent Class="stack" Style="padding:1rem;">
                            <BradixNavigationMenuLink Href="#guides">Guides</BradixNavigationMenuLink>
                            <BradixNavigationMenuLink Href="#reference">Reference</BradixNavigationMenuLink>
                        </BradixNavigationMenuContent>
                    </BradixNavigationMenuItem>
                </BradixNavigationMenuList>

                <BradixNavigationMenuIndicator Style="top:2.75rem;height:2px;background:currentColor;" />
                <BradixNavigationMenuViewport Class="card"
                                              Style="margin-top:0.5rem;" />
            </BradixNavigationMenu>

            <p>The viewport reuses a shared surface and resizes to the active content.</p>
        </article>
    </div>
</section>

@code {
    private string? _openValue;
    private string _activeLink = "buttons";

    private Task HandleOpenValueChanged(string? value)
    {
        _openValue = string.IsNullOrWhiteSpace(value) ? null : value;
        return Task.CompletedTask;
    }

    private Task SetActiveLink(string value)
    {
        _activeLink = value;
        return Task.CompletedTask;
    }
}
