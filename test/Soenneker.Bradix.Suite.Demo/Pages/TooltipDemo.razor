@page "/tooltip"

<PageTitle>Bradix Tooltip</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixTooltipProvider DelayDuration="150">
            <div style="display:flex; gap:1rem; align-items:center; justify-content:center; flex-wrap:wrap;">
                <BradixTooltip>
                    <BradixTooltipTrigger Class="tooltip-demo__button">+</BradixTooltipTrigger>
                    <BradixTooltipPortal>
                        <BradixTooltipContent Class="tooltip-demo__content" SideOffset="5">
                            Add to library
                            <BradixTooltipArrow>
                                <span class="tooltip-arrow-shape"></span>
                            </BradixTooltipArrow>
                        </BradixTooltipContent>
                    </BradixTooltipPortal>
                </BradixTooltip>

                <BradixTooltip>
                    <BradixTooltipTrigger Class="tooltip-demo__button">Top</BradixTooltipTrigger>
                    <BradixTooltipPortal>
                        <BradixTooltipContent Class="tooltip-demo__content" SideOffset="5">
                            Default placement
                            <BradixTooltipArrow>
                                <span class="tooltip-arrow-shape"></span>
                            </BradixTooltipArrow>
                        </BradixTooltipContent>
                    </BradixTooltipPortal>
                </BradixTooltip>
            </div>
        </BradixTooltipProvider>
    </section>
</section>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixTooltipProvider>
            <BradixDialog>
                <BradixDialogTrigger Class="dialog-demo__button dialog-demo__button--violet">
                    Open tooltip dialog
                </BradixDialogTrigger>

                <BradixDialogPortal>
                    <BradixDialogOverlay Class="dialog-demo__overlay" />

                    <BradixDialogContent Class="dialog-demo__content"
                                         aria-label="Tooltip dialog">
                        <BradixDialogTitle Class="dialog-demo__title">Tooltip dialog</BradixDialogTitle>
                        <BradixDialogDescription Class="dialog-demo__description">
                            Hover the nested trigger to expose tooltip content inside the modal dialog.
                        </BradixDialogDescription>

                        <BradixTooltip>
                            <BradixTooltipTrigger Class="tooltip-demo__button"
                                                  aria-label="Show nested tooltip">
                                ?
                            </BradixTooltipTrigger>
                            <BradixTooltipPortal>
                                <BradixTooltipContent Class="tooltip-demo__content"
                                                      SideOffset="5">
                                    Nested tooltip
                                    <BradixTooltipArrow>
                                        <span class="tooltip-arrow-shape"></span>
                                    </BradixTooltipArrow>
                                </BradixTooltipContent>
                            </BradixTooltipPortal>
                        </BradixTooltip>
                    </BradixDialogContent>
                </BradixDialogPortal>
            </BradixDialog>
        </BradixTooltipProvider>
    </section>
</section>
