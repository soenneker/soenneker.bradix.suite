@page "/tabs"

<PageTitle>Bradix Tabs</PageTitle>

<section class="stack">
    <DemoHero>
        <BradixTabs Class="tabs-root tabs-root--hero" DefaultValue="account">
            <BradixTabsList Class="tabs-list" aria-label="Account tabs">
                <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="account">Account</BradixTabsTrigger>
                <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="password">Password</BradixTabsTrigger>
                <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="team">Team</BradixTabsTrigger>
            </BradixTabsList>
            <BradixTabsContent Class="tabs-content" Value="account">
                <p>Manage your account settings and connected profile information.</p>
            </BradixTabsContent>
            <BradixTabsContent Class="tabs-content" Value="password">
                <p>Update credentials, review sessions, and confirm your recovery settings.</p>
            </BradixTabsContent>
            <BradixTabsContent Class="tabs-content" Value="team">
                <p>Invite collaborators and configure access for your shared workspace.</p>
            </BradixTabsContent>
        </BradixTabs>
    </DemoHero>

    <DemoSection Title="Highlights">
        <ul class="stack stack--compact demo-list">
            <li>Focus roves between triggers and the selected panel stays connected through managed ARIA ids.</li>
            <li>Supports automatic or manual activation as well as horizontal and vertical orientation.</li>
            <li>Direction inheritance works the same way as other Bradix composites that depend on roving focus.</li>
        </ul>
    </DemoSection>
</section>

