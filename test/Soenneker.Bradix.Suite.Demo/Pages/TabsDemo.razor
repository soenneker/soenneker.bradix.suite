@page "/tabs"

<PageTitle>Bradix Tabs</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixTabs Class="tabs-root tabs-root--hero" DefaultValue="account">
            <BradixTabsList Class="tabs-list" aria-label="Manage your account">
                <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="account">Account</BradixTabsTrigger>
                <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="password">Password</BradixTabsTrigger>
            </BradixTabsList>
            <BradixTabsContent Class="tabs-content" Value="account">
                <p class="popover-demo__text">Make changes to your account here. Click save when you're done.</p>
                <div class="dialog-demo__fieldset">
                    <label class="dialog-demo__label" for="tabs-name">Name</label>
                    <input class="dialog-demo__input" id="tabs-name" value="Pedro Duarte" />
                </div>
                <div class="dialog-demo__fieldset">
                    <label class="dialog-demo__label" for="tabs-username">Username</label>
                    <input class="dialog-demo__input" id="tabs-username" value="@@peduarte" />
                </div>
                <div class="dialog-demo__save-row">
                    <button class="dialog-demo__button dialog-demo__button--green" type="button">Save changes</button>
                </div>
            </BradixTabsContent>
            <BradixTabsContent Class="tabs-content" Value="password">
                <p class="popover-demo__text">Change your password here. After saving, you'll be logged out.</p>
                <div class="dialog-demo__fieldset">
                    <label class="dialog-demo__label" for="tabs-current-password">Current password</label>
                    <input class="dialog-demo__input" id="tabs-current-password" type="password" />
                </div>
                <div class="dialog-demo__fieldset">
                    <label class="dialog-demo__label" for="tabs-new-password">New password</label>
                    <input class="dialog-demo__input" id="tabs-new-password" type="password" />
                </div>
                <div class="dialog-demo__fieldset">
                    <label class="dialog-demo__label" for="tabs-confirm-password">Confirm password</label>
                    <input class="dialog-demo__input" id="tabs-confirm-password" type="password" />
                </div>
                <div class="dialog-demo__save-row">
                    <button class="dialog-demo__button dialog-demo__button--green" type="button">Change password</button>
                </div>
            </BradixTabsContent>
        </BradixTabs>
    </section>

    <section class="card website-demo-card">
        <h2>Disabled tabs</h2>
        <p>Disabled triggers should not become selected, and enabled siblings should still activate normally.</p>
        <BradixTabs Class="tabs-root" DefaultValue="overview-disabled">
            <BradixTabsList Class="tabs-list" aria-label="Disabled tabs example">
                <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="overview-disabled">Overview</BradixTabsTrigger>
                <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="disabled-tab" Disabled="true">Disabled</BradixTabsTrigger>
                <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="details-disabled">Details</BradixTabsTrigger>
            </BradixTabsList>
            <BradixTabsContent Class="tabs-content" Value="overview-disabled">
                <p>Overview tab content.</p>
            </BradixTabsContent>
            <BradixTabsContent Class="tabs-content" Value="disabled-tab">
                <p>Disabled tab content should remain unreachable.</p>
            </BradixTabsContent>
            <BradixTabsContent Class="tabs-content" Value="details-disabled">
                <p>Details tab content.</p>
            </BradixTabsContent>
        </BradixTabs>
    </section>

    <section class="card website-demo-card">
        <h2>Controlled tabs</h2>
        <p>External controls should keep the selected trigger and visible panel in sync.</p>
        <div class="stack">
            <BradixTabs Class="tabs-root" Value="@_controlledTab" ValueChanged="HandleControlledTabChanged">
                <BradixTabsList Class="tabs-list" aria-label="Controlled tabs example">
                    <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="overview-controlled">Overview</BradixTabsTrigger>
                    <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="activity-controlled">Activity</BradixTabsTrigger>
                    <BradixTabsTrigger Class="primitive__trigger tabs-trigger" Value="settings-controlled">Settings</BradixTabsTrigger>
                </BradixTabsList>
                <BradixTabsContent Class="tabs-content" Value="overview-controlled">
                    <p>Controlled overview content.</p>
                </BradixTabsContent>
                <BradixTabsContent Class="tabs-content" Value="activity-controlled">
                    <p>Controlled activity content.</p>
                </BradixTabsContent>
                <BradixTabsContent Class="tabs-content" Value="settings-controlled">
                    <p>Controlled settings content.</p>
                </BradixTabsContent>
            </BradixTabs>

            <div class="dialog-demo__save-row">
                <button class="dialog-demo__button" type="button" @onclick='() => SetControlledTab("overview-controlled")'>Overview</button>
                <button class="dialog-demo__button" type="button" @onclick='() => SetControlledTab("activity-controlled")'>Activity</button>
                <button class="dialog-demo__button" type="button" @onclick='() => SetControlledTab("settings-controlled")'>Settings</button>
            </div>
        </div>
    </section>
</section>

@code {
    private string _controlledTab = "overview-controlled";

    private Task HandleControlledTabChanged(string? value)
    {
        _controlledTab = value ?? _controlledTab;
        return Task.CompletedTask;
    }

    private Task SetControlledTab(string value)
    {
        _controlledTab = value;
        return Task.CompletedTask;
    }
}
