@page "/"
@using Soenneker.Bradix.Suite.Abstract
@inject IBradixComponent Suite

<PageTitle>Bradix Demo</PageTitle>

<section class="stack">
    <div class="card">
        <h2>Current slice</h2>
        <p>
            This workspace now includes foundational Bradix infrastructure plus demoable
            <code>Collapsible</code>, <code>Accordion</code>, <code>Toggle</code>, and <code>ToggleGroup</code>
            primitives with state, ARIA, direction, and keyboard behavior aligned to Radix.
        </p>
    </div>

    <div class="grid">
        <article class="card">
            <h3>Collapsible</h3>
            <p>Open/closed state, trigger semantics, content ids, `forceMount`, and measured CSS variables.</p>
            <NavLink class="demo-link" href="/collapsible">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Accordion</h3>
            <p>Single and multiple modes, collapsible policy, item/header/trigger/content decomposition, and keyboard navigation.</p>
            <NavLink class="demo-link" href="/accordion">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Toggle</h3>
            <p>Pressed state, controlled/uncontrolled usage, and proper `aria-pressed` / `data-state` metadata.</p>
            <NavLink class="demo-link" href="/toggle">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>ToggleGroup</h3>
            <p>Single and multiple selection, roving focus, orientation, and inherited direction support.</p>
            <NavLink class="demo-link" href="/toggle-group">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Tabs</h3>
            <p>Tablist/trigger/content decomposition with automatic and manual activation, roving focus, and stable ARIA ids.</p>
            <NavLink class="demo-link" href="/tabs">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>RadioGroup</h3>
            <p>Single-selection roving focus with radio semantics, indicator composition, direction-aware navigation, and form-friendly hidden inputs.</p>
            <NavLink class="demo-link" href="/radio-group">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Checkbox</h3>
            <p>Tri-state checkbox behavior with indicator composition, hidden-input syncing, form reset support, and correct ARIA mixed semantics.</p>
            <NavLink class="demo-link" href="/checkbox">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Switch</h3>
            <p>Boolean switch semantics with thumb composition, hidden-input syncing, and form/reset behavior while preserving the `role=&quot;switch&quot;` contract.</p>
            <NavLink class="demo-link" href="/switch">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Toolbar</h3>
            <p>Toolbar-level roving focus across buttons, links, and embedded toggle groups with direction-aware keyboard navigation.</p>
            <NavLink class="demo-link" href="/toolbar">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Slider</h3>
            <p>Orientation-aware slider with single and multiple thumbs, keyboard and pointer interaction, direction handling, and range geometry.</p>
            <NavLink class="demo-link" href="/slider">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>ScrollArea</h3>
            <p>Custom scrollbars over a hidden native viewport with overflow-driven visibility, corner sizing, and hover/scroll modes.</p>
            <NavLink class="demo-link" href="/scroll-area">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Portal</h3>
            <p>DOM reparenting primitive for overlay families that need to render into `body` or a custom container.</p>
            <NavLink class="demo-link" href="/portal">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>DismissableLayer</h3>
            <p>Outside-interaction substrate for overlay families, with escape handling, outside pointer/focus detection, and branch exceptions.</p>
            <NavLink class="demo-link" href="/dismissable-layer">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>FocusScope</h3>
            <p>Managed focus boundary with looping and trapped-focus behavior for layered and modal families.</p>
            <NavLink class="demo-link" href="/focus-scope">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Popper</h3>
            <p>Positioning substrate with anchor, collision-aware content placement, placement data attributes, and arrow support.</p>
            <NavLink class="demo-link" href="/popper">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Presence</h3>
            <p>Mount-preservation substrate that keeps content in the DOM long enough for exit animations to complete before unmounting.</p>
            <NavLink class="demo-link" href="/presence">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Label</h3>
            <p>Native label semantics plus Radix-style double-click selection protection around nested controls.</p>
            <NavLink class="demo-link" href="/label">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Separator</h3>
            <p>Semantic and decorative separators with correct orientation metadata and accessibility behavior.</p>
            <NavLink class="demo-link" href="/separator">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>AspectRatio</h3>
            <p>Unstyled ratio-preserving content wrapper matching Radix’s wrapper and inner slot structure.</p>
            <NavLink class="demo-link" href="/aspect-ratio">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>Progress</h3>
            <p>Progress root and indicator with indeterminate, loading, and complete states plus ARIA metadata.</p>
            <NavLink class="demo-link" href="/progress">Open demo</NavLink>
        </article>

        <article class="card">
            <h3>VisuallyHidden</h3>
            <p>Screen-reader-only content utility for accessible naming without visible text.</p>
            <NavLink class="demo-link" href="/visually-hidden">Open demo</NavLink>
        </article>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Suite.Initialize();
    }
}
