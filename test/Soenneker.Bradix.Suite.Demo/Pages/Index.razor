@page "/"

<PageTitle>Bradix Component Library Demo</PageTitle>

<section class="stack">
    <header class="stack stack--compact">
        <h1>Bradix primitives</h1>
        <p class="lede">Simple demos for each primitive, modeled after the straightforward presentation style of the Radix docs.</p>
    </header>

    @foreach (DemoPageGroup group in DemoCatalog.Groups)
    {
        <section class="catalog-group">
            <header class="catalog-group__header">
                <h2>@group.Title</h2>
            </header>

            <div class="simple-link-list">
                @foreach (DemoPageLink demoPage in group.Pages)
                {
                    <NavLink href="@demoPage.Href" class="simple-link-list__item">
                        <span>@demoPage.Title</span>
                        <span>@demoPage.Description</span>
                    </NavLink>
                }
            </div>
        </section>
    }
</section>
