@page "/avatar"

<PageTitle>Avatar Demo</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <div class="website-demo-row">
            <div class="avatar-demo__case">
                <p>Loaded image</p>
                <BradixAvatar Id="avatar-loaded" Class="avatar-demo__root">
                    <BradixAvatarImage Class="avatar-demo__image"
                                       Src="@LoadedAvatarSrc"
                                       Alt="Colm Tuite" />
                    <BradixAvatarFallback Class="avatar-demo__fallback" DelayMs="600">CT</BradixAvatarFallback>
                </BradixAvatar>
            </div>

            <div class="avatar-demo__case">
                <p>Broken image</p>
                <BradixAvatar Id="avatar-broken" Class="avatar-demo__root">
                    <BradixAvatarImage Class="avatar-demo__image"
                                       Src="https://example.invalid/bradix-avatar.png"
                                       Alt="Broken avatar" />
                    <BradixAvatarFallback Class="avatar-demo__fallback" DelayMs="600">BR</BradixAvatarFallback>
                </BradixAvatar>
            </div>

            <div class="avatar-demo__case">
                <p>Delayed fallback</p>
                <BradixAvatar Id="avatar-delayed" Class="avatar-demo__root">
                    <BradixAvatarFallback Class="avatar-demo__fallback" DelayMs="600">DL</BradixAvatarFallback>
                </BradixAvatar>
            </div>

            <div class="avatar-demo__case">
                <p>Fallback only</p>
                <BradixAvatar Id="avatar-fallback-only" Class="avatar-demo__root">
                    <BradixAvatarFallback Class="avatar-demo__fallback">PD</BradixAvatarFallback>
                </BradixAvatar>
            </div>
        </div>
    </section>
</section>

@code {
    private const string LoadedAvatarSvg = """
                                           <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 128 128'>
                                             <rect width='128' height='128' rx='64' fill='#0f766e'/>
                                             <text x='50%' y='50%' dominant-baseline='middle' text-anchor='middle' fill='white' font-family='Arial' font-size='44'>CT</text>
                                           </svg>
                                           """;

    private static readonly string LoadedAvatarSrc = $"data:image/svg+xml;utf8,{Uri.EscapeDataString(LoadedAvatarSvg)}";
}
