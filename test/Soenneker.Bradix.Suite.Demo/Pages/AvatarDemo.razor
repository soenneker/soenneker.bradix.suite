@page "/avatar"

<PageTitle>Avatar Demo</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <div class="website-demo-row">
            <BradixAvatar Class="avatar-demo__root">
                <BradixAvatarImage Class="avatar-demo__image"
                                   Src="https://images.unsplash.com/photo-1492633423870-43d1cd2775eb?&w=128&h=128&dpr=2&q=80"
                                   Alt="Colm Tuite" />
                <BradixAvatarFallback Class="avatar-demo__fallback" DelayMs="600">CT</BradixAvatarFallback>
            </BradixAvatar>

            <BradixAvatar Class="avatar-demo__root">
                <BradixAvatarImage Class="avatar-demo__image"
                                   Src="https://images.unsplash.com/photo-1511485977113-f34c92461ad9?ixlib=rb-1.2.1&w=128&h=128&dpr=2&q=80"
                                   Alt="Pedro Duarte" />
                <BradixAvatarFallback Class="avatar-demo__fallback" DelayMs="600">JD</BradixAvatarFallback>
            </BradixAvatar>

            <BradixAvatar Class="avatar-demo__root">
                <BradixAvatarFallback Class="avatar-demo__fallback">PD</BradixAvatarFallback>
            </BradixAvatar>
        </div>
    </section>
</section>
