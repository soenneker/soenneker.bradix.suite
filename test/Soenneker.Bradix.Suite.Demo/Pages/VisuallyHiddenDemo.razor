@page "/visually-hidden"

<PageTitle>Bradix VisuallyHidden</PageTitle>

<section class="stack">
    <header class="stack stack--compact">
        <h2>BradixVisuallyHidden</h2>
        <p>Provides screen-reader-only content without imposing visible layout, including slot-backed native element rendering for Radix-style `asChild` composition.</p>
    </header>

    <div class="demo-grid">
        <section class="card stack stack--compact">
            <h3>Accessible icon button</h3>
            <button type="button" class="primitive__trigger icon-button">
                <BradixVisuallyHidden>Save the file</BradixVisuallyHidden>
                <span aria-hidden="true">S</span>
            </button>
        </section>

    </div>
</section>

@code {
    private readonly IReadOnlyDictionary<string, object> _labelAttributes = new Dictionary<string, object>
    {
        ["for"] = "hidden-search-label",
        ["class"] = "visually-hidden__label"
    };
}
