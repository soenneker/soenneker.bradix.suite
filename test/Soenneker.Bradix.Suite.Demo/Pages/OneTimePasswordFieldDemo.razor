@page "/one-time-password-field"

<PageTitle>Bradix One-Time Password Field</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixOneTimePasswordField>
            <div class="otp-input-row">
                <BradixOneTimePasswordFieldInput Index="0" Class="text-input otp-slot" />
                <BradixOneTimePasswordFieldInput Index="1" Class="text-input otp-slot" />
                <BradixOneTimePasswordFieldInput Index="2" Class="text-input otp-slot" />
                <BradixOneTimePasswordFieldInput Index="3" Class="text-input otp-slot" />
                <BradixOneTimePasswordFieldInput Index="4" Class="text-input otp-slot" />
                <BradixOneTimePasswordFieldInput Index="5" Class="text-input otp-slot" />
            </div>
            <BradixOneTimePasswordFieldHiddenInput />
        </BradixOneTimePasswordField>
    </section>

    <section class="card website-demo-card">
        <form id="otp-reset-form">
            <BradixOneTimePasswordField DefaultValue="2468">
                <div class="otp-input-row otp-reset-row">
                    <BradixOneTimePasswordFieldInput Index="0" Class="text-input otp-slot otp-reset-slot" />
                    <BradixOneTimePasswordFieldInput Index="1" Class="text-input otp-slot otp-reset-slot" />
                    <BradixOneTimePasswordFieldInput Index="2" Class="text-input otp-slot otp-reset-slot" />
                    <BradixOneTimePasswordFieldInput Index="3" Class="text-input otp-slot otp-reset-slot" />
                </div>
                <BradixOneTimePasswordFieldHiddenInput Name="otp-reset" />
            </BradixOneTimePasswordField>

            <div class="demo-actions">
                <button type="reset" class="button button-outline" id="otp-reset-button">Reset OTP</button>
            </div>
        </form>
    </section>

    <section class="card website-demo-card">
        <div class="demo-stack">
            <BradixOneTimePasswordField Value="@_controlledOtpValue" ValueChanged="HandleControlledValueChanged" Name="otp-controlled">
                <div class="otp-input-row otp-controlled-row">
                    <BradixOneTimePasswordFieldInput Index="0" Class="text-input otp-slot otp-controlled-slot" />
                    <BradixOneTimePasswordFieldInput Index="1" Class="text-input otp-slot otp-controlled-slot" />
                    <BradixOneTimePasswordFieldInput Index="2" Class="text-input otp-slot otp-controlled-slot" />
                    <BradixOneTimePasswordFieldInput Index="3" Class="text-input otp-slot otp-controlled-slot" />
                </div>
                <BradixOneTimePasswordFieldHiddenInput />
            </BradixOneTimePasswordField>

            <p id="otp-controlled-value">Current controlled value: @_controlledOtpValue</p>

            <div class="demo-actions">
                <button type="button" class="button button-outline" id="otp-fill-button" @onclick="FillControlledOtp">Fill sample</button>
                <button type="button" class="button button-outline" id="otp-clear-button" @onclick="ClearControlledOtp">Clear</button>
            </div>
        </div>
    </section>
</section>

@code {
    private string _controlledOtpValue = "1357";

    private Task HandleControlledValueChanged(string value)
    {
        _controlledOtpValue = value;
        return Task.CompletedTask;
    }

    private Task FillControlledOtp()
    {
        _controlledOtpValue = "8642";
        return Task.CompletedTask;
    }

    private Task ClearControlledOtp()
    {
        _controlledOtpValue = string.Empty;
        return Task.CompletedTask;
    }
}
