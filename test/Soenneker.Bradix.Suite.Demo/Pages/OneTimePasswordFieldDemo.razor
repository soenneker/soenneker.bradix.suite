@page "/one-time-password-field"
@using Soenneker.Bradix.Suite.OneTimePasswordField

<PageTitle>Bradix One-Time Password Field</PageTitle>

<section class="stack">
    <header class="stack stack--compact">
        <h2>BradixOneTimePasswordField</h2>
        <p>Single-field-style OTP behavior across separate inputs, with paste distribution, hidden form participation, direction-aware navigation, and optional auto-submit.</p>
    </header>

    <div class="demo-grid">
        <section class="card stack stack--compact">
            <h3>Numeric code</h3>
            <p class="state-line">Value: @_numericValue</p>
            <p class="state-line">Auto-submit payload: @_submittedValue</p>

            <form id="otp-demo-form" @onsubmit="HandleSubmit" @onsubmit:preventDefault="true" class="stack stack--compact">
                <BradixOneTimePasswordField Name="otp"
                                            Form="otp-demo-form"
                                            Value="@_numericValue"
                                            ValueChanged="HandleNumericValueChanged"
                                            AutoSubmit
                                            OnAutoSubmit="HandleAutoSubmit"
                                            Placeholder="123456">
                    <div class="button-row" style="gap:0.5rem;">
                        <BradixOneTimePasswordFieldInput Index="0" Class="text-input" Style="width:2.75rem;text-align:center;" />
                        <BradixOneTimePasswordFieldInput Index="1" Class="text-input" Style="width:2.75rem;text-align:center;" />
                        <BradixOneTimePasswordFieldInput Index="2" Class="text-input" Style="width:2.75rem;text-align:center;" />
                        <BradixOneTimePasswordFieldInput Index="3" Class="text-input" Style="width:2.75rem;text-align:center;" />
                        <BradixOneTimePasswordFieldInput Index="4" Class="text-input" Style="width:2.75rem;text-align:center;" />
                        <BradixOneTimePasswordFieldInput Index="5" Class="text-input" Style="width:2.75rem;text-align:center;" />
                    </div>
                    <BradixOneTimePasswordFieldHiddenInput />
                </BradixOneTimePasswordField>
            </form>
        </section>

        <section class="card stack stack--compact">
            <h3>Alphanumeric code</h3>
            <p class="state-line">Value: @_alphaNumericValue</p>
            <p class="state-line">Letters and digits are accepted; whitespace and symbols are ignored.</p>

            <BradixOneTimePasswordField ValidationType="alphanumeric"
                                        Value="@_alphaNumericValue"
                                        ValueChanged="HandleAlphaNumericValueChanged"
                                        Placeholder="ABC123">
                <div class="button-row" style="gap:0.5rem;">
                    <BradixOneTimePasswordFieldInput Index="0" Class="text-input" Style="width:2.75rem;text-align:center;" />
                    <BradixOneTimePasswordFieldInput Index="1" Class="text-input" Style="width:2.75rem;text-align:center;" />
                    <BradixOneTimePasswordFieldInput Index="2" Class="text-input" Style="width:2.75rem;text-align:center;" />
                    <BradixOneTimePasswordFieldInput Index="3" Class="text-input" Style="width:2.75rem;text-align:center;" />
                    <BradixOneTimePasswordFieldInput Index="4" Class="text-input" Style="width:2.75rem;text-align:center;" />
                    <BradixOneTimePasswordFieldInput Index="5" Class="text-input" Style="width:2.75rem;text-align:center;" />
                </div>
                <BradixOneTimePasswordFieldHiddenInput />
            </BradixOneTimePasswordField>
        </section>
    </div>
</section>

@code {
    private string _numericValue = string.Empty;
    private string _alphaNumericValue = string.Empty;
    private string _submittedValue = "pending";

    private Task HandleNumericValueChanged(string value)
    {
        _numericValue = value;
        return Task.CompletedTask;
    }

    private Task HandleAlphaNumericValueChanged(string value)
    {
        _alphaNumericValue = value;
        return Task.CompletedTask;
    }

    private Task HandleAutoSubmit(string value)
    {
        _submittedValue = value;
        return Task.CompletedTask;
    }

    private Task HandleSubmit()
    {
        _submittedValue = _numericValue;
        return Task.CompletedTask;
    }
}
