@page "/collapsible"

<PageTitle>Bradix Collapsible</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixCollapsible Class="collapsible-demo__root"
                           Open="@_open"
                           OnOpenChange="HandleOpenChange">
            <div class="collapsible-demo__header-row">
                <span class="collapsible-demo__text">@@peduarte starred 3 repositories</span>
                <BradixCollapsibleTrigger Class="collapsible-demo__icon-button">
                    <span aria-hidden="true">@(_open ? "×" : "+")</span>
                </BradixCollapsibleTrigger>
            </div>

            <div class="collapsible-demo__repository">
                <span class="collapsible-demo__text">@@radix-ui/primitives</span>
            </div>

            <BradixCollapsibleContent>
                <div class="collapsible-demo__repository">
                    <span class="collapsible-demo__text">@@radix-ui/colors</span>
                </div>
                <div class="collapsible-demo__repository">
                    <span class="collapsible-demo__text">@@radix-ui/themes</span>
                </div>
            </BradixCollapsibleContent>
        </BradixCollapsible>
    </section>
</section>

@code {
    private bool _open;

    private Task HandleOpenChange(bool open)
    {
        _open = open;
        return Task.CompletedTask;
    }
}
