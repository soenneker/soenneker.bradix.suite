@page "/radio-group"

<PageTitle>Bradix RadioGroup</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <h2>Default</h2>
        <form>
            <BradixRadioGroup Class="radio-demo__root"
                              aria-label="View density"
                              Name="view-density"
                              DefaultValue="default">
                <div class="website-demo-row">
                    <BradixRadioGroupItem Class="radio-demo__item"
                                          Value="default"
                                          InputValue="default"
                                          Id="density-default">
                        <BradixRadioGroupIndicator Class="radio-demo__indicator" />
                    </BradixRadioGroupItem>
                    <BradixLabel Class="radio-demo__label" For="density-default">Default</BradixLabel>
                </div>
                <div class="website-demo-row">
                    <BradixRadioGroupItem Class="radio-demo__item"
                                          Value="comfortable"
                                          InputValue="comfortable"
                                          Id="density-comfortable">
                        <BradixRadioGroupIndicator Class="radio-demo__indicator" />
                    </BradixRadioGroupItem>
                    <BradixLabel Class="radio-demo__label" For="density-comfortable">Comfortable</BradixLabel>
                </div>
                <div class="website-demo-row">
                    <BradixRadioGroupItem Class="radio-demo__item"
                                          Value="compact"
                                          InputValue="compact"
                                          Id="density-compact">
                        <BradixRadioGroupIndicator Class="radio-demo__indicator" />
                    </BradixRadioGroupItem>
                    <BradixLabel Class="radio-demo__label" For="density-compact">Compact</BradixLabel>
                </div>
            </BradixRadioGroup>
        </form>
    </section>

    <section class="card website-demo-card">
        <h2>Disabled</h2>
        <BradixRadioGroup Class="radio-demo__root"
                          aria-label="Support tier"
                          Name="support-tier"
                          DefaultValue="pro">
            <div class="website-demo-row">
                <BradixRadioGroupItem Class="radio-demo__item"
                                      Value="starter"
                                      InputValue="starter"
                                      Id="support-starter"
                                      Disabled="true">
                    <BradixRadioGroupIndicator Class="radio-demo__indicator" />
                </BradixRadioGroupItem>
                <BradixLabel Class="radio-demo__label" For="support-starter">Starter</BradixLabel>
            </div>
            <div class="website-demo-row">
                <BradixRadioGroupItem Class="radio-demo__item"
                                      Value="pro"
                                      InputValue="pro"
                                      Id="support-pro">
                    <BradixRadioGroupIndicator Class="radio-demo__indicator" />
                </BradixRadioGroupItem>
                <BradixLabel Class="radio-demo__label" For="support-pro">Pro</BradixLabel>
            </div>
            <div class="website-demo-row">
                <BradixRadioGroupItem Class="radio-demo__item"
                                      Value="enterprise"
                                      InputValue="enterprise"
                                      Id="support-enterprise">
                    <BradixRadioGroupIndicator Class="radio-demo__indicator" />
                </BradixRadioGroupItem>
                <BradixLabel Class="radio-demo__label" For="support-enterprise">Enterprise</BradixLabel>
            </div>
        </BradixRadioGroup>
    </section>

    <section class="card website-demo-card">
        <h2>Controlled</h2>
        <div class="website-demo-row">
            <button type="button" @onclick="HandleSelectWeekly">Select weekly</button>
            <button type="button" @onclick="HandleSelectMonthly">Select monthly</button>
        </div>

        <BradixRadioGroup Class="radio-demo__root"
                          aria-label="Billing cadence"
                          Name="billing-cadence"
                          Value="@_controlledValue"
                          ValueChanged="HandleControlledValueChanged">
            <div class="website-demo-row">
                <BradixRadioGroupItem Class="radio-demo__item"
                                      Value="weekly"
                                      InputValue="weekly"
                                      Id="billing-weekly">
                    <BradixRadioGroupIndicator Class="radio-demo__indicator" />
                </BradixRadioGroupItem>
                <BradixLabel Class="radio-demo__label" For="billing-weekly">Weekly</BradixLabel>
            </div>
            <div class="website-demo-row">
                <BradixRadioGroupItem Class="radio-demo__item"
                                      Value="monthly"
                                      InputValue="monthly"
                                      Id="billing-monthly">
                    <BradixRadioGroupIndicator Class="radio-demo__indicator" />
                </BradixRadioGroupItem>
                <BradixLabel Class="radio-demo__label" For="billing-monthly">Monthly</BradixLabel>
            </div>
        </BradixRadioGroup>
    </section>
</section>

@code {
    private string _controlledValue = "weekly";

    private Task HandleControlledValueChanged(string? value)
    {
        _controlledValue = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private void HandleSelectWeekly()
    {
        _controlledValue = "weekly";
    }

    private void HandleSelectMonthly()
    {
        _controlledValue = "monthly";
    }
}
