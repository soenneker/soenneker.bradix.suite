@page "/dropdown-menu"

<PageTitle>DropdownMenu Demo</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixDropdownMenu>
            <BradixDropdownMenuTrigger Class="dialog-demo__icon-button" aria-label="Customise options">≡</BradixDropdownMenuTrigger>

            <BradixDropdownMenuPortal>
                <BradixDropdownMenuContent Class="menu-surface stack stack--compact" SideOffset="5">
                    <BradixDropdownMenuItem TextValue="New Tab">New Tab</BradixDropdownMenuItem>
                    <BradixDropdownMenuItem TextValue="New Window">New Window</BradixDropdownMenuItem>
                    <BradixDropdownMenuItem TextValue="New Private Window" Disabled>New Private Window</BradixDropdownMenuItem>
                    <BradixDropdownMenuSub>
                        <BradixDropdownMenuSubTrigger TextValue="More Tools">More Tools</BradixDropdownMenuSubTrigger>
                        <BradixDropdownMenuPortal>
                            <BradixDropdownMenuSubContent Class="menu-surface stack stack--compact" SideOffset="2">
                                <BradixDropdownMenuItem TextValue="Save Page As…">Save Page As…</BradixDropdownMenuItem>
                                <BradixDropdownMenuItem TextValue="Create Shortcut…">Create Shortcut…</BradixDropdownMenuItem>
                                <BradixDropdownMenuItem TextValue="Name Window…">Name Window…</BradixDropdownMenuItem>
                                <BradixDropdownMenuSeparator />
                                <BradixDropdownMenuItem TextValue="Developer Tools">Developer Tools</BradixDropdownMenuItem>
                            </BradixDropdownMenuSubContent>
                        </BradixDropdownMenuPortal>
                    </BradixDropdownMenuSub>

                    <BradixDropdownMenuSeparator />

                    <BradixDropdownMenuCheckboxItem Checked="@_bookmarks"
                                                    CheckedChanged="HandleBookmarksChanged"
                                                    CloseOnSelect="false">
                        <span>Show Bookmarks</span>
                        <BradixDropdownMenuItemIndicator>✓</BradixDropdownMenuItemIndicator>
                    </BradixDropdownMenuCheckboxItem>
                    <BradixDropdownMenuCheckboxItem Checked="@_urls"
                                                    CheckedChanged="HandleUrlsChanged"
                                                    CloseOnSelect="false">
                        <span>Show Full URLs</span>
                        <BradixDropdownMenuItemIndicator>✓</BradixDropdownMenuItemIndicator>
                    </BradixDropdownMenuCheckboxItem>

                    <BradixDropdownMenuSeparator />

                    <BradixDropdownMenuLabel>People</BradixDropdownMenuLabel>
                    <BradixDropdownMenuRadioGroup Value="@_person" ValueChanged="HandlePersonChanged">
                        <BradixDropdownMenuRadioItem Value="pedro" CloseOnSelect="false">
                            <span>Pedro Duarte</span>
                            <BradixDropdownMenuItemIndicator>•</BradixDropdownMenuItemIndicator>
                        </BradixDropdownMenuRadioItem>
                        <BradixDropdownMenuRadioItem Value="colm" CloseOnSelect="false">
                            <span>Colm Tuite</span>
                            <BradixDropdownMenuItemIndicator>•</BradixDropdownMenuItemIndicator>
                        </BradixDropdownMenuRadioItem>
                    </BradixDropdownMenuRadioGroup>
                </BradixDropdownMenuContent>
            </BradixDropdownMenuPortal>
        </BradixDropdownMenu>
    </section>
</section>

@code {
    private BradixCheckboxCheckedState _bookmarks = BradixCheckboxCheckedState.Checked;
    private BradixCheckboxCheckedState _urls = BradixCheckboxCheckedState.Unchecked;
    private string _person = "pedro";

    private Task HandleBookmarksChanged(BradixCheckboxCheckedState state)
    {
        _bookmarks = state;
        return Task.CompletedTask;
    }

    private Task HandleUrlsChanged(BradixCheckboxCheckedState state)
    {
        _urls = state;
        return Task.CompletedTask;
    }

    private Task HandlePersonChanged(string? value)
    {
        _person = value ?? _person;
        return Task.CompletedTask;
    }
}
