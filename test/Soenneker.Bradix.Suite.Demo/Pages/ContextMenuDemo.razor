@page "/context-menu"

<PageTitle>ContextMenu Demo</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixContextMenu>
            <BradixContextMenuTrigger>
                <span class="context-target">Right-click here.</span>
            </BradixContextMenuTrigger>

            <BradixContextMenuPortal>
                <BradixContextMenuContent Class="menu-surface stack stack--compact" SideOffset="5" Align="end">
                    <BradixContextMenuItem TextValue="Back">Back</BradixContextMenuItem>
                    <BradixContextMenuItem TextValue="Forward" Disabled>Forward</BradixContextMenuItem>
                    <BradixContextMenuItem TextValue="Reload">Reload</BradixContextMenuItem>
                    <BradixContextMenuSub>
                        <BradixContextMenuSubTrigger TextValue="More Tools">More Tools</BradixContextMenuSubTrigger>
                        <BradixContextMenuPortal>
                            <BradixContextMenuSubContent Class="menu-surface stack stack--compact" SideOffset="2">
                                <BradixContextMenuItem TextValue="Save Page As…">Save Page As…</BradixContextMenuItem>
                                <BradixContextMenuItem TextValue="Create Shortcut…">Create Shortcut…</BradixContextMenuItem>
                                <BradixContextMenuItem TextValue="Name Window…">Name Window…</BradixContextMenuItem>
                                <BradixContextMenuSeparator />
                                <BradixContextMenuItem TextValue="Developer Tools">Developer Tools</BradixContextMenuItem>
                            </BradixContextMenuSubContent>
                        </BradixContextMenuPortal>
                    </BradixContextMenuSub>

                    <BradixContextMenuSeparator />

                    <BradixContextMenuCheckboxItem Checked="@_bookmarks"
                                                   CheckedChanged="HandleBookmarksChanged"
                                                   CloseOnSelect="false">
                        <span>Show Bookmarks</span>
                        <BradixContextMenuItemIndicator>✓</BradixContextMenuItemIndicator>
                    </BradixContextMenuCheckboxItem>
                    <BradixContextMenuCheckboxItem Checked="@_urls"
                                                   CheckedChanged="HandleUrlsChanged"
                                                   CloseOnSelect="false">
                        <span>Show Full URLs</span>
                        <BradixContextMenuItemIndicator>✓</BradixContextMenuItemIndicator>
                    </BradixContextMenuCheckboxItem>

                    <BradixContextMenuSeparator />

                    <BradixContextMenuLabel>People</BradixContextMenuLabel>
                    <BradixContextMenuRadioGroup Value="@_person" ValueChanged="HandlePersonChanged">
                        <BradixContextMenuRadioItem Value="pedro" CloseOnSelect="false">
                            <span>Pedro Duarte</span>
                            <BradixContextMenuItemIndicator>•</BradixContextMenuItemIndicator>
                        </BradixContextMenuRadioItem>
                        <BradixContextMenuRadioItem Value="colm" CloseOnSelect="false">
                            <span>Colm Tuite</span>
                            <BradixContextMenuItemIndicator>•</BradixContextMenuItemIndicator>
                        </BradixContextMenuRadioItem>
                    </BradixContextMenuRadioGroup>
                </BradixContextMenuContent>
            </BradixContextMenuPortal>
        </BradixContextMenu>
    </section>
</section>

@code {
    private BradixCheckboxCheckedState _bookmarks = BradixCheckboxCheckedState.Checked;
    private BradixCheckboxCheckedState _urls = BradixCheckboxCheckedState.Unchecked;
    private string _person = "pedro";

    private Task HandleBookmarksChanged(BradixCheckboxCheckedState state)
    {
        _bookmarks = state;
        return Task.CompletedTask;
    }

    private Task HandleUrlsChanged(BradixCheckboxCheckedState state)
    {
        _urls = state;
        return Task.CompletedTask;
    }

    private Task HandlePersonChanged(string? value)
    {
        _person = value ?? _person;
        return Task.CompletedTask;
    }
}
