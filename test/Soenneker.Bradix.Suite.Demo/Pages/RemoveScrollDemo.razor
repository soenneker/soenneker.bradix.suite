@page "/remove-scroll"

<PageTitle>Bradix RemoveScroll</PageTitle>

<section class="stack">
    <header class="stack stack--compact">
        <h2>BradixRemoveScroll</h2>
        <p>Locks page scrolling while its content is mounted, providing the modal scroll policy used by dialog and modal popover families.</p>
    </header>

    <div class="demo-grid">
        <section class="card stack stack--compact">
            <h3>Mounted scroll lock</h3>
            <button class="primitive__trigger" type="button" @onclick="@(() => _mounted = !_mounted)">
                Toggle scroll lock
            </button>
            <p class="state-line">Mounted: <strong>@_mounted</strong></p>

            @if (_mounted)
            {
                <BradixRemoveScroll AllowPinchZoom>
                    <div class="remove-scroll-surface stack stack--compact">
                        <p class="state-line">The page body is scroll-locked while this subtree is mounted.</p>
                        <textarea class="text-input" rows="4">Scrollable field content</textarea>
                    </div>
                </BradixRemoveScroll>
            }
        </section>
    </div>
</section>

@code {
    private bool _mounted = true;
}
