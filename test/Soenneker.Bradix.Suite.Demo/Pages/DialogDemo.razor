@page "/dialog"

<PageTitle>Bradix Dialog</PageTitle>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixDialog Open="@_open"
                      OpenChanged="HandleOpenChanged">
            <BradixDialogTrigger Class="dialog-demo__button dialog-demo__button--violet">
                Edit profile
            </BradixDialogTrigger>

            <BradixDialogPortal>
                <BradixDialogOverlay Class="dialog-demo__overlay" />

                <BradixDialogContent Class="dialog-demo__content">
                    <BradixDialogTitle Class="dialog-demo__title">Edit profile</BradixDialogTitle>
                    <BradixDialogDescription Class="dialog-demo__description">
                        Make changes to your profile here. Click save when you're done.
                    </BradixDialogDescription>

                    <div class="dialog-demo__fieldset">
                        <label class="dialog-demo__label" for="dialog-name">Name</label>
                        <input class="dialog-demo__input" id="dialog-name" @bind="_draftName" />
                    </div>

                    <div class="dialog-demo__fieldset">
                        <label class="dialog-demo__label" for="dialog-username">Username</label>
                        <input class="dialog-demo__input" id="dialog-username" @bind="_draftUsername" />
                    </div>

                    <div class="dialog-demo__save-row">
                        <button type="button"
                                class="dialog-demo__button dialog-demo__button--green"
                                @onclick="SaveChanges">
                            Save changes
                        </button>
                    </div>

                    <button type="button"
                            class="dialog-demo__icon-button"
                            aria-label="Close"
                            @onclick="CloseDialog">
                        ×
                    </button>
                </BradixDialogContent>
            </BradixDialogPortal>
        </BradixDialog>
    </section>
</section>

<section class="website-demo-page">
    <section class="card website-demo-card">
        <BradixDialog>
            <BradixDialogTrigger Class="dialog-demo__button dialog-demo__button--violet">
                Open nested overlay dialog
            </BradixDialogTrigger>

            <BradixDialogPortal>
                <BradixDialogOverlay Class="dialog-demo__overlay" />

                <BradixDialogContent Class="dialog-demo__content"
                                     aria-label="Nested overlay dialog">
                    <BradixDialogTitle Class="dialog-demo__title">Nested overlay dialog</BradixDialogTitle>
                    <BradixDialogDescription Class="dialog-demo__description">
                        Open the inner popover and verify dismissal stays scoped to the correct layer.
                    </BradixDialogDescription>

                    <BradixPopover>
                        <BradixPopoverTrigger Class="dialog-demo__button dialog-demo__button--violet"
                                              aria-label="Open nested popover">
                            Open nested popover
                        </BradixPopoverTrigger>

                        <BradixPopoverPortal>
                            <BradixPopoverContent Class="popover-demo__content"
                                                  SideOffset="5"
                                                  aria-label="Nested popover">
                                <div class="popover-demo__fields">
                                    <p class="popover-demo__text popover-demo__text--heading">Popover in dialog</p>
                                    <p class="popover-demo__text">This popover should open without closing the dialog.</p>
                                </div>
                                <BradixPopoverClose Class="popover-demo__close" aria-label="Close nested popover">×</BradixPopoverClose>
                            </BradixPopoverContent>
                        </BradixPopoverPortal>
                    </BradixPopover>
                </BradixDialogContent>
            </BradixDialogPortal>
        </BradixDialog>
    </section>
</section>

@code {
    private bool _open;
    private string _name = "Pedro Duarte";
    private string _username = "@peduarte";
    private string _draftName = "Pedro Duarte";
    private string _draftUsername = "@peduarte";

    private Task HandleOpenChanged(bool open)
    {
        _open = open;

        if (open)
            RestoreDraft();

        return Task.CompletedTask;
    }

    private Task SaveChanges()
    {
        _name = _draftName;
        _username = _draftUsername;
        _open = false;
        return Task.CompletedTask;
    }

    private Task CloseDialog()
    {
        RestoreDraft();
        _open = false;
        return Task.CompletedTask;
    }

    private void RestoreDraft()
    {
        _draftName = _name;
        _draftUsername = _username;
    }
}
