@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation

<div class="docs-shell">
    <header class="docs-shell__header">
        <NavLink href="/" Match="NavLinkMatch.All" class="docs-shell__brand-link">
            <span class="eyebrow">Bradix</span>
            <span class="docs-shell__brand-title">Blazor primitives demo</span>
        </NavLink>
    </header>

    <div class="docs-shell__frame">
        <aside class="docs-shell__sidebar" aria-label="Component navigation">
            <nav class="docs-nav" aria-label="Bradix primitives">
                <NavLink href="/" Match="NavLinkMatch.All" class="docs-nav__overview">Overview</NavLink>

                @foreach (DemoPageGroup group in FilteredGroups)
                {
                    <section class="docs-nav__group">
                        <header class="docs-nav__group-header">
                            <h3>@group.Title</h3>
                        </header>

                        <div class="docs-nav__group-links">
                            @foreach (DemoPageLink demoPage in group.Pages)
                            {
                                <NavLink href="@demoPage.Route" class="docs-nav__link">@demoPage.Title</NavLink>
                            }
                        </div>
                    </section>
                }
            </nav>
        </aside>

        <main class="docs-shell__main">
            @if (CurrentPage is not null && CurrentPage.Route != "/")
            {
                <DemoPageIntro Title="@CurrentPage.Title"
                               Description="@CurrentPage.Description" />
            }

            <div class="@(CurrentPage is not null && CurrentPage.Route != "/" ? "docs-shell__content docs-shell__content--component" : "docs-shell__content")">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    private DemoPageLink? CurrentPage;

    private IReadOnlyList<DemoPageGroup> FilteredGroups => DemoCatalog.Groups;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        UpdateCurrentPage();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateCurrentPage();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateCurrentPage()
    {
        string route = DemoCatalog.NormalizeRoute(new Uri(Navigation.Uri).AbsolutePath);
        CurrentPage = DemoCatalog.Find(route);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
